          </button>
        </div>
      </div>
    </nav>

    <template data-media-card-template>
      <article class="media-card">
        <div class="media-art"></div>
      </article>
    </template>

    <script type="application/json" data-timeline-data>
      [
        {% for block in section.blocks %}
          {% assign year_key = block.settings.year | default: '' | strip | downcase %}
          {% assign fallback_timeline_asset_1 = '' %}
          {% assign fallback_timeline_asset_2 = '' %}
          {% assign fallback_timeline_asset_3 = '' %}
          {% case year_key %}
            {% when '1977' %}
              {% assign fallback_timeline_asset_1 = 'rc-timeline-1977.png' %}
            {% when '1984' %}
              {% assign fallback_timeline_asset_1 = 'rc-timeline-1984-1.avif' %}
              {% assign fallback_timeline_asset_2 = 'rc-timeline-1984-2.png' %}
            {% when '1986' %}
              {% assign fallback_timeline_asset_1 = 'rc-timeline-1984-1.avif' %}
              {% assign fallback_timeline_asset_2 = 'rc-timeline-1986-2.jpg' %}
            {% when '1996' %}
              {% assign fallback_timeline_asset_1 = 'rc-timeline-1996-1.jpg' %}
              {% assign fallback_timeline_asset_2 = 'rc-timeline-1996-2.jpg' %}
              {% assign fallback_timeline_asset_3 = 'rc-timeline-1996-3.webp' %}
            {% when '2000' %}
              {% assign fallback_timeline_asset_1 = 'rc-timeline-2000.jpg' %}
            {% when '2003' %}
              {% assign fallback_timeline_asset_1 = 'rc-timeline-2003.jpg' %}
            {% when '2006' %}
              {% assign fallback_timeline_asset_1 = 'rc-timeline-2007.png' %}
            {% when '2007' %}
              {% assign fallback_timeline_asset_1 = 'rc-timeline-2007.png' %}
            {% when '2008' %}
              {% assign fallback_timeline_asset_1 = 'rc-timeline-2008.png' %}
            {% when '2013' %}
              {% assign fallback_timeline_asset_1 = 'rc-timeline-2013.png' %}
            {% when '2014' %}
              {% assign fallback_timeline_asset_1 = 'rc-timeline-2014-1.webp' %}
              {% assign fallback_timeline_asset_2 = 'rc-timeline-2014-2.webp' %}
              {% assign fallback_timeline_asset_3 = 'rc-timeline-2014-3.jpg' %}
            {% when '2018' %}
              {% assign fallback_timeline_asset_1 = 'rc-timeline-2018-1.jpg' %}
              {% assign fallback_timeline_asset_2 = 'rc-timeline-2018-2.jpg' %}
            {% when '2021' %}
              {% assign fallback_timeline_asset_1 = 'rc-timeline-2021-1.jpg' %}
              {% assign fallback_timeline_asset_2 = 'rc-timeline-2021-2.jpg' %}
              {% assign fallback_timeline_asset_3 = 'rc-timeline-2021-3.jpg' %}
            {% when '2022' %}
              {% assign fallback_timeline_asset_1 = 'rc-timeline-2022-1.jpg' %}
              {% assign fallback_timeline_asset_2 = 'rc-timeline-2022-2.png' %}
            {% when '2025' %}
              {% assign fallback_timeline_asset_1 = 'rc-timeline-2025.png' %}
            {% when 'today' %}
              {% assign fallback_timeline_asset_1 = 'rc-timeline-2025.png' %}
          {% endcase %}
          {
            "id": {{ block.id | json }},
            "year": {{ block.settings.year | default: '1977' | json }},
            "title": {{ block.settings.title | default: 'Milestone' | json }},
            "copy": {{ block.settings.copy | strip_html | strip_newlines | default: block.settings.title | default: block.settings.year | json }},
            "media": [
              {
                "label": {{ block.settings.media_1_label | default: 'Media 1' | json }},
                "image": {% if block.settings.media_1_image != blank %}{{ block.settings.media_1_image | image_url: width: 2200 | json }}{% elsif block.settings.timeline_image != blank %}{{ block.settings.timeline_image | image_url: width: 2200 | json }}{% elsif section.settings.use_year_fallback_images and fallback_timeline_asset_1 != blank %}{{ fallback_timeline_asset_1 | asset_url | json }}{% else %}null{% endif %},
                "fill": {{ block.settings.media_1_fill | default: 'linear-gradient(135deg, #5f5a71 0%, #241f29 65%, #0d0d12 100%)' | json }},
                "x": {{ block.settings.media_1_x | default: 0 | json }},
                "y": {{ block.settings.media_1_y | default: 18 | json }},
                "w": {{ block.settings.media_1_w | default: 36 | json }},
                "h": {{ block.settings.media_1_h | default: 46 | json }}
              },
              {
                "label": {{ block.settings.media_2_label | default: 'Media 2' | json }},
                "image": {% if block.settings.media_2_image != blank %}{{ block.settings.media_2_image | image_url: width: 2200 | json }}{% elsif section.settings.use_year_fallback_images and fallback_timeline_asset_2 != blank %}{{ fallback_timeline_asset_2 | asset_url | json }}{% else %}null{% endif %},
                "fill": {{ block.settings.media_2_fill | default: 'linear-gradient(180deg, #d8d8d5 0%, #8f8e88 50%, #4e4d4a 100%)' | json }},
                "x": {{ block.settings.media_2_x | default: 43 | json }},
                "y": {{ block.settings.media_2_y | default: 0 | json }},
                "w": {{ block.settings.media_2_w | default: 24 | json }},
                "h": {{ block.settings.media_2_h | default: 58 | json }}
              },
              {
                "label": {{ block.settings.media_3_label | default: 'Media 3' | json }},
                "image": {% if block.settings.media_3_image != blank %}{{ block.settings.media_3_image | image_url: width: 2200 | json }}{% elsif section.settings.use_year_fallback_images and fallback_timeline_asset_3 != blank %}{{ fallback_timeline_asset_3 | asset_url | json }}{% else %}null{% endif %},
                "fill": {{ block.settings.media_3_fill | default: 'linear-gradient(135deg, #ceb78c 0%, #89683f 50%, #20150f 100%)' | json }},
                "x": {{ block.settings.media_3_x | default: 74 | json }},
                "y": {{ block.settings.media_3_y | default: 8 | json }},
                "w": {{ block.settings.media_3_w | default: 18 | json }},
                "h": {{ block.settings.media_3_h | default: 26 | json }}
              }
            ]
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    </script>

    <div class="visually-hidden" aria-hidden="true">
      {% for block in section.blocks %}
        <div data-block-id="{{ block.id }}" {{ block.shopify_attributes }}></div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Roberto Coin timeline",
  "tag": "section",
  "class": "section section-overlay-header",
  "settings": [
    { "type": "header", "content": "Theme" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#f9f9f9" },
    { "type": "color", "id": "background_soft_color", "label": "Background soft color", "default": "#f1f1f1" },
    { "type": "color", "id": "background_glow_color", "label": "Background glow color", "default": "#e7e7e7" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#1f2f2b" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#397e70" },
    { "type": "color", "id": "logo_color", "label": "Logo color", "default": "#000000" },
    { "type": "color", "id": "active_year_color", "label": "Active year color", "default": "#ffffff" },
    { "type": "color", "id": "today_color", "label": "Today year color", "default": "#27574d" },

    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow", "default": "Since 1996" },
    { "type": "text", "id": "hero_title", "label": "Title", "default": "The Brand" },
    { "type": "text", "id": "scroll_text", "label": "Scroll label", "default": "Scroll to Explore" },
    { "type": "image_picker", "id": "hero_image_top", "label": "Hero image top" },
    { "type": "image_picker", "id": "hero_image_right", "label": "Hero image right (front portrait)" },
    { "type": "image_picker", "id": "hero_image_left", "label": "Hero image left" },
    { "type": "image_picker", "id": "hero_image_bottom", "label": "Hero image bottom" },
    { "type": "image_picker", "id": "hero_image_top_alt", "label": "Hero image top (set 2)" },
    { "type": "image_picker", "id": "hero_image_right_alt", "label": "Hero image right (set 2)" },
    { "type": "image_picker", "id": "hero_image_left_alt", "label": "Hero image left (set 2)" },
    { "type": "image_picker", "id": "hero_image_bottom_alt", "label": "Hero image bottom (set 2)" },

    { "type": "header", "content": "History" },
    { "type": "text", "id": "history_title", "label": "History title", "default": "History" },
    { "type": "textarea", "id": "history_left_copy", "label": "Left copy", "default": "In 1996, Roberto Coin introduced Appassionata, the first collection to feature a hidden ruby, a symbol of protection, passion and prosperity." },
    { "type": "textarea", "id": "history_right_copy", "label": "Right copy", "default": "Today, the Maison is present in over 60 countries worldwide, and the ruby remains its enduring symbol." },
    { "type": "image_picker", "id": "history_ring_drawing", "label": "History ring drawing image" },
    { "type": "image_picker", "id": "history_ring_photo", "label": "History ring photo image" },

    { "type": "header", "content": "Creator" },
    { "type": "text", "id": "creator_title", "label": "Creator title", "default": "The Creator" },
    { "type": "textarea", "id": "creator_copy_1", "label": "Creator copy 1", "default": "Roberto Coin’s journey did not begin in jewelry. After a successful career in luxury hospitality across Europe, he returned to Italy and immersed himself in the goldsmith tradition of Vicenza." },
    { "type": "textarea", "id": "creator_copy_2", "label": "Creator copy 2", "default": "In 1984, he began designing under his own name, transforming experience into creativity and vision into craftsmanship." },
    { "type": "image_picker", "id": "creator_image", "label": "Creator portrait image" },
    { "type": "image_picker", "id": "creator_drawing", "label": "Vicenza drawing image" },

    { "type": "header", "content": "Ruby" },
    { "type": "text", "id": "ruby_title", "label": "Ruby title", "default": "The Ruby" },
    { "type": "richtext", "id": "ruby_copy", "label": "Ruby copy", "default": "<p>Roberto Coin chose the ruby as the hidden signature of his creations.</p><p>Set inside every jewel, the ruby is not meant to be seen but to be felt.</p>" },
    { "type": "image_picker", "id": "ruby_image", "label": "Ruby image" },

    { "type": "header", "content": "Bottom nav labels" },
    { "type": "text", "id": "section_nav_history", "label": "History label", "default": "History" },
    { "type": "text", "id": "section_nav_creator", "label": "Creator label", "default": "The Creator" },
    { "type": "text", "id": "section_nav_ruby", "label": "Ruby label", "default": "The Ruby" },
    { "type": "text", "id": "section_nav_timeline", "label": "Timeline label", "default": "Timeline" },

    { "type": "header", "content": "Timeline layout" },
    { "type": "text", "id": "timeline_aria_label", "label": "Timeline aria label", "default": "Heritage timeline" },
    { "type": "text", "id": "year_rail_aria_label", "label": "Year rail aria label", "default": "Timeline years" },
    { "type": "range", "id": "panel_height", "label": "Panel height", "min": 55, "max": 95, "step": 1, "unit": "vh", "default": 76 },
    { "type": "range", "id": "year_size", "label": "Year size", "min": 24, "max": 80, "step": 1, "unit": "px", "default": 40 },
    { "type": "range", "id": "caption_size", "label": "Caption size", "min": 10, "max": 22, "step": 1, "unit": "px", "default": 16 },
    { "type": "checkbox", "id": "use_year_fallback_images", "label": "Use automatic year fallback images", "default": false }
  ],
  "blocks": [
    {
      "type": "entry",
      "name": "Timeline entry",
      "settings": [
        { "type": "text", "id": "year", "label": "Year", "default": "1977" },
        { "type": "text", "id": "title", "label": "Title", "default": "Milestone" },
        { "type": "richtext", "id": "copy", "label": "Copy", "default": "<p>Roberto Coin returned to his homeland of Italy to study the goldsmithing tradition under the guidance of renowned Italian teachers. He launched his jewelry trade on the British market.</p>" },
        { "type": "image_picker", "id": "timeline_image", "label": "Timeline image (primary)" },

        { "type": "header", "content": "Media 1" },
        { "type": "text", "id": "media_1_label", "label": "Label", "default": "Workshop portrait" },
        { "type": "image_picker", "id": "media_1_image", "label": "Image 1 (optional override)" },
        { "type": "text", "id": "media_1_fill", "label": "Fallback gradient", "default": "linear-gradient(135deg, #5f5a71 0%, #241f29 65%, #0d0d12 100%)" },
        { "type": "range", "id": "media_1_x", "label": "X position", "min": 0, "max": 90, "step": 1, "unit": "%", "default": 0 },
        { "type": "range", "id": "media_1_y", "label": "Y position", "min": 0, "max": 90, "step": 1, "unit": "%", "default": 18 },
        { "type": "range", "id": "media_1_w", "label": "Width", "min": 10, "max": 60, "step": 1, "unit": "%", "default": 36 },
        { "type": "range", "id": "media_1_h", "label": "Height", "min": 10, "max": 70, "step": 1, "unit": "%", "default": 46 },

        { "type": "header", "content": "Media 2" },
        { "type": "text", "id": "media_2_label", "label": "Label", "default": "Street portrait" },
        { "type": "image_picker", "id": "media_2_image", "label": "Image 2" },
        { "type": "text", "id": "media_2_fill", "label": "Fallback gradient", "default": "linear-gradient(180deg, #d8d8d5 0%, #8f8e88 50%, #4e4d4a 100%)" },
        { "type": "range", "id": "media_2_x", "label": "X position", "min": 0, "max": 90, "step": 1, "unit": "%", "default": 43 },
        { "type": "range", "id": "media_2_y", "label": "Y position", "min": 0, "max": 90, "step": 1, "unit": "%", "default": 0 },
        { "type": "range", "id": "media_2_w", "label": "Width", "min": 10, "max": 60, "step": 1, "unit": "%", "default": 24 },
        { "type": "range", "id": "media_2_h", "label": "Height", "min": 10, "max": 70, "step": 1, "unit": "%", "default": 58 },

        { "type": "header", "content": "Media 3" },
        { "type": "text", "id": "media_3_label", "label": "Label", "default": "Gold detail" },
        { "type": "image_picker", "id": "media_3_image", "label": "Image 3" },
        { "type": "text", "id": "media_3_fill", "label": "Fallback gradient", "default": "linear-gradient(135deg, #ceb78c 0%, #89683f 50%, #20150f 100%)" },
        { "type": "range", "id": "media_3_x", "label": "X position", "min": 0, "max": 90, "step": 1, "unit": "%", "default": 74 },
        { "type": "range", "id": "media_3_y", "label": "Y position", "min": 0, "max": 90, "step": 1, "unit": "%", "default": 8 },
        { "type": "range", "id": "media_3_w", "label": "Width", "min": 10, "max": 60, "step": 1, "unit": "%", "default": 18 },
        { "type": "range", "id": "media_3_h", "label": "Height", "min": 10, "max": 70, "step": 1, "unit": "%", "default": 26 }
      ]
    }
  ],
  "max_blocks": 30,
  "presets": [
    {
      "name": "Roberto Coin timeline",
      "blocks": [
        { "type": "entry", "settings": { "year": "1977", "title": "Milestone" } },
        { "type": "entry", "settings": { "year": "1984", "title": "Expansion", "copy": "<p>He began designing and creating jewelry for some of the most prestigious international brands.</p>" } }
      ]
    }
  ]
}
{% endschema %}
