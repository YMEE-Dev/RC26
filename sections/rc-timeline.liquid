{{ 'roberto-coin-timeline.css' | asset_url | stylesheet_tag }}
<script src="{{ 'roberto-coin-timeline.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign section_id = 'rc-timeline-' | append: section.id
-%}

<section
  id="{{ section_id }}"
  class="rc-timeline"
  style="
    --rc-bg: {{ section.settings.background_color }};
    --rc-bg-soft: {{ section.settings.background_soft_color }};
    --rc-bg-glow: {{ section.settings.background_glow_color }};
    --rc-text: {{ section.settings.text_color }};
    --rc-muted: {{ section.settings.text_color | color_modify: 'alpha', 0.62 }};
    --rc-dim: {{ section.settings.text_color | color_modify: 'alpha', 0.24 }};
    --rc-accent: {{ section.settings.accent_color }};
    --rc-accent-soft: {{ section.settings.accent_color | color_modify: 'alpha', 0.35 }};
    --rc-year-size: {{ section.settings.year_size }}px;
    --rc-copy-size: {{ section.settings.caption_size }}pt;
    --rc-panel-height: {{ section.settings.panel_height }}vh;
    --rc-section-padding-top: {{ section.settings.section_padding_top }}px;
    --rc-section-padding-bottom: {{ section.settings.section_padding_bottom }}px;
  "
  data-section-id="{{ section.id }}"
>
  <div class="rc-timeline__shell">
    <div class="visually-hidden" aria-hidden="true">
      {% for block in section.blocks %}
        <div data-block-id="{{ block.id }}" {{ block.shopify_attributes }}></div>
      {% endfor %}
    </div>

    <div class="rc-timeline__body" id="{{ section_id }}-timeline" aria-label="{{ section.settings.timeline_aria_label | escape }}">
      <div class="rc-timeline__stage" data-stage>
        <div class="rc-timeline__panel">
          <div class="rc-timeline__media-layout" data-media-layout></div>
          <div class="rc-timeline__caption" data-timeline-caption>
            <p data-caption-line-one></p>
            <p data-caption-line-two></p>
          </div>
        </div>

        <div class="rc-timeline__year-rail" aria-label="{{ section.settings.year_rail_aria_label | escape }}" data-year-rail></div>
      </div>

      <div class="rc-timeline__markers" data-timeline-markers></div>
    </div>
  </div>

  <template data-media-card-template>
    <article class="rc-timeline__media-card">
      <div class="rc-timeline__media-art">
        <span class="visually-hidden rc-timeline__media-label"></span>
      </div>
    </article>
  </template>

  <script type="application/json" data-timeline-data>
    [
      {% for block in section.blocks %}
        {
          "id": {{ block.id | json }},
          "year": {{ block.settings.year | default: '1977' | json }},
          "title": {{ block.settings.title | default: 'Milestone' | json }},
          "copy": {{ block.settings.copy | strip_html | strip_newlines | default: block.settings.title | default: block.settings.year | json }},
          "media": [
            {
              "label": {{ block.settings.media_1_label | default: 'Workshop portrait' | json }},
              "image": {% if block.settings.media_1_image != blank %}{{ block.settings.media_1_image | image_url: width: 1800 | json }}{% else %}null{% endif %},
              "fill": {{ block.settings.media_1_fill | default: 'linear-gradient(135deg, #5f5a71 0%, #241f29 65%, #0d0d12 100%)' | json }},
              "x": {{ block.settings.media_1_x | default: 0 | json }},
              "y": {{ block.settings.media_1_y | default: 18 | json }},
              "w": {{ block.settings.media_1_w | default: 36 | json }},
              "h": {{ block.settings.media_1_h | default: 46 | json }}
            },
            {
              "label": {{ block.settings.media_2_label | default: 'Street portrait' | json }},
              "image": {% if block.settings.media_2_image != blank %}{{ block.settings.media_2_image | image_url: width: 1800 | json }}{% else %}null{% endif %},
              "fill": {{ block.settings.media_2_fill | default: 'linear-gradient(180deg, #d8d8d5 0%, #8f8e88 50%, #4e4d4a 100%)' | json }},
              "x": {{ block.settings.media_2_x | default: 43 | json }},
              "y": {{ block.settings.media_2_y | default: 0 | json }},
              "w": {{ block.settings.media_2_w | default: 24 | json }},
              "h": {{ block.settings.media_2_h | default: 58 | json }}
            },
            {
              "label": {{ block.settings.media_3_label | default: 'Gold detail' | json }},
              "image": {% if block.settings.media_3_image != blank %}{{ block.settings.media_3_image | image_url: width: 1800 | json }}{% else %}null{% endif %},
              "fill": {{ block.settings.media_3_fill | default: 'linear-gradient(135deg, #ceb78c 0%, #89683f 50%, #20150f 100%)' | json }},
              "x": {{ block.settings.media_3_x | default: 74 | json }},
              "y": {{ block.settings.media_3_y | default: 8 | json }},
              "w": {{ block.settings.media_3_w | default: 18 | json }},
              "h": {{ block.settings.media_3_h | default: 26 | json }}
            }
          ]
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  </script>
</section>

