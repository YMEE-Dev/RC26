{%- comment -%}
  Section: RC Heritage Timeline
  Source migrated from assets/preview.html
{%- endcomment -%}

{%- style -%}
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--body); background: #0b1d17; overflow-x: hidden; }
    img { display: block; max-width: 100%; }
    a { text-decoration: none; color: inherit; }

    :root {
      --ruby:   #B3261E;
      --green:  #26564C;
      --teal:   #397E70;
      --dark:   #27574D;
      --gold:   #B29437;
      --white:  #FFFFFF;
      --light:  #E5E5E5;
      --timeline-ruby-red: #A21616;
      --head:   var(--font-heading-family, 'Portrait LC', Georgia, serif);
      --body:   var(--font-body-family, 'Inter', sans-serif);
    }

    /* ═══════════════════════════════════════
       HERO
    ═══════════════════════════════════════ */
    .hero {
      position: relative;
      width: 100%;
      min-height: 100vh;
      background: transparent;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    /* Background image — fixed so it persists through history section on scroll */
    .hero__bg {
      position: fixed;
      inset: 0;
      background: url('{{ 'figma-images/hero-bg.jpg' | asset_url }}') center / cover no-repeat;
      filter: brightness(0.55);
      z-index: -2;
    }

    /* Vignette — also fixed, sits on top of bg layer */
    .hero__vignette {
      position: fixed;
      inset: 0;
      z-index: -1;
      pointer-events: none;
      background:
        radial-gradient(ellipse 90% 90% at 50% 50%,
          transparent 0%,
          rgba(5, 14, 10, 0.664) 55%,
          rgba(3, 9, 6, 0.923) 100%),
        linear-gradient(to bottom,
          rgba(0,0,0,0.3) 0%,
          transparent 25%,
          transparent 75%,
          rgba(0, 0, 0, 0.749) 100%);
    }

    /* Decorative 4-petal ornament — centered behind text */
    .hero__ornament {
      position: absolute;
      top: 50%;
      left: 0;
      right: 0;
      transform: translateY(calc(-50% - 18px));
      display: flex;
      justify-content: center;
      align-items: center;
      opacity: 0;
      transition: opacity 0.9s ease, transform 0.9s ease;
      pointer-events: none;
    }
    .hero.hero--ornament-in .hero__ornament {
      opacity: 0.62;
      transform: translateY(-50%);
    }
    .hero__lottie {
      width: min(620px, 76vw);
      height: min(640px, 78vw);
      display: block;
      position: relative;
      z-index: 2;
      transform-origin: center;
      animation: hero-flower-float 8s ease-in-out infinite;
    }
    .hero__lottie svg {
      overflow: visible;
    }
    .hero__lottie svg path[stroke] {
      filter: drop-shadow(0 0 10px rgba(255,255,255,0.68))
              drop-shadow(0 0 22px rgba(39,87,77,0.58));
      animation: lottie-line-glow-fade 2.6s ease-in-out infinite;
    }
    @keyframes lottie-line-glow-fade {
      0% { opacity: 0.32; }
      35% { opacity: 1; }
      100% { opacity: 0.35; }
    }
    .hero__ornament-fallback {
      display: none !important;
      width: min(520px, 70vw);
      height: auto;
      position: relative;
      z-index: 1;
      transform-origin: center;
      animation: hero-flower-float 8s ease-in-out infinite;
    }
    @keyframes hero-flower-float {
      0%, 100% { transform: scale(1); opacity: 0.95; }
      50% { transform: scale(1.035); opacity: 1; }
    }

    /* Text content */
    .hero__content {
      position: relative;
      z-index: 2;
      text-align: center;
      color: var(--white);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0;
      opacity: 0;
      transform: translateY(-24px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .hero.hero--text-in .hero__content {
      opacity: 1;
      transform: translateY(0);
    }
    .hero__eyebrow,
    .hero__title {
      opacity: 0;
      transform: translateY(-10px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .hero.hero--text-in .hero__eyebrow {
      opacity: 1;
      transform: translateY(0);
      transition-delay: 0.08s;
    }
    .hero.hero--text-in .hero__title {
      opacity: 1;
      transform: translateY(0);
      transition-delay: 0.2s;
    }
    .hero__eyebrow {
      font-family: var(--body);
      font-size: 13px;
      font-weight: 400;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.7);
      margin-bottom: 16px;
    }
    .hero__title {
      font-family: var(--head);
      font-size: 40px;
      font-weight: 500;
      letter-spacing: 0.02em;
      line-height: 1.1;
      color: var(--white);
    }

    /* Scroll CTA */
    .hero__scroll {
      position: absolute;
      bottom: 120px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 2;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      opacity: 0;
      transition: opacity 0.55s ease, transform 0.55s ease;
      transform: translate(-50%, -10px);
    }
    .hero.hero--scroll-in .hero__scroll {
      opacity: 1;
      transform: translate(-50%, 0);
    }
    .hero__scroll.is-hidden {
      opacity: 0;
      transform: translate(-50%, 8px);
      pointer-events: none;
    }
    .hero.hero--scroll-in .hero__scroll.is-hidden {
      opacity: 0;
      transform: translate(-50%, 8px);
      pointer-events: none;
    }
    .hero__scroll-label {
      font-family: var(--body);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.75);
    }
    .hero__scroll-line {
      width: 1px;
      height: 28px;
      background: rgba(255,255,255,0.5);
      animation: line-pulse 2s ease-in-out infinite;
    }
    @keyframes line-pulse {
      0%,100% { height: 28px; opacity: 0.5; }
      50%      { height: 44px; opacity: 1; }
    }
    /* ═══════════════════════════════════════
       SECTION NAV  (custom pill shape)
    ═══════════════════════════════════════ */
    .section-nav {
      position: fixed;
      bottom: 42px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 1000;
      width: 814px;
      max-width: 95vw;
    }
    .section-nav.nav-intro {
      opacity: 0;
      transform: translate(-50%, -16px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .section-nav.nav-intro.nav-intro-run {
      opacity: 1;
      transform: translate(-50%, 0);
    }
    .section-nav__shape {
      position: relative;
      width: 100%;
    }
    .section-nav__shape svg.nav-bg {
      width: 100%;
      height: auto;
      display: block;
      transform-origin: 50% 50%;
      transform-box: fill-box;
    }
    /* Highlight paths — animate via opacity */
    .nav-highlight {
      opacity: 0;
      transition: opacity 0.24s ease;
      pointer-events: none;
    }
    .nav-highlight.is-active { opacity: 1; }
    /* Clickable tab overlays on top of SVG */
    .section-nav__tabs {
      position: absolute;
      inset: 0;
      display: grid;
      grid-template-columns: 193fr 207fr 211fr 203fr;
    }
    .section-nav__tab {
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--body);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.75);
      cursor: pointer;
      transition: color 0.2s, opacity 0.45s ease, transform 0.45s ease;
      user-select: none;
      opacity: 1;
      transform: translateY(0);
    }
    .section-nav__tab.is-active { color: var(--white); }
    .section-nav__tabs {
      opacity: 1;
      transition: opacity 0.45s ease;
    }
    .section-nav.nav-intro .nav-bg {
      transform: scaleX(0.16);
      opacity: 0.96;
      filter: saturate(0.94);
    }
    .section-nav.nav-intro.nav-intro-run .nav-bg {
      animation: nav-shape-expand 2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    .section-nav.nav-intro .section-nav__tabs {
      pointer-events: none;
    }
    .section-nav.nav-intro .section-nav__tab {
      opacity: 0;
      transform: translateY(6px);
    }
    .section-nav.nav-ready .section-nav__tabs {
      pointer-events: auto;
    }
    .section-nav.nav-ready .section-nav__tab {
      opacity: 1;
      transform: translateY(0);
    }
    .section-nav.nav-ready .section-nav__tab:nth-child(1) { transition-delay: 0.04s; }
    .section-nav.nav-ready .section-nav__tab:nth-child(2) { transition-delay: 0.12s; }
    .section-nav.nav-ready .section-nav__tab:nth-child(3) { transition-delay: 0.20s; }
    .section-nav.nav-ready .section-nav__tab:nth-child(4) { transition-delay: 0.28s; }
    @keyframes nav-shape-expand {
      0% {
        transform: scaleX(0.16);
        opacity: 0.96;
        filter: saturate(0.94);
      }
      100% {
        transform: scaleX(1);
        opacity: 1;
        filter: saturate(1);
      }
    }

    /* ═══════════════════════════════════════
       HISTORY
    ═══════════════════════════════════════ */
    .history {
      background: transparent;
      padding: 120px 0;
      min-height: 1000px;
    }
    .history__inner {
      display: grid;
      grid-template-columns: 1fr minmax(360px, 520px) 1fr;
      gap: 56px;
      align-items: center;
      max-width: 1200px;
      width: 100%;
      margin: 0 auto;
    }
    .history__left {
      color: var(--white);
      align-self: start;
      margin-top: 120px;
      margin-left: 0;
    }
    .history__right {
      color: var(--white);
      align-self: start;
      margin-top: 340px;
      margin-bottom: 0;
      padding-right: 0;
    }
    .history__title {
      font-family: var(--head);
      font-size: clamp(28px,4vw,40px);
      font-weight: 500;
      color: var(--white);
      margin-bottom: 28px;
    }
    .history__left p, .history__right p {
      font-size: 14px;
      line-height: 1.85;
      color: rgba(255,255,255,0.78);
    }
        .history__center {
      display: flex;
      justify-content: center;
      align-items: center;
    }
    .history__center img {
      width: 1060px;
      max-width: none;
      height: auto;
      mix-blend-mode: screen;
      display: block;
      opacity: 0;
      transform: rotate(-18deg);
      backface-visibility: hidden;
      transform-origin: center;
      will-change: transform;
    }
    .history__center.fade {
      opacity: 1;
      transform: none;
      transition: none;
    }

    /* ═══════════════════════════════════════
       THE CREATOR
    ═══════════════════════════════════════ */
    .creator {
      position: relative;
      background: transparent;
      overflow: visible;
    }
    .creator__inner {
      display: grid;
      grid-template-columns: 644px 1fr;
      gap: 50px;
      align-items: start;
      max-width: none;
      width: 100%;
      margin: 0 auto;
      padding: 80px 80px 140px;
      min-height: 780px;
    }
    .creator__image {
      margin-top: -140px;
      margin-left: 170px;
      overflow: visible;
      z-index: 2;
    }
    .creator__image img {
      width: 580px;
      height: auto;
      object-fit: cover;
      display: block;
    }
    .creator__text {
      position: relative;
      z-index: 3;
      max-width: 620px;
      margin-top: 24px;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
    }
    .creator__title {
      font-family: var(--head);
      font-size: clamp(28px,4vw,40px);
      font-weight: 500;
      color: #fff;
      margin-bottom: 28px;
    }
    .creator__body p {
      font-size: 14px;
      line-height: 1.8;
      color: rgba(255,255,255,0.9);
      margin-bottom: 18px;
    }
    .creator__body {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 28px;
      align-items: start;
    }
    .creator__body p:last-child { margin-bottom: 0; }
    .creator__vicenza {
      position: absolute;
      right: 0;
      bottom: -130px;
      width: 760px;
      max-width: 100%;
      height: auto;
      pointer-events: none;
      mix-blend-mode: multiply;
      z-index: 1;
    }

    /* ═══════════════════════════════════════
       THE RUBY
    ═══════════════════════════════════════ */
    .ruby-section {
      position: relative;
      min-height: auto;
      display: flex;
      align-items: center;
      overflow: visible;
      background: transparent;
      padding: 120px 0 0px;
      margin-bottom: -350px;
      z-index: 2;
      isolation: isolate;
    }
    .ruby-section__bg {
      display: none;
    }
    .ruby-section__overlay {
      display: none;
    }
    .ruby-section__inner {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: flex-end;
      align-items: center;
      padding: 90px 100px;
      max-width: none;
      margin: 0 auto;
      width: min(1232px, calc(100% - 48px));
      min-height: 700px;
      background: url('{{ 'figma-images/ruby-section.jpg' | asset_url }}') center / cover no-repeat;
    }
    .ruby-section__content {
      width: min(380px, 38%);
      margin-left: auto;
      padding-top: 130px;
    }
    .ruby-section__title {
      font-family: var(--head);
      font-size: clamp(28px,4vw,40px);
      font-weight: 500;
      color: var(--white);
      margin-bottom: 28px;
    }
    .ruby-section__body p {
      font-size: 14px;
      line-height: 1.8;
      color: rgba(255,255,255,0.85);
      margin-bottom: 18px;
    }
    .ruby-section__gem {
      display: none;
    }
    .ruby-section__gem img {
      width: min(366px, 80%);
      filter: drop-shadow(0 20px 60px rgba(179,38,30,0.5));
    }

    /* ═══════════════════════════════════════
       TIMELINE
    ═══════════════════════════════════════ */
    .timeline-section {
      position: relative;
      background: var(--light);
      padding: 500px 0 0;
      overflow: visible;
      margin-top: 0;
      z-index: 1;
    }
    .timeline-section__title,
    .era-light,
    .timeline-era--ruby {
      position: relative;
      z-index: 2;
    }
    .timeline-era--ruby__map {
      position: absolute;
      left: 0;
      right: 0;
      bottom: -160px;
      z-index: 1;
      pointer-events: none;
      mix-blend-mode: multiply;
      opacity: 0.95;
    }
    .timeline-era--ruby__map img {
      display: block;
      width: min(1200px, 100%);
      height: auto;
      margin: 0 auto;
    }
.timeline-transition {
      position: relative;
      margin-top: -60px;
      margin-bottom: 1200px;
      height: 0px;
      pointer-events: none;
      overflow: visible;
      z-index: 0;
      display: flex;
      justify-content: center;
      background: transparent;
      width: 100vw;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
    }
    .timeline-transition__shape-svg {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      top: 0;
      width: 100vw;
      max-width: none;
      height: auto;
      z-index: 2;
      pointer-events: none;
      opacity: 0.98;
      mix-blend-mode: normal;
    }
    .timeline-transition__shape-base {
      fill: url(#timeline-transition-shape-texture);
    }
    .timeline-transition__shape-overlay {
      fill: var(--timeline-ruby-red);
      mix-blend-mode: multiply;
      opacity: 0.92;
    }
    .timeline-transition__flower-red-svg {
      position: absolute;
      left: 50%;
      top: calc(clamp(26px, 4.2vw, 72px) - 500px);
      transform: translateX(-50%);
      width: 100vw;
      max-width: none;
      height: auto;
      z-index: 2;
      pointer-events: none;
      mix-blend-mode: multiply;
      opacity: 0.95;
    }
.timeline-transition__flower-svg {
      position: absolute;
      left: 50%;
      top: calc(clamp(26px, 4.2vw, 72px) - 500px);
      transform: translateX(-50%);
      width: 100vw;
      max-width: none;
      height: auto;
      z-index: 3;
      pointer-events: none;
      mix-blend-mode: normal;
    }
    .timeline-transition__flower-svg .flower-red {
      mix-blend-mode: multiply;
    }
    .timeline-transition__flower-svg .flower-green {
      mix-blend-mode: normal;
    }
    .rebranding {
      position: relative;
      background: transparent;
      padding: 80px 0 24px;
      min-height: auto;
      display: block;
      z-index: 6;
      margin-bottom: 300px;
    }
    .rebranding__logo {
      position: relative;
      width: min(850px, 92vw);
      height: auto;
      min-height: 180px;
      display: block;
      margin: 0 auto;
    }
    .timeline-section__title {
      font-family: var(--head);
      font-size: clamp(28px,4vw,40px);
      font-weight: 500;
      color: #111;
      text-align: center;
      margin-bottom: 40px;
      padding: 0 40px;
    }

    /* Light band for early years */
    .era-light {
      background: transparent;
      padding: 40px 0 0;
      overflow: visible;
      position: relative;
      z-index: 3;
    }

    .timeline {
      position: relative;
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 56px;
      overflow: visible;
    }
    .timeline__spine {
      position: absolute;
      left: 50%; top: 0; bottom: 0;
      width: 1px;
      background: repeating-linear-gradient(
        to bottom,
        rgba(179, 38, 30, 0.5) 0 5px,
        transparent 5px 10px
      );
      transform: translateX(-50%);
      clip-path: inset(0 0 100% 0);
      will-change: clip-path;
    }
    .era-light .timeline__spine {
      background: repeating-linear-gradient(
        to bottom,
        rgba(179, 38, 30, 0.5) 0 5px,
        transparent 5px 10px
      );
    }

    .tl-item {
      display: grid;
      grid-template-columns: 1fr 70px 1fr;
      align-items: start;
      row-gap: 0px;
      margin-bottom: 0px;
      opacity: 0;
      transition: opacity 0.6s ease;
    }
    .tl-item.visible { opacity: 1; }
    .tl-item .tl-event,
    .tl-item .tl-media {
      margin-top: 20px;
    }

    .tl-item--left .tl-event {
      grid-column: 1;
      grid-row: 1;
      text-align: left;
      padding-right: 130px;
    }
    .tl-item--left .tl-media {
      grid-column: 1;
      grid-row: 2;
      padding-right: 130px;
    }
    .tl-item--left .tl-center {
      grid-column: 2;
      grid-row: 1 / span 2;
    }
    .tl-item--right .tl-event {
      grid-column: 3;
      grid-row: 1;
      text-align: left;
      padding-left: 130px;
    }
    .tl-item--right .tl-media {
      grid-column: 3;
      grid-row: 2;
      padding-left: 130px;
    }
    .tl-item--right .tl-center {
      grid-column: 2;
      grid-row: 1 / span 2;
    }

    .tl-center { display:flex; flex-direction:column; align-items:center; }
    .tl-dot {
      background: transparent;
      border: 0;
      color: #111;
      font-family: var(--head);
      font-size: 40px;
      font-weight: 500;
      letter-spacing: 0.02em;
      line-height: 1.1;
      margin-top: 30px;
      margin-bottom: 30px;
      flex-shrink: 0;
      position: relative;
      z-index: 2;
      background: var(--light);
      padding: 0 6px;
    }
    .tl-connector {
      width: 1px;
      min-height: 54px;
      flex: 1;
      background: transparent;
    }
    .era-light .tl-connector { background: transparent; }

    .tl-year {
      font-family: var(--head);
      font-size: clamp(22px,3vw,38px);
      font-weight: 500;
      color: #111;
      margin-bottom: 10px;
      line-height: 1.2;
    }
    .tl-event .tl-year { display: none; }
    .tl-body { font-size:14px; line-height:1.75; color:#222; }
    .tl-cta {
      display:inline-block; margin-top:12px;
      font-size:11px; font-weight:600; letter-spacing:0.1em;
      text-transform:uppercase; color:#111;
      border-bottom:1px solid rgba(0,0,0,0.35); padding-bottom:2px;
    }
    .tl-media img { width:100%; max-width:368px; height:auto; object-fit:cover; }
    .tl-item--1977 .tl-media img { max-width: 390px; }
    .tl-item--1984 .tl-media img { width: min(780px, 100%); max-width: 780px; }
    .tl-item--2014 .tl-media img { max-width: 300px; }
    .tl-item--2000 .tl-media img {
      height: 100px;
      width: auto;
      max-width: none;
    }
    .tl-media--empty { min-height:1px; }

    .timeline-break {
      position: relative;
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 56px 190px;
      overflow: visible;
      z-index: 4;
    }
    .timeline-break__line {
      display: none;
    }
    .timeline-break__dot {
      background: transparent;
      border: 0;
      color: #111;
      font-family: var(--head);
      font-size: 40px;
      font-weight: 500;
      letter-spacing: 0.02em;
      line-height: 1.1;
      margin: 30px auto;
      text-align: center;
      position: relative;
      z-index: 2;
      background: var(--light);
      padding: 0 6px;
    }
    .timeline-break__event {
      max-width: 420px;
      margin: 0 auto;
      text-align: center;
    }
    .timeline-break__year { display: none; }
    .timeline-break__body {
      font-size: 14px;
      line-height: 1.75;
      color: #222;
      margin-top: 10px;
    }
    .timeline-break__ruby {
      position: absolute;
      left: 50%;
      bottom: -228px;
      transform: translateX(-50%);
      width: min(440px, 42vw);
      height: auto;
      z-index: 10;
      pointer-events: none;
    }
    .timeline-break__event {
      opacity: 0;
      transition: opacity 0.7s ease;
    }
    .timeline-break__event.visible {
      opacity: 1;
    }
    .timeline-break__ruby,
    .timeline-break__dot {
      opacity: 0;
      transition: opacity 0.7s ease;
    }
    .timeline-break__ruby.visible,
    .timeline-break__dot.visible { opacity: 1; }

    .timeline-era--ruby {
      position: relative;
      margin-top: 0;
      padding: 180px 0 0px;
      overflow: visible;
      z-index: 1;
      isolation: isolate;
      background: url('{{ 'figma-images/hero-bg.jpg' | asset_url }}') center center / cover no-repeat fixed;
      transform: translateZ(0);
      backface-visibility: hidden;
    }
    .timeline-era--ruby::before {
      content: "";
      position: absolute;
      inset: 0;
      background: var(--timeline-ruby-red);
      mix-blend-mode: multiply;
      opacity: 0.92;
      pointer-events: none;
      z-index: 0;
    }
    .timeline-era--ruby .timeline {
      position: relative;
      z-index: 2;
    }
    .timeline-era--ruby .timeline__spine {
      background: repeating-linear-gradient(
        to bottom,
        rgba(179, 38, 30, 0.5) 0 5px,
        transparent 5px 10px
      );
    }
    .timeline-era--ruby .tl-dot {
      color: var(--white);
      background: transparent;
    }
    .timeline-era--ruby .tl-year { color: var(--white); }
    .timeline-era--ruby .tl-body { color: rgba(255,255,255,0.88); }
    .timeline-era--ruby .tl-cta {
      color: var(--white);
      border-color: rgba(255,255,255,0.5);
    }
    .era-light .tl-item:last-child { margin-bottom: 0; }

    .tl-item--today .tl-dot { color: #fff; }
    .tl-item--today .tl-event {
      grid-column: 1 / span 3;
      grid-row: 2;
      text-align: center;
      margin-top: 40px;
      max-width: 440px;
      margin-left: auto;
      margin-right: auto;
      padding: 0;
    }
    .tl-item--today .tl-media { display: none; }
    .tl-item--today .tl-body {
      margin-top: 52px;
    }

    /* ═══════════════════════════════════════
       COLLECTIONS
    ═══════════════════════════════════════ */
    .collections {
      background: transparent;
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 480px;
      padding: 80px;
      gap: 60px;
      align-items: center;
    }
    .collections__eyebrow {
      font-size: 16px;
      color: var(--white);
      margin-bottom: 32px;
    }
    .collections__list { list-style:none; display:flex; flex-wrap:wrap; gap:2px 12px; }
    .collections__list li a {
      font-family: var(--head);
      font-size: clamp(18px,2.2vw,30px);
      font-weight: 500;
      color: var(--teal);
      transition: color 0.2s;
      line-height: 1.5;
    }
    .collections__list li a:hover { color: var(--white); }
    .collections__img { overflow:hidden; }
    .collections__img img { width:100%; height:100%; object-fit:cover; }

    /* ═══════════════════════════════════════
       FADE UTILITY
    ═══════════════════════════════════════ */
    .fade { opacity:0; transform:translateY(18px); transition:opacity .7s ease, transform .7s ease; }
    .fade.d1 { transition-delay:.1s; }
    .fade.d2 { transition-delay:.22s; }
    .fade.visible { opacity:1; transform:none; }

    /* ── Responsive ── */
    @media (max-width:860px) {
      .history__inner, .creator__inner, .ruby-section__inner, .collections { grid-template-columns:1fr; }
      .history, .ruby-section__inner, .collections { padding:60px 24px; }
      .history__left {
        margin-top: 0;
        margin-left: 0;
      }
      .history__right {
        align-self: start;
        margin-top: 16px;
        margin-bottom: 0;
        padding-right: 0;
      }
      .history__center img { width: min(680px, 92vw); }
      .timeline-break {
        padding: 8px 24px 120px;
      }
      .tl-dot,
      .timeline-break__dot { font-size: 40px; }
      .timeline-break__ruby {
        bottom: -150px;
        width: min(320px, 70vw);
      }
      .timeline-era--ruby {
        padding: 140px 0 320px;
        background-attachment: scroll, scroll;
      }
      .timeline-transition {
        margin-top: -20px;
        margin-bottom: 560px;
        height: 420px;
      }
      .timeline-transition__shape-svg {
        width: 100vw;
        top: -2px;
      }
      .timeline-transition__flower-svg {
        width: 100vw;
        max-width: none;
        top: calc(clamp(22px, 5vw, 54px) - 500px);
      }
      .rebranding {
        padding: 80px 0 32px;
        min-height: auto;
      }
      .rebranding__logo {
        width: min(850px, 94vw);
        min-height: 140px;
      }
      .creator { overflow: visible; }
      .creator__inner {
        grid-template-columns: 1fr;
        gap: 24px;
        padding: 60px 24px 120px;
        min-height: auto;
      }
      .creator__image {
        margin-top: 0;
        margin-left: 0;
      }
      .creator__image img {
        width: 100%;
        height: auto;
        max-width: 580px;
      }
      .creator__text {
        max-width: none;
        margin-top: 0;
      }
      .creator__body {
        grid-template-columns: 1fr;
        gap: 0;
      }
      .creator__vicenza {
        right: 24px;
        width: min(420px, 72vw);
      }
      .ruby-section {
        padding: 60px 0 80px;
      }
      .ruby-section__inner {
        min-height: 520px;
        padding: 48px 28px;
        justify-content: center;
        width: min(1232px, calc(100% - 32px));
      }
      .ruby-section__content {
        width: min(420px, 100%);
      }
      .tl-item { grid-template-columns:1fr; margin-bottom:40px; }
      .tl-item .tl-event,
      .tl-item .tl-media { margin-top: 0; }
      .tl-item--left .tl-event, .tl-item--right .tl-event {
        grid-column:1; text-align:left; padding:0 0 12px 20px;
        border-left:2px solid rgba(255,255,255,0.25); margin-left:5px;
      }
      .era-light .tl-item--left .tl-event, .era-light .tl-item--right .tl-event { border-color:rgba(0,0,0,0.15); }
      .tl-center, .timeline__spine { display:none; }
      .tl-item--left .tl-media, .tl-item--right .tl-media { grid-column:1; padding:12px 0 0; }
      .section-nav { bottom: 24px; }
      .hero__scroll { bottom: 110px; }
    }
{%- endstyle -%}


