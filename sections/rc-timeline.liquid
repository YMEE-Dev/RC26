{% javascript %}
(function(){
  // Target only the fixed nav (not the hidden one inside hero)
  var fixedNav = document.querySelector('.section-nav--fixed');
  var heroSection = document.getElementById('hero');
  var tabs = fixedNav ? fixedNav.querySelectorAll('.section-nav__tab') : document.querySelectorAll('.section-nav--fixed .section-nav__tab');
  var highlights = fixedNav
    ? fixedNav.querySelectorAll('.nav-highlight')
    : document.querySelectorAll('.section-nav--fixed .nav-highlight');
  var activeIdx = 0;
  var hoverIdx = -1;
  var heroScrollCta = document.querySelector('.hero__scroll');
  var historySection = document.querySelector('.history');
  var historyRing = document.querySelector('.history__center img');
  var historyRotateStart = -18;
  var historyRotateEnd = 40;
  var scrollTicking = false;
  var timelineLines = document.querySelectorAll('.timeline__spine, .timeline-break__line');
  var timelineItems = document.querySelectorAll('.tl-item');
  var timelineBreak = document.querySelector('.timeline-break');
  var heroOrnament = document.querySelector('.hero__ornament');
  var heroLottieContainer = document.getElementById('hero-lottie');
  var rebrandingLogoContainer = document.getElementById('rebranding-logo-lottie');
  var navScrollRaf = null;
  var isNavAutoScrolling = false;

  function initHeroLottie(){
    if (!heroOrnament || !heroLottieContainer || !window.lottie) return;
    function loadFromData(){
      if (!window.__RC_FLOWER_DATA) return null;
      var fallback = window.lottie.loadAnimation({
        container: heroLottieContainer,
        renderer: 'svg',
        loop: true,
        autoplay: true,
        animationData: window.__RC_FLOWER_DATA
      });
      fallback.addEventListener('DOMLoaded', function(){
        fallback.loop = true;
        fallback.goToAndPlay(0, true);
        heroOrnament.classList.add('has-lottie');
      });
      return fallback;
    }

    try {
      var anim = window.lottie.loadAnimation({
        container: heroLottieContainer,
        renderer: 'svg',
        loop: true,
        autoplay: true,
        path: '{{ 'figma-images/RC_Flower.json' | asset_url }}?cb=' + Date.now()
      });
      anim.addEventListener('DOMLoaded', function(){
        anim.loop = true;
        anim.goToAndPlay(0, true);
        heroOrnament.classList.add('has-lottie');
      });
      anim.addEventListener('data_failed', function(){
        try { anim.destroy(); } catch (_e) {}
        loadFromData();
      });
    } catch (_err) {
      loadFromData();
    }
  }

  function initRebrandingLogoLottie(){
    if (!rebrandingLogoContainer || !window.lottie) return;
    var logoAnim = null;
    var played = false;

    function getWordmarkOnlyData(){
      if (!window.__ROBERTCOIN_LOGO_DATA) return null;
      try {
        var data = JSON.parse(JSON.stringify(window.__ROBERTCOIN_LOGO_DATA));
        if (Array.isArray(data.layers)) {
          data.layers = data.layers.filter(function(layer){
            var name = (layer && layer.nm ? String(layer.nm) : '');
            return !/flower/i.test(name);
          });
        }
        return data;
      } catch (_e) {
        return null;
      }
    }

    function loadFromData(){
      var filteredData = getWordmarkOnlyData();
      if (!filteredData) return null;
      return window.lottie.loadAnimation({
        container: rebrandingLogoContainer,
        renderer: 'svg',
        loop: false,
        autoplay: false,
        animationData: filteredData
      });
    }

    logoAnim = loadFromData();

    if (!logoAnim) return;

    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        if (!played && entry.isIntersecting) {
          played = true;
          logoAnim.goToAndPlay(0, true);
          io.disconnect();
        }
      });
    }, { threshold: 0.3 });
    io.observe(rebrandingLogoContainer);
  }


  function hydrateTimelineYearMarkers(){
    document.querySelectorAll('.tl-item').forEach(function(item){
      var year = item.querySelector('.tl-year');
      var dot = item.querySelector('.tl-dot');
      if (year && dot) dot.textContent = year.textContent.trim();
    });

    var breakYear = document.querySelector('.timeline-break__year');
    var breakDot = document.querySelector('.timeline-break__dot');
    if (breakDot) {
      if (breakYear) breakDot.textContent = breakYear.textContent.trim();
      else if (breakDot.dataset.year) breakDot.textContent = breakDot.dataset.year;
    }
  }

  function renderNavState() {
    var idx = hoverIdx >= 0 ? hoverIdx : activeIdx;
    tabs.forEach(function(t){ t.classList.remove('is-active'); });
    highlights.forEach(function(h){ if(h) h.classList.remove('is-active'); });
    if (tabs[idx]) tabs[idx].classList.add('is-active');
    if (highlights[idx]) highlights[idx].classList.add('is-active');
  }
  function setActive(idx) {
    activeIdx = idx;
    renderNavState();
  }
  function clearActive() {
    activeIdx = -1;
    renderNavState();
  }
  function setHover(idx) {
    hoverIdx = idx;
    renderNavState();
  }
  function clearHover() {
    hoverIdx = -1;
    renderNavState();
  }

  function smoothScrollToY(targetY, duration) {
    if (navScrollRaf) {
      window.cancelAnimationFrame(navScrollRaf);
      navScrollRaf = null;
    }
    var startY = window.scrollY || window.pageYOffset;
    var delta = targetY - startY;
    if (Math.abs(delta) < 1) return;
    var startTime = null;

    function easeInOutSine(t) {
      return -(Math.cos(Math.PI * t) - 1) / 2;
    }

    isNavAutoScrolling = true;
    function step(ts) {
      if (!startTime) startTime = ts;
      var elapsed = ts - startTime;
      var progress = Math.min(elapsed / duration, 1);
      var eased = easeInOutSine(progress);
      window.scrollTo(0, startY + (delta * eased));
      if (progress < 1) {
        navScrollRaf = window.requestAnimationFrame(step);
      } else {
        navScrollRaf = null;
        isNavAutoScrolling = false;
      }
    }

    navScrollRaf = window.requestAnimationFrame(step);
  }

  clearActive();

  if (heroSection) {
    setTimeout(function(){ heroSection.classList.add('hero--ornament-in'); }, 60);
    setTimeout(function(){ heroSection.classList.add('hero--text-in'); }, 700);
    setTimeout(function(){ heroSection.classList.add('hero--scroll-in'); }, 1020);
  }

  if (fixedNav) {
    fixedNav.classList.add('nav-intro');
    setTimeout(function(){
      requestAnimationFrame(function(){
        requestAnimationFrame(function(){
          fixedNav.classList.add('nav-intro-run');
        });
      });
    }, 980);
    setTimeout(function(){
      fixedNav.classList.add('nav-ready');
    }, 1800);
    setTimeout(function(){
      fixedNav.classList.remove('nav-intro');
      fixedNav.classList.remove('nav-intro-run');
    }, 3060);
  }

  tabs.forEach(function(tab){
    tab.addEventListener('mouseenter', function(){
      var idx = parseInt(tab.getAttribute('data-idx'));
      setHover(idx);
    });
    tab.addEventListener('mouseleave', clearHover);
    tab.addEventListener('click', function(e){
      e.preventDefault();
      var idx = parseInt(tab.getAttribute('data-idx'));
      setActive(idx);
      var target = document.getElementById(tab.getAttribute('data-section'));
      if (target) {
        var targetY = target.getBoundingClientRect().top + window.scrollY - 20;
        var distance = Math.abs(targetY - (window.scrollY || window.pageYOffset));
        var duration = Math.max(1200, Math.min(2200, distance * 1.05));
        smoothScrollToY(targetY, duration);
      }
    });
  });

  /* ── Scroll-spy ── */
  var sections = ['rct-history','rct-creator','rct-ruby','rct-timeline']
    .map(function(id){ return document.getElementById(id); }).filter(Boolean);

  function updateNav(){
    var y = window.scrollY + 100;
    var found = -1;
    sections.forEach(function(s,i){ if(s && s.getBoundingClientRect().top + window.scrollY <= y) found = i; });
    if (found === -1) {
      if (activeIdx !== -1) clearActive();
    } else if (found !== activeIdx) {
      setActive(found);
    }
    if (heroScrollCta) heroScrollCta.classList.toggle('is-hidden', window.scrollY > 0);
  }

  function updateHistoryRingRotation(){
    if (!historySection || !historyRing) return;
    var rect = historySection.getBoundingClientRect();
    var vh = window.innerHeight || document.documentElement.clientHeight;

    // Progress only while the section is crossing the viewport.
    var startPoint = vh * 0.9;
    var endPoint = -rect.height * 0.35;
    var progress = (startPoint - rect.top) / (startPoint - endPoint);
    progress = Math.max(0, Math.min(1, progress));

    var angle = historyRotateStart + (historyRotateEnd - historyRotateStart) * progress;
    var fadeProgress = (progress - 0.05) / 0.3;
    fadeProgress = Math.max(0, Math.min(1, fadeProgress));
    historyRing.style.transform = 'rotate(' + angle.toFixed(2) + 'deg)';
    historyRing.style.opacity = fadeProgress.toFixed(3);
  }

  function updateTimelineLineDraw(){
    if (!timelineLines.length) return;
    var vh = window.innerHeight || document.documentElement.clientHeight;
    timelineLines.forEach(function(line){
      var rect = line.getBoundingClientRect();
      var start = vh * 0.88;
      var end = vh * 0.16;
      var progress = (start - rect.top) / (rect.height + start - end);
      progress = Math.max(0, Math.min(1, progress));
      line.style.clipPath = 'inset(0 0 ' + ((1 - progress) * 100).toFixed(2) + '% 0)';
    });
  }

  function updateTimelineItemRevealByLine(){
    if (!timelineItems.length) return;
    var vh = window.innerHeight || document.documentElement.clientHeight;

    timelineItems.forEach(function(item){
      if (item.classList.contains('visible')) return;

      var timeline = item.closest('.timeline');
      var spine = timeline ? timeline.querySelector('.timeline__spine') : null;
      var dot = item.querySelector('.tl-dot');
      if (!timeline || !spine || !dot) return;

      var spineRect = spine.getBoundingClientRect();
      var dotRect = dot.getBoundingClientRect();

      var start = vh * 0.9;
      var end = vh * 0.16;
      var progress = (start - spineRect.top) / (spineRect.height + start - end);
      progress = Math.max(0, Math.min(1, progress));

      // Line tip in viewport coordinates.
      var lineTipY = spineRect.top + (progress * spineRect.height);
      var dotCenterY = dotRect.top + (dotRect.height * 0.5);

      // Show "Today" once it reaches mid-viewport instead of waiting for late line progression.
      if (item.classList.contains('tl-item--today')) {
        if (dotCenterY <= vh * 0.7) item.classList.add('visible');
        return;
      }

      var revealThreshold = item.closest('.timeline-era--ruby') ? 24 : 16;

      if (lineTipY >= dotCenterY - revealThreshold) item.classList.add('visible');
    });
  }

  function updateTimelineBreakRevealByLine(){
    if (!timelineBreak) return;
    var lightTimeline = document.querySelector('.era-light .timeline');
    var spine = lightTimeline ? lightTimeline.querySelector('.timeline__spine') : null;
    var breakDot = timelineBreak.querySelector('.timeline-break__dot');
    if (!spine || !breakDot) return;

    var vh = window.innerHeight || document.documentElement.clientHeight;
    var spineRect = spine.getBoundingClientRect();
    var breakDotRect = breakDot.getBoundingClientRect();
    var breakCenterY = breakDotRect.top + (breakDotRect.height * 0.5);

    var start = vh * 0.88;
    var end = vh * 0.16;
    var progress = (start - spineRect.top) / (spineRect.height + start - end);
    progress = Math.max(0, Math.min(1, progress));
    var lineTipY = spineRect.top + (progress * spineRect.height);
    var lineToBreakDistance = breakCenterY - spineRect.bottom;

    // Reveal 1996 when the drawn line is near the breakpoint zone.
    var isLineNearBreak =
      (progress >= 0.88 && lineToBreakDistance <= vh * 0.22) ||
      (lineTipY >= breakCenterY - 20);

    if (isLineNearBreak) {
      var eventEl = timelineBreak.querySelector('.timeline-break__event');
      var rubyEl = timelineBreak.querySelector('.timeline-break__ruby');
      if (eventEl) eventEl.classList.add('visible');
      if (breakDot) breakDot.classList.add('visible');
      if (rubyEl) rubyEl.classList.add('visible');
    }
  }

  function onScroll(){
    if (scrollTicking) return;
    scrollTicking = true;
    window.requestAnimationFrame(function(){
      updateNav();
      if (!isNavAutoScrolling) {
        updateHistoryRingRotation();
        updateTimelineLineDraw();
        updateTimelineItemRevealByLine();
        updateTimelineBreakRevealByLine();
      }
      scrollTicking = false;
    });
  }

  window.addEventListener('scroll', onScroll, { passive:true });
  window.addEventListener('resize', function(){
    updateHistoryRingRotation();
    updateTimelineLineDraw();
  });
  hydrateTimelineYearMarkers();
  initHeroLottie();
  initRebrandingLogoLottie();
  updateNav();
  updateHistoryRingRotation();
  updateTimelineLineDraw();
  updateTimelineItemRevealByLine();
  updateTimelineBreakRevealByLine();

  /* ── Fade-in on scroll ── */
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.isIntersecting){ e.target.classList.add('visible'); io.unobserve(e.target); }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade:not(.hero__content)').forEach(function(el){ io.observe(el); });
})();
{% endjavascript %}

