{%- assign bg_url = section.settings.background_image | image_url: width: 2600 -%}
{%- if bg_url == blank -%}
  {%- assign bg_url = 'figma-images/hero-bg.jpg' | asset_url -%}
{%- endif -%}
{%- assign history_years = '1977|1986|1996|2000|2002|2003|2006|2008|2010|2013|2014|2018|2021|2022|2025|TODAY' | split: '|' -%}

<section class="rc-history-page" style="--rc-bg:url('{{ bg_url }}');">
  <div class="rc-history-page__fixed-bg" aria-hidden="true"></div>
  <div class="rc-history-page__fixed-vignette" aria-hidden="true"></div>
  <div class="rc-history-hero">
    <div class="rc-history-hero__flower" aria-hidden="true">
      <svg width="452" height="466" viewBox="0 0 452 466" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M253.807 274.486C269.754 297.022 275.418 309.308 275.418 330.306C275.418 356.938 258.949 385.107 228.059 405.585C197.169 385.107 180.7 356.938 180.7 330.306C180.7 309.308 186.364 297.022 202.331 274.486L198.214 272.428L186.364 286.253C155.996 321.595 147.741 338.497 147.741 354.36C147.741 394.816 196.646 427.082 216.731 455.252L224.443 466H231.653L239.386 455.252C259.471 427.602 308.377 394.816 308.377 354.36C308.377 338.476 300.142 321.574 269.754 286.253L257.924 272.428L253.807 274.486ZM10.8052 221.742L0 229.435V236.607L10.8052 244.278C39.6261 264.756 71.54 312.905 112.232 312.905C128.199 312.905 145.17 304.714 180.7 274.507L194.598 262.719L192.529 258.623C169.874 274.507 157.522 280.12 136.936 280.12C109.64 280.12 81.3421 263.218 61.2573 233.01C81.3421 202.782 109.661 185.901 136.936 185.901C157.522 185.901 169.874 191.535 192.529 207.418L194.598 203.323L180.7 191.556C145.17 161.348 128.199 153.137 112.232 153.137C71.5609 153.137 39.1245 201.784 10.8052 221.763M271.3 191.535L257.402 203.302L259.45 207.398C282.106 191.514 294.457 185.88 315.044 185.88C342.318 185.88 370.637 202.782 390.722 232.99C370.637 263.197 342.318 280.099 315.044 280.099C294.457 280.099 282.106 274.465 259.45 258.602L257.402 262.698L271.3 274.486C306.83 304.693 323.821 312.884 339.768 312.884C380.439 312.884 412.353 264.735 441.195 244.258L452 236.586V229.414L441.195 221.722C412.876 201.743 380.439 153.095 339.768 153.095C323.801 153.095 306.809 161.286 271.3 191.514M224.464 0L216.752 10.7482C196.667 38.9182 147.762 71.1838 147.762 111.64C147.762 127.503 155.996 144.405 186.384 179.747L198.235 193.572L202.352 191.514C186.384 168.978 180.721 156.692 180.721 136.214C180.721 109.083 197.712 80.9133 228.08 60.9345C258.447 80.9133 275.438 109.083 275.438 136.214C275.438 156.692 269.775 168.978 253.828 191.514L257.945 193.572L269.775 179.747C300.163 144.405 308.397 127.503 308.397 111.64C308.397 71.1838 260.014 39.438 239.407 10.7482L231.674 0H224.464Z" fill="#397E70"/>
      </svg>
    </div>
    <p class="rc-history-hero__eyebrow">{{ section.settings.hero_eyebrow | default: 'SINCE 1996' }}</p>
    <h1 class="rc-history-hero__title">{{ section.settings.hero_title | default: 'The Brand' }}</h1>
    <p class="rc-history-hero__scroll">{{ section.settings.hero_scroll_label | default: 'Scroll to discover our story' }}</p>
  </div>

<section class="rc-history" id="rc-history-{{ section.id }}" style="--steps: {{ history_years.size }};">
  <div class="rc-history__stage" id="rc-history-stage-{{ section.id }}">
    <div class="rc-history__vignette" aria-hidden="true"></div>

    <div class="rc-history__media" id="rc-history-media-{{ section.id }}" aria-live="polite">
      {%- for y in history_years -%}
        <article class="rc-history__panel{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}">
          <figure class="rc-history__img rc-history__img--left"><span class="rc-history__ph-label">Placeholder {{ y }}</span></figure>
          <figure class="rc-history__img rc-history__img--main"><span class="rc-history__ph-label">Main {{ y }}</span></figure>
          <figure class="rc-history__img rc-history__img--right"><span class="rc-history__ph-label">Detail {{ y }}</span></figure>
        </article>
      {%- endfor -%}
    </div> 

    <div class="rc-history__years-window">
      <div class="rc-history__years-track" id="rc-history-track-{{ section.id }}">
        {%- for y in history_years -%}
          <button class="rc-history__year{% if forloop.first %} is-active{% endif %}" type="button" data-index="{{ forloop.index0 }}">{{ y }}</button>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>
</section>

{% stylesheet %}
  .rc-history-page {
    position: relative;
    background: transparent;
  }

  .rc-history-page__fixed-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: #27574D;
  }

  .rc-history-page__fixed-vignette {
    display: none;
  }

  .rc-history-page.is-over-footer .rc-history-page__fixed-bg,
  .rc-history-page.is-over-footer .rc-history-page__fixed-vignette {
    opacity: 0;
  }

  .rc-history-hero {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
    margin-top: calc((var(--header-height, 0px) + var(--announcement-height, 0px)) * -1);
    background: transparent;
    overflow: hidden;
  }

  .rc-history-hero::before {
    display: none;
  }

  .rc-history-hero__flower {
    position: absolute;
    width: 500px;
    height: 500px;
    opacity: 0.36;
    z-index: 1;
    pointer-events: none;
    display: grid;
    place-items: center;
  }

  .rc-history-hero__flower svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .rc-history-hero__eyebrow,
  .rc-history-hero__title,
  .rc-history-hero__scroll {
    position: relative;
    z-index: 2;
  }

  .rc-history-hero__eyebrow {
    margin-top: 0;
    font-size: 12px;
    letter-spacing: 0.2em;
    font-family: var(--font-body-family, "Inter", sans-serif);
    font-weight: 500;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.82);
  }

  .rc-history-hero__title {
    margin-top: 20px;
    font-size: 40px;
    letter-spacing: 0.02em;
    font-family: "Portrait LC", "Didot", "Bodoni MT", "Times New Roman", Georgia, serif;
    font-weight: 500;
    color: #fff;
  }

  .rc-history-hero__scroll {
    margin-top: 22px;
    font-size: 12px;
    letter-spacing: 0.16em;
    font-family: var(--font-body-family, "Inter", sans-serif);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
  }

  .rc-history {
    --gap-y: 60px;
    --year-size: 46px;
    position: relative;
    height: calc(var(--steps, 16) * 100vh);
    z-index: 2;
    background: transparent;
  }

  .rc-history__stage {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    background: transparent;
  }

  .rc-history__vignette {
    display: none;
  }

  .rc-history__media {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  .rc-history__panel {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 260ms ease;
  }

  .rc-history__panel.is-active {
    opacity: 1;
  }

  .rc-history__img {
    position: absolute;
    overflow: hidden;
    background: linear-gradient(145deg, rgba(240, 240, 240, 0.3), rgba(170, 170, 170, 0.18));
    border: 1px solid rgba(255, 255, 255, 0.25);
    clip-path: inset(0 100% 0 0);
    opacity: 0;
    transform: translateY(18px) scale(0.985);
  }

  .rc-history__ph-label {
    position: absolute;
    left: 14px;
    bottom: 12px;
    color: rgba(255, 255, 255, 0.92);
    font-family: var(--font-body-family, "Inter", sans-serif);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .rc-history__panel.is-active .rc-history__img {
    animation: rc-history-reveal 0.65s ease-out forwards;
  }

  .rc-history__panel.is-active .rc-history__img--left { animation-delay: 0.02s; }
  .rc-history__panel.is-active .rc-history__img--main { animation-delay: 0.09s; }
  .rc-history__panel.is-active .rc-history__img--right { animation-delay: 0.16s; }

  .rc-history__img--left {
    width: min(30vw, 580px);
    height: min(28vh, 340px);
    left: min(12vw, 220px);
    top: 34vh;
  }

  .rc-history__img--main {
    width: min(21vw, 320px);
    height: min(56vh, 620px);
    left: 50%;
    top: 18vh;
    transform: translateX(-50%) translateY(18px) scale(0.985);
  }

  .rc-history__img--right {
    width: min(10vw, 170px);
    height: min(25vh, 240px);
    left: calc(50% + min(14vw, 235px));
    top: 18vh;
  }

  .rc-history__years-window {
    position: absolute;
    inset: 0;
    z-index: 6;
    display: grid;
    place-items: center;
    pointer-events: auto;
    opacity: 0;
    transition: opacity 420ms ease;
  }

  .rc-history__years-window.is-visible {
    opacity: 1;
  }

  .rc-history__years-track {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap-y);
    width: 100%;
    transform: translate3d(0, 0, 0);
    transition: transform 650ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
    pointer-events: auto;
  }

  .rc-history__year {
    appearance: none;
    border: 0;
    background: transparent;
    margin: 0;
    padding: 0;
    color: #fff;
    opacity: 0;
    cursor: pointer;
    font-family: "Portrait LC", "Didot", "Bodoni MT", "Times New Roman", Georgia, serif;
    font-size: var(--year-size);
    font-weight: 500;
    letter-spacing: 0.06em;
    line-height: 1;
    transform: translateY(8px) scale(0.94);
    transition: opacity 280ms ease, transform 280ms ease;
    text-shadow: none;
  }

  .rc-history__year.is-seen {
    opacity: 0.38;
    transform: translateY(0) scale(0.94);
  }

  .rc-history__year.is-active {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .rc-history__year:focus-visible {
    outline: 1px solid rgba(255, 255, 255, 0.7);
    outline-offset: 10px;
  }

  @keyframes rc-history-reveal {
    from {
      clip-path: inset(0 100% 0 0);
      opacity: 0;
      transform: translateY(18px) scale(0.985);
    }
    to {
      clip-path: inset(0 0 0 0);
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (max-width: 860px) {
    .rc-history {
      --gap-y: 44px;
      --year-size: 38px;
    }

    .rc-history__img--left {
      width: 58vw;
      height: 20vh;
      left: 6vw;
      top: 40vh;
    }

    .rc-history__img--main {
      width: 36vw;
      height: 40vh;
      top: 23vh;
    }

    .rc-history__img--right {
      width: 20vw;
      height: 16vh;
      left: auto;
      right: 6vw;
      top: 23vh;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var root = document.getElementById('rc-history-{{ section.id }}');
    if (!root) return;

    var stage = document.getElementById('rc-history-stage-{{ section.id }}');
    var track = document.getElementById('rc-history-track-{{ section.id }}');
    var media = document.getElementById('rc-history-media-{{ section.id }}');
    var yearsWindow = root.querySelector('.rc-history__years-window');
    if (!stage || !track || !media || !yearsWindow) return;

    var years = Array.prototype.slice.call(track.querySelectorAll('.rc-history__year'));
    var panels = Array.prototype.slice.call(media.querySelectorAll('.rc-history__panel'));

    var steps = years.length;
    var activeIndex = -1;
    var segment = window.innerHeight;
    var yearOffsets = [];

    function clamp(n, min, max) {
      return Math.max(min, Math.min(max, n));
    }

    function measureOffsets() {
      var winCenter = stage.clientHeight / 2;
      yearOffsets = years.map(function (yearEl) {
        return winCenter - (yearEl.offsetTop + (yearEl.offsetHeight / 2));
      });
    }

    function setTrackY(y) {
      track.style.transform = 'translate3d(0,' + y + 'px,0)';
    }

    function setActive(index) {
      index = clamp(index, 0, steps - 1);
      if (index === activeIndex) return;
      activeIndex = index;

      years.forEach(function (el, i) {
        el.classList.toggle('is-active', i === index);
        el.classList.toggle('is-seen', i <= index);
      });

      panels.forEach(function (panel, i) {
        panel.classList.toggle('is-active', i === index);
      });
    }

    function syncToScrollPosition() {
      if (segment <= 0 || steps <= 1) {
        setActive(0);
        return;
      }

      var rect = root.getBoundingClientRect();
      var isVisible = rect.top <= (window.innerHeight * 0.1);
      yearsWindow.classList.toggle('is-visible', isVisible);
      var maxTravel = (steps - 1) * segment;
      var scrollInside = clamp(-rect.top, 0, maxTravel);
      var idx = clamp(Math.round(scrollInside / segment), 0, steps - 1);
      if (yearOffsets[idx] != null) setTrackY(yearOffsets[idx]);
      if (isVisible) {
        setActive(idx);
      } else {
        years.forEach(function (el) {
          el.classList.remove('is-active');
          el.classList.remove('is-seen');
        });
      }
    }

    function scrollToYear(index) {
      var top = root.offsetTop + (index * segment);
      window.scrollTo({ top: top, behavior: 'smooth' });
    }

    function onResize() {
      segment = window.innerHeight;
      root.style.height = (steps * segment) + 'px';
      measureOffsets();
      if (yearOffsets[activeIndex] != null) {
        setTrackY(yearOffsets[activeIndex]);
      }
      syncToScrollPosition();
    }

    years.forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        var idx = parseInt(btn.getAttribute('data-index'), 10);
        if (isNaN(idx)) return;
        setActive(idx);
        if (yearOffsets[idx] != null) setTrackY(yearOffsets[idx]);
        scrollToYear(idx);
      });
    });

    years.forEach(function (el, i) {
      el.classList.toggle('is-active', i === 0);
      el.classList.toggle('is-seen', i === 0);
    });
    panels.forEach(function (panel, i) {
      panel.classList.toggle('is-active', i === 0);
    });

    onResize();

    requestAnimationFrame(function () {
      if (yearOffsets[0] != null) setTrackY(yearOffsets[0]);
      syncToScrollPosition();
    });

    window.addEventListener('scroll', syncToScrollPosition, { passive: true });
    window.addEventListener('resize', onResize);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "RC Timeline",
  "tag": "section",
  "class": "section rc-history-section",
  "settings": [
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Hero eyebrow",
      "default": "SINCE 1996"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero title",
      "default": "The Brand"
    },
    {
      "type": "text",
      "id": "hero_scroll_label",
      "label": "Hero scroll label",
      "default": "Scroll to discover our story"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    }
  ],
  "presets": [
    {
      "name": "RC Timeline"
    }
  ]
}
{% endschema %}
