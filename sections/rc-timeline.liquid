{{ 'roberto-coin-story.css' | asset_url | stylesheet_tag }}
<script src="{{ 'roberto-coin-story.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign section_id = 'rc-story-' | append: section.id
  assign history_id = section_id | append: '-history'
  assign creator_id = section_id | append: '-creator'
  assign ruby_id = section_id | append: '-ruby'
  assign timeline_id = section_id | append: '-timeline'
-%}

<section
  id="{{ section_id }}"
  class="rc-story"
  style="
    --bg: {{ section.settings.background_color }};
    --bg-soft: {{ section.settings.background_soft_color }};
    --bg-glow: {{ section.settings.background_glow_color }};
    --text: {{ section.settings.text_color }};
    --muted: {{ section.settings.text_color | color_modify: 'alpha', 0.62 }};
    --dim: {{ section.settings.text_color | color_modify: 'alpha', 0.34 }};
    --accent: {{ section.settings.accent_color }};
    --accent-soft: {{ section.settings.accent_color | color_modify: 'alpha', 0.35 }};
    --logo-color: {{ section.settings.logo_color }};
    --today-color: {{ section.settings.today_color }};
    --active-year-color: {{ section.settings.active_year_color }};
    --year-size: {{ section.settings.year_size }}px;
    --copy-size: {{ section.settings.caption_size }}px;
    --panel-height: {{ section.settings.panel_height }}vh;
  "
  data-section-id="{{ section.id }}"
>
  <div class="page-shell">
    <main>
      <section class="hero" id="{{ section_id }}-top">

        {%- liquid
          assign hero_top_a = section.settings.rc_tl_hero_image_top | default: section.settings.hero_image_top
          assign hero_right_a = section.settings.rc_tl_hero_image_right | default: section.settings.hero_image_right
          assign hero_left_a = section.settings.rc_tl_hero_image_left | default: section.settings.hero_image_left
          assign hero_bottom_a = section.settings.rc_tl_hero_image_bottom | default: section.settings.hero_image_bottom
          assign hero_top_b = section.settings.rc_tl_hero_image_top_alt | default: section.settings.hero_image_top_alt
          assign hero_right_b = section.settings.rc_tl_hero_image_right_alt | default: section.settings.hero_image_right_alt
          assign hero_left_b = section.settings.rc_tl_hero_image_left_alt | default: section.settings.hero_image_left_alt
          assign hero_bottom_b = section.settings.rc_tl_hero_image_bottom_alt | default: section.settings.hero_image_bottom_alt
          assign hero_eyebrow = section.settings.rc_tl_hero_eyebrow | default: section.settings.hero_eyebrow
          assign hero_title = section.settings.rc_tl_hero_title | default: section.settings.hero_title
        -%}
        <div class="hero-center">
          <div class="hero-collage" aria-hidden="true">
            <figure class="hero-collage__item hero-collage__item--top">
              {% if hero_top_a != blank or hero_top_b != blank %}
                <img
                  src="{{ hero_top_a | default: hero_top_b | image_url: width: 1400 }}"
                  alt="{{ hero_top_a.alt | default: hero_top_b.alt | escape }}"
                  data-image-a="{{ hero_top_a | default: hero_top_b | image_url: width: 1400 }}"
                  data-image-b="{{ hero_top_b | default: hero_top_a | image_url: width: 1400 }}"
                  data-alt-a="{{ hero_top_a.alt | default: hero_top_b.alt | escape }}"
                  data-alt-b="{{ hero_top_b.alt | default: hero_top_a.alt | escape }}"
                >
              {% endif %}
            </figure>
            <figure class="hero-collage__item hero-collage__item--right">
              {% if hero_right_a != blank or hero_right_b != blank %}
                <img
                  src="{{ hero_right_a | default: hero_right_b | image_url: width: 1800 }}"
                  alt="{{ hero_right_a.alt | default: hero_right_b.alt | escape }}"
                  data-image-a="{{ hero_right_a | default: hero_right_b | image_url: width: 1800 }}"
                  data-image-b="{{ hero_right_b | default: hero_right_a | image_url: width: 1800 }}"
                  data-alt-a="{{ hero_right_a.alt | default: hero_right_b.alt | escape }}"
                  data-alt-b="{{ hero_right_b.alt | default: hero_right_a.alt | escape }}"
                >
              {% endif %}
            </figure>
            <figure class="hero-collage__item hero-collage__item--left">
              {% if hero_left_a != blank or hero_left_b != blank %}
                <img
                  src="{{ hero_left_a | default: hero_left_b | image_url: width: 1800 }}"
                  alt="{{ hero_left_a.alt | default: hero_left_b.alt | escape }}"
                  data-image-a="{{ hero_left_a | default: hero_left_b | image_url: width: 1800 }}"
                  data-image-b="{{ hero_left_b | default: hero_left_a | image_url: width: 1800 }}"
                  data-alt-a="{{ hero_left_a.alt | default: hero_left_b.alt | escape }}"
                  data-alt-b="{{ hero_left_b.alt | default: hero_left_a.alt | escape }}"
                >
              {% endif %}
            </figure>
            <figure class="hero-collage__item hero-collage__item--bottom">
              {% if hero_bottom_a != blank or hero_bottom_b != blank %}
                <img
                  src="{{ hero_bottom_a | default: hero_bottom_b | image_url: width: 1800 }}"
                  alt="{{ hero_bottom_a.alt | default: hero_bottom_b.alt | escape }}"
                  data-image-a="{{ hero_bottom_a | default: hero_bottom_b | image_url: width: 1800 }}"
                  data-image-b="{{ hero_bottom_b | default: hero_bottom_a | image_url: width: 1800 }}"
                  data-alt-a="{{ hero_bottom_a.alt | default: hero_bottom_b.alt | escape }}"
                  data-alt-b="{{ hero_bottom_b.alt | default: hero_bottom_a.alt | escape }}"
                >
              {% endif %}
            </figure>
          </div>

          <div class="hero-copy">
            <svg class="hero-copy__flower" width="452" height="466" viewBox="0 0 452 466" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
              <path d="M253.807 274.486C269.754 297.022 275.418 309.308 275.418 330.306C275.418 356.938 258.949 385.107 228.059 405.585C197.169 385.107 180.7 356.938 180.7 330.306C180.7 309.308 186.364 297.022 202.331 274.486L198.214 272.428L186.364 286.253C155.996 321.595 147.741 338.497 147.741 354.36C147.741 394.816 196.646 427.082 216.731 455.252L224.443 466H231.653L239.386 455.252C259.471 427.602 308.377 394.816 308.377 354.36C308.377 338.476 300.142 321.574 269.754 286.253L257.924 272.428L253.807 274.486ZM10.8052 221.742L0 229.435V236.607L10.8052 244.278C39.6261 264.756 71.54 312.905 112.232 312.905C128.199 312.905 145.17 304.714 180.7 274.507L194.598 262.719L192.529 258.623C169.874 274.507 157.522 280.12 136.936 280.12C109.64 280.12 81.3421 263.218 61.2573 233.01C81.3421 202.782 109.661 185.901 136.936 185.901C157.522 185.901 169.874 191.535 192.529 207.418L194.598 203.323L180.7 191.556C145.17 161.348 128.199 153.137 112.232 153.137C71.5609 153.137 39.1245 201.784 10.8052 221.763M271.3 191.535L257.402 203.302L259.45 207.398C282.106 191.514 294.457 185.88 315.044 185.88C342.318 185.88 370.637 202.782 390.722 232.99C370.637 263.197 342.318 280.099 315.044 280.099C294.457 280.099 282.106 274.465 259.45 258.602L257.402 262.698L271.3 274.486C306.83 304.693 323.821 312.884 339.768 312.884C380.439 312.884 412.353 264.735 441.195 244.258L452 236.586V229.414L441.195 221.722C412.876 201.743 380.439 153.095 339.768 153.095C323.801 153.095 306.809 161.286 271.3 191.514M224.464 0L216.752 10.7482C196.667 38.9182 147.762 71.1838 147.762 111.64C147.762 127.503 155.996 144.405 186.384 179.747L198.235 193.572L202.352 191.514C186.384 168.978 180.721 156.692 180.721 136.214C180.721 109.083 197.712 80.9133 228.08 60.9345C258.447 80.9133 275.438 109.083 275.438 136.214C275.438 156.692 269.775 168.978 253.828 191.514L257.945 193.572L269.775 179.747C300.163 144.405 308.397 127.503 308.397 111.64C308.397 71.1838 260.014 39.438 239.407 10.7482L231.674 0H224.464Z" fill="#397E70"/>
            </svg>
            <p class="eyebrow">{{ hero_eyebrow }}</p>
            <h2>{{ hero_title }}</h2>
          </div>

          <a class="scroll-link" href="#{{ timeline_id }}">{{ section.settings.scroll_text }}</a>
        </div>
      </section>

      <section id="{{ history_id }}" class="history">
        <div class="history__inner">
          <div class="history__left">
            <h2 class="history__title reveal-up">{{ section.settings.history_title }}</h2>
            <p class="reveal-up reveal-up--delay-1">{{ section.settings.history_left_copy }}</p>
          </div>

          <div class="history__center">
            {% if section.settings.history_ring_drawing != blank %}
              <img class="history__ring history__ring--drawing" src="{{ section.settings.history_ring_drawing | image_url: width: 2200 }}" alt="{{ section.settings.history_ring_drawing.alt | escape }}">
            {% endif %}
            {% if section.settings.history_ring_photo != blank %}
              <img class="history__ring history__ring--photo" src="{{ section.settings.history_ring_photo | image_url: width: 2200 }}" alt="{{ section.settings.history_ring_photo.alt | escape }}">
            {% endif %}
          </div>

          <div class="history__right">
            <p class="reveal-up reveal-up--delay-2">{{ section.settings.history_right_copy }}</p>
          </div>
        </div>
      </section>

      <section id="{{ creator_id }}" class="creator">
        <div class="creator__inner">
          <div class="creator__image reveal-up">
            {% if section.settings.creator_image != blank %}
              <img src="{{ section.settings.creator_image | image_url: width: 1800 }}" alt="{{ section.settings.creator_image.alt | escape }}">
            {% endif %}
          </div>
          <div class="creator__text">
            <h2 class="creator__title reveal-up reveal-up--delay-1">{{ section.settings.creator_title }}</h2>
            <div class="creator__body">
              <p class="reveal-up reveal-up--delay-2">{{ section.settings.creator_copy_1 }}</p>
              <p class="reveal-up reveal-up--delay-3">{{ section.settings.creator_copy_2 }}</p>
            </div>
          </div>
        </div>
        {% if section.settings.creator_drawing != blank %}
          <img class="creator__vicenza reveal-up reveal-up--delay-3" src="{{ section.settings.creator_drawing | image_url: width: 2200 }}" alt="{{ section.settings.creator_drawing.alt | escape }}">
        {% endif %}
      </section>

      <section id="{{ ruby_id }}" class="ruby-section">
        <div
          class="ruby-section__inner"
          {% if section.settings.ruby_image != blank %}
            style="background-image: url('{{ section.settings.ruby_image | image_url: width: 2400 }}');"
          {% endif %}
        >
          <div class="ruby-section__content">
            <h2 class="ruby-section__title reveal-up">{{ section.settings.ruby_title }}</h2>
            <div class="ruby-section__body ruby-section__body--stagger reveal-up reveal-up--delay-1">
              {{ section.settings.ruby_copy }}
            </div>
          </div>
        </div>
      </section>

      <section class="timeline" id="{{ timeline_id }}" aria-label="{{ section.settings.timeline_aria_label | escape }}">
        <div class="timeline-stage" data-stage>
          <div class="timeline-panel">
            <div class="media-layout" data-media-layout></div>
            <div class="timeline-caption" data-timeline-caption>
              <p data-caption-line-one></p>
              <p data-caption-line-two></p>
            </div>
          </div>
          <div class="year-rail" aria-label="{{ section.settings.year_rail_aria_label | escape }}" data-year-rail></div>
        </div>
        <div class="timeline-markers" data-timeline-markers></div>
      </section>
    </main>

    <nav class="section-nav section-nav--fixed" aria-label="Page sections">
      <div class="section-nav__shape">
