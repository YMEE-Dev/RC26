{{ 'roberto-coin-story.css' | asset_url | stylesheet_tag }}
<script src="{{ 'roberto-coin-story.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign section_id = 'rc-story-' | append: section.id
  assign history_id = section_id | append: '-history'
  assign creator_id = section_id | append: '-creator'
  assign ruby_id = section_id | append: '-ruby'
  assign timeline_id = section_id | append: '-timeline'
-%}

<section
  id="{{ section_id }}"
  class="rc-story"
  style="
    --bg: {{ section.settings.background_color }};
    --bg-soft: {{ section.settings.background_soft_color }};
    --bg-glow: {{ section.settings.background_glow_color }};
    --text: {{ section.settings.text_color }};
    --muted: {{ section.settings.text_color | color_modify: 'alpha', 0.62 }};
    --dim: {{ section.settings.text_color | color_modify: 'alpha', 0.34 }};
    --accent: {{ section.settings.accent_color }};
    --accent-soft: {{ section.settings.accent_color | color_modify: 'alpha', 0.35 }};
    --logo-color: {{ section.settings.logo_color }};
    --today-color: {{ section.settings.today_color }};
    --active-year-color: {{ section.settings.active_year_color }};
    --year-size: {{ section.settings.year_size }}px;
    --copy-size: {{ section.settings.caption_size }}px;
    --panel-height: {{ section.settings.panel_height }}vh;
  "
  data-section-id="{{ section.id }}"
>
  <div class="page-shell">
    <main>
      <section class="hero" id="{{ section_id }}-top">

        <div class="hero-center">
          <div class="hero-collage" aria-hidden="true">
            <figure class="hero-collage__item hero-collage__item--top">
              {% if section.settings.hero_image_top != blank %}
                <img src="{{ section.settings.hero_image_top | image_url: width: 1400 }}" alt="{{ section.settings.hero_image_top.alt | escape }}">
              {% endif %}
            </figure>
            <figure class="hero-collage__item hero-collage__item--right">
              {% if section.settings.hero_image_right != blank %}
                <img src="{{ section.settings.hero_image_right | image_url: width: 1800 }}" alt="{{ section.settings.hero_image_right.alt | escape }}">
              {% endif %}
            </figure>
            <figure class="hero-collage__item hero-collage__item--left">
              {% if section.settings.hero_image_left != blank %}
                <img src="{{ section.settings.hero_image_left | image_url: width: 1800 }}" alt="{{ section.settings.hero_image_left.alt | escape }}">
              {% endif %}
            </figure>
            <figure class="hero-collage__item hero-collage__item--bottom">
              {% if section.settings.hero_image_bottom != blank %}
                <img src="{{ section.settings.hero_image_bottom | image_url: width: 1800 }}" alt="{{ section.settings.hero_image_bottom.alt | escape }}">
              {% endif %}
            </figure>
          </div>

          <div class="hero-copy">
            <p class="eyebrow">{{ section.settings.hero_eyebrow }}</p>
            <h2>{{ section.settings.hero_title }}</h2>
          </div>

          <a class="scroll-link" href="#{{ timeline_id }}">{{ section.settings.scroll_text }}</a>
        </div>
      </section>

      <section id="{{ history_id }}" class="history">
        <div class="history__inner">
          <div class="history__left">
            <h2 class="history__title">{{ section.settings.history_title }}</h2>
            <p>{{ section.settings.history_left_copy }}</p>
          </div>

          <div class="history__center">
            {% if section.settings.history_ring_drawing != blank %}
              <img class="history__ring history__ring--drawing" src="{{ section.settings.history_ring_drawing | image_url: width: 2200 }}" alt="{{ section.settings.history_ring_drawing.alt | escape }}">
            {% endif %}
            {% if section.settings.history_ring_photo != blank %}
              <img class="history__ring history__ring--photo" src="{{ section.settings.history_ring_photo | image_url: width: 2200 }}" alt="{{ section.settings.history_ring_photo.alt | escape }}">
            {% endif %}
          </div>

          <div class="history__right">
            <p>{{ section.settings.history_right_copy }}</p>
          </div>
        </div>
      </section>

      <section id="{{ creator_id }}" class="creator">
        <div class="creator__inner">
          <div class="creator__image reveal-up">
            {% if section.settings.creator_image != blank %}
              <img src="{{ section.settings.creator_image | image_url: width: 1800 }}" alt="{{ section.settings.creator_image.alt | escape }}">
            {% endif %}
          </div>
          <div class="creator__text reveal-up reveal-up--delay-1">
            <h2 class="creator__title">{{ section.settings.creator_title }}</h2>
            <div class="creator__body reveal-up reveal-up--delay-2">
              <p>{{ section.settings.creator_copy_1 }}</p>
              <p>{{ section.settings.creator_copy_2 }}</p>
            </div>
          </div>
        </div>
        {% if section.settings.creator_drawing != blank %}
          <img class="creator__vicenza reveal-up reveal-up--delay-3" src="{{ section.settings.creator_drawing | image_url: width: 2200 }}" alt="{{ section.settings.creator_drawing.alt | escape }}">
        {% endif %}
      </section>

      <section id="{{ ruby_id }}" class="ruby-section">
        <div
          class="ruby-section__inner"
          {% if section.settings.ruby_image != blank %}
            style="background-image: url('{{ section.settings.ruby_image | image_url: width: 2400 }}');"
          {% endif %}
        >
          <div class="ruby-section__content">
            <h2 class="ruby-section__title">{{ section.settings.ruby_title }}</h2>
            <div class="ruby-section__body">
              {{ section.settings.ruby_copy }}
            </div>
          </div>
        </div>
      </section>

      <section class="timeline" id="{{ timeline_id }}" aria-label="{{ section.settings.timeline_aria_label | escape }}">
        <div class="timeline-stage" data-stage>
          <div class="timeline-panel">
            <div class="media-layout" data-media-layout></div>
            <div class="timeline-caption" data-timeline-caption>
              <p data-caption-line-one></p>
              <p data-caption-line-two></p>
            </div>
          </div>
          <div class="year-rail" aria-label="{{ section.settings.year_rail_aria_label | escape }}" data-year-rail></div>
        </div>
        <div class="timeline-markers" data-timeline-markers></div>
      </section>
    </main>

    <nav class="section-nav section-nav--fixed" aria-label="Page sections">
      <div class="section-nav__shape">
