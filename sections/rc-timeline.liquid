<script>
  (function () {
    /* ── Scroll-spy: highlight active nav tab ── */
    var tabs = document.querySelectorAll('.rct-nav__tab');
    var sections = ['rct-history', 'rct-creator', 'rct-ruby', 'rct-timeline'].map(function (id) {
      return document.getElementById(id);
    }).filter(Boolean);

    function getActiveSection() {
      var scrollY = window.scrollY + 80;
      var active = sections[0];
      sections.forEach(function (sec) {
        if (sec.getBoundingClientRect().top + window.scrollY <= scrollY) active = sec;
      });
      return active;
    }

    function updateNav() {
      var active = getActiveSection();
      tabs.forEach(function (tab) {
        var id = tab.getAttribute('data-section');
        tab.classList.toggle('is-active', active && active.id === id);
      });
    }

    window.addEventListener('scroll', updateNav, { passive: true });
    updateNav();

    /* ── Smooth scroll on tab click ── */
    tabs.forEach(function (tab) {
      tab.addEventListener('click', function (e) {
        e.preventDefault();
        var targetId = tab.getAttribute('data-section');
        var target = document.getElementById(targetId);
        if (target) {
          var navH = document.querySelector('.rct-nav').offsetHeight;
          var top = target.getBoundingClientRect().top + window.scrollY - navH;
          window.scrollTo({ top: top, behavior: 'smooth' });
        }
      });
    });

    /* ── Intersection Observer: fade-in animations ── */
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12 });

      document.querySelectorAll('.rct-fade, .rct-timeline__item').forEach(function (el) {
        io.observe(el);
      });
    } else {
      /* Fallback: show everything for old browsers */
      document.querySelectorAll('.rct-fade, .rct-timeline__item').forEach(function (el) {
        el.classList.add('is-visible');
      });
    }
  })();
</script>

