    { "type": "text", "id": "right_link_1_label", "label": "Right link 1 label", "default": "Find a Boutique" },
    { "type": "url", "id": "right_link_1_url", "label": "Right link 1 URL" },
    { "type": "text", "id": "right_link_2_label", "label": "Right link 2 label", "default": "Concierge" },
