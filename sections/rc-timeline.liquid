          <line x1="611" y1="4" x2="611" y2="46" stroke="#27574D" stroke-width="1.5" stroke-opacity="0.8"/>
        </svg>
        <div class="section-nav__tabs">
          <a class="section-nav__tab" data-idx="0" data-section="{{ history_id }}" href="#{{ history_id }}">{{ section.settings.section_nav_history }}</a>
          <a class="section-nav__tab" data-idx="1" data-section="{{ creator_id }}" href="#{{ creator_id }}">{{ section.settings.section_nav_creator }}</a>
          <a class="section-nav__tab" data-idx="2" data-section="{{ ruby_id }}" href="#{{ ruby_id }}">{{ section.settings.section_nav_ruby }}</a>
          <a class="section-nav__tab" data-idx="3" data-section="{{ timeline_id }}" href="#{{ timeline_id }}">{{ section.settings.section_nav_timeline }}</a>
        </div>
        <div class="section-nav__mobile" aria-hidden="true">
          <div class="section-nav__mobile-dropdown" aria-hidden="true">
            <a class="section-nav__mobile-link" href="#{{ history_id }}" data-section="{{ history_id }}" data-idx="0">{{ section.settings.section_nav_history }}</a>
            <a class="section-nav__mobile-link" href="#{{ creator_id }}" data-section="{{ creator_id }}" data-idx="1">{{ section.settings.section_nav_creator }}</a>
            <a class="section-nav__mobile-link" href="#{{ ruby_id }}" data-section="{{ ruby_id }}" data-idx="2">{{ section.settings.section_nav_ruby }}</a>
            <a class="section-nav__mobile-link" href="#{{ timeline_id }}" data-section="{{ timeline_id }}" data-idx="3">{{ section.settings.section_nav_timeline }}</a>
          </div>
