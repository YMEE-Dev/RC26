{{ 'roberto-coin-story.css' | asset_url | stylesheet_tag }}
<script src="{{ 'roberto-coin-story.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign section_id = 'rc-story-' | append: section.id
  assign history_id = section_id | append: '-history'
  assign creator_id = section_id | append: '-creator'
  assign ruby_id = section_id | append: '-ruby'
  assign timeline_id = section_id | append: '-timeline'
-%}

<section
  id="{{ section_id }}"
  class="rc-story"
  style="
    --bg: {{ section.settings.background_color }};
    --bg-soft: {{ section.settings.background_soft_color }};
    --bg-glow: {{ section.settings.background_glow_color }};
    --text: {{ section.settings.text_color }};
    --muted: {{ section.settings.text_color | color_modify: 'alpha', 0.62 }};
    --dim: {{ section.settings.text_color | color_modify: 'alpha', 0.34 }};
    --accent: {{ section.settings.accent_color }};
    --accent-soft: {{ section.settings.accent_color | color_modify: 'alpha', 0.35 }};
    --logo-color: {{ section.settings.logo_color }};
    --today-color: {{ section.settings.today_color }};
    --active-year-color: {{ section.settings.active_year_color }};
    --year-size: {{ section.settings.year_size }}px;
    --copy-size: {{ section.settings.caption_size }}px;
    --panel-height: {{ section.settings.panel_height }}vh;
  "
  data-section-id="{{ section.id }}"
>
  <div class="page-shell">
    <aside class="site-nav site-nav-left" aria-label="Primary">
      <button class="search-toggle" aria-label="Search">
        <span class="search-icon"></span>
      </button>
      <nav>
        <a href="{{ section.settings.left_link_1_url }}">{{ section.settings.left_link_1_label }}</a>
        <a href="{{ section.settings.left_link_2_url }}">{{ section.settings.left_link_2_label }}</a>
        <a href="{{ section.settings.left_link_3_url }}">{{ section.settings.left_link_3_label }}</a>
        <a href="{{ section.settings.left_link_4_url }}">{{ section.settings.left_link_4_label }}</a>
      </nav>
    </aside>

    <aside class="site-nav site-nav-right" aria-label="Utility">
      <nav>
        <a href="{{ section.settings.right_link_1_url }}">{{ section.settings.right_link_1_label }}</a>
        <a href="{{ section.settings.right_link_2_url }}">{{ section.settings.right_link_2_label }}</a>
        <a href="{{ section.settings.right_link_3_url }}">{{ section.settings.right_link_3_label }}</a>
        <a href="{{ section.settings.right_link_4_url }}">{{ section.settings.right_link_4_label }}</a>
      </nav>
      <a class="bag-link" href="{{ section.settings.bag_link_url }}" aria-label="Shopping bag">
        <span class="bag-icon"></span>
        <span class="bag-count">{{ section.settings.bag_count }}</span>
      </a>
    </aside>

    <main>
      <section class="hero" id="{{ section_id }}-top">
        <header class="brand-header">
          <div class="brand-logo" aria-label="Roberto Coin">
            <svg width="814" height="76" viewBox="0 0 814 76" fill="none" xmlns="http://www.w3.org/2000/svg">
              <g clip-path="url(#clip0_5975_3294)">
