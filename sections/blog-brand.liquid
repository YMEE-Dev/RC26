<!-- /sections/blog-brand.liquid -->
{%- liquid
  assign featured_article = blank

  if section.settings.featured_article != blank
    assign featured_article = articles[section.settings.featured_article]
  endif

  if featured_article == blank
    if article != blank
      assign featured_article = article
    endif
  endif

  if featured_article == blank
    assign featured_article = blog.articles.first
  endif
-%}

{%- style -%}
  #BlogBrand--{{ section.id }} {
    --brand-top-padding: {{ section.settings.padding_top }}px;
    --brand-bottom-padding: {{ section.settings.padding_bottom }}px;
    --brand-content-max-width: {{ section.settings.content_max_width }}px;
    --brand-content-gap: {{ section.settings.content_gap }}px;
    --brand-title-max-width: {{ section.settings.title_max_width }}px;
    --brand-media-height-mobile: {{ section.settings.video_height_mobile }}vh;
  }
{%- endstyle -%}

<section
  id="BlogBrand--{{ section.id }}"
  class="blog-brand"
  data-section-id="{{ section.id }}"
  data-section-type="blog-brand"
>
  {%- if featured_article != blank -%}
    <div class="blog-brand__top">
      <h2 class="h2 blog-brand__title" data-brand-fade data-brand-fade-delay="0">{{ featured_article.title }}</h2>
      <p class="body blog-brand__date" data-brand-fade data-brand-fade-delay="0.3">
        <time datetime="{{ featured_article.published_at | date: '%Y-%m-%d' }}">
          {{ featured_article.published_at | date: '%B %-d, %Y' }}
        </time>
      </p>
    </div>

    {%- if section.settings.video != blank or section.settings.video_url != blank -%}
      <div class="blog-brand__media" data-brand-fade data-brand-fade-delay="0.6">
        {%- if section.settings.video != blank -%}
          {{
            section.settings.video
            | video_tag:
              autoplay: true,
              loop: true,
              controls: false,
              muted: true,
              playsinline: true,
              class: 'blog-brand__video blog-brand__video--inline'
          }}
        {%- else -%}
          <video class="blog-brand__video blog-brand__video--inline" autoplay loop muted playsinline>
            <source src="{{ section.settings.video_url }}">
          </video>
        {%- endif -%}

        <button
          type="button"
          class="blog-brand__sound-trigger"
          data-brand-video-open
          aria-label="Play with sound"
        >
          <span class="blog-brand__sound-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 43.52 43.52" fill="none">
              <circle cx="21.76" cy="21.76" r="21.26" />
              <line x1="27.18" y1="17.88" x2="34.16" y2="24.87" />
              <line x1="34.16" y1="17.88" x2="27.18" y2="24.87" />
              <polygon points="11.47 17.21 11.47 26.31 18.41 26.31 23.99 31.89 23.99 11.63 18.41 17.21 11.47 17.21" />
            </svg>
          </span>
          <span>PLAY WITH SOUND</span>
        </button>
      </div>

      <div class="blog-brand__video-modal" data-brand-video-modal hidden>
        <div class="blog-brand__video-modal-backdrop" data-brand-video-close></div>
        <div class="blog-brand__video-modal-dialog" role="dialog" aria-modal="true" aria-label="Brand video">
          <button type="button" class="blog-brand__video-modal-close" data-brand-video-close aria-label="Close">
            &times;
          </button>
          <div class="blog-brand__video-modal-player">
            {%- if section.settings.video != blank -%}
              {{
                section.settings.video
                | video_tag:
                  autoplay: false,
                  loop: true,
                  controls: false,
                  muted: false,
                  playsinline: true,
                  class: 'blog-brand__video blog-brand__video--modal'
              }}
            {%- else -%}
              <video class="blog-brand__video blog-brand__video--modal" playsinline>
                <source src="{{ section.settings.video_url }}">
              </video>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endif -%}

    {%- if featured_article.content != blank -%}
      <div class="blog-brand__content-wrapper" data-brand-fade data-brand-fade-delay="0.9">
        <div class="blog-brand__content body rte">
          {{ featured_article.content }}
        </div>
      </div>
    {%- endif -%}
  {%- else -%}
    <div class="blog-brand__empty h4">{{ 'blogs.article.no_articles' | t }}</div>
  {%- endif -%}
</section>

{% stylesheet %}
  .blog-brand {
    padding-top: var(--brand-top-padding);
    padding-bottom: var(--brand-bottom-padding);
  }

  .blog-brand__top {
    width: min(100% - 48px, var(--brand-content-max-width));
    margin-left: auto;
    margin-right: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--brand-content-gap);
    text-align: center;
  }

  .blog-brand__title {
    max-width: var(--brand-title-max-width);
    margin: 0;
    font-size: 40px;
    line-height: 48px;
  }

  .blog-brand__date {
    margin: 0;
    font-size: 16px;
  }

  .blog-brand__media {
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    margin-top: 100px;
    margin-bottom: 100px;
    height: 600px;
    position: relative;
    overflow: hidden;
  }

  .blog-brand__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .blog-brand__sound-trigger {
    position: absolute;
    top: 24px;
    left: 24px;
    border: 0;
    background: transparent;
    color: #fff;
    display: inline-flex;
    align-items: center;
    gap: 14px;
    cursor: pointer;
    padding: 0 8px;
    height: 40px;
    font-family: Inter, sans-serif;
    font-size: 12px;
    line-height: 20px;
    font-weight: 600;
    letter-spacing: 0.1em;
    z-index: 3;
    pointer-events: auto;
  }

  .blog-brand__sound-icon {
    width: 40px !important;
    height: 40px !important;
    min-width: 40px;
    min-height: 40px;
    max-width: 40px;
    max-height: 40px;
    flex: 0 0 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .blog-brand__sound-icon svg {
    width: 40px;
    height: 40px;
  }

  .blog-brand__sound-icon circle,
  .blog-brand__sound-icon line,
  .blog-brand__sound-icon polygon {
    stroke: currentColor;
    stroke-width: 1;
    stroke-miterlimit: 10;
    fill: none;
  }

  .blog-brand__video-modal[hidden] {
    display: flex;
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
  }

  .blog-brand__video-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .blog-brand__video-modal.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .blog-brand__video-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(0);
    -webkit-backdrop-filter: blur(0);
    opacity: 0;
    transition: opacity 0.4s ease, backdrop-filter 0.4s ease, -webkit-backdrop-filter 0.4s ease;
    will-change: opacity, backdrop-filter;
    transform: translateZ(0);
  }

  .blog-brand__video-modal.is-open .blog-brand__video-modal-backdrop {
    opacity: 1;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .blog-brand__video-modal-dialog {
    position: relative;
    z-index: 1;
    width: calc(100vw - 200px);
    max-width: calc(100vw - 200px);
    height: calc(100vh - 200px);
    max-height: calc(100vh - 200px);
    opacity: 0;
    transform: translate3d(0, 10px, 0);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .blog-brand__video-modal.is-open .blog-brand__video-modal-dialog {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .blog-brand__video-modal-player {
    background: #000;
    width: 100%;
    height: 100%;
  }

  .blog-brand__video-modal-close {
    position: absolute;
    top: -50px;
    right: 0;
    width: 28px;
    height: 28px;
    padding: 0;
    border: 0;
    background: transparent;
    color: transparent;
    font-size: 0;
    line-height: 0;
    cursor: pointer;
    transition: transform 0.2s ease;
    z-index: 2;
  }

  .blog-brand__video-modal-close::before,
  .blog-brand__video-modal-close::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 24px;
    height: 1px;
    background: #fff;
    transform-origin: center;
  }

  .blog-brand__video-modal-close::before {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .blog-brand__video-modal-close::after {
    transform: translate(-50%, -50%) rotate(-45deg);
  }

  .blog-brand__video-modal-close:hover,
  .blog-brand__video-modal-close:focus-visible {
    transform: translateY(-3px);
  }

  .blog-brand__video--modal {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: #000;
  }

  .blog-brand__content-wrapper {
    width: min(100% - 48px, var(--brand-content-max-width));
    margin: 0 auto 100px;
  }

  .blog-brand__content {
    width: min(100%, 500px);
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .blog-brand__content p {
    margin-left: auto;
    margin-right: auto;
  }

  .blog-brand__empty {
    width: min(100% - 48px, var(--brand-content-max-width));
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  [data-brand-fade].brand-fade-init {
    opacity: 0;
    transition: opacity 2s ease;
    transition-property: opacity;
    transition-duration: 2s;
    transition-timing-function: ease;
    transition-delay: var(--brand-fade-delay, 0s);
    will-change: opacity;
  }

  [data-brand-fade].brand-fade-init.brand-fade-visible {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-brand-fade].brand-fade-init {
      opacity: 1;
      transition: none;
    }
  }

  @media (max-width: 749px) {
    .blog-brand__top {
      width: min(100% - 32px, var(--brand-content-max-width));
      gap: 16px;
    }

    .blog-brand__media {
      width: 100%;
      max-width: 100%;
      margin-left: 0;
      margin-right: 0;
      margin-top: 40px;
      height: var(--brand-media-height-mobile);
      overflow: hidden;
    }

    .blog-brand__video {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .blog-brand__sound-trigger {
      top: 12px;
      left: 12px;
      gap: 10px;
      font-size: 11px;
    }

    .blog-brand__sound-icon {
      width: 40px !important;
      height: 40px !important;
    }

    .blog-brand__video-modal-dialog {
      width: calc(100vw - 32px);
      max-width: calc(100vw - 32px);
      height: calc(100vh - 96px);
      max-height: calc(100vh - 96px);
    }

    .blog-brand__video-modal-close {
      top: -40px;
      right: 0;
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    const initBrandFade = () => {
      const targets = document.querySelectorAll('[data-brand-fade]');
      if (!targets.length) return;

      targets.forEach((el) => {
        if (el.dataset.brandFadeReady == 'true') return;
        el.dataset.brandFadeReady = 'true';
        const delay = el.getAttribute('data-brand-fade-delay');
        if (delay) {
          el.style.setProperty('--brand-fade-delay', `${delay}s`);
        }
        el.classList.add('brand-fade-init');
        requestAnimationFrame(() => el.classList.add('brand-fade-visible'));
      });
    };

    const initBrandVideo = (root) => {
      const openBtn = root.querySelector('[data-brand-video-open]');
      const modal = root.querySelector('[data-brand-video-modal]');
      if (!openBtn || !modal) return;

      const inlineVideo = root.querySelector('.blog-brand__video--inline');
      const modalVideo = modal.querySelector('.blog-brand__video--modal');
      const closeEls = modal.querySelectorAll('[data-brand-video-close]');
      const modalTransitionMs = 400;

      const closeModal = () => {
        if (modal.hidden || modal.classList.contains('is-closing')) return;
        modal.classList.remove('is-open');
        modal.classList.add('is-closing');
        document.body.style.overflow = '';
        window.clearTimeout(modal._closeTimer);
        modal._closeTimer = window.setTimeout(() => {
          modal.hidden = true;
          modal.classList.remove('is-closing');
          if (modalVideo) {
            modalVideo.pause();
            modalVideo.currentTime = 0;
          }
          if (inlineVideo) inlineVideo.play().catch(() => {});
        }, modalTransitionMs);
      };

      openBtn.addEventListener('click', () => {
        window.clearTimeout(modal._closeTimer);
        modal.hidden = false;
        modal.classList.remove('is-closing');
        requestAnimationFrame(() => {
          modal.classList.add('is-open');
        });
        document.body.style.overflow = 'hidden';
        if (inlineVideo) inlineVideo.pause();
        if (modalVideo) {
          modalVideo.muted = false;
          modalVideo.play().catch(() => {});
        }
      });

      closeEls.forEach((el) => el.addEventListener('click', closeModal));

      modal.addEventListener('click', (event) => {
        const clickedInsidePlayer = event.target.closest('.blog-brand__video-modal-player');
        const clickedCloseButton = event.target.closest('.blog-brand__video-modal-close');
        if (!clickedInsidePlayer && !clickedCloseButton) {
          closeModal();
        }
      });

      if (inlineVideo) {
        inlineVideo.muted = true;
        inlineVideo.play().catch(() => {});
      }

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && !modal.hidden) closeModal();
      });
    };

    const initAllBrandVideos = () => {
      const roots = document.querySelectorAll('[data-section-type="blog-brand"]');
      roots.forEach((root) => initBrandVideo(root));
    };

    if (document.readyState === 'loading') {
      document.addEventListener(
        'DOMContentLoaded',
        () => {
          initAllBrandVideos();
          initBrandFade();
        },
        { once: true }
      );
    } else {
      initAllBrandVideos();
      initBrandFade();
    }

    document.addEventListener('shopify:section:load', initBrandFade);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Blog - Header Media",
  "settings": [
    {
      "type": "article",
      "id": "featured_article",
      "label": "Featured blog post",
      "info": "Optional. If empty, current article or latest post is used."
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL (fallback)"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 700,
      "max": 1500,
      "step": 20,
      "unit": "px",
      "label": "Content max width",
      "default": 1100
    },
    {
      "type": "range",
      "id": "title_max_width",
      "min": 500,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "label": "Title max width",
      "default": 980
    },
    {
      "type": "range",
      "id": "content_gap",
      "min": 10,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Title and date spacing",
      "default": 28
    },
    {
      "type": "range",
      "id": "video_height_mobile",
      "min": 30,
      "max": 70,
      "step": 1,
      "unit": "%",
      "label": "Video height on mobile",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Blog - Header Media"
    }
  ]
}
{% endschema %}
