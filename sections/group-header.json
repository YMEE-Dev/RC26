      "settings": {
        "code": "<section class=\"commitments-wrapper\">\n\n  <!-- Intro -->\n  <div class=\"commitments-intro\">\n    <p>\n      The company is committed to ensuring integrity in all stages of sourcing and manufacturing processes. We source diamonds from suppliers who adhere to the highest ethical standards and follow the Kimberley Process.\n    </p>\n  </div>\n\n  <!-- Kimberley Section -->\n  <div class=\"commitments-grid\">\n    <div class=\"commitments-image\">\n      <img src=\"YOUR_IMAGE_1_URL_HERE\" alt=\"Kimberley Process\">\n    </div>\n\n    <div class=\"commitments-content\">\n      <h2>The Kimberley Process</h2>\n      <p>\n        We purchase polished diamonds only from legitimate sources not involved in funding conflict and in compliance with United Nations resolutions.\n      </p>\n    </div>\n  </div>\n\n</section>\n\n<section class=\"associations-section\">\n\n  <div class=\"associations-grid\">\n\n    <div class=\"associations-image\">\n      <img src=\"YOUR_IMAGE_2_URL_HERE\" alt=\"Associations\">\n    </div>\n\n    <div class=\"associations-content\">\n      <h2>Associations & Organizations</h2>\n      <ul>\n        <li>American Gem Society</li>\n        <li>Jewelers of America</li>\n        <li>Responsible Jewellery Council</li>\n        <li>JVC Legal Compliance</li>\n        <li>World Diamond Council</li>\n      </ul>\n    </div>\n\n  </div>\n\n  <div class=\"associations-button\">\n    <a href=\"#\" class=\"commitments-btn\">\n      View More Ethical Initiatives\n    </a>\n  </div>\n\n</section>\n\n<style>\n.commitments-wrapper {\n  padding: 80px 5%;\n  background: #ffffff;\n}\n\n.commitments-intro {\n  max-width: 800px;\n  margin: 0 auto 60px;\n  text-align: center;\n  font-size: 15px;\n  line-height: 1.7;\n  color: #333;\n}\n\n.commitments-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 60px;\n  align-items: center;\n}\n\n.commitments-image img {\n  width: 100%;\n  height: auto;\n}\n\n.commitments-content h2 {\n  font-size: 26px;\n  margin-bottom: 20px;\n  font-weight: 500;\n}\n\n.commitments-content p {\n  font-size: 15px;\n  line-height: 1.7;\n  color: #555;\n}\n\n/* Associations */\n.associations-section {\n  background: #f5f5f5;\n  padding: 80px 5%;\n}\n\n.associations-grid {\n  display: grid;\n  grid-template-columns: 1.2fr 1fr;\n  gap: 60px;\n  align-items: center;\n}\n\n.associations-image img {\n  width: 100%;\n  height: auto;\n}\n\n.associations-content h2 {\n  font-size: 24px;\n  margin-bottom: 25px;\n}\n\n.associations-content ul {\n  list-style: none;\n  padding: 0;\n}\n\n.associations-content li {\n  margin-bottom: 12px;\n  font-size: 14px;\n  letter-spacing: 0.5px;\n}\n\n.associations-button {\n  text-align: center;\n  margin-top: 50px;\n}\n\n.commitments-btn {\n  border: 1px solid #000;\n  padding: 12px 28px;\n  text-decoration: none;\n  font-size: 13px;\n  letter-spacing: 1px;\n  text-transform: uppercase;\n  display: inline-block;\n  transition: 0.3s ease;\n}\n\n.commitments-btn:hover {\n  background: #000;\n  color: #fff;\n}\n\n/* Responsive */\n@media (max-width: 990px) {\n  .commitments-grid,\n  .associations-grid {\n    grid-template-columns: 1fr;\n  }\n}\n</style>",
