      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "Color scheme"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "button_margin_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Button margin top",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Protection cards",
      "category": "Image",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Size Guide",
            "description": "The style of Roberto Coin combines new visions to the definition. Please text us for measurement."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Product Care",
