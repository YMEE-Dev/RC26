<!-- /sections/section-protection-cards.liquid -->
{%- liquid
  assign color_scheme = 'color-' | append: section.settings.color_scheme
-%}

{%- style -%}
  #ProtectionCards--{{ section.id }} {
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<section
  id="ProtectionCards--{{ section.id }}"
  class="protection-cards section-padding {{ color_scheme }}"
  data-section-id="{{ section.id }}"
  data-section-type="protection-cards"
>
  <div class="protection-cards__wrapper {{ section.settings.width }}">
    {%- if section.settings.heading != blank -%}
      <h2 class="protection-cards__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="protection-cards__carousel-container grid-outer">
        <grid-slider>
          <div
            class="protection-cards__grid grid grid--slider grid--mobile-slider"
            data-grid-slider
            style="--column-count: 3;"
          >
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'card' -%}
                  <div class="grid-item protection-card" data-grid-item {{ block.shopify_attributes }}>
                    {%- if template.suffix == 'concierge' -%}
                      {%- if forloop.first -%}
                        <a
                          href="https://cdn.shopify.com/s/files/1/0969/2990/7075/files/00_Size-Guide-Bracelets_Rings_ENG_2026.pdf?v=1775035281"
                          download
                          target="_blank"
                          class="protection-card__overlay-link"
                          aria-label="{{ block.settings.title | escape }}"
                        ></a>
                      {%- elsif forloop.last -%}
                        <button
                          type="button"
                          class="protection-card__overlay-link"
                          data-drawer-open="ask-concierge"
                          aria-label="{{ block.settings.title | escape }}"
                        ></button>
                      {%- else -%}
                        <button
                          type="button"
                          class="protection-card__overlay-link"
                          data-drawer-open="care-recommendations"
                          aria-label="{{ block.settings.title | escape }}"
                        ></button>
                      {%- endif -%}
                    {%- endif -%}
                    {%- if block.settings.image != blank -%}
                      <div class="protection-card__image">
                        {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
                      </div>
                    {%- else -%}
                      <div class="protection-card__placeholder">
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                    {%- endif -%}

                    <div class="protection-card__content">
                      {%- if block.settings.title != blank -%}
                        <h3 class="protection-card__title">{{ block.settings.title }}</h3>
                      {%- endif -%}

                      {%- if block.settings.description != blank -%}
                        <p class="protection-card__description">{{ block.settings.description }}</p>
                      {%- endif -%}

                      {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
                        <a href="{{ block.settings.button_link }}" class="protection-card__btn btn btn--outline">
                          {{- block.settings.button_label -}}
                        </a>
                      {%- endif -%}
                    </div>
                  </div>
              {%- endcase -%}
            {%- endfor -%}
          </div>
        </grid-slider>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  (function () {
    const sectionId = '{{ section.id }}';

    function initProtectionSlider() {
      const section = document.querySelector('[data-section-id="' + sectionId + '"]');
      if (!section) return;

      const gridSlider = section.querySelector('grid-slider');
      if (gridSlider) {
        gridSlider.dispatchEvent(new CustomEvent('theme:grid-slider:init'));
      }
    }

    function runInit() {
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initProtectionSlider);
      } else {
        initProtectionSlider();
      }
    }

    runInit();

    document.addEventListener('shopify:section:load', function (event) {
      const loadedSection = event.target?.querySelector?.('[data-section-id]') || event.target;

      const isOurSection =
        (loadedSection && loadedSection.dataset?.sectionId === sectionId) ||
        (event.detail && String(event.detail.sectionId) === String(sectionId));

      if (isOurSection) {
        initProtectionSlider();
      }
    });
  })();
</script>

{% stylesheet %}
  .protection-cards {
    position: relative;
    width: 100%;
  }

  .protection-cards__wrapper {
    width: 100%;
    margin: 0 auto;
  }

  .protection-cards__wrapper.wrapper {
    max-width: 1440px;
    padding: 0 var(--outer);
  }

  .protection-cards__wrapper.wrapper--full-padded {
    width: 100%;
    padding: 0 var(--outer);
  }

  .protection-cards__wrapper.wrapper--narrow {
    max-width: 1200px;
    padding: 0 var(--outer);
  }

  .protection-cards__heading {
    color: #000;
    text-align: center;
    margin: 0 0 40px;
    font-family: var(--FONT-STACK-HEADING);
    font-style: normal;
    font-weight: 500;
  }

  .protection-cards__heading.heading-small {
    font-size: 24px;
    line-height: 32px;
  }

  .protection-cards__heading.heading-medium {
    font-size: 32px;
    line-height: 40px;
  }

  .protection-cards__heading.heading-large {
    font-size: 40px;
    line-height: 48px;
  }

  .protection-cards__heading.heading-x-large {
    font-size: 48px;
    line-height: 56px;
  }

  @media (max-width: 767px) {
    .protection-cards__heading.heading-small {
      font-size: 20px;
      line-height: 28px;
    }

    .protection-cards__heading.heading-medium {
      font-size: 24px;
      line-height: 32px;
    }

    .protection-cards__heading.heading-large {
      font-size: 28px;
      line-height: 36px;
    }

    .protection-cards__heading.heading-x-large {
      font-size: 32px;
      line-height: 40px;
    }
  }

  .protection-cards__grid {
    --column-count: 3;
  }

  @media (max-width: 990px) {
    .protection-cards__grid {
      --column-count: 2;
    }
  }

  @media (max-width: 768px) {
    .protection-cards__grid {
      --column-count: 1;
    }
  }

  /* .protection-cards__grid {
    display: grid;
    grid-template-columns: 2fr 2fr 2fr;
    gap: 80px;
    width: 100%;
  }

  @media (max-width: 1024px) {
    .protection-cards__grid {
      grid-template-columns: 2fr 2fr;
      gap: 80px;
    }
  }

  @media (max-width: 768px) {
    .protection-cards__grid {
      gap: 40px !important;
    }
  }
  @media (max-width: 425px) {
    .protection-cards__grid {
      grid-template-columns: 1fr;
      gap: 80px;
    }
  } */

  .protection-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    /* gap: 24px; */
  }

  .protection-card__overlay-link {
    position: absolute;
    inset: 0;
    z-index: 1;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    text-decoration: none;
  }

  .protection-card__image {
    width: 100%;
    margin-bottom: 40px;
    aspect-ratio: 357/318;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
    overflow: hidden;
  }

  .protection-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .protection-card:hover .protection-card__image img {
    transform: scale(1.05);
  }

  .protection-card__btn {
    margin-top: 24px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.25s ease, transform 0.25s ease;
    pointer-events: none;
    --btn-border: #000;
    --btn-bg: #000;
    --btn-text: #fff;
    --btn-bg-hover: #27574d;
    --btn-border-hover: #27574d;
    --btn-text-hover: #fff;
  }

  @media (max-width: 989px) {
    .protection-card__btn {
      opacity: 1;
      transform: none;
      pointer-events: auto;
    }
  }

  @media (min-width: 990px) {
    .protection-card:hover .protection-card__btn {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }
  }

  @media (max-width: 768px) {
    .protection-card__image {
      height: auto !important;
      aspect-ratio: 79 / 62 !important;
      margin-bottom: 20px;
    }
  }
  .protection-card__placeholder {
    width: 100%;
    max-width: 280px;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
  }

  .protection-card__placeholder .placeholder-svg {
    width: 50%;
    height: auto;
    opacity: 0.3;
  }

  .protection-card__content {
    display: flex;
    flex-direction: column;
  }

  .protection-card__title {
    margin: 0 0 20px;
    color: var(--COLOR-TEXT);
    font-family: var(--FONT-STACK-HEADING);
    font-style: var(--FONT-STYLE-HEADING);
    font-weight: var(--FONT-WEIGHT-HEADING);
    text-align: center;
    font-size: var(--FONT-DISPLAY-S);
    line-height: var(--LINE-HEIGHT-DISPLAY-S);
  }

  .protection-card__description {
    color: var(--COLOR-TEXT);
    text-align: center;
    margin: 0;
    font-family: var(--FONT-STACK-BODY);
    font-size: var(--font-body-small);
    font-style: var(--FONT-STYLE-BODY);
    font-weight: var(--FONT-WEIGHT-BODY);
    line-height: var(--LINE-HEIGHT-BODY);
  }

  @media (min-width: 990px) {
    .grid--slider .grid-item.protection-card {
      flex: unset;
    }
  }

  @media (min-width: 750px) {
    .grid--slider .grid-item.protection-card:last-child {
      margin-right: 0;
    }
  }

  .grid--slider .grid-item.protection-card {
    margin-right: 80px;
    max-width: 33.33%;
  }
  .protection-cards__grid.grid.grid--slider {
    padding-inline: 0;
  }

  @media (max-width: 990px) {
    .grid--slider .grid-item.protection-card {
      margin-right: 40px;
      max-width: 60%;
    }
  }

  @media (max-width: 749px) {
    .grid--slider .grid-item.protection-card {
      margin-right: 20px;
      max-width: 80%;
      width: 80%;
    }
  }
{% endstylesheet %}

