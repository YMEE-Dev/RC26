        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Card title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Card description text goes here"
        },
        {
          "type": "url",
          "id": "card_link",
          "label": "Card link",
          "info": "Makes the entire card clickable."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Header observer"
    },
    {
      "type": "select",
      "id": "header_observer_mode",
      "label": "Header mode",
      "default": "dark",
      "options": [
        {"value": "light", "label": "Light"},
        {"value": "dark", "label": "Dark"}
      ]
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Art of Protecting Beauty"
    },
    {
      "type": "select",
      "id": "heading_size",
