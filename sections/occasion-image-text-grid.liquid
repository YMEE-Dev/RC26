<!-- /sections/occasion-image-text-grid.liquid -->
{%- liquid
  assign visible_items = 0

  for block in section.blocks
    assign has_image = false
    assign has_text = false

    if block.settings.image != blank
      assign has_image = true
    endif

    if block.settings.text != blank
      assign has_text = true
    endif

    if has_image or has_text
      assign visible_items = visible_items | plus: 1
    endif
  endfor
-%}

{%- if visible_items > 0 -%}
  {%- style -%}
    #OccasionImageTextGrid--{{ section.id }} {
      --occasion-grid-pt: {{ section.settings.padding_top }}px;
      --occasion-grid-pb: {{ section.settings.padding_bottom }}px;
      --occasion-grid-columns: {{ visible_items }};
    }
  {%- endstyle -%}

  <section
    id="OccasionImageTextGrid--{{ section.id }}"
    class="occasion-image-text-grid"
    data-section-id="{{ section.id }}"
    data-section-type="occasion-image-text-grid"
  >
    <div class="occasion-image-text-grid__inner {{ section.settings.width }}">
      {%- for block in section.blocks -%}
        {%- liquid
          assign has_image = false
          assign has_text = false

          if block.settings.image != blank
            assign has_image = true
          endif

          if block.settings.text != blank
            assign has_text = true
          endif
        -%}

        {%- if has_image or has_text -%}
          <article class="occasion-image-text-grid__item" data-brand-fade {{ block.shopify_attributes }}>
            {%- if has_image -%}
              <div class="occasion-image-text-grid__media">
                {{
                  block.settings.image
                  | image_url: width: 1200
                  | image_tag:
                    class: 'occasion-image-text-grid__image',
                    widths: '375, 550, 750, 900, 1100, 1200',
                    sizes: '(min-width: 1200px) 380px, (min-width: 750px) calc((100vw - 64px) / 3), calc(100vw - 32px)',
                    loading: 'lazy'
                }}
              </div>
            {%- endif -%}

            {%- if has_text -%}
              <div class="occasion-image-text-grid__text body rte">
                {{ block.settings.text }}
              </div>
            {%- endif -%}
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </section>
{%- endif -%}

{% stylesheet %}
  .occasion-image-text-grid {
    padding-top: var(--occasion-grid-pt);
    padding-bottom: var(--occasion-grid-pb);
  }

  .occasion-image-text-grid__inner {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(var(--occasion-grid-columns), minmax(0, 1fr));
    gap: 40px;
  }

  .occasion-image-text-grid__item {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .occasion-image-text-grid__media {
    width: 100%;
  }

  .occasion-image-text-grid__image {
    width: 100%;
    height: auto;
    display: block;
  }

  .occasion-image-text-grid__text {
    text-align: left;
  }

  .occasion-image-text-grid__text p {
    margin: 0;
  }

  @media (max-width: 749px) {
    .occasion-image-text-grid__inner {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Image Text Grid",
  "max_blocks": 3,
  "settings": [
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "default": "wrapper",
      "options": [
        {"value": "wrapper--full", "label": "Full width"},
        {"value": "wrapper--full-padded", "label": "Full width padded"},
        {"value": "wrapper", "label": "Normal"}
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Image + text",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Text Grid",
      "category": "Blog",
      "blocks": [
        {"type": "item"},
        {"type": "item"},
        {"type": "item"}
      ]
    }
  ]
}
{% endschema %}
