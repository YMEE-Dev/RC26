<!-- /sections/homepage-product-list.liquid -->
{%- liquid
  assign animation_anchor = '#HomepageProductList--' | append: section.id
  assign color_scheme = 'color-' | append: section.settings.color_scheme
  assign heading_alignment = section.settings.heading_alignment
  assign limit = section.settings.limit
  assign layout_desktop = section.settings.layout_desktop
  assign layout_mobile = section.settings.layout_mobile
  assign grid_columns = section.settings.grid
  assign related_category_limit = limit
  assign columns_mobile = section.settings.layout_mobile | plus: 0
  assign columns_desktop = grid_columns | plus: 0
  assign columns_medium = 3
  assign columns_small = 2
  assign column_count = limit | at_most: 4
  assign rendered_tab_count = 0

  if columns_desktop == 2 or columns_desktop == 4
    assign columns_medium = 2
  endif

  if layout_desktop == 'grid'
    assign limit = grid_columns | times: section.settings.rows
    assign column_count = columns_desktop

    if grid_columns == 2 or grid_columns == 4
      assign columns_medium = 2
    endif
  endif

  if layout_desktop == 'slider'
    if related_category_limit <= 4
      assign related_category_limit = 10
    endif
  endif
-%}

{%- capture tabs_markup -%}{%- endcapture -%}
{%- capture contents_markup -%}{%- endcapture -%}

{%- for block in section.blocks -%}
  {%- if block.type == 'tab' -%}
    {%- liquid
      assign tab_products_count = 0
    -%}

    {%- capture tab_products -%}
      {%- for selected_product in block.settings.product_list -%}
        {%- liquid
          assign hidden_product = false
          if selected_product.tags contains 'hide'
            assign hidden_product = true
          endif
        -%}

        {%- if hidden_product == false and tab_products_count < related_category_limit -%}
          {%- assign tab_products_count = tab_products_count | plus: 1 -%}
          {%- render 'product-grid-item',
            product: selected_product,
            animation_delay: forloop.index0 | times: 1,
            animation_anchor: '#HomepageProductsTab--' | append: section.id | append: '-' | append: rendered_tab_count,
            index: forloop.index
          -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endcapture -%}

    {%- if tab_products_count > 0 -%}
      {%- assign tab_heading = block.settings.tab_heading | strip -%}
      {%- if tab_heading == blank -%}
        {%- assign tab_heading = 'Products' -%}
      {%- endif -%}

      {%- capture tabs_markup -%}
        {{ tabs_markup }}
        <li class="tab-link tab-link-{{ rendered_tab_count }}{% if rendered_tab_count == 0 %} current{% endif %}" data-tab="{{ rendered_tab_count }}" tabindex="0">
          <span>{{ tab_heading | escape }}</span>
        </li>
      {%- endcapture -%}

      {%- capture contents_markup -%}
        {{ contents_markup }}
        <div
          class="tab-content tab-content-{{ rendered_tab_count }} tabs__recommendation{% if rendered_tab_count == 0 %} current{% endif %}"
          data-tab-index="{{ rendered_tab_count }}"
          {{ block.shopify_attributes }}
        >
          <div class="grid-outer" style="--column-count: {{ column_count }}; --COLUMNS: {{ columns_desktop }}; --COLUMNS-MEDIUM: {{ columns_medium }}; --COLUMNS-SMALL: {{ columns_small }}; --COLUMNS-MOBILE: {{ columns_mobile }};">
            <grid-slider align-arrows>
              <div
                class="grid{% if layout_desktop == 'slider' %} grid--slider{% if tab_products_count <= 4 %} grid--slider-disabled{% endif %}{% endif %}{% if layout_mobile == 'slider' or layout_mobile == nil %} grid--mobile-slider{% else %} grid--mobile-vertical{% endif %}"
                data-grid-slider
                id="HomepageProductsTab--{{ section.id }}-{{ rendered_tab_count }}"
              >
                {{ tab_products }}
              </div>
            </grid-slider>
          </div>
        </div>
      {%- endcapture -%}

      {%- assign rendered_tab_count = rendered_tab_count | plus: 1 -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- style -%}
  #HomepageProductList--{{ section.id }} {
    --bg-color: #f9f9f9;
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
    padding-top: var(--PT);
    padding-bottom: var(--PB);
  }

  #HomepageProductList--{{ section.id }} .tabs-wrapper {
    margin: 100px 0 0;
  }

  #HomepageProductList--{{ section.id }} .tab-content {
    border-top: 1px solid #E5E5E5;
    background: var(--bg-color);
  }

  #HomepageProductList--{{ section.id }} .grid__heading-holder {
    padding: 0;
    margin: 0 auto;
    max-width: min(var(--content-max), 1200px);
  }

  #HomepageProductList--{{ section.id }} .tabs {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 30px;
    padding: 0;
    margin: 0;
    overflow: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  #HomepageProductList--{{ section.id }} .tabs::-webkit-scrollbar {
    display: none;
  }

  #HomepageProductList--{{ section.id }} .tabs .tab-link {
    padding: 0;
    margin: 0;
    flex-shrink: 0;
  }

  #HomepageProductList--{{ section.id }} .tabs .tab-link span {
    padding-bottom: 10px;
    display: inline-block;
  }

  #HomepageProductList--{{ section.id }} .tabs .tab-link.current span:first-of-type::after {
    bottom: 0;
  }

  #HomepageProductList--{{ section.id }} grid-slider {
    padding-bottom: 28px;
  }

  #HomepageProductList--{{ section.id }} .related-slider-progress {
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    width: 200px;
    height: 1px;
    background: rgba(17, 17, 17, 0.2);
    z-index: 2;
    overflow: hidden;
    pointer-events: none;
  }

  #HomepageProductList--{{ section.id }} .slider__arrows {
    opacity: 0;
    visibility: hidden;
  }

  #HomepageProductList--{{ section.id }} .slider__button {
    pointer-events: none;
  }

  #HomepageProductList--{{ section.id }} .related-slider-progress.hidden {
    display: none;
  }

  #HomepageProductList--{{ section.id }} .related-slider-progress__line {
    display: block;
    width: var(--related-slider-progress, 0%);
    height: 100%;
    background: #111111;
    transition: width 0.2s ease;
  }

  @media only screen and (min-width: 990px) {
    #HomepageProductList--{{ section.id }} .grid--slider {
      --item-width: calc((100% - (var(--gap) * 3)) / 4);
    }
  }

  @media only screen and (max-width: 989px) {
    #HomepageProductList--{{ section.id }} {
      padding-top: calc(var(--PT) * 0.5);
      padding-bottom: calc(var(--PB) * 0.5);
    }

    #HomepageProductList--{{ section.id }} .tabs__head {
      padding-left: 20px;
      padding-right: 20px;
    }
  }

  @media only screen and (min-width: 750px) and (max-width: 989px) {
    #HomepageProductList--{{ section.id }} .tabs-wrapper {
      margin: 50px 0 0;
    }
  }

  @media only screen and (max-width: 749px) {
    #HomepageProductList--{{ section.id }} {
      padding-top: var(--PT-MOBILE, calc(var(--PT) * 0.5));
      padding-bottom: calc(var(--PB) * 0.5);
    }

    #HomepageProductList--{{ section.id }} .tabs-wrapper {
      margin: 30px 0 0;
    }

    #HomepageProductList--{{ section.id }} .tabs {
      gap: 25px;
      overflow-x: auto;
    }

    #HomepageProductList--{{ section.id }} grid-slider {
      padding-bottom: 20px;
    }

    #HomepageProductList--{{ section.id }} .related-slider-progress__line {
      width: var(--related-slider-progress, 0%);
    }
  }
{%- endstyle -%}

<section
  class="related__wrapper {{ color_scheme }}"
  id="HomepageProductList--{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="homepage-product-list"
>
  {%- if rendered_tab_count > 0 -%}
    <tabs-component class="tabs-wrapper related__products">
      <div
        class="tabs__head"
        data-aos="hero"
        data-aos-anchor="{{ animation_anchor }}"
        data-aos-order="1"
      >
        <div class="grid__heading-holder{% if heading_alignment == 'text-left' %} grid__heading-holder--left{% endif %}">
          <native-scrollbar class="grid__heading-actions">
            <ul class="tabs {{ heading_alignment }}">
              {{ tabs_markup }}
            </ul>

            <button type="button" class="tabs__arrow tabs__arrow--prev is-hidden" data-scrollbar-arrow-prev>
              {%- render 'icon-nav-arrow-left' -%}
              <span class="visually-hidden">{{ 'products.general.see_all' | t }}</span>
            </button>

            <button type="button" class="tabs__arrow tabs__arrow--next is-hidden" data-scrollbar-arrow-next>
              {%- render 'icon-nav-arrow-right' -%}
              <span class="visually-hidden">{{ 'products.general.see_all' | t }}</span>
            </button>
          </native-scrollbar>
        </div>
      </div>

      {{ contents_markup }}
    </tabs-component>
  {%- else -%}
    <div class="section-padding">
      <p class="center">{{ 'home_page.onboarding.no_content' | t }}</p>
    </div>
  {%- endif -%}
</section>

<script>
  (() => {
    const section = document.getElementById('HomepageProductList--{{ section.id }}');

    if (!section) {
      return;
    }

    const relatedSliderSelector = '[data-grid-slider]';
    const gridItemSelector = '[data-grid-item]';

    const getClosestSlideIndex = (items, slider) => {
      let closestIndex = 0;
      let minDistance = Number.POSITIVE_INFINITY;

      items.forEach((item, index) => {
        const distance = Math.abs(item.offsetLeft - slider.scrollLeft);

        if (distance < minDistance) {
          minDistance = distance;
          closestIndex = index;
        }
      });

      return closestIndex;
    };

    const setupProgress = (gridSlider) => {
      const slider = gridSlider.querySelector(relatedSliderSelector);

      if (!slider) {
        return;
      }

      let progress = gridSlider.querySelector('[data-related-slider-progress]');

      if (!progress) {
        progress = document.createElement('div');
        progress.className = 'related-slider-progress';
        progress.setAttribute('data-related-slider-progress', '');
        progress.innerHTML = '<span class="related-slider-progress__line"></span>';
        gridSlider.append(progress);
      }

      const syncSliderState = (items) => {
        if (!slider.classList.contains('grid--slider')) {
          return;
        }

        const shouldDisableSlider = items.length <= 4;
        const isSliderDisabled = slider.classList.contains('grid--slider-disabled');

        if (shouldDisableSlider != isSliderDisabled) {
          slider.classList.toggle('grid--slider-disabled', shouldDisableSlider);
          gridSlider.dispatchEvent(new CustomEvent('theme:grid-slider:init'));
        }
      };

      const updateActive = () => {
        const items = Array.from(slider.querySelectorAll(gridItemSelector));
        syncSliderState(items);

        if (items.length < 2) {
          progress.classList.add('hidden');
          progress.style.setProperty('--related-slider-progress', '0%');
          return;
        }

        const isScrollable = slider.scrollWidth > slider.clientWidth + 1;
        progress.classList.toggle('hidden', !isScrollable);

        if (!isScrollable) {
          progress.style.setProperty('--related-slider-progress', '0%');
          return;
        }

        const progressPercent = ((slider.scrollLeft + slider.clientWidth) / slider.scrollWidth) * 100;
        const safeProgress = Math.max(0, Math.min(100, progressPercent));

        progress.style.setProperty('--related-slider-progress', `${safeProgress}%`);
      };

      if (!slider.hasAttribute('data-related-progress-bound')) {
        slider.addEventListener(
          'scroll',
          () => {
            requestAnimationFrame(updateActive);
          },
          {passive: true}
        );
        slider.setAttribute('data-related-progress-bound', 'true');
      }

      if (!slider.hasAttribute('data-related-progress-observer-bound')) {
        const observer = new MutationObserver(() => {
          requestAnimationFrame(updateActive);
        });

        observer.observe(slider, {childList: true, subtree: true});
        slider.setAttribute('data-related-progress-observer-bound', 'true');
      }

      if (!slider.hasAttribute('data-related-progress-resize-bound') && window.ResizeObserver) {
        const resizeObserver = new ResizeObserver(() => {
          requestAnimationFrame(updateActive);
        });

        resizeObserver.observe(slider);
        slider.setAttribute('data-related-progress-resize-bound', 'true');
      }

      if (!gridSlider.hasAttribute('data-related-arrow-bound')) {
        gridSlider.addEventListener('click', (event) => {
          const arrow = event.target.closest('[data-button-arrow]');
          if (!arrow || !gridSlider.contains(arrow)) {
            return;
          }

          const items = Array.from(slider.querySelectorAll(gridItemSelector));
          if (items.length < 2) {
            return;
          }

          const firstVisibleSlide = slider.querySelector(`${gridItemSelector}.is-visible`);
          let currentIndex = firstVisibleSlide ? items.indexOf(firstVisibleSlide) : getClosestSlideIndex(items, slider);

          if (currentIndex < 0) {
            currentIndex = 0;
          }

          let targetIndex = currentIndex;
          if (arrow.hasAttribute('data-button-prev')) {
            targetIndex = Math.max(0, currentIndex - 1);
          }

          if (arrow.hasAttribute('data-button-next')) {
            targetIndex = Math.min(items.length - 1, currentIndex + 1);
          }

          if (targetIndex == currentIndex) {
            return;
          }

          event.preventDefault();
          slider.scrollTo({
            top: 0,
            left: items[targetIndex].offsetLeft,
            behavior: 'smooth',
          });
        });

        gridSlider.setAttribute('data-related-arrow-bound', 'true');
      }

      updateActive();
    };

    const initProgress = () => {
      section.querySelectorAll('grid-slider').forEach((gridSlider) => {
        setupProgress(gridSlider);
      });
    };

    initProgress();

    section.addEventListener('theme:tab:change', initProgress);
    section.addEventListener('theme:grid-slider:init', initProgress);
    document.addEventListener('theme:resize:width', initProgress);
    window.addEventListener('resize', initProgress, {passive: true});
  })();
</script>

{% schema %}
{
  "name": "Homepage product list",
  "settings": [
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Alignment",
      "default": "text-center",
      "options": [
        {"value": "text-left", "label": "Left"},
        {"value": "text-center", "label": "Centered"}
      ]
    },
    {
      "type": "range",
      "id": "limit",
      "min": 1,
      "max": 10,
      "step": 1,
      "label": "Product limit",
      "default": 4
    },
    {
      "type": "header",
      "content": "Desktop"
    },
    {
      "type": "select",
      "id": "layout_desktop",
      "label": "Product grid layout",
      "options": [
        {"value": "grid", "label": "Grid"},
        {"value": "slider", "label": "Slider"}
      ],
      "default": "slider"
    },
    {
      "type": "header",
      "content": "Grid",
      "info": "Applies only when product grid layout is set to Grid"
    },
    {
      "type": "range",
      "id": "grid",
      "label": "Products per row",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "rows",
      "label": "Number of rows",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "select",
      "id": "layout_mobile",
      "label": "Mobile layout",
      "options": [
        {"value": "1", "label": "1 item per row"},
        {"value": "2", "label": "2 items per row"},
        {"value": "slider", "label": "Slider"}
      ],
      "default": "slider"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "Color scheme"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "tab_heading",
          "label": "Tab heading",
          "default": "Products"
        },
        {
          "type": "product_list",
          "id": "product_list",
          "label": "Products"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Homepage product list",
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "tab_heading": "Featured products"
          }
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["index"]
  }
}
{% endschema %}
