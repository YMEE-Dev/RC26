{%- liquid
  assign modal_heading = section.settings.modal_heading | strip
  assign redirect_button_label = section.settings.redirect_button_label | strip
-%}

<head-country-redirect
  class="head-country-redirect"
  data-section-id="{{ section.id }}"
  data-section-type="head-country-redirect"
>
  <script type="application/json" data-country-redirect-config>
    {
      "enabled": {{ section.settings.enabled | json }},
      "rules": [
        {%- for block in section.blocks -%}
          {
            "enabled": {{ block.settings.enabled | json }},
            "siteName": {{ block.settings.site_name | json }},
            "countryCodes": {{ block.settings.country_codes | json }},
            "destinationUrl": {{ block.settings.destination_url | json }}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
  </script>

  <dialog
    class="head-country-redirect__dialog"
    aria-modal="true"
    {% if modal_heading != blank %}
      aria-labelledby="HeadCountryRedirectTitle--{{ section.id }}"
    {% else %}
      aria-label="Country redirect notice"
    {% endif %}
    aria-hidden="true"
    inert
  >
    <div class="head-country-redirect__body" data-scroll-lock-scrollable tabindex="-1">
      {%- if modal_heading != blank -%}
        <h2 id="HeadCountryRedirectTitle--{{ section.id }}" class="head-country-redirect__title">
          {{ modal_heading | escape }}
        </h2>
      {%- endif -%}

      {%- if section.settings.modal_body != blank -%}
        <div class="head-country-redirect__copy rte">
          {{ section.settings.modal_body }}
        </div>
      {%- endif -%}

      <p class="head-country-redirect__site body-medium" data-country-redirect-site></p>

      <button
        type="button"
        class="btn btn--primary head-country-redirect__button"
        data-country-redirect-cta
      >
        {{ redirect_button_label | default: 'Go to regional site' | escape }}
      </button>
    </div>
  </dialog>
</head-country-redirect>

{% stylesheet %}
  head-country-redirect {
    display: block;
  }

  head-country-redirect[data-fallback-open='true'] {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: grid;
    place-items: center;
    padding: 16px;
  }

  head-country-redirect[data-fallback-open='true']::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(17, 17, 17, 0.64);
  }

  .head-country-redirect__dialog {
    width: min(560px, calc(100vw - 32px));
    max-width: calc(100vw - 32px);
    margin: auto;
    border: none;
    padding: 0;
    background-color: transparent;
    color: inherit;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .head-country-redirect__dialog::backdrop {
    background: rgba(17, 17, 17, 0.64);
  }

  .head-country-redirect__body {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 16px;
    max-height: calc(100vh - 32px);
    overflow-y: auto;
    padding: 28px;
    border-radius: 24px;
    background: #fff;
    color: rgb(var(--text));
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.18);
  }

  .head-country-redirect__title {
    margin: 0;
  }

  .head-country-redirect__copy > *:first-child,
  .head-country-redirect__site {
    margin-top: 0;
  }

  .head-country-redirect__copy > *:last-child,
  .head-country-redirect__site {
    margin-bottom: 0;
  }

  .head-country-redirect__site {
    font-weight: 600;
  }

  .head-country-redirect__button {
    width: 100%;
    justify-content: center;
  }

  @media only screen and (max-width: 749px) {
    .head-country-redirect__body {
      padding: 22px;
      border-radius: 20px;
    }
  }
{% endstylesheet %}

{% javascript %}
  class HeadCountryRedirect extends HTMLElement {
    connectedCallback() {
      if (this.initialized) return;
      this.initialized = true;

      const init = () => {
        if (window.Shopify?.designMode || window.Shopify?.visualPreviewMode) return;

        this.dialog = this.querySelector('.head-country-redirect__dialog');
        this.scrollableEl = this.querySelector('[data-scroll-lock-scrollable]');
        this.ctaButton = this.querySelector('[data-country-redirect-cta]');
        this.siteText = this.querySelector('[data-country-redirect-site]');
        this.config = this.getConfig();

        if (!this.dialog || !this.config?.enabled) return;

        const detectedCountry = String(window.Shopify?.country || '')
          .trim()
          .toUpperCase();

        if (!detectedCountry) return;

        const matchedRule = this.getMatchingRule(detectedCountry);

        if (!matchedRule) return;

        this.detectedCountry = detectedCountry;
        this.matchedRule = matchedRule;
        this.siteLabel = matchedRule.siteName || matchedRule.url.hostname;

        this.bindEvents();
        this.updateDynamicContent();
        this.open();
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init, {once: true});
      } else {
        init();
      }
    }

    disconnectedCallback() {
      if (this.handleCancel) {
        this.dialog?.removeEventListener('cancel', this.handleCancel);
      }

      if (this.handleEscape) {
        document.removeEventListener('keydown', this.handleEscape, true);
      }

      if (this.handleImmediateRedirect) {
        this.ctaButton?.removeEventListener('click', this.handleImmediateRedirect);
      }
    }

    getConfig() {
      const configNode = this.querySelector('[data-country-redirect-config]');

      if (!configNode) return null;

      try {
        return JSON.parse(configNode.textContent);
      } catch (error) {
        return null;
      }
    }

    getMatchingRule(countryCode) {
      const rules = Array.isArray(this.config?.rules) ? this.config.rules : [];
      const currentHost = window.location.hostname.toLowerCase();

      for (const rule of rules) {
        if (!rule?.enabled) continue;

        const countryCodes = String(rule.countryCodes || '')
          .split(',')
          .map((code) => code.trim().toUpperCase())
          .filter(Boolean);

        if (!countryCodes.includes(countryCode)) continue;

        const destinationUrl = String(rule.destinationUrl || '').trim();

        if (!destinationUrl) continue;

        try {
          const parsedUrl = new URL(destinationUrl, window.location.href);

          if (!parsedUrl.hostname || parsedUrl.hostname.toLowerCase() === currentHost) {
            continue;
          }

          return {
            siteName: String(rule.siteName || '').trim(),
            url: parsedUrl,
          };
        } catch (error) {
          continue;
        }
      }

      return null;
    }

    bindEvents() {
      if (this.eventsBound) return;
      this.eventsBound = true;

      this.handleCancel = (event) => {
        event.preventDefault();
      };

      this.handleEscape = (event) => {
        if (event.key !== 'Escape') return;
        event.preventDefault();
        event.stopPropagation();
      };

      this.handleImmediateRedirect = () => {
        this.redirectNow();
      };

      this.dialog.addEventListener('cancel', this.handleCancel);
      document.addEventListener('keydown', this.handleEscape, true);
      this.ctaButton?.addEventListener('click', this.handleImmediateRedirect);
    }

    updateDynamicContent() {
      if (this.siteText) {
        this.siteText.textContent =
          'You are navigating from ' +
          this.detectedCountry +
          '. Please continue on the dedicated ' +
          this.siteLabel +
          ' site for your region.';
      }
    }

    open() {
      document.dispatchEvent(
        new CustomEvent('theme:scroll:lock', {
          bubbles: true,
          detail: this.scrollableEl,
        })
      );

      this.dialog.removeAttribute('inert');
      this.dialog.setAttribute('aria-hidden', 'false');

      if (typeof this.dialog.showModal === 'function') {
        try {
          this.dialog.showModal();
        } catch (error) {
          this.dataset.fallbackOpen = 'true';
          this.dialog.setAttribute('open', '');
        }
      } else {
        this.dataset.fallbackOpen = 'true';
        this.dialog.setAttribute('open', '');
      }

      if (window.theme?.a11y?.trapFocus) {
        window.theme.a11y.trapFocus(this.dialog, {
          elementToFocus: this.ctaButton || this.scrollableEl || this.dialog,
        });
      } else {
        (this.ctaButton || this.scrollableEl || this.dialog).focus?.();
      }
    }

    redirectNow() {
      if (this.hasRedirected || !this.matchedRule?.url) return;

      this.hasRedirected = true;
      window.location.assign(this.matchedRule.url.toString());
    }
  }

  if (!customElements.get('head-country-redirect')) {
    customElements.define('head-country-redirect', HeadCountryRedirect);
  }
{% endjavascript %}

{% schema %}
{
  "name": "Head country redirect",
  "limit": 1,
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Enable redirect popup",
      "default": false
    },
    {
      "type": "text",
      "id": "modal_heading",
      "label": "Popup heading",
      "default": "Please visit your regional store"
    },
    {
      "type": "richtext",
      "id": "modal_body",
      "label": "Popup body",
      "default": "<p>We detected that you are browsing from a region with a dedicated store. Please continue on the correct regional site.</p>"
    },
    {
      "type": "text",
      "id": "redirect_button_label",
      "label": "Redirect button label",
      "default": "Continue to regional site"
    }
  ],
  "blocks": [
    {
      "type": "country_redirect_rule",
      "name": "Country redirect rule",
      "settings": [
        {
          "type": "checkbox",
          "id": "enabled",
          "label": "Enable rule",
          "default": true
        },
        {
          "type": "text",
          "id": "site_name",
          "label": "Destination site name",
          "default": "United States"
        },
        {
          "type": "textarea",
          "id": "country_codes",
          "label": "Country codes",
          "info": "Use comma-separated ISO alpha-2 country codes, for example: US, CA, MX"
        },
        {
          "type": "url",
          "id": "destination_url",
          "label": "Destination site URL"
        }
      ]
    }
  ]
}
{% endschema %}
