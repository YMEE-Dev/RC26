<!-- /sections/section-prestige-service.liquid -->
{{ 'section-prestige-service.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign color_scheme = 'color-' | append: section.settings.color_scheme
-%}

{%- style -%}
  #PrestigeService--{{ section.id }} {
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<section
  id="PrestigeService--{{ section.id }}"
  class="prestige-service section-padding {{ color_scheme }}"
  data-section-id="{{ section.id }}"
  data-section-type="prestige-service"
>
  <div class="prestige-service__wrapper {{ section.settings.width }}">
    <div class="prestige-service__background">
      {%- if section.settings.background_image != blank -%}
        {{ section.settings.background_image | image_url: width: 2000 | image_tag: loading: 'lazy' }}

        {%- if section.settings.background_image_mob != blank -%}
          {{ section.settings.background_image_mob | image_url: width: 2000 | image_tag: loading: 'lazy', class: 'prestige-service__background-mobile' }}
        {% endif %}
      {%- else -%}
        <div class="prestige-service__placeholder">
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }} 
        </div>
      {%- endif -%}
    </div>

    <div class="prestige-service__content"> 
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'subheading' -%}
            <div
              class="prestige-subheading"
              style="
                --text-color: {{ block.settings.text_color }};
                --font-size: {{ block.settings.font_size }}px;
                --letter-spacing: {{ block.settings.letter_spacing }}px;
              "
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text | upcase }}
            </div>
          {%- when 'heading' -%}
            <h2
              class="prestige-heading"
              style="
                --text-color: {{ block.settings.text_color }};
                --font-size: {{ block.settings.font_size }}px;
                --line-height: {{ block.settings.line_height }};
                --max-width: {{ block.settings.max_width }}px;
              "
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text }}
            </h2>
          {%- when 'button' -%}
            <a
              class="prestige-button"
              href="{{ block.settings.link | default: '#' }}"
              style="
                --text-color: {{ block.settings.text_color }};
                --bg-color: {{ block.settings.background_color }};
                --hover-text-color: {{ block.settings.hover_text_color }};
                --hover-bg-color: {{ block.settings.hover_background_color }};
                --border-color: {{ block.settings.border_color }};
                --border-width: {{ block.settings.border_width }}px;
              "
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text | upcase }}
            </a>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>


{% schema %}
{
  "name": "Prestige service",
  "tag": "section",
  "class": "section-prestige-service",
  "blocks": [
    {
      "type": "subheading",
      "name": "Subheading",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Roberto Coin Prestige Service"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#FFFFFF"
        },
        {
          "type": "range",
          "id": "font_size",
          "label": "Font size",
          "min": 10,
          "max": 24,
          "step": 1,
          "unit": "px",
          "default": 16
        },
        {
          "type": "range",
          "id": "letter_spacing",
          "label": "Letter spacing",
          "min": 0,
          "max": 5,
          "step": 0.1,
          "unit": "px",
          "default": 1.6
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Included Global Damage & Theft Protection"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#FFFFFF"
        },
        {
          "type": "range",
          "id": "font_size",
          "label": "Font size",
          "min": 24,
          "max": 80,
          "step": 2,
          "unit": "px",
          "default": 48
        },
        {
          "type": "range",
          "id": "line_height",
          "label": "Line height",
          "min": 1,
          "max": 2,
          "step": 0.1,
          "default": 1.2
        },
        {
          "type": "range",
          "id": "max_width",
          "label": "Max width",
          "min": 300,
          "max": 1000,
          "step": 10,
          "unit": "px",
          "default": 600
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Button text",
          "default": "Sign up to the prestige service"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button link"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#000000"
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "Background color",
          "default": "#FFFFFF"
        },
        {
          "type": "color",
          "id": "hover_text_color",
          "label": "Hover text color",
          "default": "#FFFFFF"
        },
        {
          "type": "color",
          "id": "hover_background_color",
          "label": "Hover background color",
          "default": "#000000"
        },
        {
          "type": "color",
          "id": "border_color",
          "label": "Border color",
          "default": "#FFFFFF"
        },
        {
          "type": "range",
          "id": "border_width",
          "label": "Border width",
          "min": 0,
          "max": 5,
          "step": 1,
          "unit": "px",
          "default": 1
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "image_picker",
      "id": "background_image_mob",
      "label": "Background image (mobile)",
      "info": "leave blank if not needed"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "default": "wrapper",
      "options": [
        { "value": "wrapper--full-padded", "label": "Full width padded" },
        { "value": "wrapper", "label": "Normal" },
        { "value": "wrapper--narrow", "label": "Narrow" },
        { "value": "wrapper--custom", "label": "Custom (max-width: 1232px)" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "Color scheme"
    }
  ],
  "presets": [
    {
      "name": "Prestige service",
      "category": "Image",
      "blocks": [
        {
          "type": "subheading",
          "settings": {
            "text": "Roberto Coin Prestige Service"
          }
        },
        {
          "type": "heading",
          "settings": {
            "text": "Included Global Damage & Theft Protection"
          }
        },
        {
          "type": "button",
          "settings": {
            "text": "Sign up to the prestige service"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "aside", "footer"]
  }
}
{% endschema %}