<!-- /sections/section-prestige-service.liquid -->
{%- liquid
  assign color_scheme = 'color-' | append: section.settings.color_scheme
-%}

{%- style -%}
  #PrestigeService--{{ section.id }} {
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<section
  id="PrestigeService--{{ section.id }}"
  class="prestige-service section-padding {{ color_scheme }}"
  data-section-id="{{ section.id }}"
  data-section-type="prestige-service"
>
  <div class="prestige-service__wrapper">
    <div class="prestige-service__background">
      {%- if section.settings.background_image != blank -%}
        {{ section.settings.background_image | image_url: width: 2000 | image_tag: loading: 'lazy' }}
      {%- else -%}
        <div class="prestige-service__placeholder">
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }} 
        </div>
      {%- endif -%}
    </div>

    <div class="prestige-service__content">
      {% content_for 'blocks' %}
    </div>
  </div>
</section>

{% stylesheet %}
  .prestige-service {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .prestige-service__wrapper {
    position: relative;
    width: 100%;
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .prestige-service__background {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .prestige-service__background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .prestige-service__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.05);
  }

  .prestige-service__placeholder .placeholder-svg {
    width: 60%;
    height: auto;
    opacity: 0.3;
  }

  .prestige-service__content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1232px;
    margin: 0 auto;
    padding: 60px 20px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .prestige-service__wrapper {
      min-height: 600px;
    }

    .prestige-service__content {
      padding: 80px 40px;
      gap: 32px;
    }
  }

  @media (min-width: 990px) {
    .prestige-service__wrapper {
      min-height: 700px;
    }

    .prestige-service__content {
      padding: 100px 60px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Prestige service",
  "tag": "section",
  "class": "section-prestige-service",
  "blocks": [
    {
      "type": "subheading",
      "name": "Subheading",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Roberto Coin Prestige Service"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#FFFFFF"
        },
        {
          "type": "range",
          "id": "font_size",
          "label": "Font size",
          "min": 10,
          "max": 24,
          "step": 1,
          "unit": "px",
          "default": 16
        },
        {
          "type": "range",
          "id": "letter_spacing",
          "label": "Letter spacing",
          "min": 0,
          "max": 5,
          "step": 0.1,
          "unit": "px",
          "default": 1.6
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Included Global Damage & Theft Protection"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#FFFFFF"
        },
        {
          "type": "range",
          "id": "font_size",
          "label": "Font size",
          "min": 24,
          "max": 80,
          "step": 2,
          "unit": "px",
          "default": 48
        },
        {
          "type": "range",
          "id": "line_height",
          "label": "Line height",
          "min": 1,
          "max": 2,
          "step": 0.1,
          "default": 1.2
        },
        {
          "type": "range",
          "id": "max_width",
          "label": "Max width",
          "min": 300,
          "max": 1000,
          "step": 10,
          "unit": "px",
          "default": 600
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Button text",
          "default": "Sign up to the prestige service"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button link"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#000000"
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "Background color",
          "default": "#FFFFFF"
        },
        {
          "type": "color",
          "id": "hover_text_color",
          "label": "Hover text color",
          "default": "#FFFFFF"
        },
        {
          "type": "color",
          "id": "hover_background_color",
          "label": "Hover background color",
          "default": "#000000"
        },
        {
          "type": "color",
          "id": "border_color",
          "label": "Border color",
          "default": "#FFFFFF"
        },
        {
          "type": "range",
          "id": "border_width",
          "label": "Border width",
          "min": 0,
          "max": 5,
          "step": 1,
          "unit": "px",
          "default": 1
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "Color scheme"
    }
  ],
  "presets": [
    {
      "name": "Prestige service",
      "category": "Image",
      "blocks": [
        {
          "type": "subheading",
          "settings": {
            "text": "Roberto Coin Prestige Service"
          }
        },
        {
          "type": "heading",
          "settings": {
            "text": "Included Global Damage & Theft Protection"
          }
        },
        {
          "type": "button",
          "settings": {
            "text": "Sign up to the prestige service"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "aside", "footer"]
  }
}
{% endschema %}
