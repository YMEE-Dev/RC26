<!-- /sections/section-prestige-service.liquid -->
{%- liquid
  assign color_scheme = 'color-' | append: section.settings.color_scheme
-%}

{%- style -%}
  #PrestigeService--{{ section.id }} {
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<section
  id="PrestigeService--{{ section.id }}"
  class="prestige-service section-padding {{ color_scheme }}"
  data-section-id="{{ section.id }}"
  data-section-type="prestige-service"
>
  <div class="prestige-service__wrapper {{ section.settings.width }}">
    <div class="prestige-service__background">
      {%- if section.settings.background_image != blank -%}
        {{ section.settings.background_image | image_url: width: 2000 | image_tag: loading: 'lazy' }}
      {%- else -%}
        <div class="prestige-service__placeholder">
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }} 
        </div>
      {%- endif -%}
    </div>

    <div class="prestige-service__content"> 
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'subheading' -%}
            <div
              class="prestige-subheading"
              style="
                --text-color: {{ block.settings.text_color }};
                --font-size: {{ block.settings.font_size }}px;
                --letter-spacing: {{ block.settings.letter_spacing }}px;
              "
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text | upcase }}
            </div>
          {%- when 'heading' -%}
            <h2
              class="prestige-heading"
              style="
                --text-color: {{ block.settings.text_color }};
                --font-size: {{ block.settings.font_size }}px;
                --line-height: {{ block.settings.line_height }};
                --max-width: {{ block.settings.max_width }}px;
              "
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text }}
            </h2>
          {%- when 'button' -%}
            <a
              class="prestige-button"
              href="{{ block.settings.link | default: '#' }}"
              style="
                --text-color: {{ block.settings.text_color }};
                --bg-color: {{ block.settings.background_color }};
                --hover-text-color: {{ block.settings.hover_text_color }};
                --hover-bg-color: {{ block.settings.hover_background_color }};
                --border-color: {{ block.settings.border_color }};
                --border-width: {{ block.settings.border_width }}px;
              "
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text | upcase }}
            </a>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .prestige-service {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .prestige-service__wrapper {
    position: relative;
    width: 100%;
    min-height: 677px; 
    display: flex;
    padding-left: 72px;
    align-items: center;
    justify-content:flex-start;
  }



  .prestige-service__wrapper.wrapper--full-padded {
    width: 100%;
    padding: 0 40px;
  }

  .prestige-service__wrapper.wrapper--narrow {
    max-width: 1200px;
    margin: 0 auto;
  }

  .prestige-service__background {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .prestige-service__background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .prestige-service__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.05);
  }

  .prestige-service__placeholder .placeholder-svg {
    width: 60%;
    height: auto;
    opacity: 0.3;
  }

  .prestige-service__content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 419px;
 
    /* padding: 72px 20px; */
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    /* gap: 24px; */
  }

  @media (min-width: 768px) {
    .prestige-service__wrapper {
      min-height: 600px;
    }

    .prestige-service__content {
      /* padding: 80px 40px; */
      /* gap: 32px; */
    }
  }

  @media (min-width: 990px) {
    .prestige-service__wrapper {
      min-height: 700px;
    }

    .prestige-service__content {
      /* padding: 100px 60px; */
    }
  }
  @media (max-width: 768px) {
    .prestige-service__content {
      width: 100%;
      max-width: 100%;
    }
    .prestige-service__wrapper {
      padding: 20px;
    }
    .prestige-button {
      width: 100%;
    }
  }

  .prestige-subheading {
    color: var(--f-9-f-9-f-9, #F9F9F9);

    /* RC26/Title (ALL CAPS) */
    font-family: Inter;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 22px; /* 137.5% */
    letter-spacing: 1.6px;
    text-transform: uppercase;
    text-transform: uppercase;
    margin: 0;
  }

  .prestige-heading {
    color: var(--f-9-f-9-f-9, #F9F9F9);

    /* RC26/Display/L */
    font-family: var(--FONT-STACK-HEADING);
    font-size: 40px;
    font-style: normal;
    font-weight: 500;
    line-height: 48px; /* 120% */
    margin: 0 0 20px;
  }

  @media (max-width: 767px) {
    .prestige-heading {
      font-size: calc(var(--font-size, 48px) * 0.65);
    }
  }

  .prestige-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    color: var(--text-color, #000000);
    background-color: var(--bg-color, #FFFFFF);
    border: var(--border-width, 1px) solid var(--border-color, #FFFFFF);
    font-family: Inter, sans-serif;
    font-size: 12px;
    font-style: normal;
    font-weight: 600;
    line-height: 20px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .prestige-button:hover {
    color: var(--hover-text-color, #FFFFFF);
    background-color: var(--hover-bg-color, #000000);
    border-color: var(--hover-bg-color, #000000);
  }

  .prestige-button:focus {
    outline: 2px solid var(--hover-bg-color, #000000);
    outline-offset: 2px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Prestige service",
  "tag": "section",
  "class": "section-prestige-service",
  "blocks": [
    {
      "type": "subheading",
      "name": "Subheading",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Roberto Coin Prestige Service"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#FFFFFF"
        },
        {
          "type": "range",
          "id": "font_size",
          "label": "Font size",
          "min": 10,
          "max": 24,
          "step": 1,
          "unit": "px",
          "default": 16
        },
        {
          "type": "range",
          "id": "letter_spacing",
          "label": "Letter spacing",
          "min": 0,
          "max": 5,
          "step": 0.1,
          "unit": "px",
          "default": 1.6
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Included Global Damage & Theft Protection"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#FFFFFF"
        },
        {
          "type": "range",
          "id": "font_size",
          "label": "Font size",
          "min": 24,
          "max": 80,
          "step": 2,
          "unit": "px",
          "default": 48
        },
        {
          "type": "range",
          "id": "line_height",
          "label": "Line height",
          "min": 1,
          "max": 2,
          "step": 0.1,
          "default": 1.2
        },
        {
          "type": "range",
          "id": "max_width",
          "label": "Max width",
          "min": 300,
          "max": 1000,
          "step": 10,
          "unit": "px",
          "default": 600
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Button text",
          "default": "Sign up to the prestige service"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button link"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#000000"
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "Background color",
          "default": "#FFFFFF"
        },
        {
          "type": "color",
          "id": "hover_text_color",
          "label": "Hover text color",
          "default": "#FFFFFF"
        },
        {
          "type": "color",
          "id": "hover_background_color",
          "label": "Hover background color",
          "default": "#000000"
        },
        {
          "type": "color",
          "id": "border_color",
          "label": "Border color",
          "default": "#FFFFFF"
        },
        {
          "type": "range",
          "id": "border_width",
          "label": "Border width",
          "min": 0,
          "max": 5,
          "step": 1,
          "unit": "px",
          "default": 1
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "default": "wrapper",
      "options": [
        { "value": "wrapper--full-padded", "label": "Full width padded" },
        { "value": "wrapper", "label": "Normal" },
        { "value": "wrapper--narrow", "label": "Narrow" },
        { "value": "wrapper--custom", "label": "Custom (max-width: 1232px)" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "Color scheme"
    }
  ],
  "presets": [
    {
      "name": "Prestige service",
      "category": "Image",
      "blocks": [
        {
          "type": "subheading",
          "settings": {
            "text": "Roberto Coin Prestige Service"
          }
        },
        {
          "type": "heading",
          "settings": {
            "text": "Included Global Damage & Theft Protection"
          }
        },
        {
          "type": "button",
          "settings": {
            "text": "Sign up to the prestige service"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "aside", "footer"]
  }
}
{% endschema %}
