{%- liquid
  assign color_scheme = 'color-' | append: section.settings.color_scheme
  assign interval_ms = section.settings.interval_seconds | times: 1000

  assign top_a = section.settings.image_top
  assign right_a = section.settings.image_right
  assign left_a = section.settings.image_left
  assign bottom_a = section.settings.image_bottom

  assign top_b = section.settings.image_top_alt
  assign right_b = section.settings.image_right_alt
  assign left_b = section.settings.image_left_alt
  assign bottom_b = section.settings.image_bottom_alt
-%}

{%- style -%}
  #MaisonHeroCollage--{{ section.id }} {
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<section
  id="MaisonHeroCollage--{{ section.id }}"
  class="maison-hero-collage section-padding {{ color_scheme }}"
  data-section-id="{{ section.id }}"
  data-section-type="maison-hero-collage"
>
  <div
    class="maison-hero-collage__inner {{ section.settings.width }}"
    data-maison-collage
    data-interval-ms="{{ interval_ms }}"
  >
    {%- if section.settings.show_text -%}
      <div class="maison-hero-collage__copy">
        {%- if section.settings.eyebrow != blank -%}
          <p class="maison-hero-collage__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="maison-hero-collage__title">{{ section.settings.title }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="maison-collage is-intro" aria-hidden="true" data-maison-collage-inner>
      <figure class="maison-collage__item maison-collage__item--top">
        {% if top_a != blank or top_b != blank %}
          <div
            class="maison-collage__shift"
            style="--shift-x: {{ section.settings.top_shift_x }}px; --shift-y: {{ section.settings.top_shift_y }}px;"
          >
            <img
              src="{{ top_a | default: top_b | image_url: width: 1400 }}"
              alt="{{ top_a.alt | default: top_b.alt | escape }}"
              loading="eager"
              data-image-a="{{ top_a | default: top_b | image_url: width: 1400 }}"
              data-image-b="{% if top_b != blank %}{{ top_b | image_url: width: 1400 }}{% endif %}"
              data-alt-a="{{ top_a.alt | default: top_b.alt | escape }}"
              data-alt-b="{% if top_b != blank %}{{ top_b.alt | escape }}{% endif %}"
            >
          </div>
        {% endif %}
      </figure>

      <figure class="maison-collage__item maison-collage__item--right">
        {% if right_a != blank or right_b != blank %}
          <div
            class="maison-collage__shift"
            style="--shift-x: {{ section.settings.right_shift_x }}px; --shift-y: {{ section.settings.right_shift_y }}px;"
          >
            <img
              src="{{ right_a | default: right_b | image_url: width: 1800 }}"
              alt="{{ right_a.alt | default: right_b.alt | escape }}"
              loading="eager"
              data-image-a="{{ right_a | default: right_b | image_url: width: 1800 }}"
              data-image-b="{% if right_b != blank %}{{ right_b | image_url: width: 1800 }}{% endif %}"
              data-alt-a="{{ right_a.alt | default: right_b.alt | escape }}"
              data-alt-b="{% if right_b != blank %}{{ right_b.alt | escape }}{% endif %}"
            >
          </div>
        {% endif %}
      </figure>

      <figure class="maison-collage__item maison-collage__item--left">
        {% if left_a != blank or left_b != blank %}
          <div
            class="maison-collage__shift"
            style="--shift-x: {{ section.settings.left_shift_x }}px; --shift-y: {{ section.settings.left_shift_y }}px;"
          >
            <img
              src="{{ left_a | default: left_b | image_url: width: 1800 }}"
              alt="{{ left_a.alt | default: left_b.alt | escape }}"
              loading="eager"
              data-image-a="{{ left_a | default: left_b | image_url: width: 1800 }}"
              data-image-b="{% if left_b != blank %}{{ left_b | image_url: width: 1800 }}{% endif %}"
              data-alt-a="{{ left_a.alt | default: left_b.alt | escape }}"
              data-alt-b="{% if left_b != blank %}{{ left_b.alt | escape }}{% endif %}"
            >
          </div>
        {% endif %}
      </figure>

      <figure class="maison-collage__item maison-collage__item--bottom">
        {% if bottom_a != blank or bottom_b != blank %}
          <div
            class="maison-collage__shift"
            style="--shift-x: {{ section.settings.bottom_shift_x }}px; --shift-y: {{ section.settings.bottom_shift_y }}px;"
          >
            <img
              src="{{ bottom_a | default: bottom_b | image_url: width: 1800 }}"
              alt="{{ bottom_a.alt | default: bottom_b.alt | escape }}"
              loading="eager"
              data-image-a="{{ bottom_a | default: bottom_b | image_url: width: 1800 }}"
              data-image-b="{% if bottom_b != blank %}{{ bottom_b | image_url: width: 1800 }}{% endif %}"
              data-alt-a="{{ bottom_a.alt | default: bottom_b.alt | escape }}"
              data-alt-b="{% if bottom_b != blank %}{{ bottom_b.alt | escape }}{% endif %}"
            >
          </div>
        {% endif %}
      </figure>
    </div>
  </div>
</section>

{% stylesheet %}
  .maison-hero-collage {
    background: var(--COLOR-BG, #fff);
    color: var(--COLOR-TEXT, #212121);
  }

  .maison-hero-collage__inner {
    position: relative;
    padding-top: clamp(40px, 7vw, 90px);
    padding-bottom: clamp(30px, 6vw, 70px);
  }

  .maison-hero-collage__copy {
    position: absolute;
    left: 50%;
    top: 46%;
    transform: translate(-50%, -50%);
    z-index: 3;
    text-align: center;
    pointer-events: none;
  }

  .maison-hero-collage__eyebrow {
    margin: 0 0 8px;
    font-family: var(--FONT-STACK-BODY, Inter, sans-serif);
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    opacity: 0.9;
  }

  .maison-hero-collage__title {
    margin: 0;
    font-family: var(--FONT-STACK-HEADING, 'Portrait LS', serif);
    font-weight: var(--FONT-WEIGHT-HEADING, 500);
    font-size: 40px;
    line-height: 1;
    letter-spacing: 0.01em;
  }

  /* Collage (adapted from rc-timeline) */
  .maison-collage {
    position: relative;
    width: min(980px, 82vw);
    min-height: 620px;
    margin: 0 auto;
    transform: translateY(28px);
    z-index: 1;
  }

  .maison-collage__item {
    position: absolute;
    margin: 0;
    overflow: hidden;
    opacity: 1;
    transform: none;
    transition:
      top 1.25s cubic-bezier(0.2, 0.88, 0.28, 1),
      right 1.25s cubic-bezier(0.2, 0.88, 0.28, 1),
      bottom 1.25s cubic-bezier(0.2, 0.88, 0.28, 1),
      left 1.25s cubic-bezier(0.2, 0.88, 0.28, 1),
      width 1.25s cubic-bezier(0.2, 0.88, 0.28, 1),
      height 1.25s cubic-bezier(0.2, 0.88, 0.28, 1),
      opacity 0.9s cubic-bezier(0.33, 0.01, 0.25, 1),
      transform 1.15s cubic-bezier(0.2, 0.88, 0.28, 1);
    will-change: opacity, transform;
  }

  .maison-collage__item img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .maison-collage__shift {
    width: 100%;
    height: 100%;
    translate: var(--shift-x, 0px) var(--shift-y, 0px);
  }

  .maison-collage.is-alt .maison-collage__item img {
    object-fit: contain;
    object-position: center;
  }

  .maison-collage.is-intro .maison-collage__item {
    opacity: 1;
    transform: none;
  }

  .maison-collage.is-animating.is-intro .maison-collage__item {
    opacity: 0;
    transform: translateY(8px) scale(0.995);
    transition-duration: 1.1s;
    transition-timing-function: cubic-bezier(0.22, 0.84, 0.28, 1);
    transition-delay: var(--intro-delay, 0ms);
  }

  .maison-collage.is-intro.is-intro-visible .maison-collage__item {
    opacity: 1;
    transform: none;
  }

  .maison-collage__item--top {
    top: -10px;
    left: calc(33% - 100px);
    width: 200px;
    height: 262px;
  }

  .maison-collage__item--right {
    top: 0;
    right: 9%;
    width: 278px;
    height: 376px;
    z-index: 5;
  }

  .maison-collage__item--left {
    left: calc(8% - 200px);
    bottom: 92px;
    width: 464px;
    height: 360px;
    z-index: 2;
  }

  .maison-collage__item--bottom {
    right: 0;
    bottom: 8px;
    width: 296px;
    height: 198px;
    z-index: 2;
  }

  .maison-collage.is-intro.is-intro-visible .maison-collage__item--top { --intro-delay: 0ms; }
  .maison-collage.is-intro.is-intro-visible .maison-collage__item--right { --intro-delay: 170ms; }
  .maison-collage.is-intro.is-intro-visible .maison-collage__item--left { --intro-delay: 340ms; }
  .maison-collage.is-intro.is-intro-visible .maison-collage__item--bottom { --intro-delay: 510ms; }

  .maison-collage.is-switching {
    filter: saturate(0.98);
  }

  @media (max-width: 749px) {
    .maison-hero-collage__copy {
      top: 42%;
    }

    .maison-collage {
      width: min(560px, 92vw);
      min-height: 520px;
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    const init = (root) => {
      if (!root || root.dataset.maisonCollageInitialized === 'true') return;
      root.dataset.maisonCollageInitialized = 'true';

      const collage = root.querySelector('[data-maison-collage-inner]');
      if (!collage) return;

      const prefersReducedMotion =
        window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const heroCollage = collage;
      const heroCollageItems = [...heroCollage.querySelectorAll('.maison-collage__item')];
      if (!heroCollageItems.length) return;

      const introAppearDuration = 1400;
      heroCollage.classList.add('is-animating');
      heroCollage.classList.add('is-intro');
      window.setTimeout(() => heroCollage.classList.add('is-intro-visible'), 60);

      window.setTimeout(() => {
        heroCollage.classList.remove('is-intro');
        heroCollage.classList.remove('is-intro-visible');
        heroCollage.classList.remove('is-animating');
      }, introAppearDuration);

      if (prefersReducedMotion) return;

      const intervalMsRaw = Number(root.dataset.intervalMs || 6000);
      const intervalMs = Math.max(3000, Math.min(15000, intervalMsRaw));

      const heroAltLayoutPresets = [
        [
          { top: '14px', left: '5%', width: '172px', height: '220px' },
          { top: '30px', right: '-4%', width: '190px', height: '172px' },
          { bottom: '0px', left: '0%', width: '190px', height: '200px' },
          { bottom: '-50px', right: '0%', width: '214px', height: '206px' },
        ],
      ];

      const timeoutIds = new Set();
      const intervalIds = new Set();

      const scheduleTimeout = (callback, delay) => {
        const timeoutId = window.setTimeout(() => {
          timeoutIds.delete(timeoutId);
          callback();
        }, delay);
        timeoutIds.add(timeoutId);
        return timeoutId;
      };

      const scheduleInterval = (callback, delay) => {
        const intervalId = window.setInterval(callback, delay);
        intervalIds.add(intervalId);
        return intervalId;
      };

      const clearScheduledWork = () => {
        timeoutIds.forEach((timeoutId) => window.clearTimeout(timeoutId));
        timeoutIds.clear();
        intervalIds.forEach((intervalId) => window.clearInterval(intervalId));
        intervalIds.clear();
      };

      const preload = (url) => {
        if (!url) return;
        const image = new Image();
        image.decoding = 'async';
        image.loading = 'eager';
        image.src = url;
      };

      const resetHeroItemPosition = (item) => {
        if (!item) return;
        item.style.removeProperty('top');
        item.style.removeProperty('right');
        item.style.removeProperty('bottom');
        item.style.removeProperty('left');
        item.style.removeProperty('width');
        item.style.removeProperty('height');
        item.style.removeProperty('z-index');
      };

      const applyHeroAltLayout = () => {
        if (!heroCollageItems.length) return;

        if (window.innerWidth > 820) {
          const altDesktopLayout = [
            { top: '-100px', left: '25%', width: '252px', height: '328px' },
            { top: '-42px', right: '4%', width: '300px', height: '416px' },
            { left: 'calc(6% - 100px)', bottom: '100px', width: '530px', height: '418px' },
            { right: '-50px', bottom: '0px', width: '386px', height: '256px' },
          ];

          heroCollageItems.forEach((item, index) => {
            const styles = altDesktopLayout[index] || {};
            item.style.top = styles.top ?? 'auto';
            item.style.right = styles.right ?? 'auto';
            item.style.bottom = styles.bottom ?? 'auto';
            item.style.left = styles.left ?? 'auto';
            item.style.width = styles.width ?? '';
            item.style.height = styles.height ?? '';
            item.style.zIndex = index === 3 ? '8' : '';
          });
          return;
        }

        const preset = heroAltLayoutPresets[Math.floor(Math.random() * heroAltLayoutPresets.length)];
        heroCollageItems.forEach((item, index) => {
          const styles = { ...(preset[index] || {}) };
          item.style.top = styles.top ?? 'auto';
          item.style.right = styles.right ?? 'auto';
          item.style.bottom = styles.bottom ?? 'auto';
          item.style.left = styles.left ?? 'auto';
          item.style.width = styles.width ?? '';
          item.style.height = styles.height ?? '';
        });
      };

      const sourcesA = [];
      const altsA = [];
      const sourcesB = [];
      const altsB = [];

      heroCollageItems.forEach((item) => {
        const image = item.querySelector('img');
        if (!image) return;

        const sourceA = image.dataset.imageA || image.getAttribute('src') || '';
        const sourceB = image.dataset.imageB || '';
        const altA = image.dataset.altA || image.getAttribute('alt') || '';
        const altB = image.dataset.altB || '';

        sourcesA.push(sourceA);
        altsA.push(altA);
        sourcesB.push(sourceB);
        altsB.push(altB);

        preload(sourceB);
      });

      const hasAltSet = sourcesB.some(Boolean);
      if (!hasAltSet) return;

      let heroSwapAnimating = false;

      function animateHeroSwap(showAlt) {
        if (heroSwapAnimating) return;
        heroSwapAnimating = true;

        const totalFadeOutMs = 380;
        const staggerMs = 70;
        const totalMs = totalFadeOutMs + 520;

        heroCollageItems.forEach((item, index) => {
          const image = item.querySelector('img');
          if (!image) return;

          const nextSource = showAlt ? sourcesB[index] : sourcesA[index];
          const nextAlt = showAlt ? altsB[index] : altsA[index];
          const startDelay = index * staggerMs;

          scheduleTimeout(() => {
            item.style.opacity = '0';
          }, startDelay);

          scheduleTimeout(() => {
            if (nextSource && image.getAttribute('src') !== nextSource) {
              image.setAttribute('src', nextSource);
            }
            image.setAttribute('alt', nextAlt || '');
          }, totalFadeOutMs + 40);

          scheduleTimeout(() => {
            item.style.opacity = '1';
          }, totalFadeOutMs + 80 + startDelay);
        });

        scheduleTimeout(() => {
          if (showAlt) {
            applyHeroAltLayout();
            heroCollage.classList.add('is-alt');
          } else {
            heroCollageItems.forEach(resetHeroItemPosition);
            heroCollage.classList.remove('is-alt');
          }
        }, totalFadeOutMs + 20);

        scheduleTimeout(() => {
          heroSwapAnimating = false;
        }, totalMs);
      }

      let heroSlideshowShowingAlt = false;
      let intervalId = null;

      const start = () => {
        if (intervalId) return;
        intervalId = scheduleInterval(() => {
          heroSlideshowShowingAlt = !heroSlideshowShowingAlt;
          animateHeroSwap(heroSlideshowShowingAlt);
        }, intervalMs);
      };

      const stop = () => {
        if (!intervalId) return;
        window.clearInterval(intervalId);
        intervalIds.delete(intervalId);
        intervalId = null;
      };

      start();

      const observer = new IntersectionObserver(
        (entries) => {
          const entry = entries[0];
          if (!entry) return;
          if (entry.isIntersecting) start();
          else stop();
        },
        { threshold: 0.15 }
      );

      observer.observe(root);
    };

    const initAll = (scope) => {
      const container = scope && scope.querySelectorAll ? scope : document;
      container.querySelectorAll('[data-maison-collage]').forEach(init);
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => initAll(document));
    } else {
      initAll(document);
    }

    document.addEventListener('shopify:section:load', (event) => {
      initAll(event.target);
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Maison — Hero collage",
  "tag": "section",
  "class": "section-maison-hero-collage",
  "settings": [
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "checkbox",
      "id": "show_text",
      "label": "Show text overlay",
      "default": true
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Since 1996"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "The Brand"
    },
    {
      "type": "header",
      "content": "Slideshow"
    },
    {
      "type": "range",
      "id": "interval_seconds",
      "min": 3,
      "max": 12,
      "step": 1,
      "unit": "s",
      "label": "Slide change interval",
      "default": 6
    },
    {
      "type": "image_picker",
      "id": "image_top",
      "label": "Image top (set 1)"
    },
    {
      "type": "image_picker",
      "id": "image_right",
      "label": "Image right (set 1)"
    },
    {
      "type": "image_picker",
      "id": "image_left",
      "label": "Image left (set 1)"
    },
    {
      "type": "image_picker",
      "id": "image_bottom",
      "label": "Image bottom (set 1)"
    },
    {
      "type": "image_picker",
      "id": "image_top_alt",
      "label": "Image top (set 2)"
    },
    {
      "type": "image_picker",
      "id": "image_right_alt",
      "label": "Image right (set 2)"
    },
    {
      "type": "image_picker",
      "id": "image_left_alt",
      "label": "Image left (set 2)"
    },
    {
      "type": "image_picker",
      "id": "image_bottom_alt",
      "label": "Image bottom (set 2)"
    },
    {
      "type": "header",
      "content": "Fine tune positioning"
    },
    {
      "type": "range",
      "id": "top_shift_x",
      "min": -240,
      "max": 240,
      "step": 5,
      "unit": "px",
      "label": "Top image horizontal",
      "default": 0
