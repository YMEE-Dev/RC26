    {
      "type": "range",
      "id": "right_shift_y",
      "min": -240,
      "max": 240,
      "step": 5,
      "unit": "px",
      "label": "Right image vertical",
      "default": 0
    },
    {
      "type": "range",
      "id": "left_shift_x",
      "min": -240,
      "max": 240,
      "step": 5,
      "unit": "px",
      "label": "Left image horizontal",
      "default": 0
    },
    {
      "type": "range",
      "id": "left_shift_y",
      "min": -240,
      "max": 240,
      "step": 5,
      "unit": "px",
      "label": "Left image vertical",
      "default": 0
    },
    {
      "type": "range",
      "id": "bottom_shift_x",
