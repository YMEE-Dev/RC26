<!-- /sections/blog-occasion-style.liquid -->
{%- liquid
  assign featured_article = blank

  if section.settings.featured_article != blank
    assign featured_article = articles[section.settings.featured_article]
  endif

  if featured_article == blank
    if article != blank
      assign featured_article = article
    endif
  endif

  if featured_article == blank
    assign featured_article = blog.articles.first
  endif
-%}

{{ 'blog-occasion.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #BlogOccasion--{{ section.id }} {
    --occasion-top-padding: {{ section.settings.padding_top }}px;
    --occasion-bottom-padding: {{ section.settings.padding_bottom }}px;
    --occasion-content-max-width: {{ section.settings.content_max_width }}px;
    --occasion-content-gap: {{ section.settings.content_gap }}px;
    --occasion-title-max-width: {{ section.settings.title_max_width }}px;
    --occasion-media-height-mobile: {{ section.settings.image_height_mobile }}vh;
  }
{%- endstyle -%}

<section
  id="BlogOccasion--{{ section.id }}"
  class="blog-occasion"
  data-section-id="{{ section.id }}"
  data-section-type="blog-occasion-style"
>
  {%- if featured_article != blank -%}
    <div class="blog-occasion__top" data-blog-fade data-blog-fade-delay="0.08">
      <h2 class="h2 blog-occasion__title">{{ featured_article.title }}</h2>
      <p class="body blog-occasion__date">
        <time datetime="{{ featured_article.published_at | date: '%Y-%m-%d' }}">
          {{ featured_article.published_at | date: '%B %-d, %Y' }}
        </time>
      </p>
    </div>

    {%- if section.settings.video != blank or section.settings.video_url != blank or featured_article.image != blank -%}
      <div class="blog-occasion__media" data-blog-fade data-blog-fade-delay="0.18">
        {%- if section.settings.video != blank -%}
          {{
            section.settings.video
            | video_tag:
              autoplay: true,
              loop: true,
              controls: false,
              muted: true,
              playsinline: true,
              class: 'blog-occasion__video'
          }}
        {%- elsif section.settings.video_url != blank -%}
          <video class="blog-occasion__video" autoplay loop muted playsinline>
            <source src="{{ section.settings.video_url }}">
          </video>
        {%- elsif featured_article.image != blank -%}
          {%- liquid
            assign featured_image_alt = featured_article.image.alt
            if featured_image_alt == blank
              assign featured_image_alt = featured_article.title
            endif
          -%}
          {{
            featured_article.image
            | image_url: width: 2800
            | image_tag:
              alt: featured_image_alt,
              widths: '750, 1100, 1500, 2000, 2400, 2800',
              sizes: '100vw',
              loading: 'eager',
              class: 'blog-occasion__image'
          }}
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if featured_article.content != blank -%}
      <div class="blog-occasion__content-wrapper" data-blog-fade data-blog-fade-delay="0.26">
        <div class="blog-occasion__content body rte">
          {{ featured_article.content }}
        </div>
      </div>
    {%- endif -%}
  {%- else -%}
    <div class="blog-occasion__empty h4">{{ 'blogs.article.no_articles' | t }}</div>
  {%- endif -%}
</section>

{% stylesheet %}
  .blog-fade-js [data-blog-fade] {
    opacity: 0;
    transform: translate3d(0, 22px, 0);
    transition-property: opacity, transform;
    transition-duration: 1.2s, 1.2s;
    transition-timing-function: ease, cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--blog-fade-delay, 0s);
    will-change: opacity, transform;
  }

  .blog-fade-js [data-blog-fade].blog-fade-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-fade-js [data-blog-fade] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    const initBlogFade = () => {
      document.documentElement.classList.add('blog-fade-js');

      const roots = document.querySelectorAll('[data-section-type="blog-occasion-style"]');
      roots.forEach((root) => {
        const targets = root.querySelectorAll('[data-blog-fade]:not(.blog-fade-observed)');
        if (!targets.length) return;

        if (!('IntersectionObserver' in window)) {
          targets.forEach((el) => el.classList.add('blog-fade-visible'));
          return;
        }

        if (!window.__blogFadeObserver) {
          window.__blogFadeObserver = new IntersectionObserver(
            (entries, obs) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                entry.target.classList.add('blog-fade-visible');
                obs.unobserve(entry.target);
              });
            },
            { threshold: 0.12 }
          );
        }

        targets.forEach((el) => {
          const delay = el.getAttribute('data-blog-fade-delay');
          if (delay) el.style.setProperty('--blog-fade-delay', `${delay}s`);
          el.classList.add('blog-fade-observed');
          window.__blogFadeObserver.observe(el);
        });

        requestAnimationFrame(() => {
          targets.forEach((el) => {
            const rect = el.getBoundingClientRect();
            if (rect.top < window.innerHeight * 0.92 && rect.bottom > 0) {
              el.classList.add('blog-fade-visible');
              window.__blogFadeObserver.unobserve(el);
            }
          });
        });
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initBlogFade, { once: true });
    } else {
      initBlogFade();
    }

    document.addEventListener('shopify:section:load', initBlogFade);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Blog - Header Media",
  "settings": [
    {
      "type": "article",
      "id": "featured_article",
      "label": "Featured blog post",
      "info": "Optional. If empty, current article or latest post is used."
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 700,
      "max": 1500,
      "step": 20,
      "unit": "px",
      "label": "Content max width",
      "default": 1100
    },
    {
      "type": "range",
      "id": "title_max_width",
      "min": 500,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "label": "Title max width",
      "default": 980
    },
    {
      "type": "range",
      "id": "content_gap",
      "min": 10,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Title and date spacing",
      "default": 28
    },
    {
      "type": "video",
      "id": "video",
      "label": "Top video"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Top video URL (fallback)"
    },
    {
      "type": "range",
      "id": "image_height_mobile",
      "min": 30,
      "max": 70,
      "step": 1,
      "unit": "%",
      "label": "Image height on mobile",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Blog - Header Media"
    }
  ]
}
{% endschema %}
