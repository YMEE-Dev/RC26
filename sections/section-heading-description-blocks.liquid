<!-- /sections/section-heading-description-blocks.liquid -->
{%- liquid
  assign color_scheme = 'color-' | append: section.settings.color_scheme
-%}

{%- style -%}
  #HeadingDescBlocks--{{ section.id }} {
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
    {%- if section.settings.background_color != blank -%}
    background-color: {{ section.settings.background_color }};
    {%- endif -%}
  }
{%- endstyle -%}

<section
  id="HeadingDescBlocks--{{ section.id }}"
  class="heading-description-blocks section-padding {{ color_scheme }}"
  data-section-id="{{ section.id }}"
  data-section-type="heading-desc-blocks"
>
  <div class="heading-description-blocks__wrapper">
    <div class="heading-description-blocks__content">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'heading' -%}
          {%- if block.settings.title != blank -%}
            {%- liquid
              assign heading_tag = 'h2'
              unless block.settings.heading_tag == 'automatic' or block.settings.heading_tag == blank
                assign heading_tag = block.settings.heading_tag
              endunless
            -%}
            <{{ heading_tag }}
              class="heading-description-blocks__heading {{ block.settings.heading_font_size }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.title }}
            </{{ heading_tag }}>
          {%- endif -%}

        {%- when 'description' -%}
          {%- if block.settings.text != blank -%}
            <div
              class="heading-description-blocks__description rte"
              style="--description-margin-bottom: {{ block.settings.margin_bottom }}px"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text }}
            </div>
          {%- endif -%}
      {%- endcase -%}
    {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .heading-description-blocks__wrapper {
    width: 100%;
    max-width: 1232px;
    margin: 0 auto;
    text-align: left;
  }
  .heading-description-blocks__content {
    max-width: 814px;
    /* margin: 0 auto; */
    text-align: left;
  }

  .heading-description-blocks__heading {
    margin: 0 0 1.5rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .heading-description-blocks__description {
    margin: 0 0 var(--description-margin-bottom, 1rem);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .heading-description-blocks__description:last-child {
    margin-bottom: 0;
  }

  .heading-description-blocks__description p {
    margin: 0 0 0.75em;
  }

  .heading-description-blocks__description p:last-child {
    margin-bottom: 0;
  }


{% endstylesheet %}

{% schema %}
{
  "name": "Heading & text blocks",
  "tag": "section",
  "class": "section-heading-desc-blocks",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Layout width",
      "default": "wrapper",
      "options": [
        { "value": "wrapper--full-padded", "label": "Full width padded" },
        { "value": "wrapper", "label": "Normal" },
        { "value": "wrapper--wide", "label": "Wide" },
        { "value": "wrapper--narrow", "label": "Narrow" },
        { "value": "wrapper--custom", "label": "Custom (max-width: 1232px)" }
      ]
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Bottom",
      "default": 60
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F9F9F9"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "Color scheme"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Terms & Conditions (Hereinafter \"T&C\")"
        },
        {
          "type": "select",
          "id": "heading_font_size",
          "label": "Heading size",
          "default": "heading-large",
          "options": [
            { "value": "heading-mini", "label": "Mini" },
            { "value": "heading-x-small", "label": "Extra small" },
            { "value": "heading-small", "label": "Small" },
            { "value": "heading-medium", "label": "Medium" },
            { "value": "heading-large", "label": "Large" },
            { "value": "heading-x-large", "label": "Extra large" }
          ]
        },
        {
          "type": "select",
          "id": "heading_tag",
          "label": "Heading SEO tag",
          "default": "automatic",
          "options": [
            { "value": "automatic", "label": "Automatic" },
            { "value": "h1", "label": "H1" },
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" },
            { "value": "h4", "label": "H4" },
            { "value": "h5", "label": "H5" },
            { "value": "h6", "label": "H6" }
          ]
        }
      ]
    },
    {
      "type": "description",
      "name": "Description",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Roberto Coin Prestige Service is an exclusive and complimentary program dedicated to its clients who purchase the brand creations from December 22, 2025 in the official boutiques in Rome and Venice, in addition to the statutory warranty.</p>"
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "min": 0,
          "max": 60,
          "step": 2,
          "unit": "px",
          "label": "Margin bottom",
          "default": 24
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Heading & text blocks",
      "category": "Text",
      "blocks": [
        {
          "type": "heading",
          "settings": {
            "title": "Terms & Conditions (Hereinafter \"T&C\")",
            "heading_font_size": "heading-large"
          }
        },
        {
          "type": "description",
          "settings": {
            "text": "<p>Roberto Coin Prestige Service is an exclusive and complimentary program dedicated to its clients who purchase the brand creations from December 22, 2025 in the official boutiques in Rome and Venice, in addition to the statutory warranty.</p>",
            "margin_bottom": 24
          }
        },
        {
          "type": "description",
          "settings": {
            "text": "<p>Prestige Service is a complimentary, voluntary, and discretionary program offered by Roberto Coin to enhance the clients experience, ensuring a secure purchasing experience fully aligned with the standards of the brand. Prestige Service may be activated for any Roberto Coin Creation with a retail price between €1,000.00 and €100,000.00 (VAT included), purchased exclusively at the official boutiques in Rome and Venice.</p>",
            "margin_bottom": 24
          }
        },
        {
          "type": "description",
          "settings": {
            "text": "<p>Roberto Coin relies on the digital platform available at <a href=\"#\">this link</a> for the management of Prestige Service. The platform has been developed by the technology partner AION Cover S.r.I., which collaborates with the brand for the purpose of enabling access to the service.</p>",
            "margin_bottom": 0
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "aside", "footer"]
  }
}
{% endschema %}
