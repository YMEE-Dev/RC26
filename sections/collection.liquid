<!-- /sections/collections.liquid -->

{{ 'custom-collection.css' | asset_url | stylesheet_tag }}
{{ 'collection-floating-bar.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign enable_infinity_scroll = settings.enable_infinity_scroll
  assign enable_sort = section.settings.enable_sort
  assign enable_filters = section.settings.enable_filters
  assign filter_layout = section.settings.filter_layout
  assign show_recently_viewed_indicator = settings.show_recently_viewed_indicator
  assign color_scheme = 'color-' | append: section.settings.color_scheme
  assign sub_collections = linklists[collection.handle].links
  assign sub_collection_links_limit = 6
  assign has_active_subcollection_link = false

  if collection.handle contains '-'
    assign possible_parent_handle = collection.handle | split: '-' | first
    assign possible_parent_collection = collections[possible_parent_handle]

    if possible_parent_collection != blank
      assign has_active_subcollection_link = true
    endif
  endif

  if filter_layout == 'inline-open'
    assign filters_expanded = true
  endif
  comment
    The product limit decrement will be removed once we add more block types
  endcomment

  assign product_limit = section.settings.products_per_page
  assign blocks_featured_image = section.blocks | where: 'type', 'featured_image'
  assign collection_template_suffix = collection.template_suffix | default: template.suffix | downcase | strip
  assign is_spotlight_collection_template = false
  assign is_media_only_collection_template = false
  assign should_use_spotlight_images = false
  assign spotlight_images = collection.metafields.custom.spotlight_collection_images.value
  assign spotlight_menu_color = collection.metafields.custom.spotlight_collection_menu_color.value
  assign spotlight_images_position = 'left'

  if collection_template_suffix == 'spotlight'
    assign is_spotlight_collection_template = true
  endif

  if collection_template_suffix == 'media-only'
    assign is_media_only_collection_template = true
  endif

  assign spotlight_images_position = collection.metafields.custom.spotlight_collection_images_position.value | default: 'left' | downcase | strip

  assign spotlight_column_offset = 1
  if spotlight_images_position == 'center'
    assign spotlight_column_offset = 2
  endif
  if spotlight_images_position == 'right'
    assign spotlight_column_offset = 3
  endif

  if is_spotlight_collection_template and spotlight_images != blank
    assign should_use_spotlight_images = true
  endif

  assign spotlight_images_count = 0
  if should_use_spotlight_images
    assign spotlight_images_count = spotlight_images.count | default: spotlight_images.size
  endif

  assign columns_desktop = section.settings.grid | plus: 0
  assign columns_medium = 3
  assign columns_small = 2
  assign columns_mobile = section.settings.grid_mobile | plus: 0

  if columns_desktop == 2 or columns_desktop == 4
    assign columns_medium = 2
  endif

  if is_spotlight_collection_template
    assign columns_desktop = 3
    assign columns_medium = 3
  endif

  assign animation_anchor = '.collection-' | append: collection.handle
  assign animation_duration = 800

  assign items_container_tag = 'div'
  if enable_infinity_scroll
    assign items_container_tag = 'ajaxinate-items'
  endif
-%}
{%- capture image_sizes -%}
  {%- if filter_layout == 'inline-open' and enable_filters -%}
    {%- if settings.grid_style == 'compact' -%}
      (min-width: 990px) calc((100vw - 288px) / {{ columns_desktop }}), (min-width: 750px) calc((100vw - 258px) / {{ columns_medium }}), (min-width: 480px) calc(100vw / {{ columns_small }}), calc(100vw / {{ columns_mobile }})
    {%- else -%}
      (min-width: 990px) calc((100vw - 288px - 100px) / {{ columns_desktop }} - 32px), (min-width: 750px) calc((100vw - 258px - 64px) / {{ columns_medium }} - 32px), (min-width: 480px) calc((100vw - 32px) / {{ columns_small }}), calc((100vw - 32px) / {{ columns_mobile }})
    {%- endif -%}
  {%- else-%}
    {%- if settings.grid_style == 'compact' -%}
      (min-width: 990px) calc((100vw) / {{ columns_desktop }}), (min-width: 750px) calc((100vw) / {{ columns_medium }}), (min-width: 480px) calc(100vw / {{ columns_small }}), calc(100vw / {{ columns_mobile }})
    {%- else -%}
      (min-width: 990px) calc((100vw - 100px) / {{ columns_desktop }} - 32px), (min-width: 750px) calc((100vw - 64px) / {{ columns_medium }} - 32px), (min-width: 480px) calc((100vw - 32px) / {{ columns_small }}), calc((100vw - 32px) / {{ columns_mobile }})
    {%- endif -%}
  {%- endif -%}
{%- endcapture -%}

{%- style -%}
  #Collection--{{ section.id }} {
    position: relative;
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
    --COLLECTION-PRODUCTS-BG: var(--bg);

    --COLUMNS: {{ columns_desktop }};
    --COLUMNS-MEDIUM: {{ columns_medium }};
    --COLUMNS-SMALL: {{ columns_small }};
    --COLUMNS-MOBILE: {{ columns_mobile }};

    {% unless section.settings.collection_grid_background == 'rgba(0,0,0,0)' or section.settings.collection_grid_background == blank %}
      --COLLECTION-PRODUCTS-BG: {{ section.settings.collection_grid_background }};
    {% endunless %}

    {% unless border_color == 'rgba(0,0,0,0)' or border_color == blank %}
      --border-hairline: {{ border_color }};
    {% endunless %}
  }

  #Collection--{{ section.id }} .collection__products {
    background: var(--COLLECTION-PRODUCTS-BG);
  }

  {% if is_spotlight_collection_template and spotlight_menu_color != blank %}
    body.template-collection:has(#Collection--{{ section.id }}.collection--spotlight) {
      --spotlight-collection-menu-link: {{ spotlight_menu_color }};
    }
  {% endif %}
{%- endstyle -%}

{%- capture collection_sidebar_class -%}
  {%- if filter_layout == 'slide-out' -%}
    collection__sidebar__slide-out
    {%- else -%}
    collection__sidebar__slider{% if filters_expanded %} expanded drawer--animated no-mobile-animation{% endif %}
  {%- endif -%}
{%- endcapture -%}

{%- paginate collection.products by product_limit -%}
  {%- assign featured_images_array = '' -%}

  {%- if paginate.current_page == 1 -%}
    {%- unless should_use_spotlight_images -%}
      {%- for block in section.blocks -%}
        {%- capture current_featured_image -%}
          {%- liquid
            assign featured_image = block.settings.featured_image
            assign featured_image_position = block.settings.position
            assign featured_image_order = featured_image_position | append: '-' | append: forloop.index

            if featured_image_position < 10
              assign featured_image_order = featured_image_order | prepend: '0'
            endif
          -%}
          {%- render 'collection-featured-image' block: block -%}
        {%- endcapture -%}

        {%- assign featured_images_array = featured_images_array
          | append: featured_image_order
          | append: '#featured_image_position#'
          | append: featured_image_position
          | append: '#featured_image_html#'
          | append: current_featured_image
          | append: '#featured_image#'
          | append: featured_image
          | append: '@@'
        -%}
      {%- endfor -%}
    {%- endunless -%}

    {%- unless should_use_spotlight_images -%}
      {%- assign featured_images_array = featured_images_array | split: '@@' | sort | reject: '' -%}
    {%- endunless -%}
  {%- endif -%}

  <collection-component
    class="collection collection-products collection-{{ collection.handle }} section-padding {{ color_scheme }}{% if is_spotlight_collection_template %} collection--spotlight collection--spotlight-position-{{ spotlight_images_position }}{% endif %}"
    id="Collection--{{ section.id }}"
    data-section-id="{{ section.id }}"
    data-section-type="collection"
    data-sort="{{ enable_sort }}"
    data-collection="{{ collection.url | default: '/collections/all' }}"
  >
    {%- capture sub_collection_links_html -%}
      {%- if sub_collections.size > 0 -%}
        {%- assign sub_collection_links_counter = 0 -%}
        {%- for sublink in sub_collections -%}
          {%- liquid
            if sublink.type != 'collection_link' or sublink.object.handle == blank
              continue
            endif

            assign sub_collection_handle = sublink.object.handle
            assign sub_collection_title = sublink.title
            assign sub_collection_handle_separator = sub_collection_handle | append: ',' | prepend: ','
            assign sub_collection = collections[sub_collection_handle]
            assign is_active_sub_collection_link = false

            if sublink.object.handle contains sub_collection_handle_separator
              continue
            endif

            if sub_collection.handle == collection.handle
              assign is_active_sub_collection_link = true
              assign has_active_subcollection_link = true
            endif
          -%}

          <a
            class="subcollection_links-link navlink{% if is_active_sub_collection_link %} is-active{% endif %}"
            href="{{ sub_collection.url }}"
          >
            {{- sub_collection_title -}}
          </a>

          {%- assign sub_collection_links_counter = sub_collection_links_counter | plus: 1 -%}
          {%- if sub_collection_links_counter >= sub_collection_links_limit -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endcapture -%}

    {%- assign align_classes = '' -%}
    {%- if enable_sort -%}
      {%- assign align_classes = align_classes | append: ' collection__nav--sort ' -%}
    {%- endif -%}

    {%- if enable_filters -%}
      {% assign align_classes = align_classes | append: ' collection__nav--filter ' %}
    {%- endif -%}

    {%- if enable_sort or enable_filters -%}
      <nav
        class="collection__nav {{ align_classes }}{% if is_media_only_collection_template %} collection__nav--media-only{% endif %}"
        data-collection-nav
        data-has-active-subcollection-link="{{ has_active_subcollection_link }}"
      >
        <div class="availability_filter-wrapper" data-availability-filter>
          <a
            href="{{ collection.url | split: '-' | first }}"
            type="button"
            class="availability-filter__button navlink"
            data-availability-view-all
            data-availability-view-all-default-active="false"
            aria-pressed="false"
          >
            <span class="availability-filter__label availability-filter__label--count">
              {{ collection.products_count }} Pieces
            </span>
            <span class="availability-filter__label availability-filter__label--view-all"> View all </span>
          </a>
        </div>
        {%- if sub_collection_links_html != blank -%}
          <div class="subcollection_links-wrapper">
            {{- sub_collection_links_html -}}
          </div>
        {%- endif -%}
        <div class="popout_filters-wrapper">
          <label class="availability-filter__button navlink" data-availability-filter-control>
            <input
              type="checkbox"
              class="availability-filter__checkbox"
              data-availability-filter-checkbox
              aria-label="In Stock"
            >
            <span>In Stock</span>
          </label>
          {%- if enable_filters -%}
            {%- liquid
              assign filter_active_count = 0

              if enable_filters
                for filter in collection.filters
                  assign filter_active_count = filter_active_count | plus: filter.active_values.size
                endfor
              endif
            -%}
            <div class="popout--group">
              <button
                type="button"
                class="popout__toggle{% unless filter_layout == 'slide-out' %} popout__toggle--filters{% endunless %}"
                aria-expanded="{% if filters_expanded %}true{% else %}false{% endif %}"
                aria-controls="filter-groups"
                data-aria-toggle
              >
                {%- render 'icon-filter' -%}

                {%- if filter_layout == 'slide-out' -%}
                  {{ 'collections.general.filters' | t }}
                {%- else -%}
                  <span class="popout__toggleable-text">
                    <span class="popout__expanded-show">
                      {{- 'collections.general.show_filters' | t -}}
                      <span class="filter-count{% if filter_active_count < 1 %} hidden{% endif %}" data-active-filters>
                        {{- filter_active_count -}}
                      </span>
                    </span>

                    <span class="popout__expanded-hide">
                      {{- 'collections.general.hide_filters' | t -}}
                      <span class="filter-count{% if filter_active_count < 1 %} hidden{% endif %}" data-active-filters>
                        {{- filter_active_count -}}
                      </span>
                    </span>
                  </span>
                {%- endif -%}

                {%- unless filter_layout == 'slide-out' -%}
                  {%- render 'icon-nav-arrow-down' -%}
                {%- endunless -%}
              </button>
            </div>
          {%- endif -%}

          {%- if enable_sort -%}
            {% render 'collection-sorting' %}
          {%- endif -%}
        </div>
      </nav>
    {%- endif -%}

    {%- render 'collection-floating-bar' -%}

    <div class="collection__products">
      {%- if enable_filters -%}
        <div class="{{ collection_sidebar_class }}" id="filter-groups" data-collection-sidebar>
          <div class="collection__sidebar__head{% unless filter_layout == 'slide-out' %} mobile{% endunless %}">
            {% comment %}
              <h3>
                {{- 'collections.general.filters' | t -}}

                <span
                  class="filter-count{% if filter_active_count < 1 %} hidden{% endif %}"
                  data-active-filters
                >
                  {{- filter_active_count -}}
                </span>
              </h3>
            {% endcomment %}

            <a
              href="#filters-group"
              class="collection__sidebar__close"
              data-collection-sidebar-close
              aria-label="{{ 'collections.general.hide_filters' | t }}"
            >
              {%- render 'icon-close' -%}
            </a>
          </div>

          {%- render 'collection-filters-sidebar', section: section -%}
        </div>

        <div
          class="underlay{% unless filter_layout == 'slide-out' %} mobile{% endunless %}"
          data-collection-sidebar-close
        ></div>
      {%- elsif enable_sort -%}
        <collection-filters-form>
          <form
            data-collection-filters-form
            class="collection__filters hidden"
            id="{{ section.id }}-form-filter"
          ></form>
        </collection-filters-form>
      {%- endif -%}

      <div class="grid-outer" data-products-grid>
        <{{ items_container_tag }}
          class="grid"
          {% if enable_infinity_scroll %}
            id="AjaxinateLoop" data-ajaxinate-id="{{ section.id }}"
          {% endif %}
        >
          {%- if collection.products_count > 0 -%}
            {%- if should_use_spotlight_images -%}
              {%- liquid
                assign counter_grid = 1
                assign spotlight_image_index = 0

                for product in collection.products
                  if spotlight_image_index < spotlight_images_count
                    assign spotlight_image_position = spotlight_image_index | times: 3 | plus: spotlight_column_offset

                    if spotlight_image_position <= counter_grid
                      assign spotlight_render_index = spotlight_image_index | plus: 1
                      for spotlight_image in spotlight_images limit: 1 offset: spotlight_image_index
                        render 'collection-spotlight-image', media: spotlight_image, index: spotlight_render_index, stack_index: counter_grid, image_sizes: image_sizes
                      endfor
                      assign spotlight_image_index = spotlight_image_index | plus: 1
                      assign counter_grid = counter_grid | plus: 1
                    endif
                  endif

                  assign product_storytelling = false
                  unless is_spotlight_collection_template
                    assign product_type = product.type | downcase
                    if product_type == 'storytelling' or product_type contains 'storytelling'
                      assign product_storytelling = true
                    endif
                  endunless

                  if product_storytelling
                    render 'product-tile-storytelling', product: product, index: forloop.index, is_highlight: false, is_spotlight: false
                  else
                    capture spotlight_product_attributes
                      echo 'style="--spotlight-stack-index: ' | append: counter_grid | append: ';"'
                    endcapture
                    render 'product-grid-item', product: product, index: forloop.index, sizes: image_sizes, attributes: spotlight_product_attributes
                  endif

                  assign counter_grid = counter_grid | plus: 1
                endfor
              -%}
            {%- elsif featured_images_array.size > 0 -%}
              {%- liquid
                assign counter_grid = 1
                assign counter_delay = 0
                assign added_images_index = ''
                assign items_on_row_remaining = columns_desktop

                for product in collection.products
                  for featured_image in featured_images_array
                    if featured_image == ''
                      continue
                    endif

                    assign featured_image_index = forloop.index
                    assign featured_image_position = featured_image | split: '#featured_image_position#' | last | split: '#featured_image_html#' | first | times: 1
                    assign featured_image_markup = featured_image | split: '#featured_image_html#' | last | split: '#featured_image#' | first
                    assign featured_image_index_tag = '@' | append: featured_image_index | append: '@'

                    if featured_image_position <= counter_grid
                      unless added_images_index contains featured_image_index_tag
                        assign counter_grid = counter_grid | plus: 1
                        assign added_images_index = added_images_index | append: '@' | append: featured_image_index | append: '@#'

                        echo featured_image_markup
                      endunless
                    endif
                  endfor

                  assign counter_delay = counter_delay | plus: 1
                  assign counter_grid = counter_grid | plus: 1
                  assign items_on_row_remaining = items_on_row_remaining | minus: 1

                  assign product_storytelling = false
                  unless is_spotlight_collection_template
                    assign product_type = product.type | downcase
                    if product_type == 'storytelling' or product_type contains 'storytelling'
                      assign product_storytelling = true
                    endif
                  endunless

                  if product_storytelling
                    render 'product-tile-storytelling', product: product, index: forloop.index, is_highlight: false, is_spotlight: false
                  else
                    render 'product-grid-item', product: product, index: forloop.index, sizes: image_sizes
                  endif
                endfor
              -%}

            {%- else -%}
              {%- liquid
                for product in collection.products
                  assign grid_int = section.settings.grid | times: 1
                  assign animation_delay = forloop.index0 | modulo: grid_int | times: 1

                  assign product_storytelling = false
                  unless is_spotlight_collection_template
                    assign product_type = product.type | downcase
                    if product_type == 'storytelling' or product_type contains 'storytelling'
                      assign product_storytelling = true
                    endif
                  endunless

                  if product_storytelling
                    render 'product-tile-storytelling', product: product, index: forloop.index, is_highlight: false, is_spotlight: false
                  else
                    render 'product-grid-item', product: product, animation_delay: animation_delay, index: forloop.index, sizes: image_sizes
                  endif
                endfor
              -%}
            {%- endif -%}
          {%- else -%}
            <div class="no-results">
              <p>
                <strong>{{ 'collections.general.no_matches' | t }}</strong>
              </p>
              {%- assign sort_by_string = '' -%}
              {%- if collection.sort_by != blank -%}
                {%- assign sort_by_string = '?sort_by=' | append: collection.sort_by -%}
              {%- endif -%}
              <a
                class="btn caps btn--primary btn--solid"
                href="{{ collection.url | append: sort_by_string }}"
                data-filter-update-url
                ><span>{{ 'collections.general.reset' | t }}</span></a
              >
            </div>
          {%- endif -%}
        </{{ items_container_tag }}>

        {%- if enable_infinity_scroll -%}
          <div
            class="pagination pagination--infinite"
            id="AjaxinatePagination"
            data-ajaxinate-id="{{ section.id }}"
          >
            {%- if paginate.next -%}
              <div class="pagination__loading">
                <span class="btn__loader">
                  <svg height="18" width="18" class="svg-loader">
                    <circle r="7" cx="9" cy="9" />
                    <circle stroke-dasharray="87.96459430051421 87.96459430051421" r="7" cx="9" cy="9" />
                  </svg>
                </span>
                <a href="{{ paginate.next.url }}">
                  <span class="visually-hidden">{{ 'general.pagination.next' | t }}</span>
                </a>
              </div>
            {%- endif -%}
          </div>
        {%- else -%}
          {%- if paginate.pages > 1 -%}
            {%- render 'pagination', paginate: paginate -%}
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>
  </collection-component>

  <script>
    (() => {
      if (window.__collectionAvailabilityFilterInit) {
        return;
      }
      window.__collectionAvailabilityFilterInit = true;

      const updateCollectionNavStickyState = (root = document) => {
        root.querySelectorAll('[data-collection-nav]').forEach((nav) => {
          const stickyTop = Number.parseFloat(window.getComputedStyle(nav).top) || 0;
          const navTop = nav.getBoundingClientRect().top;
          const isStuck = window.scrollY > 0 && navTop <= stickyTop + 1;
          nav.classList.toggle('is-stuck', isStuck);
        });
      };

      const getActiveAvailabilityFilter = (component) => {
        if (!component) return 'all';

        const availabilityCheckbox = component.querySelector('[data-availability-filter-checkbox]');
        if (!availabilityCheckbox) return 'all';

        return availabilityCheckbox.checked ? 'available' : 'all';
      };

      const filterItems = (component, filterValue) => {
        if (!component) return;

        const activeFilter = filterValue === 'available' ? 'available' : 'all';
        const items = component.querySelectorAll('[data-products-grid] [data-product-available]');
        items.forEach((item) => {
          const isAvailable = item.getAttribute('data-product-available') === 'true';
          const showItem = activeFilter === 'all' || isAvailable;

          item.hidden = !showItem;
          item.setAttribute('aria-hidden', showItem ? 'false' : 'true');
        });

        const availabilityControl = component.querySelector('[data-availability-filter-control]');
        const availabilityCheckbox = component.querySelector('[data-availability-filter-checkbox]');
        const viewAllButton = component.querySelector('[data-availability-view-all]');
        const isActive = activeFilter === 'available';
        const viewAllDefaultActive = viewAllButton
          ? viewAllButton.getAttribute('data-availability-view-all-default-active') === 'true'
          : false;
        const isViewAllActive = activeFilter === 'all' && viewAllDefaultActive;

        if (availabilityControl) {
          availabilityControl.classList.toggle('is-active', isActive);
        }

        if (availabilityCheckbox) {
          availabilityCheckbox.checked = isActive;
        }

        if (viewAllButton) {
          viewAllButton.classList.toggle('is-active', isViewAllActive);
          viewAllButton.setAttribute('aria-pressed', isViewAllActive ? 'true' : 'false');
        }
      };

      const initComponent = (component) => {
        if (!component || component.dataset.availabilityFilterReady === 'true') {
          return;
        }

        component.dataset.availabilityFilterReady = 'true';
        filterItems(component, getActiveAvailabilityFilter(component));
        updateCollectionNavStickyState(component);

        const productsGrid = component.querySelector('[data-products-grid]');
        if (!productsGrid) return;

        const observer = new MutationObserver(() => {
          filterItems(component, getActiveAvailabilityFilter(component));
        });

        observer.observe(productsGrid, {childList: true, subtree: true});
      };

      const initAll = (root) => {
        const scope = root || document;
        scope.querySelectorAll('collection-component').forEach((component) => {
          initComponent(component);
        });

        updateCollectionNavStickyState(scope);
      };

      document.addEventListener('change', (event) => {
        const checkbox = event.target.closest('[data-availability-filter-checkbox]');
        if (!checkbox) return;

        const component = checkbox.closest('collection-component');
        if (!component) return;

        filterItems(component, checkbox.checked ? 'available' : 'all');
      });

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          initAll(document);
        });
      } else {
        initAll(document);
      }

      document.addEventListener('theme:scroll', () => {
        updateCollectionNavStickyState(document);
      });

      document.addEventListener('theme:resize', () => {
        updateCollectionNavStickyState(document);
      });

      document.addEventListener('shopify:section:load', (event) => {
        initAll(event.target);
        requestAnimationFrame(() => {
          updateCollectionNavStickyState(event.target);
        });
      });
    })();
  </script>

  {%- if enable_sort or enable_filters -%}
    <script src="{{ 'collection.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'collection-filters-form.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  <script src="{{ 'collection-floating-bar.js' | asset_url }}" defer="defer"></script>

  {%- if settings.quickview_enable -%}
    <script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- if enable_infinity_scroll -%}
    <script src="{{ 'ajaxinate.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- if show_recently_viewed_indicator -%}
    <script src="{{ 'grid-item.js' | asset_url }}" defer></script>
  {%- endif -%}
{%- endpaginate -%}

{% schema %}
{
  "name": "Collection products",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_sort",
      "label": "Show sorting",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_filters",
      "label": "Enable filters",
      "default": true
    },
    {
      "type": "select",
      "id": "filter_layout",
      "label": "Filter layout",
      "default": "inline-open",
      "options": [
        {"label": "Slide out", "value": "slide-out"},
        {"label": "Inline (closed)", "value": "inline-closed"},
        {"label": "Inline (open)", "value": "inline-open"}
      ]
    },
    {
      "type": "checkbox",
      "id": "default_open",
      "label": "Open filter accordions by default",
      "default": true
    },
    {
      "type": "link_list",
      "id": "collection_linklist",
