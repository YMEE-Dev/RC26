<!-- /sections/collections.liquid -->

{{ 'custom-collection.css' | asset_url | stylesheet_tag }}
{{ 'collection-floating-bar.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign enable_infinity_scroll = settings.enable_infinity_scroll
  assign enable_sort = section.settings.enable_sort
  assign enable_filters = section.settings.enable_filters
  assign filter_layout = section.settings.filter_layout
  assign show_recently_viewed_indicator = settings.show_recently_viewed_indicator
  assign color_scheme = 'color-' | append: section.settings.color_scheme
  assign sub_collections = linklists[collection.handle].links
  assign sub_collection_links_limit = 6
  assign has_active_subcollection_link = false
  assign parent_collection_url = collection.url

  assign collection_handle = collection.handle | default: ''
  if collection_handle == blank and collection.url != blank
    assign collection_handle = collection.url | split: '/collections/' | last | split: '?' | first | split: '/' | first
  endif

  if collection_handle != blank
    assign parent_collection_handle = collection_handle | split: '-' | first
    assign parent_collection_obj = collections[parent_collection_handle]

    if parent_collection_obj != blank and parent_collection_obj.handle != collection.handle
      assign parent_collection_url = parent_collection_obj.url
      assign has_active_subcollection_link = true
    endif
  endif

  if filter_layout == 'inline-open'
    assign filters_expanded = true
  endif
  comment
    The product limit decrement will be removed once we add more block types
  endcomment

  assign product_limit = section.settings.products_per_page
  assign blocks_featured_image = section.blocks | where: 'type', 'featured_image'
  assign collection_template_suffix = collection.template_suffix | default: template.suffix | downcase | strip
  assign is_spotlight_collection_template = false
  assign is_media_only_collection_template = false
  assign should_use_light_product_backgrounds = false
  assign should_use_spotlight_images = false
  assign spotlight_images = collection.metafields.custom.spotlight_collection_images.value
  assign spotlight_menu_color = collection.metafields.custom.spotlight_collection_menu_color.value
  assign spotlight_images_position = 'left'

  if collection_template_suffix == 'spotlight'
    assign is_spotlight_collection_template = true
  endif

  if collection_template_suffix == 'media-only' or collection_template_suffix == 'naked'
    assign is_media_only_collection_template = true
  endif

  unless is_spotlight_collection_template
    assign should_use_light_product_backgrounds = true
  endunless

  assign spotlight_images_position = collection.metafields.custom.spotlight_collection_images_position.value | default: 'left' | downcase | strip

  assign spotlight_column_offset = 1
  if spotlight_images_position == 'center'
    assign spotlight_column_offset = 2
  endif
  if spotlight_images_position == 'right'
    assign spotlight_column_offset = 3
  endif

  if is_spotlight_collection_template and spotlight_images != blank
    assign should_use_spotlight_images = true
  endif

  assign spotlight_images_count = 0
  if should_use_spotlight_images
    assign spotlight_images_count = spotlight_images.count | default: spotlight_images.size
  endif

  assign columns_desktop = section.settings.grid | plus: 0
  assign columns_medium = 3
  assign columns_small = 2
  assign columns_mobile = section.settings.grid_mobile | plus: 0

  if columns_desktop == 2 or columns_desktop == 4
    assign columns_medium = 2
  endif

  if is_spotlight_collection_template
    assign columns_desktop = 3
    assign columns_medium = 3
  endif

  assign animation_anchor = '.collection-' | append: collection.handle
  assign animation_duration = 800

  assign items_container_tag = 'div'
  if enable_infinity_scroll
    assign items_container_tag = 'ajaxinate-items'
  endif
-%}
{%- capture image_sizes -%}
  {%- if filter_layout == 'inline-open' and enable_filters -%}
    {%- if settings.grid_style == 'compact' -%}
      (min-width: 990px) calc((100vw - 288px) / {{ columns_desktop }}), (min-width: 750px) calc((100vw - 258px) / {{ columns_medium }}), (min-width: 480px) calc(100vw / {{ columns_small }}), calc(100vw / {{ columns_mobile }})
    {%- else -%}
      (min-width: 990px) calc((100vw - 288px - 100px) / {{ columns_desktop }} - 32px), (min-width: 750px) calc((100vw - 258px - 64px) / {{ columns_medium }} - 32px), (min-width: 480px) calc((100vw - 32px) / {{ columns_small }}), calc((100vw - 32px) / {{ columns_mobile }})
    {%- endif -%}
  {%- else-%}
    {%- if settings.grid_style == 'compact' -%}
      (min-width: 990px) calc((100vw) / {{ columns_desktop }}), (min-width: 750px) calc((100vw) / {{ columns_medium }}), (min-width: 480px) calc(100vw / {{ columns_small }}), calc(100vw / {{ columns_mobile }})
    {%- else -%}
      (min-width: 990px) calc((100vw - 100px) / {{ columns_desktop }} - 32px), (min-width: 750px) calc((100vw - 64px) / {{ columns_medium }} - 32px), (min-width: 480px) calc((100vw - 32px) / {{ columns_small }}), calc((100vw - 32px) / {{ columns_mobile }})
    {%- endif -%}
  {%- endif -%}
{%- endcapture -%}

{%- style -%}
  body:has(.main-content--collection-super-naked) #Collection--{{ section.id }} .collection__products {
    padding-top: calc(({{ section.settings.padding_top }}px / 2) + var(--header-height));
  }

  @media screen and (max-width: 749px) {
     body:has(.main-content--collection-super-naked) #Collection--{{ section.id }} .collection__products {
      padding-top: var(--header-height);
    }
  }
  #Collection--{{ section.id }} {
    position: relative;
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
    --COLLECTION-PRODUCTS-BG: var(--bg);

    --COLUMNS: {{ columns_desktop }};
    --COLUMNS-MEDIUM: {{ columns_medium }};
    --COLUMNS-SMALL: {{ columns_small }};
    --COLUMNS-MOBILE: {{ columns_mobile }};

    {% unless section.settings.collection_grid_background == 'rgba(0,0,0,0)' or section.settings.collection_grid_background == blank %}
      --COLLECTION-PRODUCTS-BG: {{ section.settings.collection_grid_background }};
    {% endunless %}

    {% unless border_color == 'rgba(0,0,0,0)' or border_color == blank %}
      --border-hairline: {{ border_color }};
    {% endunless %}
  }

  #Collection--{{ section.id }} .collection__products {
    background: var(--COLLECTION-PRODUCTS-BG);
  }

  {% if is_spotlight_collection_template %}
    body.template-collection:has(#Collection--{{ section.id }}.collection--spotlight) .theme__header__scroll-blur {
      display: none;
      opacity: 0;
      --header-scroll-reveal-blur: 0px;
      -webkit-backdrop-filter: blur(0);
      backdrop-filter: blur(0);
    }
  {% endif %}

  {% if is_spotlight_collection_template and spotlight_menu_color != blank %}
    body.template-collection:has(#Collection--{{ section.id }}.collection--spotlight) {
      --spotlight-collection-menu-link: {{ spotlight_menu_color }};
    }
  {% endif %}
{%- endstyle -%}

{%- capture collection_sidebar_class -%}
  {%- if filter_layout == 'slide-out' -%}
    collection__sidebar__slide-out
    {%- else -%}
    collection__sidebar__slider{% if filters_expanded %} expanded drawer--animated no-mobile-animation{% endif %}
  {%- endif -%}
{%- endcapture -%}

{%- paginate collection.products by product_limit -%}
  {%- assign featured_images_array = '' -%}
  {%- assign has_available_products = false -%}
  {%- assign availability_filter_param_name = '' -%}
  {%- assign availability_filter_true_value = '' -%}
  {%- assign availability_filter_active = false -%}
  {%- capture collection_products_count_markup -%}
    {% render 'collection-products-count', collection_obj: collection, products_per_page: product_limit %}
  {%- endcapture -%}
  {%- assign collection_products_count = collection_products_count_markup | strip | plus: 0 -%}

  {%- if paginate.current_page == 1 -%}
    {%- unless should_use_spotlight_images -%}
      {%- for block in section.blocks -%}
        {%- capture current_featured_image -%}
          {%- liquid
            assign featured_image = block.settings.featured_image
            assign featured_image_position = block.settings.position
            assign featured_image_order = featured_image_position | append: '-' | append: forloop.index

            if featured_image_position < 10
              assign featured_image_order = featured_image_order | prepend: '0'
            endif
          -%}
          {%- render 'collection-featured-image' block: block -%}
        {%- endcapture -%}

        {%- assign featured_images_array = featured_images_array
          | append: featured_image_order
          | append: '#featured_image_position#'
          | append: featured_image_position
          | append: '#featured_image_html#'
          | append: current_featured_image
          | append: '#featured_image#'
          | append: featured_image
          | append: '@@'
        -%}
      {%- endfor -%}
    {%- endunless -%}

    {%- unless should_use_spotlight_images -%}
      {%- assign featured_images_array = featured_images_array | split: '@@' | sort | reject: '' -%}
    {%- endunless -%}
  {%- endif -%}

  {%- for product in collection.products -%}
    {%- liquid
      assign product_storytelling = false

      unless is_spotlight_collection_template
        assign product_type = product.type | downcase
        if product_type == 'storytelling' or product_type contains 'storytelling'
          assign product_storytelling = true
        endif
      endunless
    -%}

    {%- if product_storytelling == false -%}
      {%- if product.available -%}
        {%- assign has_available_products = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}

  {%- for filter in collection.filters -%}
    {%- if filter.type == 'boolean' -%}
      {%- if filter.param_name contains 'availability' -%}
        {%- if filter.true_value != blank -%}
          {%- assign availability_filter_param_name = filter.param_name -%}
          {%- assign availability_filter_true_value = filter.true_value.value -%}

          {%- if filter.true_value.active -%}
            {%- assign availability_filter_active = true -%}
          {%- endif -%}

          {%- if filter.true_value.count > 0 -%}
            {%- assign has_available_products = true -%}
          {%- endif -%}
        {%- endif -%}

        {%- break -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}

  <collection-component
    class="collection collection-products collection-{{ collection.handle }} section-padding {{ color_scheme }}{% if is_spotlight_collection_template %} collection--spotlight collection--spotlight-position-{{ spotlight_images_position }}{% endif %}"
    id="Collection--{{ section.id }}"
    data-section-id="{{ section.id }}"
    data-section-type="collection"
    data-sort="{{ enable_sort }}"
    data-collection="{{ collection.url | default: '/collections/all' }}"
  >
    {%- capture sub_collection_links_html -%}
      {%- if sub_collections.size > 0 -%}
        {%- assign sub_collection_links_counter = 0 -%}
        {%- for sublink in sub_collections -%}
          {%- liquid
            if sublink.type != 'collection_link' or sublink.object.handle == blank
              continue
            endif

            assign sub_collection_handle = sublink.object.handle
            assign sub_collection_title = sublink.title
            assign sub_collection_handle_separator = sub_collection_handle | append: ',' | prepend: ','
            assign sub_collection = collections[sub_collection_handle]
            assign is_active_sub_collection_link = false

            if sublink.object.handle contains sub_collection_handle_separator
              continue
            endif

            if sub_collection.handle == collection.handle
              assign is_active_sub_collection_link = true
              assign has_active_subcollection_link = true
            endif
          -%}

          <a
            class="subcollection_links-link navlink{% if is_active_sub_collection_link %} is-active{% endif %}"
            href="{{ sub_collection.url }}"
          >
            {{- sub_collection_title -}}
          </a>

          {%- assign sub_collection_links_counter = sub_collection_links_counter | plus: 1 -%}
          {%- if sub_collection_links_counter >= sub_collection_links_limit -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endcapture -%}

    {%- assign align_classes = '' -%}
    {%- if enable_sort -%}
      {%- assign align_classes = align_classes | append: ' collection__nav--sort ' -%}
    {%- endif -%}

    {%- if enable_filters -%}
      {% assign align_classes = align_classes | append: ' collection__nav--filter ' %}
    {%- endif -%}

    {%- if enable_sort or enable_filters -%}
      <nav
        class="collection__nav {{ align_classes }}{% if is_media_only_collection_template %} collection__nav--media-only{% endif %} {%  unless has_available_products %} has-no-available-products{% endunless %}"
        data-collection-nav
        data-has-active-subcollection-link="{{ has_active_subcollection_link }}"
      >
        <div class="availability_filter-wrapper" data-availability-filter>
          <a
            href="{{ parent_collection_url }}"
            type="button"
            class="availability-filter__button navlink{% unless availability_filter_active %} is-active{% endunless %}"
            data-availability-view-all
            data-availability-view-all-default-active="{% unless availability_filter_active %}true{% else %}false{% endunless %}"
            aria-pressed="{% unless availability_filter_active %}true{% else %}false{% endunless %}"
          >
            <span
              class="availability-filter__label availability-filter__label--count"
              data-availability-products-count
              data-availability-products-label="{{ 'collections.general.pieces' | t }}"
            >
              {{ collection_products_count }}
              {{ 'collections.general.pieces' | t }}
            </span>
            <span class="availability-filter__label availability-filter__label--view-all">
              {{- 'collections.general.view_all' | t -}}
            </span>
          </a>
        </div>
        {%- if sub_collection_links_html != blank -%}
          <div class="subcollection_links-wrapper">
            {{- sub_collection_links_html -}}
          </div>
        {%- endif -%}
        <div class="popout_filters-wrapper">
          {%- if has_available_products -%}
            <label
              class="availability-filter__button navlink{% if availability_filter_active %} is-active{% endif %}"
              data-availability-filter-control
            >
              <input
                type="checkbox"
                class="availability-filter__checkbox"
                data-availability-filter-checkbox
                data-availability-filter-param-name="{{ availability_filter_param_name }}"
                data-availability-filter-value="{{ availability_filter_true_value }}"
                aria-label="{{ 'collections.general.in_stock' | t }}"
                {% if availability_filter_active %}
                  checked
                {% endif %}
              >
              <span>{{ 'collections.general.in_stock' | t }}</span>
            </label>
          {%- endif -%}
          {%- if enable_filters -%}
            {%- liquid
              assign filter_active_count = 0

              if enable_filters
                for filter in collection.filters
                  assign filter_active_count = filter_active_count | plus: filter.active_values.size
                endfor
              endif
            -%}
            <div class="popout--group">
              <button
                type="button"
                class="popout__toggle{% unless filter_layout == 'slide-out' %} popout__toggle--filters{% endunless %}"
                aria-expanded="{% if filters_expanded %}true{% else %}false{% endif %}"
                aria-controls="filter-groups"
                data-aria-toggle
              >
                {%- render 'icon-filter' -%}

                {%- if filter_layout == 'slide-out' -%}
                  {{ 'collections.general.filters' | t }}
                {%- else -%}
                  <span class="popout__toggleable-text">
                    <span class="popout__expanded-show">
                      {{- 'collections.general.show_filters' | t -}}
                      <span class="filter-count{% if filter_active_count < 1 %} hidden{% endif %}" data-active-filters>
                        {{- filter_active_count -}}
                      </span>
                    </span>

                    <span class="popout__expanded-hide">
                      {{- 'collections.general.hide_filters' | t -}}
                      <span class="filter-count{% if filter_active_count < 1 %} hidden{% endif %}" data-active-filters>
                        {{- filter_active_count -}}
                      </span>
                    </span>
                  </span>
                {%- endif -%}

                {%- unless filter_layout == 'slide-out' -%}
                  {%- render 'icon-nav-arrow-down' -%}
                {%- endunless -%}
              </button>
            </div>
          {%- endif -%}

          {%- if enable_sort -%}
            {% render 'collection-sorting' %}
          {%- endif -%}
        </div>
      </nav>
    {%- endif -%}

    {%- render 'collection-floating-bar' -%}

    <div class="collection__products">
      {%- if enable_filters -%}
        <div class="{{ collection_sidebar_class }}" id="filter-groups" data-collection-sidebar>
          <div class="collection__sidebar__head{% unless filter_layout == 'slide-out' %} mobile{% endunless %}">
            {% comment %}
              <h3>
                {{- 'collections.general.filters' | t -}}

                <span
                  class="filter-count{% if filter_active_count < 1 %} hidden{% endif %}"
                  data-active-filters
                >
                  {{- filter_active_count -}}
                </span>
              </h3>
            {% endcomment %}

            <a
              href="#filters-group"
              class="collection__sidebar__close"
              data-collection-sidebar-close
              aria-label="{{ 'collections.general.hide_filters' | t }}"
            >
              {%- render 'icon-close' -%}
            </a>
          </div>

          {%- render 'collection-filters-sidebar', section: section -%}
        </div>

        <div
          class="underlay{% unless filter_layout == 'slide-out' %} mobile{% endunless %}"
          data-collection-sidebar-close
        ></div>
      {%- elsif enable_sort -%}
        <collection-filters-form>
          <form
            data-collection-filters-form
            class="collection__filters hidden"
            id="{{ section.id }}-form-filter"
          ></form>
        </collection-filters-form>
      {%- endif -%}

      <div class="grid-outer" data-products-grid>
        <div
          hidden
          data-collection-counts
          data-collection-products-count="{{ collection_products_count }}"
          data-availability-filter-active="{% if availability_filter_active %}true{% else %}false{% endif %}"
          data-availability-filter-param-name="{{ availability_filter_param_name }}"
          data-availability-filter-value="{{ availability_filter_true_value }}"
        ></div>
        <{{ items_container_tag }}
          class="grid"
          {% if enable_infinity_scroll %}
            id="AjaxinateLoop" data-ajaxinate-id="{{ section.id }}"
          {% endif %}
        >
          {%- if collection.products_count > 0 -%}
            {% if should_use_light_product_backgrounds %}
              <style>
                grid-item.product-item {
                  mix-blend-mode: initial;
                }
                grid-item.product-item .product-item__bg__featured,
                grid-item.product-item .product-item__bg__featured figure {
                  background-color: #f9f9f9;
                }

                grid-item.product-item .product-item__bg__inner figure img,
                grid-item.product-item .product-item__bg__featured figure img {
                  mix-blend-mode: multiply;
                }

                grid-item.product-item .product-item__bg__slide figure {
                  background-color: #f9f9f9;
                }
                grid-item.product-item .product-item__bg__slide figure img {
                  mix-blend-mode: multiply;
                }
              </style>
            {% endif %}
            {%- if should_use_spotlight_images -%}
              {%- liquid
                assign counter_grid = 1
                assign spotlight_image_index = 0

                for product in collection.products
                  if spotlight_image_index < spotlight_images_count
                    assign spotlight_image_position = spotlight_image_index | times: 3 | plus: spotlight_column_offset

                    if spotlight_image_position <= counter_grid
                      assign spotlight_render_index = spotlight_image_index | plus: 1
                      for spotlight_image in spotlight_images limit: 1 offset: spotlight_image_index
                        render 'collection-spotlight-image', media: spotlight_image, index: spotlight_render_index, stack_index: counter_grid, image_sizes: image_sizes
                      endfor
                      assign spotlight_image_index = spotlight_image_index | plus: 1
                      assign counter_grid = counter_grid | plus: 1
                    endif
                  endif

                  assign product_storytelling = false
                  unless is_spotlight_collection_template
                    assign product_type = product.type | downcase
                    if product_type == 'storytelling' or product_type contains 'storytelling'
                      assign product_storytelling = true
                    endif
                  endunless

                  if product_storytelling
                    render 'product-tile-storytelling', product: product, index: forloop.index, is_highlight: false, is_spotlight: false
                  else
                    capture spotlight_product_attributes
                      echo 'style="--spotlight-stack-index: ' | append: counter_grid | append: ';"'
                    endcapture
                    render 'product-grid-item', product: product, index: forloop.index, sizes: image_sizes, attributes: spotlight_product_attributes, card_animation: 'plp'
                  endif

                  assign counter_grid = counter_grid | plus: 1
                endfor
              -%}
            {%- elsif featured_images_array.size > 0 -%}
              {%- liquid
                assign counter_grid = 1
                assign counter_delay = 0
                assign added_images_index = ''
                assign items_on_row_remaining = columns_desktop

                for product in collection.products
                  for featured_image in featured_images_array
                    if featured_image == ''
                      continue
                    endif

                    assign featured_image_index = forloop.index
                    assign featured_image_position = featured_image | split: '#featured_image_position#' | last | split: '#featured_image_html#' | first | times: 1
                    assign featured_image_markup = featured_image | split: '#featured_image_html#' | last | split: '#featured_image#' | first
                    assign featured_image_index_tag = '@' | append: featured_image_index | append: '@'

                    if featured_image_position <= counter_grid
                      unless added_images_index contains featured_image_index_tag
                        assign counter_grid = counter_grid | plus: 1
                        assign added_images_index = added_images_index | append: '@' | append: featured_image_index | append: '@#'

                        echo featured_image_markup
                      endunless
                    endif
                  endfor

                  assign counter_delay = counter_delay | plus: 1
                  assign counter_grid = counter_grid | plus: 1
                  assign items_on_row_remaining = items_on_row_remaining | minus: 1

                  assign product_storytelling = false
                  unless is_spotlight_collection_template
                    assign product_type = product.type | downcase
                    if product_type == 'storytelling' or product_type contains 'storytelling'
                      assign product_storytelling = true
                    endif
                  endunless

                  if product_storytelling
                    render 'product-tile-storytelling', product: product, index: forloop.index, is_highlight: false, is_spotlight: false
                  else
                    render 'product-grid-item', product: product, index: forloop.index, sizes: image_sizes, card_animation: 'plp'
                  endif
                endfor
              -%}

            {%- else -%}
              {%- liquid
                for product in collection.products
                  assign grid_int = section.settings.grid | times: 1
                  assign animation_delay = forloop.index0 | modulo: grid_int | times: 1

                  assign product_storytelling = false
                  unless is_spotlight_collection_template
                    assign product_type = product.type | downcase
                    if product_type == 'storytelling' or product_type contains 'storytelling'
                      assign product_storytelling = true
                    endif
                  endunless

                  if product_storytelling
                    render 'product-tile-storytelling', product: product, index: forloop.index, is_highlight: false, is_spotlight: false
                  else
                    render 'product-grid-item', product: product, animation_delay: animation_delay, index: forloop.index, sizes: image_sizes, card_animation: 'plp'
                  endif
                endfor
              -%}
            {%- endif -%}
          {%- else -%}
            <div class="no-results">
              <p>
                <strong>{{ 'collections.general.no_matches' | t }}</strong>
              </p>
              {%- assign sort_by_string = '' -%}
              {%- if collection.sort_by != blank -%}
                {%- assign sort_by_string = '?sort_by=' | append: collection.sort_by -%}
              {%- endif -%}
              <a
                class="btn caps btn--primary btn--solid"
                href="{{ collection.url | append: sort_by_string }}"
                data-filter-update-url
                ><span>{{ 'collections.general.reset' | t }}</span></a
              >
            </div>
          {%- endif -%}
        </{{ items_container_tag }}>

        {%- if enable_infinity_scroll -%}
          <div
            class="pagination pagination--infinite"
            id="AjaxinatePagination"
            data-ajaxinate-id="{{ section.id }}"
          >
            {%- if paginate.next -%}
              <div class="pagination__loading">
                <span class="btn__loader">
                  <svg height="18" width="18" class="svg-loader">
                    <circle r="7" cx="9" cy="9" />
                    <circle stroke-dasharray="87.96459430051421 87.96459430051421" r="7" cx="9" cy="9" />
                  </svg>
                </span>
                <a href="{{ paginate.next.url }}">
                  <span class="visually-hidden">{{ 'general.pagination.next' | t }}</span>
                </a>
              </div>
            {%- endif -%}
          </div>
        {%- else -%}
          {%- if paginate.pages > 1 -%}
            {%- render 'pagination', paginate: paginate -%}
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>
  </collection-component>

  <script>
    (() => {
      if (window.__collectionAvailabilityFilterInit) {
        return;
      }
      window.__collectionAvailabilityFilterInit = true;

      const updateCollectionNavStickyState = (root = document) => {
        root.querySelectorAll('[data-collection-nav]').forEach((nav) => {
          const stickyTop = Number.parseFloat(window.getComputedStyle(nav).top) || 0;
          const navTop = nav.getBoundingClientRect().top;
          const isStuck = window.scrollY > 0 && navTop <= stickyTop + 1;
          nav.classList.toggle('is-stuck', isStuck);
        });
      };

      const getCollectionCounts = (component) => {
        if (!component) return null;

        return component.querySelector('[data-collection-counts]');
      };

      const hasServerAvailabilityFilter = (component) => {
        const countsData = getCollectionCounts(component);
        if (!countsData) return false;

        const paramName = countsData.getAttribute('data-availability-filter-param-name');
        const filterValue = countsData.getAttribute('data-availability-filter-value');

        return Boolean(paramName && filterValue);
      };

      const getAvailabilityActiveState = (component) => {
        const countsData = getCollectionCounts(component);

        if (hasServerAvailabilityFilter(component)) {
          return countsData ? countsData.getAttribute('data-availability-filter-active') === 'true' : false;
        }

        return component.dataset.localAvailabilityFilterActive === 'true';
      };

      const updateAvailabilityCount = (component, countValue) => {
        if (!component || Number.isNaN(countValue)) return;

        const availabilityCount = component.querySelector('[data-availability-products-count]');
        if (!availabilityCount) return;

        const countLabel = availabilityCount.getAttribute('data-availability-products-label') || '';
        availabilityCount.textContent = `${countValue} ${countLabel}`.trim();
      };

      const applyLocalAvailabilityFilter = (component, enabled) => {
        if (!component) return;

        const countsData = getCollectionCounts(component);
        const items = component.querySelectorAll('[data-products-grid] [data-product-available]');
        const defaultCount = countsData
          ? Number.parseInt(countsData.getAttribute('data-collection-products-count'), 10)
          : Number.NaN;
        let availableCount = 0;

        items.forEach((item) => {
          const isStorytelling = item.hasAttribute('data-product-storytelling');
          const isAvailable = item.getAttribute('data-product-available') === 'true';
          let showItem = true;

          if (isStorytelling == false && isAvailable) {
            availableCount += 1;
          }

          if (enabled) {
            if (isStorytelling) {
              showItem = false;
            } else {
              showItem = isAvailable;
            }
          }

          item.hidden = !showItem;
          item.setAttribute('aria-hidden', showItem ? 'false' : 'true');
        });

        component.dataset.localAvailabilityFilterActive = enabled ? 'true' : 'false';
        updateAvailabilityCount(component, enabled ? availableCount : defaultCount);
      };

      const syncAvailabilityUi = (component) => {
        if (!component) return;

        const countsData = getCollectionCounts(component);
        const availabilityControl = component.querySelector('[data-availability-filter-control]');
        const availabilityCheckbox = component.querySelector('[data-availability-filter-checkbox]');
        const viewAllButton = component.querySelector('[data-availability-view-all]');
        const availabilityCount = component.querySelector('[data-availability-products-count]');
        const countLabel = availabilityCount
          ? availabilityCount.getAttribute('data-availability-products-label') || ''
          : '';
        const productsCount = countsData
          ? Number.parseInt(countsData.getAttribute('data-collection-products-count'), 10)
          : Number.NaN;
        const isActive = getAvailabilityActiveState(component);

        if (hasServerAvailabilityFilter(component)) {
          setAvailabilityFilterInputState(component, isActive);
        } else {
          if (isActive) {
            applyLocalAvailabilityFilter(component, true);
          }
        }

        if (availabilityControl) {
          availabilityControl.classList.toggle('is-active', isActive);
        }

        if (availabilityCheckbox) {
          availabilityCheckbox.checked = isActive;
        }

        if (viewAllButton) {
          viewAllButton.classList.toggle('is-active', !isActive);
          viewAllButton.setAttribute('aria-pressed', !isActive ? 'true' : 'false');
        }

        if (
          availabilityCount &&
          !Number.isNaN(productsCount) &&
          (hasServerAvailabilityFilter(component) || !isActive)
        ) {
          availabilityCount.textContent = `${productsCount} ${countLabel}`.trim();
        }
      };

      const setAvailabilityFilterInputState = (component, enabled) => {
        if (!component) return false;

        const countsData = getCollectionCounts(component);
        const form = component.querySelector('[data-collection-filters-form]');
        if (!countsData || !form) return false;

        const paramName = countsData.getAttribute('data-availability-filter-param-name');
        const filterValue = countsData.getAttribute('data-availability-filter-value');
        if (!paramName || !filterValue) return false;

        let input = null;
        Array.from(form.elements).forEach((field) => {
          if (input) return;
          if (field.name !== paramName) return;
          if (field.value !== filterValue) return;

          input = field;
        });

        if (!input && enabled) {
          input = document.createElement('input');
          input.type = 'hidden';
          input.name = paramName;
          input.value = filterValue;
          input.setAttribute('data-generated-availability-filter-input', '');
          form.appendChild(input);
        }

        form.querySelectorAll('[data-generated-availability-filter-input]').forEach((generatedInput) => {
          if (!enabled) {
            generatedInput.remove();
          }
        });

        if (input) {
          if (input.type === 'checkbox') {
            input.checked = enabled;
          } else if (!enabled) {
            input.remove();
          }
        }

        return true;
      };

      const submitAvailabilityFilter = (component, enabled) => {
        if (!component) return;

        const filtersForm = component.querySelector('collection-filters-form');
        if (!filtersForm) {
          applyLocalAvailabilityFilter(component, enabled);
          syncAvailabilityUi(component);
          return;
        }

        const didUpdateInput = setAvailabilityFilterInputState(component, enabled);
        if (!didUpdateInput) {
          applyLocalAvailabilityFilter(component, enabled);
          syncAvailabilityUi(component);
          return;
        }

        component.dataset.localAvailabilityFilterActive = 'false';
        const countsData = getCollectionCounts(component);
        if (countsData) {
          countsData.setAttribute('data-availability-filter-active', enabled ? 'true' : 'false');
        }

        syncAvailabilityUi(component);
        filtersForm.submitForm(new Event('change'));
      };

      const initComponent = (component) => {
        if (!component || component.dataset.availabilityFilterReady === 'true') {
          return;
        }

        component.dataset.availabilityFilterReady = 'true';
        syncAvailabilityUi(component);
        updateCollectionNavStickyState(component);

        const productsGrid = component.querySelector('[data-products-grid]');
        if (!productsGrid) return;

        const observer = new MutationObserver(() => {
          syncAvailabilityUi(component);
        });

        observer.observe(productsGrid, {childList: true, subtree: true});
      };

      const initAll = (root) => {
        const scope = root || document;
        scope.querySelectorAll('collection-component').forEach((component) => {
          initComponent(component);
        });

        updateCollectionNavStickyState(scope);
      };

      document.addEventListener('click', (event) => {
        const availabilityControl = event.target.closest('[data-availability-filter-control]');
        if (!availabilityControl) return;

        const component = availabilityControl.closest('collection-component');
        if (!component) return;

        const checkbox = availabilityControl.querySelector('[data-availability-filter-checkbox]');
        if (!checkbox) return;

        event.preventDefault();
        submitAvailabilityFilter(component, !getAvailabilityActiveState(component));
      });

      document.addEventListener('click', (event) => {
        const viewAllButton = event.target.closest('[data-availability-view-all]');
        if (!viewAllButton) return;

        const component = viewAllButton.closest('collection-component');
        if (!component) return;

        const countsData = getCollectionCounts(component);
        if (!countsData) return;

        const isActive = getAvailabilityActiveState(component);
        if (!isActive) return;

        event.preventDefault();
        submitAvailabilityFilter(component, false);
      });

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          initAll(document);
        });
      } else {
        initAll(document);
      }

      document.addEventListener('theme:scroll', () => {
        updateCollectionNavStickyState(document);
      });

      document.addEventListener('theme:resize', () => {
        updateCollectionNavStickyState(document);
      });

      document.addEventListener('shopify:section:load', (event) => {
        initAll(event.target);
        requestAnimationFrame(() => {
          updateCollectionNavStickyState(event.target);
        });
      });
    })();
  </script>

  {% render 'header-init-animation' %}

  <script>
    (function () {
      /* Page exit fade */
      document.addEventListener('click', function (e) {
        const link = e.target.closest('a[href]');
        if (!link) return;
        const href = link.getAttribute('href');
        if (!href || href.startsWith('#') || href.startsWith('javascript') || link.target === '_blank') return;
        if (link.origin && link.origin !== location.origin) return;
        e.preventDefault();
        document.body.classList.add('page-exit');
        setTimeout(function () { window.location.href = href; }, 600);
      });

      /* PLP card animation — above-fold cards wait for subcollections, below-fold animate on scroll */
      const cards = Array.from(document.querySelectorAll('.plp-card-up'));
      if (!cards.length) return;

      let subcollectionsDone = false;
      const aboveFold = [];
      const belowFold = [];

      const partitionCards = function () {
        const vh = window.innerHeight;
        cards.forEach(function (card) {
          if (card.getBoundingClientRect().top < vh) {
            aboveFold.push(card);
          } else {
            belowFold.push(card);
          }
        });
      };

      const scrollObserver = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          scrollObserver.unobserve(entry.target);
          entry.target.classList.add('plp-card-up--visible');
        });
      }, { threshold: 0, rootMargin: '0px' });

      const releaseAboveFold = function () {
        aboveFold.forEach(function (card) {
          card.classList.add('plp-card-up--visible');
        });
      };

      const init = function () {
        partitionCards();
        belowFold.forEach(function (card) { scrollObserver.observe(card); });
        if (subcollectionsDone) releaseAboveFold();
      };

      const hasSubcollections = !!document.querySelector('[data-section-type="subcollections"]');

      document.addEventListener('theme:subcollections:animated', function () {
        subcollectionsDone = true;
        if (!aboveFold.length) return;

        /* Wait for the last visible category item's transform transition to actually finish,
           then release cards. Fallback timeout in case transitionend never fires
           (reduced motion, element off-screen, transition cancelled). */
        const lastItem = document.querySelector('.subcollection__item.plp-el-up--visible:last-child')
          || document.querySelector('.subcollection__item.plp-el-up--visible');
        if (!lastItem) { releaseAboveFold(); return; }

        var fallback = setTimeout(releaseAboveFold, 900);
        lastItem.addEventListener('transitionend', function handler(e) {
          if (e.propertyName !== 'transform') return;
          clearTimeout(fallback);
          lastItem.removeEventListener('transitionend', handler);
          releaseAboveFold();
        });
      }, { once: true });

      if (hasSubcollections) {
        setTimeout(function () {
          if (!subcollectionsDone) {
            subcollectionsDone = true;
            if (aboveFold.length) releaseAboveFold();
          }
        }, 3000);
      } else {
        subcollectionsDone = true;
      }

      const scheduleInit = function () { requestAnimationFrame(init); };
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', scheduleInit, { once: true });
      } else {
        scheduleInit();
      }
    })();
  </script>

