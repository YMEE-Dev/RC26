<!-- /sections/section-cento-diamond-comparison.liquid -->
{%- liquid
  assign item_blocks = section.blocks | where: 'type', 'item'
-%}

{%- style -%}
  #CentoDiamondComparison--{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    --cento-bg: url({{ 'cento-diamond-comparison-bg.jpg' | asset_url }});
    padding-top: {{ section.settings.padding_top | default: 150 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 150 }}px;
  }
{%- endstyle -%}

<section
  id="CentoDiamondComparison--{{ section.id }}"
  class="cento-comparison section-padding1"
  data-section-id="{{ section.id }}"
  data-section-type="cento-comparison"
>
  <div class="cento-comparison__bg"></div>

  {%- if item_blocks.size > 0 -%}
    <div class="cento-comparison__wrapper">
      {%- for block in item_blocks -%}
        {%- unless forloop.first -%}
          <div class="cento-comparison__divider">
            <span class="cento-comparison__divider-line"></span>
            <span class="cento-comparison__vs">vs</span>
            <span class="cento-comparison__divider-line"></span>
          </div>
        {%- endunless -%}
        <div class="cento-comparison__row" {{ block.shopify_attributes }}>
          <div class="cento-comparison__title-col">
            <h3 class="cento-comparison__title">{{ block.settings.title }}</h3>
          </div>
          <div class="cento-comparison__image-col">
            {%- if forloop.index0 == 0 -%}
              <span class="cento-comparison__svg-wrap">{{ 'cento-diamond-facets.svg' | inline_asset_content }}</span>
              <span class="cento-comparison__svg-wrap">{{ 'cento-diamond-side.svg' | inline_asset_content }}</span>
            {%- else -%}
              <span class="cento-comparison__svg-wrap">{{ 'standard-diamond-facets.svg' | inline_asset_content }}</span>
              <span class="cento-comparison__svg-wrap">{{ 'standard-diamond-side.svg' | inline_asset_content }}</span>
            {%- endif -%}
          </div>
          {%- if block.settings.description != blank -%}
            <div class="cento-comparison__desc-col">
              <div class="cento-comparison__description rte">
                {{ block.settings.description }}
              </div>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- else -%}
    {%- render 'no-blocks' -%}
  {%- endif -%}
</section>

{% stylesheet %}
  .cento-comparison {
    position: relative;
    overflow: hidden;
    max-width: 1232px;
    margin-left: auto;
    margin-right: auto;
    padding-left: clamp(20px, 8vw, 200px);
    padding-right: clamp(20px, 8vw, 200px);
  }

  .cento-comparison__bg {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    border-bottom: 1px solid #e5e5e5;
    background: var(--cento-bg) lightgray 0px -132.752px / 160.866% 134.653% no-repeat;
    box-shadow: 0 4px 4px 0 rgba(0, 0, 0, 0.25);
    filter: blur(25px);
  }

  .cento-comparison__wrapper {
    width: 100%;
    padding: 0;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .cento-comparison__row {
    display: grid;
    grid-template-columns: 1fr 1fr 2fr;
    gap: 40px 20px;
    align-items: center;
  }

  .cento-comparison__title-col {
    display: flex;
    align-items: center;
  }

  .cento-comparison__title {
    max-width: min-content;
    text-wrap: balance;
    color: #ffffff;
    font-family: var(--FONT-STACK-HEADING);
    font-size: var(--FONT-DISPLAY-S);
    line-height: var(--FONT-DISPLAY-M);
    margin: 0;
    font-weight: var(--FONT-WEIGHT-HEADING);
    font-style: var(--FONT-STYLE-HEADING);
    letter-spacing: var(--LETTER-SPACING-HEADING);
    text-transform: var(--FONT-UPPERCASE-HEADING, none);
  }

  .cento-comparison__image-col {
    display: flex;
    align-items: flex-start;
    gap: 7.66px;
  }

  .cento-comparison__svg-wrap {
    display: block;
    width: 72px;
    height: 72px;
    flex-shrink: 0;
  }

  .cento-comparison__svg-wrap svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .cento-comparison__desc-col {
    display: flex;
    align-items: center;
  }

  .cento-comparison__description {
    color: #ffffff;
    font-family: var(--FONT-STACK-BODY);
    font-size: 12px;
    font-style: normal;
    font-weight: 400;
    line-height: 20px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .cento-comparison__description p {
    margin: 0 0 0.8em;
  }

  .cento-comparison__description p:last-child {
    margin-bottom: 0;
  }

  .cento-comparison__description strong {
    font-weight: 600;
  }

  .cento-comparison__divider {
    display: flex;
    align-items: center;
    gap: 40px;
    padding: 40px 0;
  }

  .cento-comparison__divider-line {
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 1);
    display: block;
  }

  .cento-comparison__vs {
    color: #ffffff;
    font-family: var(--FONT-STACK-HEADING);
    font-size: var(--FONT-DISPLAY-S);
    line-height: var(--FONT-DISPLAY-M);
    font-weight: var(--FONT-WEIGHT-HEADING);
    letter-spacing: 0.15em;
    white-space: nowrap;
    flex-shrink: 0;
    font-style: var(--FONT-STYLE-HEADING);
    text-transform: var(--FONT-UPPERCASE-HEADING, none);
  }

  @media only screen and (max-width: 749px) {
    .cento-comparison {
      padding-left: var(--outer, 20px);
      padding-right: var(--outer, 20px);
    }

    .cento-comparison__row {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .cento-comparison__image-col {
      order: -1;
      gap: 16px;
    }

    .cento-comparison__svg-wrap {
      width: 120px;
      height: 120px;
    }

    .cento-comparison__title-col {
      order: 0;
    }

    .cento-comparison__desc-col {
      order: 1;
    }

    .cento-comparison__divider {
      padding: 32px 0;
      gap: 20px;
    }

    .cento-comparison__description {
      font-size: 11px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Cento Diamond Comparison",
  "tag": "section",
  "class": "section-cento-comparison",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#142038"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Top",
      "default": 150
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Bottom",
      "default": 150
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Diamond type",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Cento Diamond"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cento Diamond Comparison",
      "category": "Custom",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "title": "Cento Diamond",
            "description": "<p><strong>9-fold symmetry = 100 facets</strong> designed to display more light. More “fire”</p><p>Floral pattern. 12-15 hours to cut by hand. <strong>Certified</strong></p><p>Laser inscribed and <strong>Conflict free</strong></p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Standard Diamond",
            "description": "<p><strong>8-fold symmetry = 57/58 facets.</strong> Low light display. Less “fire”</p><p>No pattern. 6-8 hours to cut by hand. <strong>May or may not be Certified</strong></p><p>May or may not be laser inscribed and <strong>may or may not be Conflict free</strong></p>"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "aside", "footer"]
  }
}
{% endschema %}
