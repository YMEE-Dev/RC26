      const debounceFn = (fn, wait) => {
        if (window.theme && typeof window.theme.debounce === 'function') {
          return window.theme.debounce(fn, wait);
        }
        let timer;
        return (...args) => {
          clearTimeout(timer);
          timer = setTimeout(() => fn(...args), wait);
        };
      };

      const scheduleApply = debounceFn(applyForSection, APPLY_DEBOUNCE);

      const pickTopEntry = (entries) => {
        const visible = entries.filter((entry) => entry.isIntersecting);
        if (!visible.length) return null;
        return visible.sort((a, b) => {
          if (b.intersectionRatio !== a.intersectionRatio) {
            return b.intersectionRatio - a.intersectionRatio;
          }
          return a.boundingClientRect.top - b.boundingClientRect.top;
        })[0];
      };

      let rootMargin = computeRootMargin();
      let overlay;
      const ensureOverlay = () => {
        if (!DEBUG_HEADER_OBSERVER) return;
        if (!overlay) {
