          }

          if (!isMediaReady(mediaEl)) {
            watchMediaReadiness(sectionEl, mediaEl);
            return true;
          }

          applyAsyncLuminance(
            sectionEl,
            computeVideoLuminance(mediaEl, point, mediaFallbackRgb),
            'video-frame-sampled',
            fallbackLuminance
          );
          return true;
        }

        return false;
      };

      const applyForSection = (sectionEl) => {
        const cached = luminanceCache.get(sectionEl);
        if (cached !== undefined) {
          logLuminance(cached, sectionEl, 'cache');
          applyLuminanceMode(cached);
          return;
        }

        const mediaMatch = findMediaUnderHeader(sectionEl);
        const bgUrl = findElementBackgroundImage(sectionEl);
        const fallbackLuminance = getSectionFallbackLuminance(sectionEl);

        if (applyMediaLuminance(sectionEl, mediaMatch, fallbackLuminance)) return;

        if (bgUrl) {
