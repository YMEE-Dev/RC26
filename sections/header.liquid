{% javascript %}
  // custom menu logics
  document.addEventListener('DOMContentLoaded', () => {
    /* Helpers */
    const selectAll = (sel, ctx = document) => Array.from(ctx.querySelectorAll(sel));

    /* Mobile hamburger press animation */
    // const hamburgerButtons = selectAll('.header__mobile__hamburger');
    // hamburgerButtons.forEach((btn) => {
    //   const triggerPress = () => {
    //     btn.classList.remove('is-pressed');
    //     void btn.offsetWidth; // restart animation
    //     btn.classList.add('is-pressed');
    //   };
    //   btn.addEventListener('click', triggerPress);
    //   btn.addEventListener('animationend', () => btn.classList.remove('is-pressed'));
    // });

    const syncHamburgerDrawerLabel = () => {
      const drawer = document.querySelector('header-drawer.drawer--header');
      const buttons = selectAll('.header__mobile__hamburger[data-drawer-toggle="hamburger"]');
      if (!drawer || !buttons.length) return;

      const setLabels = () => {
        const drawerVisible =
          document.body.classList.contains('header-drawer-is-open') ||
          drawer.classList.contains('is-open') ||
          drawer.classList.contains('is-closing');

        buttons.forEach((button) => {
          const label = drawerVisible ? button.dataset.closeLabel : button.dataset.openLabel;
          button.classList.toggle('is-drawer-open', drawerVisible);

          if (label) {
            button.setAttribute('aria-label', label);
          }
        });
      };

      setLabels();

      new MutationObserver(setLabels).observe(drawer, {
        attributes: true,
        attributeFilter: ['class'],
      });

      new MutationObserver(setLabels).observe(document.body, {
        attributes: true,
        attributeFilter: ['class'],
      });
    };

    syncHamburgerDrawerLabel();

    /* Scroll animation for header visibility is handled in assets/theme.dev.js */

    /* Menu images + overlay */
    const initCollectionLabelMirroring = () => {
      const collectionLists = selectAll('ul.tmenu_submenu_type_automatic.tmenu_submenu');
      if (!collectionLists.length) return;

      const replaceCollectionPlaceholder = (element, value, datasetKey) => {
        if (!element) return;

        const sourceValue = element.dataset[datasetKey] || element.textContent;
        element.dataset[datasetKey] = sourceValue;

        if (!sourceValue.includes('[collection]')) return;

        element.textContent = sourceValue.replaceAll('[collection]', value);
      };

      collectionLists.forEach((list) => {
        const links = selectAll(
          ':scope > li:not(.tmenu_item_mobile) > .tmenu_item_link:not([tmenu-disabled-link])',
          list
        );
        if (links.length < 2) return;

        const firstLink = links[0];
        const lastLink = links[links.length - 1];
        const firstLabelElement = firstLink.querySelector('.tmenu_item_text');
        const lastLabelElement = lastLink.querySelector('.tmenu_item_text');
        const firstLabel = (firstLabelElement ? firstLabelElement.textContent : firstLink.textContent).trim();
        if (!firstLabel) return;

        replaceCollectionPlaceholder(lastLabelElement || lastLink, firstLabel, 'collectionTemplateText');

        const lastTitle = lastLink.dataset.collectionTemplateTitle || lastLink.getAttribute('title') || '';
        lastLink.dataset.collectionTemplateTitle = lastTitle;

        if (lastTitle.includes('[collection]')) {
          lastLink.setAttribute('title', lastTitle.replaceAll('[collection]', firstLabel));
        }
      });
    };

    const initMenuImages = () => {
      const images = selectAll(
        '.tmenu_nav .tmenu_item_level_0.tmenu_item_has_child .tmenu_submenu--desktop .tmenu_item_has_child .tmenu_collection--above > img'
      );
      if (!images.length) return;
      const defaultImage = images[0];
      const lastCollectionLink = document.querySelector(
        '.tmenu_nav .tmenu_item_level_0.tmenu_item_has_child .tmenu_submenu--desktop .tmenu_item_has_child:has(.tmenu_collection--above) li:last-child a'
      );

      const resetToDefaultImage = () => {
        images.forEach((img) => {
          if (img === defaultImage) {
            img.classList.remove('hide-menu-image');
          } else {
            img.classList.add('hide-menu-image');
          }
        });

        if (lastCollectionLink) {
          lastCollectionLink.classList.remove('mild-hide');
        }
      };

      resetToDefaultImage();

      // DISCLAMER: find links that should trigger image changes - these are right-aligned links in mega menu collections
      const links = selectAll(
        '.header__desktop__bar__c .tmenu_nav .tmenu_item_level_1:nth-last-child(-n + 2) .tmenu_item_level_2 a.tmenu_item_link'
      );
      if (!links.length) return;

      const imageByAlt = new Map();
      images.forEach((img) => {
        const alt = img.getAttribute('alt') || '';
        if (alt) imageByAlt.set(alt.trim(), img);
      });

      const showImageForTitle = (title) => {
        const match = imageByAlt.get((title || '').trim());
        if (match) {
          images.forEach((img) => img.classList.add('hide-menu-image'));
          match.classList.remove('hide-menu-image');
          if (lastCollectionLink) {
            lastCollectionLink.classList.add('mild-hide');
          }
        } else {
          resetToDefaultImage();
        }
      };

      const linksContainer = links[0].closest('.tmenu_submenu');
      if (linksContainer && linksContainer.dataset.menuImageResetBound !== 'true') {
        linksContainer.dataset.menuImageResetBound = 'true';
        linksContainer.addEventListener('mouseleave', resetToDefaultImage);
        linksContainer.addEventListener('focusout', (event) => {
          if (linksContainer.contains(event.relatedTarget)) return;
          resetToDefaultImage();
        });
      }

      links.forEach((link) => {
        const linkText = link.querySelector('.tmenu_item_text') || link;
        if (linkText.dataset.menuImageBound === 'true') return;
        linkText.dataset.menuImageBound = 'true';
        linkText.addEventListener('mouseenter', () => showImageForTitle(link.textContent));
        linkText.addEventListener('focus', () => showImageForTitle(link.textContent));
      });
    };

    const rootSelector = '.tmenu_item.tmenu_item--root.tmenu_item_level_0.tmenu_item_submenu_type_mega';
    const tmenuActiveSelector = '.tmenu_item--root.tmenu_item_level_0.tmenu_item_active';
    const mobileDrawerMenuSelector = '.drawer__menu.tmenu_app';
    const mobileDrawerActiveRootSelector =
      '.drawer__menu.tmenu_app .tmenu_item_level_0.tmenu_item_mobile.tmenu_item_active';
    const mobileDrawerThirdLevelSubmenuSelector =
      '.drawer__menu.tmenu_app .tmenu_item_level_0.tmenu_item_mobile > .tmenu_submenu--mobile.tmenu_submenu > li.tmenu_item_level_1.tmenu_item_mobile:nth-of-type(3) > .tmenu_submenu';
    const jewelryMobileThirdLevelSubmenuSelector =
      '.drawer__menu.tmenu_app [title="JEWELRY"] + .tmenu_submenu--mobile.tmenu_submenu > li.tmenu_item_level_1.tmenu_item_mobile:nth-of-type(3) > .tmenu_submenu';
    const mobileTouchSafeSubmenuSelector = [
      'ul.tmenu_submenu_type_automatic.tmenu_submenu--mobile.tmenu_submenu',
      mobileDrawerThirdLevelSubmenuSelector,
    ].join(', ');
    const mobileMenuLazyImageSelector = 'img[data-src], img[data-srcset]';
    let initialized = false;
    let tmenuIsActive = false;
    let tmenuScrollLocked = false;
    let tmenuScrollLockTarget = null;

    const applyMenuOpenStyles = () => {
      initCollectionLabelMirroring();
      initMenuImages();
    };

    const forceLoadImageFromDataset = (image) => {
      if (!(image instanceof HTMLImageElement)) return;
      if (image.dataset.tmenuForcedLoadDone === 'true') return;

      const dataSrc = image.getAttribute('data-src');
      const dataSrcset = image.getAttribute('data-srcset');

      if (dataSrcset) {
        image.setAttribute('srcset', dataSrcset);
        image.removeAttribute('data-srcset');
      }
      if (dataSrc) {
        image.setAttribute('src', dataSrc);
        image.removeAttribute('data-src');
      }

      image.setAttribute('loading', 'eager');
      image.setAttribute('decoding', 'async');
      image.dataset.tmenuForcedLoadDone = 'true';

      if (typeof image.decode === 'function') {
        image.decode().catch(() => {});
      }
    };

    const getMobileThirdPanels = () => {
      const jewelryPanels = selectAll(jewelryMobileThirdLevelSubmenuSelector);
      if (jewelryPanels.length) return jewelryPanels;
      return selectAll(mobileDrawerThirdLevelSubmenuSelector);
    };

    const ensureMobileThirdPanelImagesLoaded = () => {
      const mobileThirdPanels = getMobileThirdPanels();
      if (!mobileThirdPanels.length) return;

      mobileThirdPanels.forEach((panel) => {
        selectAll(mobileMenuLazyImageSelector, panel).forEach(forceLoadImageFromDataset);

        if (panel.dataset.mobileImageLoadObserverBound === 'true') return;
        panel.dataset.mobileImageLoadObserverBound = 'true';

        new MutationObserver(() => {
          selectAll(mobileMenuLazyImageSelector, panel).forEach(forceLoadImageFromDataset);
        }).observe(panel, {childList: true, subtree: true});
      });
    };

    const bindMobileDrawerMenuObservers = () => {
      if (document.documentElement.dataset.tmenuMobileDrawerObserversBound === 'true') return;
      document.documentElement.dataset.tmenuMobileDrawerObserversBound = 'true';

      const attachObservers = (menu) => {
        if (!menu || menu.dataset.tmenuMobileMenuObserverBound === 'true') return;
        menu.dataset.tmenuMobileMenuObserverBound = 'true';

        const refreshMobileMenuState = () => {
          ensureMobileThirdPanelImagesLoaded();

          const mobileMenuIsOpen = Boolean(document.querySelector(mobileDrawerActiveRootSelector));
          if (mobileMenuIsOpen) {
            setTmenuScrollLock(true);
          } else if (tmenuScrollLocked) {
            setTmenuScrollLock(false);
          }
        };

        new MutationObserver(refreshMobileMenuState).observe(menu, {
          childList: true,
          subtree: true,
          attributes: true,
          attributeFilter: ['class'],
        });

        menu.addEventListener('scroll', refreshMobileMenuState, {passive: true});
        menu.addEventListener('touchstart', refreshMobileMenuState, {passive: true});
        menu.addEventListener('touchmove', refreshMobileMenuState, {passive: true});

        refreshMobileMenuState();
      };

      selectAll(mobileDrawerMenuSelector).forEach(attachObservers);

      new MutationObserver(() => {
        selectAll(mobileDrawerMenuSelector).forEach(attachObservers);
        ensureMobileThirdPanelImagesLoaded();
      }).observe(document.body, {childList: true, subtree: true});
    };

    const enableMobileSubmenuTouchScrollGuard = () => {
      if (document.documentElement.dataset.tmenuMobileTouchScrollGuardBound === 'true') return;
      document.documentElement.dataset.tmenuMobileTouchScrollGuardBound = 'true';

      const getTouchScrollableSubmenu = (target) => {
        if (!(target instanceof Element)) return null;
        return target.closest(mobileTouchSafeSubmenuSelector);
      };

      const applyBoundaryScrollHack = (submenu) => {
        if (!submenu) return;
        if (submenu.scrollHeight <= submenu.clientHeight) return;

        if (submenu.scrollTop <= 0) {
          submenu.scrollTop = 1;
          return;
        }

        if (submenu.scrollTop + submenu.clientHeight >= submenu.scrollHeight) {
          submenu.scrollTop -= 1;
        }
      };

      document.addEventListener(
        'touchstart',
        (event) => {
          const submenu = getTouchScrollableSubmenu(event.target);
          if (!submenu) return;

          applyBoundaryScrollHack(submenu);
        },
        {capture: true, passive: true}
      );
    };

    const enableMobileSubmenuDownScroll = (submenu) => {
      if (!submenu || submenu.dataset.mobileDownScrollEnabled === 'true') return;

      submenu.dataset.mobileDownScrollEnabled = 'true';
      submenu.style.touchAction = 'pan-y';
      submenu.style.overscrollBehaviorY = 'contain';
      submenu.style.webkitOverflowScrolling = 'touch';
    };

    const getTmenuScrollLockTarget = () => {
      const submenuCandidates = selectAll(mobileTouchSafeSubmenuSelector);
      const activeSubmenu =
        submenuCandidates.find((submenu) => submenu.closest('.tmenu_item_mobile.tmenu_item_active')) ||
        submenuCandidates[0];

      if (activeSubmenu) {
        enableMobileSubmenuDownScroll(activeSubmenu);
        return activeSubmenu;
      }

      return document.querySelector('header-drawer.drawer--header .drawer__content__scroll');
    };

    const setTmenuScrollLock = (shouldLock) => {
      if (shouldLock) {
        const nextScrollLockTarget = getTmenuScrollLockTarget();
        const targetChanged = nextScrollLockTarget !== tmenuScrollLockTarget;

        if (targetChanged && tmenuScrollLocked) {
          document.dispatchEvent(new CustomEvent('theme:scroll:unlock', {bubbles: true}));
          tmenuScrollLocked = false;
        }

        if (!tmenuScrollLocked) {
          document.dispatchEvent(
            new CustomEvent('theme:scroll:lock', {
              detail: nextScrollLockTarget || undefined,
              bubbles: true,
            })
          );
          tmenuScrollLocked = true;
        }

        tmenuScrollLockTarget = nextScrollLockTarget || null;
        return;
      }

      if (tmenuScrollLocked) {
        document.dispatchEvent(new CustomEvent('theme:scroll:unlock', {bubbles: true}));
        tmenuScrollLocked = false;
      }

      tmenuScrollLockTarget = null;
    };

    enableMobileSubmenuTouchScrollGuard();
    ensureMobileThirdPanelImagesLoaded();
    bindMobileDrawerMenuObservers();

    const observeRoot = (root) => {
      const handleMutations = () => {
        if (!initialized) {
          initialized = true;
          applyMenuOpenStyles();
          ensureMobileThirdPanelImagesLoaded();
        }
        const activeNow = Boolean(document.querySelector(tmenuActiveSelector));
        if (activeNow && !tmenuIsActive) {
          applyMenuOpenStyles();
          ensureMobileThirdPanelImagesLoaded();
        }
        if (activeNow) {
          setTmenuScrollLock(true);
          ensureMobileThirdPanelImagesLoaded();
        }
        if (activeNow !== tmenuIsActive) {
          if (!activeNow) {
            setTmenuScrollLock(false);
          }
          tmenuIsActive = activeNow;
          document.dispatchEvent(
            new CustomEvent('theme:tmenu:state', {
              detail: {isOpen: tmenuIsActive},
            })
          );
        }
      };
      new MutationObserver(handleMutations).observe(root, {
        childList: true,
        subtree: true,
        attributes: true,
        attributeFilter: ['class'],
      });
    };

    const roots = selectAll(rootSelector);
    if (roots.length) {
      roots.forEach(observeRoot);
    } else {
      new MutationObserver((_, observer) => {
        const found = selectAll(rootSelector);
        if (!found.length) return;
        observer.disconnect();
        found.forEach(observeRoot);
      }).observe(document.body, {childList: true, subtree: true});
    }

    /* Header light/dark switcher */
    const initHeaderObserver = () => {
      const headerWrapper = document.querySelector('header.theme__header');
      const body = document.body;
      const drawerWrapper = document.querySelector('header-drawer.drawer--header');
      const headerTargets = selectAll('.header__desktop, .header__mobile');
      const logoLinks = selectAll('.header__logo__link[data-logo-light][data-logo-dark]');
      const transparentImages = selectAll('.logo__img.logo__img--transparent');
      const revealResolvedHeader = () => {
        if (!headerWrapper || headerWrapper.dataset.headerColorReady === 'true') return;

        requestAnimationFrame(() => {
          headerWrapper.removeAttribute('data-header-color-pending');
          headerWrapper.setAttribute('data-header-color-ready', 'true');
        });
      };
      if (!(headerTargets.length && logoLinks.length)) {
        revealResolvedHeader();
        return;
      }

      const colors = {
        light: {
          link: '#fff',
          hover: '#f0f0f0',
        },
        dark: {
          link: '#000',
          hover: '#222',
        },
      };

      const logoLightUrl = logoLinks[0].dataset.logoLight;
      const logoDarkUrl = logoLinks[0].dataset.logoDark;
      const forcedDrawerLogoMode = 'dark';
      const forcedTmenuLogoMode = 'dark';
      const DEBUG_HEADER_OBSERVER = false;
      const observedSectionSelector = 'main .shopify-section [data-header-observer-mode]';
      const intersectionThresholds = [0, 0.01, 0.1, 0.25, 0.5, 0.75, 1];
      const getSectionLabel = (sectionEl) =>
        sectionEl?.dataset.sectionId || sectionEl?.id || sectionEl?.className || 'unknown-section';
      const debugLog = (message, payload = {}) => {
        if (!DEBUG_HEADER_OBSERVER) return;
        console.log('[HeaderObserver]', message, payload);
      };
      const getHeaderHeight = () => document.querySelector('[data-header-height]')?.offsetHeight || 0;

      const drawerIsOpen = () => drawerWrapper?.classList.contains('is-open');
      const tmenuIsOpen = () => tmenuIsActive || Boolean(document.querySelector(tmenuActiveSelector));
      const getForcedLogoMode = () => {
        if (drawerIsOpen()) {
          return forcedDrawerLogoMode;
        }

        if (tmenuIsOpen()) {
          return forcedTmenuLogoMode;
        }

        return '';
      };

      const setHeaderColors = (mode) => {
        const colorSet = colors[mode] || colors.light;
        body.style.setProperty('--globaltext', colorSet.link);
        headerWrapper.style.setProperty('--link', colorSet.link);
        headerWrapper.style.setProperty('--link-hover', colorSet.hover);
        headerTargets.forEach((header) => {
          header.style.setProperty('--link', colorSet.link);
          header.style.setProperty('--link-hover', colorSet.hover);
        });
      };

      const setLogoSource = (mode) => {
        const useLightLogo = mode === 'light';
        const logoUrl = useLightLogo ? logoLightUrl : logoDarkUrl;
        if (!logoUrl) return;
        logoLinks.forEach((link) => {
          const img = link.querySelector('.logo__img.logo__img--color');
          if (img && img.getAttribute('src') !== logoUrl) img.setAttribute('src', logoUrl);
        });
        transparentImages.forEach((img) => {
          if (img && img.getAttribute('src') !== logoUrl) img.setAttribute('src', logoUrl);
        });
      };

      const defaultMode = headerWrapper?.dataset.headerDefaultMode === 'light' ? 'light' : 'dark';
      let currentMode = defaultMode;
      const applyMode = (mode) => {
        const resolved = mode || defaultMode;
        if (resolved === currentMode) return;
        currentMode = resolved;
        setHeaderColors(currentMode);
        if (!getForcedLogoMode()) {
          setLogoSource(currentMode);
        }
        debugLog('Applied mode', {
          mode: currentMode,
          forcedLogoMode: getForcedLogoMode() || null,
        });
      };

      const syncLogoWithHeaderState = () => {
        const forcedLogoMode = getForcedLogoMode();

        if (forcedLogoMode) {
          setLogoSource(forcedLogoMode);
          debugLog('Applied forced logo mode', {
            forcedLogoMode,
            drawerOpen: drawerIsOpen(),
            tmenuOpen: tmenuIsOpen(),
          });
          return;
        }

        setLogoSource(currentMode);
        debugLog('Synced logo with header mode', {
          mode: currentMode,
        });
      };

      setHeaderColors(currentMode);
      setLogoSource(currentMode);
      syncLogoWithHeaderState();

      if (drawerWrapper) {
        document.addEventListener('theme:drawer:open', (event) => {
          if (event.target !== drawerWrapper) return;
          document.body.classList.add('header-drawer-is-open');
          syncLogoWithHeaderState();
        });

        document.addEventListener('theme:drawer:close', (event) => {
          if (event.target !== drawerWrapper) return;
          syncLogoWithHeaderState();
        });

        new MutationObserver(() => {
          const isOpen = drawerWrapper.classList.contains('is-open');
          const isClosing = drawerWrapper.classList.contains('is-closing');
          if (!isOpen && !isClosing) {
            document.body.classList.remove('header-drawer-is-open');
          }
          syncLogoWithHeaderState();
        }).observe(drawerWrapper, {
          attributes: true,
          attributeFilter: ['class'],
        });
      }

      document.addEventListener('theme:tmenu:state', syncLogoWithHeaderState);

      let sectionsToObserve = selectAll(observedSectionSelector);
      if (!sectionsToObserve.length) {
        revealResolvedHeader();
        return;
      }

      const createOverlay = (label, color) => {
        const existing = document.querySelector(`[data-header-observer-overlay="${label}"]`);
        if (existing) return existing;
        const el = document.createElement('div');
        el.dataset.headerObserverOverlay = label;
        el.classList.add('header-observer-overlay');
        el.style.setProperty('--overlay-color', color);
        el.textContent = label;
        document.body.appendChild(el);
        return el;
      };

      const updateOverlayPosition = (el) => {
        const band = getHeaderProbeBand();
        el.style.top = `${band.top}px`;
        el.style.left = '0px';
        el.style.width = '100vw';
        el.style.height = `${band.bottom - band.top}px`;
      };

      let currentObservedSection = null;
      let sectionObserver = null;
      const headerProbeBandHeight = 32;
      const getHeaderProbeBand = () => {
        const headerHeight = getHeaderHeight();
        const bandHeight = Math.min(headerProbeBandHeight, Math.max(1, headerHeight || headerProbeBandHeight));
        // Probe band always sits inside the header (top of the screen) on every
        // viewport. The previous mobile-only band ~80% down the screen was removed
        // so the mobile header color/logo follows the section directly behind the
        // header, exactly like desktop.
        const top = Math.max(0, (headerHeight - bandHeight) / 2);
        const bottom = Math.min(window.innerHeight, top + bandHeight);

        return {top, bottom};
      };
      let overlay;
      const sectionOverlapsProbeBand = (sectionEl) => {
        const rect = sectionEl.getBoundingClientRect();
        const band = getHeaderProbeBand();
        return rect.bottom > band.top && rect.top < band.bottom;
      };
      const getSectionMode = (sectionEl) => (sectionEl?.dataset.headerObserverMode === 'dark' ? 'dark' : 'light');
      const getBandCenter = () => {
        const band = getHeaderProbeBand();
        return band.top + (band.bottom - band.top) / 2;
      };
      const getSectionDistanceToBandCenter = (sectionEl) => {
        const rect = sectionEl.getBoundingClientRect();
        const bandCenter = getBandCenter();

        if (rect.top <= bandCenter && rect.bottom >= bandCenter) {
          return 0;
        }

        if (rect.bottom < bandCenter) {
          return bandCenter - rect.bottom;
        }

        return rect.top - bandCenter;
      };
      const getSectionOverlapHeight = (sectionEl) => {
        const rect = sectionEl.getBoundingClientRect();
        const band = getHeaderProbeBand();
        return Math.max(0, Math.min(rect.bottom, band.bottom) - Math.max(rect.top, band.top));
      };
      const findActiveSection = () =>
        sectionsToObserve
          .filter((sectionEl) => sectionOverlapsProbeBand(sectionEl))
          .sort((sectionA, sectionB) => {
            const overlapDiff = getSectionOverlapHeight(sectionB) - getSectionOverlapHeight(sectionA);
            if (overlapDiff !== 0) return overlapDiff;

            const distanceDiff = getSectionDistanceToBandCenter(sectionA) - getSectionDistanceToBandCenter(sectionB);
            if (distanceDiff !== 0) return distanceDiff;

            return sectionA.getBoundingClientRect().top - sectionB.getBoundingClientRect().top;
          })[0] || null;
      const ensureOverlay = () => {
        if (!DEBUG_HEADER_OBSERVER) return;
        if (!overlay) {
          overlay = createOverlay('header observer root', 'rgba(0, 128, 255, 0.2)');
        }
        updateOverlayPosition(overlay);
      };
      const refreshTrackedSections = () => {
        sectionsToObserve = selectAll(observedSectionSelector);
      };
      const getObserverRootMargin = () => {
        const band = getHeaderProbeBand();
        const bottomMargin = Math.max(0, window.innerHeight - band.bottom);
        return `-${Math.max(0, band.top)}px 0px -${bottomMargin}px 0px`;
      };
      const applyForSection = (sectionEl, source = 'intersection') => {
        const mode = getSectionMode(sectionEl);
        debugLog('Resolved section mode', {
          section: getSectionLabel(sectionEl),
          mode,
          source,
        });
        applyMode(mode);
        revealResolvedHeader();
      };
      const refreshObservedSection = (source = 'refresh') => {
        const sectionEl = findActiveSection();
        ensureOverlay();
        if (!sectionEl) {
          currentObservedSection = null;
          debugLog('No observer section matched probe band, using default mode', {
            mode: defaultMode,
            source,
          });
          currentMode = defaultMode;
          setHeaderColors(defaultMode);
          if (!getForcedLogoMode()) {
            setLogoSource(defaultMode);
          }
          revealResolvedHeader();
          return;
        }

        const nextMode = getSectionMode(sectionEl);
        if (currentObservedSection === sectionEl && currentMode === nextMode) return;

        currentObservedSection = sectionEl;
        applyForSection(sectionEl, source);
      };
      const disconnectSectionObserver = () => {
        if (!sectionObserver) return;
        sectionObserver.disconnect();
        sectionObserver = null;
      };
      const observeSections = () => {
        disconnectSectionObserver();
        refreshTrackedSections();
        ensureOverlay();
        currentObservedSection = null;

        if (!sectionsToObserve.length) {
          revealResolvedHeader();
          return;
        }

        sectionObserver = new IntersectionObserver(
          () => {
            refreshObservedSection('intersection');
          },
          {
            root: null,
            rootMargin: getObserverRootMargin(),
            threshold: intersectionThresholds,
          }
        );

        sectionsToObserve.forEach((sectionEl) => {
          sectionObserver.observe(sectionEl);
        });

        debugLog('Initialized section observer', {
          trackedSections: sectionsToObserve.map((sectionEl) => getSectionLabel(sectionEl)),
          rootMargin: getObserverRootMargin(),
          thresholds: intersectionThresholds,
        });

        refreshObservedSection('initial');
      };
      window.setTimeout(() => {
        if (headerWrapper?.dataset.headerColorReady === 'true') return;

        debugLog('Header observer fallback revealed default dark state', {
          mode: defaultMode,
        });
        currentObservedSection = null;
        currentMode = defaultMode;
        setHeaderColors(defaultMode);
        if (!getForcedLogoMode()) {
          setLogoSource(defaultMode);
        }
        revealResolvedHeader();
      }, 0);
      const resetSectionObserver = () => {
        observeSections();
      };

      observeSections();
      window.addEventListener('resize', resetSectionObserver);
    };

    window.addEventListener(
      'load',
      () => {
        initHeaderObserver();
      },
      {once: true}
    );
  });
