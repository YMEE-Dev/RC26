      };

      const isImageReady = (imgEl) => {
        const src = imgEl?.currentSrc || imgEl?.src;
        return Boolean(src) && imgEl.complete && imgEl.naturalWidth > 0;
      };
      const isImageFailed = (imgEl) => {
        const src = imgEl?.currentSrc || imgEl?.src;
        return Boolean(src) && imgEl.complete && imgEl.naturalWidth === 0;
      };

      const isVideoReady = (videoEl) => videoEl.readyState >= 2 && videoEl.videoWidth > 0 && videoEl.videoHeight > 0;
      const isVideoFailed = (videoEl) => Boolean(videoEl?.error);
      const isMediaReady = (mediaEl) => {
        if (isImageElement(mediaEl)) return isImageReady(mediaEl);
        if (isVideoElement(mediaEl)) return isVideoReady(mediaEl);
        return false;
      };
      const isMediaFailed = (mediaEl) => {
        if (isImageElement(mediaEl)) return isImageFailed(mediaEl);
        if (isVideoElement(mediaEl)) return isVideoFailed(mediaEl);
        return false;
      };
      const isPendingMedia = (mediaEl) => {
        if (!mediaEl) return false;
        if (isVideoElement(mediaEl) && mediaEl.poster) return false;
        return !isMediaReady(mediaEl) && !isMediaFailed(mediaEl);
      };

      const getMediaDescriptor = (mediaEl) => {
        if (!mediaEl) return {};

        if (isImageElement(mediaEl)) {
          return {
            tag: 'IMG',
            src: mediaEl.currentSrc || mediaEl.src || null,
            complete: mediaEl.complete,
            naturalWidth: mediaEl.naturalWidth,
