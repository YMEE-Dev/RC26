{%- liquid
  assign animation_name = 'drawer-items-fade'
  assign animation_duration = 500
  assign animation_delay = 0
  assign animation_delay_increment = 50

  assign toolbar_block = section.blocks | where: 'type', 'toolbar'
  assign toolbar_block = toolbar_block[0]
  assign show_toolbar_socials = false
  assign show_toolbar_gift_card = toolbar_block.settings.show_gift_card | default: false
  assign show_separator_line = section.settings.show_separator_line
  assign border_color = section.settings.header_border_color
  assign show_socials = false

  assign padding_top = section.settings.padding_top
  assign padding_top_medium = padding_top | times: 0.8
  assign padding_top_mobile = padding_top | times: 0.6
  assign padding_bottom = section.settings.padding_bottom
  assign padding_bottom_medium = padding_bottom | times: 0.8
  assign padding_bottom_mobile = padding_bottom | times: 0.6

  assign menu_height_default = 47
  assign menu_height_medium_default = 42
  assign menu_height_mobile_default = 42
  assign header_icons_height = 34
  assign toolbar_height = 0

  assign transparent_header = false
  if template contains 'collection' and section.settings.transparent_collection
    assign transparent_header = true
  elsif template contains 'article' and section.settings.transparent_article
    assign transparent_header = true
  elsif template == 'index' and section.settings.transparent_home
    assign transparent_header = true
  elsif template == '404'
    assign transparent_header = true
  elsif template.name == 'page' and section.settings.transparent_page
    assign transparent_header = true
  elsif template.name == 'search' and section.settings.transparent_search
    assign transparent_header = true
  elsif template.name == 'product' and section.settings.transparent_product_page
    assign transparent_header = true
  elsif template.name == 'blog' and section.settings.transparent_blog
    assign transparent_header = true
  endif

  assign main_menu_linklist = section.settings.main_menu_linklist | default: 'main-menu'
  assign secondary_menu_linklist = section.settings.secondary_menu_linklist
  assign right_menu_linklist = section.settings.right_menu_linklist
  assign header_default_mode = 'dark'
  if template == 'index'
    assign header_default_mode = 'light'
  elsif template.name == 'product'
    assign header_default_mode = 'dark'
  elsif template.name == 'page'
    assign header_default_mode = 'dark'
  elsif template.name == 'collection'
    assign header_default_mode = collection.metafields.custom.header_observer_mode.value | default: header_default_mode
    assign header_default_mode = header_default_mode | downcase | strip
    unless header_default_mode == 'light' or header_default_mode == 'dark'
      assign header_default_mode = 'dark'
    endunless
  endif
  assign header_default_link = '#000'
  assign header_default_link_hover = '#222'
  if header_default_mode == 'light'
    assign header_default_link = '#fff'
    assign header_default_link_hover = '#f0f0f0'
  endif
  assign logo_variant = section.settings.logo_variant | default: 'dark'
  if template.name == 'product' or template.name == 'page'
    assign logo_variant = 'dark'
  elsif template == 'index' or template.name == 'collection'
    assign logo_variant = header_default_mode
  endif
  assign logo_light_asset = 'RC_LOGO_light.svg'
  assign logo_dark_asset = 'RC_LOGO_dark.svg'
  assign logo_asset = logo_dark_asset
  assign logo_denom = 814 | divided_by: 76
  if logo_variant == 'light'
    assign logo_asset = logo_light_asset
    assign logo_denom = 814 | divided_by: 76
  else
    assign logo_asset = logo_dark_asset
    assign logo_denom = 800 | divided_by: 74
  endif
  assign transparent_logo_asset = logo_asset
  if template.name == 'product' or template.name == 'page'
    assign transparent_logo_asset = logo_dark_asset
  endif
  assign transparent_logo_pdp = section.settings.transparent_logo_pdp
  assign use_transparent_logo_pdp = false
  if template.name == 'product' and section.settings.transparent_product_page and transparent_logo_pdp != blank
    assign use_transparent_logo_pdp = true
  endif

  assign logo_width = '800'
  assign logo_width_15x = logo_width | times: 1.5 | round
  assign logo_width_2x = logo_width | times: 2 | round
  assign logo_width_mobile = '700'
  assign logo_width_mobile_15x = logo_width_mobile | times: 1.5 | round
  assign logo_width_mobile_2x = logo_width_mobile | times: 2 | round
  assign logo_sizes = '(min-width: 750px) ' | append: logo_width | append: 'px, (min-width: ' | append: logo_width_mobile_2x | append: 'px) ' | append: logo_width_mobile | append: 'px, calc((100vw - 64px) * 0.5)'
  assign logo_widths = logo_width | append: ',' | append: logo_width_15x | append: ',' | append: logo_width_2x | append: ',' | append: logo_width_mobile | append: ',' | append: logo_width_mobile_15x | append: ',' | append: logo_width_mobile_2x

  if logo_asset != blank
    assign logo_height = logo_width | divided_by: logo_denom
    assign logo_height_mobile = logo_width_mobile | divided_by: logo_denom
    assign menu_height = logo_height | at_least: menu_height_default
    assign menu_height_medium = logo_height | at_least: menu_height_medium_default
    assign menu_height_mobile = logo_height_mobile | at_least: menu_height_mobile_default
    assign header_height = menu_height | floor | plus: padding_top | plus: padding_bottom
    assign header_height_medium = menu_height_medium | floor | plus: padding_top_medium | plus: padding_bottom_medium
    assign header_height_mobile = menu_height_mobile | floor | plus: padding_top_mobile | plus: padding_bottom_mobile
    assign logo_padding = 50 | divided_by: logo_denom | append: '%'
  else
    assign header_height = menu_height_default | plus: padding_top | plus: padding_bottom
    assign header_height_medium = menu_height_medium_default | plus: padding_top_medium | plus: padding_bottom_medium
    assign header_height_mobile = menu_height_mobile_default | plus: padding_top_mobile | plus: padding_bottom_mobile
    assign logo_width = 'auto'
  endif

  if section.settings.header_style contains 'logo_above'
    assign header_upper_height = logo_height | at_least: header_icons_height
    assign header_upper_height_mobile = logo_height_mobile | at_least: menu_height_mobile_default
    assign header_height = header_upper_height | plus: menu_height_default | plus: padding_top | plus: padding_bottom
    assign header_height_medium = header_upper_height | plus: padding_top_medium | plus: padding_bottom_medium
    assign header_height_mobile = header_upper_height_mobile | plus: padding_top_mobile | plus: padding_bottom_mobile
  endif

  if secondary_menu_linklist != blank and linklists[secondary_menu_linklist].links.size > 0
    assign secondary_menu_height = 0.75 | times: settings.nav_text_size | times: 1.2 | plus: 32
    assign header_height_mobile = header_height_mobile | plus: secondary_menu_height
  endif

  if toolbar_block
    assign toolbar_height = 2.25 | times: settings.nav_text_size

    assign header_height = header_height | plus: toolbar_height
    assign header_height_medium = header_height_medium | plus: toolbar_height
    assign header_height_mobile = header_height_mobile | plus: toolbar_height
  endif

  assign cart_item_count = cart.item_count
  assign cart_icon_as_circle = section.settings.icon_as_circle

  if cart_item_count > 9
    assign cart_item_count = '9+'
  endif

  assign cart_icon_family = section.settings.cart_icon_family
  assign show_icons = section.settings.show_icons
  assign icon_string_cart = 'icon-' | append: cart_icon_family

  capture navlink_cart_classes
    echo 'navlink--cart'

    if cart_icon_as_circle
      echo ' navlink--cart--circle'
    endif

    if cart_icon_as_circle == false and show_icons
      echo ' navlink--cart--icon'
    elsif cart_icon_as_circle == false and show_icons == false
      echo ' navlink--cart--text'
    endif

    if show_icons == false
      echo ' navlink--toplevel'
    endif
  endcapture

  assign highlight_item = section.settings.highlight_item
  assign highlight_item_color = section.settings.highlight_item_color

  capture highlight_style
    if highlight_item_color.alpha != 0 and highlight_item_color != blank
      echo 'style="--highlight: ' | append: highlight_item_color | append: ';"'
    endif
  endcapture
-%}
{%- if section.settings.show_social_icons -%}
  {%- if settings.instagram_link != ''
    or settings.pinterest_link != ''
    or settings.facebook_link != ''
    or settings.twitter_link != ''
    or settings.youtube_link != ''
    or settings.tiktok_link != ''
    or settings.linkedin_link != ''
    or settings.vimeo_link != ''
    or settings.tumblr_link != ''
    or settings.snapchat_link != ''
    or settings.feed_link != ''
  -%}
    {%- assign show_socials = true -%}
  {%- endif -%}
{%- endif -%}

{%- style -%}
  :root {
    --HEADER-HEIGHT: {{ header_height }}px;
    --HEADER-HEIGHT-MEDIUM: {{ header_height_medium }}px;
    --HEADER-HEIGHT-MOBILE: {{ header_height_mobile }}px;

    {% comment %} --icon-add-cart variable is used on PGI and Product upsell block {% endcomment %}
    {%- if cart_icon_family == 'bag' -%}
      --icon-add-cart: var(--ICON-ADD-BAG);
    {%- else -%}
      --icon-add-cart: var(--ICON-ADD-CART);
    {%- endif -%}
  }

  .theme__header {
    --PT: calc({{ padding_top }}px + var(--announcement-height, 36px));
    --PB: {{ padding_bottom }}px;
    isolation: isolate;
    opacity: 1;
    visibility: visible;
    transition:
      opacity 0.16s ease,
      visibility 0s linear;

    {% if show_separator_line %}
      {% unless border_color.alpha == 0.0 or border_color == blank %}
        --border-color: {{ border_color }};
      {% endunless %}
      --border-opacity: {{ section.settings.separator_opacity | times: 0.01 }};
    {% endif %}
  }

  .theme__header[data-header-color-pending='true'] {
    opacity: 0 !important;
    visibility: hidden;
    pointer-events: none;
  }

  .theme__header[data-header-color-pending='true']::before,
  .theme__header[data-header-color-pending='true']::after {
    opacity: 0 !important;
    visibility: hidden !important;
  }

  .theme__header[data-header-color-ready='true'] {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  /* tech debt */
  /* .header__wrapper.js__header__stuck .theme__header[data-header-color-ready='true'] .section-padding,
  .header__wrapper.js__header__stuck .theme__header[data-header-color-ready='true'] .section-padding .header__mobile,
  .header__wrapper.js__header__stuck .theme__header[data-header-color-ready='true'] {
    height: 0;
  } */

  .theme__header__scroll-blur {
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    bottom: calc(var(--header-scroll-reveal-fade-distance, 72px) * -1);
    z-index: -4;
    pointer-events: none;
    opacity: var(--header-scroll-reveal-opacity, 0);
    background: var(
      --header-scroll-reveal-background,
      linear-gradient(180deg, rgba(249, 249, 249, 0.25) 0%, rgba(249, 249, 249, 0) 100%)
    );
    -webkit-backdrop-filter: blur(var(--header-scroll-reveal-blur, 0px));
    backdrop-filter: blur(var(--header-scroll-reveal-blur, 0px));
    -webkit-mask-image: linear-gradient(180deg, #000 0%, #000 58%, transparent 100%);
    mask-image: linear-gradient(180deg, #000 0%, #000 58%, transparent 100%);
    transition:
      opacity 0.35s ease,
      -webkit-backdrop-filter 0.35s ease,
      backdrop-filter 0.35s ease;
    will-change: opacity, backdrop-filter;
  }

  .theme__header.search-open .theme__header__scroll-blur,
  .theme__header:has(.tmenu_item--root.tmenu_item_level_0.tmenu_item_active) .theme__header__scroll-blur,
  body:has(header-drawer.drawer--header.is-open) .theme__header__scroll-blur,
  body:has(side-drawer.is-open) .theme__header__scroll-blur,
  body:has(.drawer.is-open) .theme__header__scroll-blur {
    opacity: 0;
    --header-scroll-reveal-blur: 0px;
    -webkit-backdrop-filter: blur(0);
    backdrop-filter: blur(0);
  }

  /* Desktop collection pages keep the scroll-reveal blur off; on mobile (< 960px) it is
     allowed so the header reveal blur shows on every template (driven by theme.dev.js). */
  @media only screen and (min-width: 960px) {
    .template-collection .theme__header__scroll-blur {
      display: none;
    }
  }

  {%- if logo_asset != blank -%}
    .header__logo__link {
      --logo-padding: 30px;
      --logo-padding_product: {{ logo_padding | times: 0.60 }};
      --logo-width-desktop: {{ logo_width }}px;
      --logo-width-mobile: {{ logo_width_mobile }}px;
      --logo-width-mobile-desktop: 540px;
    }
  {%- endif -%}

  {%- unless transparent_header -%}
    .main-content > .shopify-section:first-of-type .backdrop--linear:before { display: none; }
  {%- endunless -%}

  /* Show the header underlay when the tmenu root item is active */
  .header__wrapper:has(.tmenu_item--root.tmenu_item_level_0.tmenu_item_active) > .underlay {
    visibility: visible;
    opacity: var(--underlay-opacity);
    transition-duration: 0.3s, 0s;
    transition-delay: 0.1s, 0s;
  }
{%- endstyle -%}

{{ 'custom-menu.css' | asset_url | stylesheet_tag }}

{%- capture toolbar -%}
  {%- render 'header-toolbar' block: toolbar_block -%}
{%- endcapture -%}

{%- capture logos -%}
  {%- if transparent_header and logo_asset != blank -%}
    {%- assign has_transparent_logo = true -%}
  {%- endif -%}
  <div class="header__logo header__logo--image{% if has_transparent_logo %} header__logo--has-transparent{% endif %}
    {% unless template == 'index' %} header__logo--small{% endunless %}
  ">
    <a
      class="header__logo__link"
      href="{{ routes.root_url }}"
      data-logo-link
      data-logo-light="{{ logo_light_asset | asset_url }}"
      data-logo-dark="{{ logo_dark_asset | asset_url }}"
      data-logo-default="{{ logo_variant }}"
    >
      <h1>
        {%- if logo_asset != blank -%}
          {%- assign logo_alt = shop.name | strip_html | escape -%}
          <img
            class="logo__img logo__img--color"
            src="{{ logo_asset | asset_url }}"
            width="{{ logo_width }}"
            height="{{ logo_height | round }}"
            alt="{{ logo_alt }}"
            loading="eager"
            fetchpriority="high"
          />
        {%- else -%}
          {%- liquid
            assign classes = ''
            assign title_length = shop.name | size
            assign oneword = true
            if shop.name contains ' ' or shop.name contains '-'
              assign oneword = false
            endif
            if title_length > 15
              assign classes = classes | append: ' header__logo__text--long'
              if oneword
                assign classes = classes | append: ' header__logo__text--break'
              endif
            endif
          -%}
          <div class="header__logo__text {{ classes }}">
            <span>{{ shop.name }}</span>
          </div>
        {%- endif -%}

        {%- if has_transparent_logo -%}
          {%- if use_transparent_logo_pdp -%}
            {%- liquid
              assign alt = transparent_logo_pdp.alt | default: shop.name | strip_html | escape
              render 'image' image: transparent_logo_pdp, width: logo_width_2x, sizes: logo_sizes, widths: logo_widths, aspect_ratio: transparent_logo_pdp.aspect_ratio, alt: alt, modifier: 'logo__img logo__img--transparent', fetchpriority: 'high', preload: true, show_backfill: false
            -%}
          {%- else -%}
            {%- assign transparent_alt = shop.name | strip_html | escape -%}
            <img
              class="logo__img logo__img--transparent"
              src="{{ transparent_logo_asset | asset_url }}"
              width="{{ logo_width }}"
              height="{{ logo_height | round }}"
              alt="{{ transparent_alt }}"
              loading="eager"
              fetchpriority="high"
            />
          {%- endif -%}
        {%- endif -%}
      </h1>
    </a>
    {%- if template.name == 'product' or template contains 'collection' or template contains 'page' or template.name == 'search' -%}
      <div class="header__logo__meta">
        {%- if template.name == 'product' -%}
          {%- assign current_collection = collection | default: product.metafields.custom.collection -%}
          {%- assign has_collection = false -%}
          {%- if current_collection != blank -%}
            {%- assign has_collection = true -%}
          {%- endif -%}
          {%- assign has_type = false -%}
          {%- if product.type != blank -%}
            {%- assign has_type = true -%}
          {%- endif -%}
          <h6 class="header__logo__meta__line">
            {%- if has_collection -%}
              <span class="header__logo__meta__collection">
                {%- assign current_collection_title = current_collection.title | default: current_collection -%}
                {%- if current_collection_title contains ' - ' -%}
                  {%- liquid
                    assign parent_collection_title = current_collection_title | split: ' - ' | first | strip
                    assign child_collection_title = current_collection_title | remove_first: parent_collection_title | remove_first: ' - ' | strip
                  -%}
                  {%- if parent_collection_title != blank -%}
                    {%- if child_collection_title != blank -%}
                      {%- liquid
                        assign parent_collection_handle = current_collection.handle | default: ''
                        if parent_collection_handle == blank and current_collection.url != blank
                          assign parent_collection_handle = current_collection.url | split: '/collections/' | last | split: '?' | first | split: '/' | first
                        endif
                        if parent_collection_handle != blank
                          assign parent_collection_handle = parent_collection_handle | split: '-' | first
                        elsif parent_collection_title != blank
                          assign parent_collection_handle = parent_collection_title | handleize
                        endif
                        assign parent_collection_obj = collections[parent_collection_handle]
                        assign parent_collection_url = current_collection.url
                        if parent_collection_obj != blank
                          assign parent_collection_url = parent_collection_obj.url
                        endif
                      -%}
                      <a href="{{ parent_collection_url }}">{{ parent_collection_title }}</a>
                      <span class="header__logo__meta__separator">&nbsp;/&nbsp;</span>
                      <a class="header__logo__meta__subcollection header__logo__meta__subcollection--no-underline" href="{{ current_collection.url }}">{{ child_collection_title }}</a>
                    {%- else -%}
                      <a href="{{ current_collection.url }}">{{ current_collection.title }}</a>
                    {%- endif -%}
                  {%- else -%}
                    <a href="{{ current_collection.url }}">{{ current_collection.title }}</a>
                  {%- endif -%}
                {%- elsif current_collection.url != blank -%}
                  <a href="{{ current_collection.url }}">{{ current_collection.title }}</a>
                {%- else -%}
                  {%- assign collection_handle = product.metafields.custom.collection | handleize -%}
                  {%-  assign parent_collection_url = '/collections/' | append: collection_handle -%}
                  <a href="{{ parent_collection_url }}">{{ product.metafields.custom.collection }}</a>
                {%- endif -%}
              </span>
            {%- endif -%}
          </h6>
        {%- elsif template contains 'collection' and collection -%}
              <h6 class="header__logo__meta__collection">
            {%- assign collection_title = collection.title -%}
            {%- if collection_title contains ' - ' -%}
              {%- liquid
                assign parent_collection_title = collection_title | split: ' - ' | first | strip
                assign child_collection_title = collection_title | remove_first: parent_collection_title | remove_first: ' - ' | strip
              -%}
              {%- if parent_collection_title != blank -%}
                {%- if child_collection_title != blank -%}
                  {%- liquid
                    assign parent_collection_handle = collection.handle | default: ''
                    if parent_collection_handle == blank and collection.url != blank
                      assign parent_collection_handle = collection.url | split: '/collections/' | last | split: '?' | first | split: '/' | first
                    endif
                    if parent_collection_handle != blank
                      assign parent_collection_handle = parent_collection_handle | split: '-' | first
                    endif
                    assign parent_collection_obj = collections[parent_collection_handle]
                    assign parent_collection_url = collection.url
                    if parent_collection_obj != blank
                      assign parent_collection_url = parent_collection_obj.url
                    endif
                  -%}
                  <a href="{{ parent_collection_url }}">{{ parent_collection_title }}</a>
                  <span class="header__logo__meta__separator">&nbsp;/&nbsp;</span>
                  <span class="header__logo__meta__subcollection">{{ child_collection_title }}</span>
                {%- else -%}
                  <a href="{{ collection.url }}">{{ collection.title }}</a>
                {%- endif -%}
              {%- else -%}
                <span>{{ collection.title }}</span>
              {%- endif -%}
            {%- else -%}
              <span>{{ collection.title }}</span>
            {%- endif -%}
          </h6>
        {%  elsif template contains 'page' %}
          <h6 class="header__logo__meta__page">
            <span>{{ page.title }}</span>
          </h6>
        {%- elsif template.name == 'search' -%}
          <h6 class="header__logo__meta__page">
            {%- if search.terms != blank -%}
              <span>{{ 'general.search.title' | t }}</span>
            {%- endif -%}
          </h6>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
{%- endcapture -%}

{%- capture cart_status -%}
  <div class="navlink__cart__content">
    <span class="{% if show_icons == false %}navtext{% else %}visually-hidden{% endif %}">{{ 'layout.header.cart' | t }}</span>

    <span class="header__cart__status__holder">
      <cart-count class="header__cart__status{% if show_icons == false %} navtext{% endif %}" data-status-separator=": " data-cart-count="{{ cart.item_count }}" data-limit="10">
        {{ cart_item_count }}
      </cart-count>

      {%- if cart_icon_as_circle == false -%}
        {%- render 'icon-cart' -%}
      {%- endif -%}
    </span>
  </div>
{%- endcapture -%}

{%- capture cta -%}
  {%- if section.settings.enable_call_to_action and section.settings.button_text != blank -%}
    <div class="header__desktop__button header__desktop__button--cta">
      <a class="btn btn--small btn--solid {{ section.settings.button_type }}" href="{{ section.settings.button_link }}">
        <span>{{ section.settings.button_text | escape }}</span>
      </a>
    </div>
  {%- endif -%}
{%- endcapture -%}

{%- liquid
  assign languages = false
  assign countries = false
  assign header_popouts = false

  assign show_locale_selector = section.settings.show_locale_selector
  assign show_locale_code = section.settings.show_locale_code
  assign show_locale_selector_toolbar = toolbar_block.settings.show_locale_selector

  assign show_globe_icon = section.settings.show_globe_icon
  assign show_globe_icon_toolbar = toolbar_block.settings.show_globe_icon

  assign show_country_selector = section.settings.show_country_selector
  assign show_country_selector_toolbar = toolbar_block.settings.show_country_selector

  assign show_country_name = section.settings.show_country_name
  assign show_country_name_toolbar = toolbar_block.settings.show_country_name

  assign show_country_flag = section.settings.show_country_flag
  assign show_country_flag_toolbar = toolbar_block.settings.show_country_flag

  if show_locale_selector and localization.available_languages.size > 1
    assign languages = true
  endif

  if show_locale_selector_toolbar and localization.available_languages.size > 1
    assign languages_toolbar = true
  endif

  if show_country_selector and localization.available_countries.size > 1
    assign countries = true
  endif

  if show_country_selector_toolbar and localization.available_countries.size > 1
    assign countries_toolbar = true
  endif

  if languages or countries
    assign header_popouts = true
  endif

  if languages or languages_toolbar or countries or countries_toolbar
    assign header_popouts_mobile = true
  endif
-%}

{%- capture minimal -%}
  <div class="header__mobile__left">
    <button
      class="header__mobile__button header__mobile__hamburger{% if show_icons == false %} navlink navlink--toplevel{% endif %}{% if settings.type_nav_caps %} caps{% endif %}"
      data-drawer-toggle="hamburger"
      data-open-label="{{ 'general.accessibility.show_menu' | t | escape }}"
      data-close-label="{{ 'general.accessibility.close' | t | escape }}"
      aria-label="{{ 'general.accessibility.show_menu' | t }}"
      aria-haspopup="true"
      aria-expanded="false"
      aria-controls="header-menu"
    >
      <span class="header__mobile__hamburger-icon header__mobile__hamburger-icon--menu" aria-hidden="true">
        {%- render 'icon-menu' -%}
      </span>
      <span class="header__mobile__hamburger-icon header__mobile__hamburger-icon--close" aria-hidden="true">
        {%- render 'icon-cancel' -%}
      </span>
    </button>
  </div>

  {{ logos }}

  <div class="header__mobile__right{% if settings.type_nav_caps %} caps{% endif %}">
    {{ cta }}

    {%- if header_popouts -%}
      {%- assign unique = section.id | append: '-header-mobile-top' -%}
      <div class="header__mobile__button desktop">
        {%- render 'localization',
          unique: unique,
          show_locale_selector: show_locale_selector,
          show_locale_code: show_locale_code,
