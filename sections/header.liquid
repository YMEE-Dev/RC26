      document.addEventListener('theme:tmenu:state', syncLogoWithHeaderState);

      let sectionsToObserve = selectAll(
        'main .shopify-section section, main .shopify-section collection-component, main .shopify-section [data-section-id]'
      );
      if (!sectionsToObserve.length) {
        revealResolvedHeader();
        return;
      }

      const computeRootMargin = () => {
        const h = window.innerHeight || document.documentElement.clientHeight || 0;
        const headerHeight = getHeaderHeight();
        // Pull the root box down to just beneath the header so we sample what's under it.
        const top = `-${headerHeight}px`;
        const target = 200;
        const bottom = target - h; // negative when h > target
        return `${top} 0px ${bottom}px 0px`;
      };

      const marginToPx = (value, axisLength) => {
        if (value.endsWith && value.endsWith('%')) {
          return (parseFloat(value) / 100) * axisLength;
        }
        return parseFloat(value);
      };

      const parseRootMargin = (marginStr) => {
        const [top, right, bottom, left] = marginStr.split(' ');
        return {
          top: marginToPx(top, window.innerHeight),
          right: marginToPx(right, window.innerWidth),
          bottom: marginToPx(bottom, window.innerHeight),
          left: marginToPx(left, window.innerWidth),
        };
      };

      const createOverlay = (label, color) => {
        const existing = document.querySelector(`[data-header-observer-overlay="${label}"]`);
        if (existing) return existing;
        const el = document.createElement('div');
        el.dataset.headerObserverOverlay = label;
        el.classList.add('header-observer-overlay');
        el.style.setProperty('--overlay-color', color);
        el.textContent = label;
        document.body.appendChild(el);
        return el;
      };

      const updateOverlayPosition = (el, marginStr) => {
        const m = parseRootMargin(marginStr);
        const top = 0 - m.top;
        const left = 0 - m.left;
        const right = window.innerWidth + m.right;
        const bottom = window.innerHeight + m.bottom;
        el.style.top = `${top}px`;
        el.style.left = `${left}px`;
        el.style.width = `${right - left}px`;
        el.style.height = `${bottom - top}px`;
      };

      const luminanceCache = new WeakMap();
      const mediaReadyListeners = new WeakSet();
      const deferredRevealTimers = new WeakMap();
      let currentObservedSection = null;
      const mediaSelector = 'img, video';
      const sectionMediaRevealMargin = 200;
      const deferredRevealTimeout = 1400;
      const getHeaderProbeBand = () => {
        const headerHeight = getHeaderHeight();
        const top = Math.max(0, headerHeight);
        const bottom = Math.min(window.innerHeight, top + 32);

        return {top, bottom};
      };
      const getHeaderProbePoints = () => {
        const band = getHeaderProbeBand();
        const y = Math.min(window.innerHeight - 1, Math.max(1, band.top + (band.bottom - band.top) / 2));

        return [0.5, 0.18, 0.82].map((ratio) => ({
          x: Math.min(window.innerWidth - 1, Math.max(1, window.innerWidth * ratio)),
          y,
        }));
      };
      const mediaContainsPoint = (mediaEl, point) => {
        const rect = mediaEl.getBoundingClientRect();
        return point.x >= rect.left && point.x <= rect.right && point.y >= rect.top && point.y <= rect.bottom;
      };
      const mediaOverlapsProbeBand = (mediaEl) => {
        const rect = mediaEl.getBoundingClientRect();
        const band = getHeaderProbeBand();

        if (rect.width <= 0 || rect.height <= 0) return false;

        return rect.bottom > band.top && rect.top < band.bottom && rect.right > 0 && rect.left < window.innerWidth;
      };
      const getMediaCandidatesFromElement = (element) => {
        if (!(element instanceof Element)) return [];

        const candidates = [];
        if (element.matches(mediaSelector)) {
          candidates.push(element);
        }

        element.querySelectorAll(mediaSelector).forEach((mediaEl) => {
          candidates.push(mediaEl);
        });

        return candidates;
      };
      const getClampedProbePointForMedia = (mediaEl) => {
        const rect = mediaEl.getBoundingClientRect();
        const preferredPoint = getHeaderProbePoints()[0];

        return {
          x: clamp(preferredPoint.x, rect.left + 1, rect.right - 1),
          y: clamp(preferredPoint.y, rect.top + 1, rect.bottom - 1),
        };
      };
      const pickMediaFromElements = (elements, point, sectionEl) => {
        const matches = [];

        elements.forEach((element, index) => {
          getMediaCandidatesFromElement(element).forEach((mediaEl) => {
            if (!mediaContainsPoint(mediaEl, point) || !mediaOverlapsProbeBand(mediaEl)) return;

            matches.push({
              mediaEl,
              depth: index,
              inSection: Boolean(sectionEl && sectionEl.contains(mediaEl)),
            });
          });
        });

        if (!matches.length) return null;

        matches.sort((a, b) => {
          if (a.inSection !== b.inSection) {
            return a.inSection ? -1 : 1;
          }

          return a.depth - b.depth;
        });

        return matches[0].mediaEl;
      };
      const findMediaUnderHeader = (sectionEl) => {
        const probePoints = getHeaderProbePoints();

        for (const point of probePoints) {
          const elements = document.elementsFromPoint(point.x, point.y);
          const mediaEl = pickMediaFromElements(elements, point, sectionEl);

          if (mediaEl) {
            debugLog('Picked media from header probe', {
              section: getSectionLabel(sectionEl),
              point: {
                x: roundForLog(point.x),
                y: roundForLog(point.y),
              },
              ...getMediaDescriptor(mediaEl),
            });

            return {
              mediaEl,
              point,
            };
          }
        }

        const sectionMedia = Array.from(sectionEl.querySelectorAll(mediaSelector)).find((mediaEl) =>
          mediaOverlapsProbeBand(mediaEl)
        );

        if (sectionMedia) {
          debugLog('Picked overlapping section media', {
            section: getSectionLabel(sectionEl),
            ...getMediaDescriptor(sectionMedia),
          });
        }

        if (!sectionMedia) return null;

        return {
          mediaEl: sectionMedia,
          point: getClampedProbePointForMedia(sectionMedia),
