          luminance: roundForLog(luminance),
          source,
          threshold: roundForLog(nearWhiteLuminanceThreshold),
          section: getSectionLabel(sectionEl),
          resultingMode: luminance >= nearWhiteLuminanceThreshold ? 'dark' : 'light',
