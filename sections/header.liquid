        return {
          tag: mediaEl.tagName || 'UNKNOWN',
        };
      };

      const watchMediaReadiness = (sectionEl, mediaEl) => {
        if (!mediaEl || mediaReadyListeners.has(mediaEl)) return;

        const eventNames = isImageElement(mediaEl)
          ? ['load', 'error']
          : ['loadeddata', 'loadedmetadata', 'canplay', 'error'];

        const onMediaReady = (event) => {
          eventNames.forEach((eventName) => {
            mediaEl.removeEventListener(eventName, onMediaReady);
          });

          mediaReadyListeners.delete(mediaEl);
          luminanceCache.delete(sectionEl);

          debugLog('Media readiness event received', {
            section: getSectionLabel(sectionEl),
            eventType: event.type,
            ...getMediaDescriptor(mediaEl),
          });

          if (currentObservedSection === sectionEl) {
            scheduleApply(sectionEl);
          }
        };

        mediaReadyListeners.add(mediaEl);
        eventNames.forEach((eventName) => {
          mediaEl.addEventListener(eventName, onMediaReady);
        });

        debugLog('Waiting for media readiness before computing luminance', {
          section: getSectionLabel(sectionEl),
          ...getMediaDescriptor(mediaEl),
        });
      };

      const clearDeferredRevealTimer = (sectionEl) => {
        const timer = deferredRevealTimers.get(sectionEl);
        if (!timer) return;
        clearTimeout(timer);
        deferredRevealTimers.delete(sectionEl);
      };

      const queueDeferredReveal = (sectionEl) => {
        if (deferredRevealTimers.has(sectionEl)) return;

        const timer = window.setTimeout(() => {
          deferredRevealTimers.delete(sectionEl);

          if (
            currentObservedSection !== sectionEl ||
            !headerWrapper ||
            headerWrapper.dataset.headerColorReady === 'true'
          ) {
            return;
          }

          debugLog('Revealed header after deferred media wait timeout', {
            section: getSectionLabel(sectionEl),
            timeoutMs: deferredRevealTimeout,
          });
          revealResolvedHeader();
        }, deferredRevealTimeout);

        deferredRevealTimers.set(sectionEl, timer);
      };

      const isRelevantSectionMedia = (mediaEl) => {
        const rect = mediaEl.getBoundingClientRect();
        const band = getHeaderProbeBand();

        if (rect.right <= 0 || rect.left >= window.innerWidth) return false;

        if (rect.width > 0 || rect.height > 0) {
          return rect.bottom > band.top - sectionMediaRevealMargin && rect.top < band.bottom + sectionMediaRevealMargin;
        }

        return rect.top < band.bottom + sectionMediaRevealMargin;
      };

      const getPendingSectionMedia = (sectionEl) =>
        Array.from(sectionEl.querySelectorAll(mediaSelector))
          .filter((mediaEl) => isRelevantSectionMedia(mediaEl))
          .slice(0, 3)
          .filter((mediaEl) => isPendingMedia(mediaEl));

      const deferRevealUntilMediaSettles = (sectionEl, source) => {
        if (source !== 'background') {
          clearDeferredRevealTimer(sectionEl);
          return false;
        }

        const pendingMedia = getPendingSectionMedia(sectionEl);
        if (!pendingMedia.length) {
