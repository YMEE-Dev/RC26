        }

        if (isVideoElement(mediaEl)) {
          return {
            tag: 'VIDEO',
            poster: mediaEl.poster || null,
            readyState: mediaEl.readyState,
            videoWidth: mediaEl.videoWidth,
            videoHeight: mediaEl.videoHeight,
            currentSrc: mediaEl.currentSrc || null,
          };
