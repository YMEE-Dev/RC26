        ensureOverlay();
      };

      const resetObserver = () => {
        intersectionObserver && intersectionObserver.disconnect();
        startObserver();
      };

      startObserver();
      window.addEventListener('resize', resetObserver);
    };

    window.addEventListener(
      'load',
      () => {
        initHeaderObserver();
      },
      {once: true}
    );
  });
