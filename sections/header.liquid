        updateOverlayPosition(overlay, rootMargin);
      };

      const onIntersect = (entries) => {
        const entry = pickTopEntry(entries);
        if (!entry) return;
        currentObservedSection = entry.target;
        debugLog('Intersection selected section', {
          section: getSectionLabel(entry.target),
          intersectionRatio: roundForLog(entry.intersectionRatio),
          top: roundForLog(entry.boundingClientRect.top),
