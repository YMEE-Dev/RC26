<!-- /sections/section-heading-image.liquid -->
{%- liquid
  assign color_scheme = 'color-' | append: section.settings.color_scheme
-%}

{%- style -%}
  #HeadingImage--{{ section.id }} {
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<section
  id="HeadingImage--{{ section.id }}"
  class="heading-image section-padding {{ color_scheme }}"
  data-section-id="{{ section.id }}"
  data-section-type="heading-image"
>
  {%- if section.blocks.size > 0 -%}
    <div class="heading-image__wrapper text-center">
      <div class="heading-image__inner">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'heading' -%}
              {%- if block.settings.title != blank -%}
                {%- liquid
                  assign heading_tag = 'h2'
                  unless block.settings.heading_tag == 'automatic' or block.settings.heading_tag == blank
                    assign heading_tag = block.settings.heading_tag
                  endunless
                -%}
                <div class="heading-image__heading-wrap" {{ block.shopify_attributes }}>
                  <{{ heading_tag }}
                    class="heading-image__heading {{ block.settings.heading_font_size }}"
                  >
                    {{ block.settings.title }}
                  </{{ heading_tag }}>
                </div>
              {%- endif -%}

            {%- when 'image' -%}
              {%- if block.settings.image != blank -%}
                {%- liquid
                  assign image = block.settings.image
                  assign image_container_max = 1232

                  capture sizes
                    assign image_size_mobile = 'calc(100vw - 32px)'
                    assign image_size_desktop = image_container_max | append: 'px'
                    echo '(min-width: 750px) ' | append: image_size_desktop | append: ', ' | append: image_size_mobile
                  endcapture
                -%}
                <div
                  class="heading-image__media"
                  {{ block.shopify_attributes }}
                >
                  {%- render 'image', image: image, sizes: sizes -%}
                </div>
              {%- endif -%}
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  {%- else -%}
    {%- render 'no-blocks' -%}
  {%- endif -%}
</section>

{% stylesheet %}
  .heading-image__wrapper {
    width: 100%;
    margin-left: auto;
    margin-right: auto;
  }

  .heading-image__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    width: 100%;
  }

  .heading-image__heading-wrap {
    width: 100%;
    margin: 0 0 1.5rem;
  }

  .heading-image__heading-wrap:last-child {
    margin-bottom: 0;
  }

  .heading-image__heading {
    margin: 0;
    line-height: 1.3;
    max-width: 100%;
  }

  .heading-image__media {
    width: 100%;
    max-width: 1232px;
    margin: 0 auto;
  }

  .heading-image__media img {
    width: 100%;
    height: auto;
    display: block;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Heading and image",
  "tag": "section",
  "class": "section-heading-image",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Layout width",
      "default": "wrapper--narrow",
      "options": [
        { "value": "wrapper--full-padded", "label": "Full width padded" },
        { "value": "wrapper", "label": "Normal" },
        { "value": "wrapper--wide", "label": "Wide" },
        { "value": "wrapper--narrow", "label": "Narrow" }
      ]
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Bottom",
      "default": 60
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "Color scheme"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "A complimentary 2-years program designed to protect your Roberto Coin jewel against theft, robbery, and irreparable accidental damage."
        },
        {
          "type": "select",
          "id": "heading_font_size",
          "label": "Heading size",
          "default": "heading-medium",
          "options": [
            { "value": "heading-mini", "label": "Mini" },
            { "value": "heading-x-small", "label": "Extra small" },
            { "value": "heading-small", "label": "Small" },
            { "value": "heading-medium", "label": "Medium" },
            { "value": "heading-large", "label": "Large" },
            { "value": "heading-x-large", "label": "Extra large" }
          ]
        },
        {
          "type": "select",
          "id": "heading_tag",
          "label": "Heading SEO tag",
          "default": "automatic",
          "options": [
            { "value": "automatic", "label": "Automatic" },
            { "value": "h1", "label": "H1" },
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" },
            { "value": "h4", "label": "H4" },
            { "value": "h5", "label": "H5" },
            { "value": "h6", "label": "H6" }
          ]
        }
      ]
    },
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Heading and image",
      "category": "Text",
      "blocks": [
        {
          "type": "heading",
          "settings": {
            "title": "A complimentary 2-years program designed to protect your Roberto Coin jewel against theft, robbery, and irreparable accidental damage.",
            "heading_font_size": "heading-medium"
          }
        },
        {
          "type": "image"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "aside", "footer"]
  }
}
{% endschema %}
