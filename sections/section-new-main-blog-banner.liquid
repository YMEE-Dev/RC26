<!-- /sections/section-new-main-blog-banner.liquid -->
{%- liquid
  assign color_scheme = 'color-' | append: section.settings.color_scheme
  assign subheading_text = ''
  if blog != blank
    if section.settings.subheading != blank
      assign subheading_text = section.settings.subheading
    else
      assign subheading_text = section.settings.subheading_prefix | append: blog.title
    endif
  endif
-%}

{%- style -%}
  #NewMainBlogBanner--{{ section.id }} {
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
    padding-inline:  var(--outer);
  }
  
{%- endstyle -%}

<section
  id="NewMainBlogBanner--{{ section.id }}"
  class="new-main-blog-banner section-padding {{ color_scheme }}"
  data-section-id="{{ section.id }}"
  data-section-type="new-main-blog-banner"
  data-blog-handle="{{ blog.handle | default: 'all' }}"
>
  <div class="new-main-blog-banner__wrapper {{ section.settings.width }}" id="blogBannerContent">
    <div class="blog-banner-loading">
      <div class="spinner"></div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('[data-section-type="new-main-blog-banner"]');
    const container = document.getElementById('blogBannerContent');
    const STOREFRONT_TOKEN = "{{ shop.metaobjects.storefront_access_token.value }}";
    const SHOP_DOMAIN = "{{ shop.domain }}";
    
    // Get current blog handle from URL
    const currentPath = window.location.pathname;
    const blogMatch = currentPath.match(/\/blogs\/([^\/]+)/);
    const currentBlogHandle = blogMatch ? blogMatch[1] : 'all';
    const isAllBlogs = currentBlogHandle === 'all';
    const articleQuery = isAllBlogs 
    ? `{
        articles(first: 1, sortKey: PUBLISHED_AT, reverse: true) {
          nodes {
            title
            handle
            excerpt
            tags
            image {
              url
              altText
            }
            blog {
              handle
            }
          }
        }
      }`
    : `{
        blog(handle: "${currentBlogHandle}") {
          articles(first: 250, sortKey: PUBLISHED_AT, reverse: true) {
            nodes {
              title
              handle
              excerpt
              tags
              image {
                url
                altText
              }
              blog {
                handle
              }
            }
          }
        }
      }`;
    fetch(`https://${SHOP_DOMAIN}/api/2026-01/graphql.json`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "X-Shopify-Storefront-Access-Token": STOREFRONT_TOKEN
      },
      body: JSON.stringify({ query: articleQuery })
    })
    .then(res => res.json())
    .then(data => {
      let article;
      
      if (isAllBlogs) {
        article = data.data.articles.nodes[0];
      } else {
        article = data.data.blog?.articles?.nodes[0];
      }
      
      if (!article) {
        container.innerHTML = '<p class="new-main-blog-banner__empty">{{ section.settings.empty_message | default: "No posts yet." }}</p>';
        return;
      }
      
      const articleUrl = `/blogs/${article.blog.handle}/${article.handle}`;
      
      // Check if custom image exists, otherwise use article image
      const settingsImageUrl = '{{ section.settings.image | img_url: "master" }}';
      const hasSettingsImage = '{{ section.settings.image }}' !== '';
      const imageUrl = hasSettingsImage ? settingsImageUrl : (article.image?.url || '');
      const imageAlt = '{{ section.settings.image_alt }}' || article.image?.altText || article.title;
      
      const subheading = '{{ subheading_text }}';
      const showSubheading = {{ section.settings.show_subheading }};
      const showDescription = {{ section.settings.show_description }};
      
      const buttonText = '{{ section.settings.button_text | default: "Read story" }}';
      const buttonStyle = '{{ section.settings.button_style }}';
      const buttonSize = '{{ section.settings.button_size }}';
      const buttonType = '{{ section.settings.button_type }}';
      
      const excerpt = article.excerpt ;
      
      container.innerHTML = `
        <div class="new-main-blog-banner__media">
          ${imageUrl ? `
            <a href="${articleUrl}" class="new-main-blog-banner__media-link">
              <img src="${imageUrl}" alt="${imageAlt}" width="1000" height="1000">
            </a>
          ` : ''}
        </div>
        
        <div class="new-main-blog-banner__content">
          <div class="new-main-blog-banner__text">
            ${showSubheading && subheading ? `
              <p class="new-main-blog-banner__subheading">${subheading.toUpperCase()}</p>
            ` : ''}
            <h1 class="new-main-blog-banner__heading {{ section.settings.heading_font_size }}">
              <a href="${articleUrl}">${article.title}</a>
            </h1>
            ${showDescription && excerpt ? `
              <div class="new-main-blog-banner__description rte">
                ${excerpt}
              </div>
            ` : ''}
          </div>
          <div class="new-main-blog-banner__button-wrap">
            <a
              href="${articleUrl}"
              class="btn ${buttonStyle} ${buttonSize} ${buttonType} new-main-blog-banner__button"
            >
              ${buttonText}
            </a>
          </div>
        </div>
      `;
    })
    .catch(err => {
      console.error('Error loading blog banner:', err);
      container.innerHTML = '<p class="new-main-blog-banner__empty">Error loading content.</p>';
    });
  });
</script>

{% stylesheet %}
  .blog-banner-loading {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 60px;
    min-height: 300px;
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 4px solid #ddd;
    border-top-color: #333;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .new-main-blog-banner__wrapper {
    width: 100%;
    margin-left: auto;
    margin-right: auto;
  }

  .new-main-blog-banner__media {
    width: 100%;
    margin-bottom: 40px;
    overflow: hidden;
  }

  .new-main-blog-banner__media-link {
    display: block;
  }

  .new-main-blog-banner__media img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .new-main-blog-banner__content {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .new-main-blog-banner__text {
    flex: 1;
    min-width: 0;
  }

  @media (max-width: 768px) {
    .new-main-blog-banner__text,.new-main-blog-banner__button {
    min-width: 50% !important;
  }
  }
  @media (max-width: 425px) {
    .new-main-blog-banner__text,.new-main-blog-banner__button {
    min-width: 100% !important;
  }
  .new-main-blog-banner__button-wrap {
    width: 100%;
  }
  .blog-listing__card-title {
    font-size: 20px;
    line-height: 26px !important;
}
  }
  .new-main-blog-banner__subheading {
    margin: 0 0 10px;
    color: var(--000000, #000);

    /* RC26/Nav (ALL CAPS) */
    font-family: Inter;
    font-size: 12px;
    font-style: normal;
    font-weight: 400;
    line-height: 20px; /* 166.667% */
    letter-spacing: 1.2px;
    text-transform: uppercase;
  }

  .new-main-blog-banner__heading {
    margin: 0 0 20px;
    line-height: 1.2;
  }

  .new-main-blog-banner__heading a {
    text-decoration: none;
    color: inherit;
  }

  /* .new-main-blog-banner__heading a:hover {
    text-decoration: underline;
  } */

  .new-main-blog-banner__description {
    margin: 0;
    color: var(--000000, #000);

    /* RC26/Body */
    font-family: Inter;
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 22px; /* 157.143% */
  }

  .new-main-blog-banner__description p {
    margin: 0 0 0.5em;
  }

  .new-main-blog-banner__description p:last-child {
    margin-bottom: 0;
  }

  .new-main-blog-banner__button-wrap {
    flex-shrink: 0;
    align-self: center;
  }

  .new-main-blog-banner__empty {
    margin: 0;
    text-align: center;
    padding: 2rem;
  }

  .new-main-blog-banner__button {
    min-width: 396px;
    text-align: center;

    /* RC26/Button (ALL CAPS) */
    font-family: Inter;
    font-size: 12px;
    font-style: normal;
    font-weight: 600;
    line-height: 20px; /* 166.667% */
    letter-spacing: 1.2px;
    text-transform: uppercase;
  }
  .new-main-blog-banner__button:hover {
    text-decoration: none;
    background-color: var(--000000, #000);
    color: var(--FFFFFF, #FFF);
  }
  @media (max-width: 425px) {
    .new-main-blog-banner__button {
      min-width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Blog banner",
  "tag": "section",
  "class": "section-new-main-blog-banner",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Banner image",
      "info": "Overrides the latest article's featured image when set. Leave blank to use the article image."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "info": "Optional. Leave blank to use the article title."
    },
    {
      "type": "header",
      "content": "Subheading"
    },
    {
      "type": "checkbox", 
      "id": "show_subheading",
      "label": "Show subheading",
      "default": true
    },
    {
      "type": "text",
      "id": "subheading_prefix",
      "label": "Subheading prefix",
      "default": "Latest in #",
      "info": "Shown before the blog title. Leave blank to show only blog title."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading override",
      "info": "Leave blank to use blog title (e.g. Celebrity). Set to override (e.g. FASHION)."
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "range",
      "id": "description_length",
      "min": 80,
      "max": 300,
      "step": 20,
      "unit": "chr",
      "label": "Description length",
      "default": 120
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Read story"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "default": "btn--outline",
      "options": [
        { "value": "btn--solid", "label": "Solid" },
        { "value": "btn--outline", "label": "Outline" },
        { "value": "btn--text", "label": "Text" }
      ]
    },
    {
      "type": "select",
      "id": "button_type",
      "label": "Button color",
      "default": "btn--black",
      "options": [
        { "value": "btn--black", "label": "Black" },
        { "value": "btn--white", "label": "White" },
        { "value": "btn--primary", "label": "Primary" },
        { "value": "btn--secondary", "label": "Secondary" }
      ]
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "Button size",
      "default": "",
      "options": [
        { "value": "btn--small", "label": "Small" },
        { "value": "", "label": "Medium" },
        { "value": "btn--large", "label": "Large" }
      ]
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "heading_font_size",
      "label": "Heading size",
      "default": "heading-large",
      "options": [
        { "value": "heading-mini", "label": "Mini" },
        { "value": "heading-x-small", "label": "Extra small" },
        { "value": "heading-small", "label": "Small" },
        { "value": "heading-medium", "label": "Medium" },
        { "value": "heading-large", "label": "Large" },
        { "value": "heading-x-large", "label": "Extra large" }
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Layout width",
      "default": "wrapper",
      "options": [
        { "value": "wrapper--full-padded", "label": "Full width padded" },
        { "value": "wrapper", "label": "Normal" },
        { "value": "wrapper--wide", "label": "Wide" },
        { "value": "wrapper--narrow", "label": "Narrow" },
        { "value": "wrapper--custom", "label": "Custom (max-width: 1232px)" }
      ]
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Bottom",
      "default": 40
    },
    {
      "type": "header",
      "content": "Empty state"
    },
    {
      "type": "text",
      "id": "empty_message",
      "label": "Message when no posts",
      "default": "No posts yet."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "Color scheme"
    }
  ],
  "presets": [
    {
      "name": "Blog banner",
      "category": "Blog"
    }
  ],
  "disabled_on": {
    "groups": ["header", "aside", "footer"]
  }
}
{% endschema %}
