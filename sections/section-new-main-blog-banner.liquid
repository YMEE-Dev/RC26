<!-- /sections/section-new-main-blog-banner.liquid -->
{%- liquid
  assign color_scheme = 'color-' | append: section.settings.color_scheme
  assign subheading_text = ''
  assign featured_article = blank
  assign banner_image = section.settings.image
  assign banner_alt = section.settings.image_alt
  assign description_text = ''
  assign data_blog_handle = 'all'

  if banner_image != blank and banner_image.value != blank
    assign banner_image = banner_image.value
  endif

  if blog != blank
    assign featured_article = blog.articles.first
    assign data_blog_handle = blog.handle | default: data_blog_handle

    if section.settings.subheading != blank
      assign subheading_text = section.settings.subheading
    else
      assign subheading_text = section.settings.subheading_prefix | append: blog.title
    endif
  else
    assign latest_article = blank
    for blog_kv in blogs
      assign candidate_blog = blog_kv[1]
      if candidate_blog != blank
        assign candidate_article = candidate_blog.articles.first
        if candidate_article != blank
          if latest_article == blank
            assign latest_article = candidate_article
          elsif candidate_article.published_at > latest_article.published_at
            assign latest_article = candidate_article
          endif
        endif
      endif
    endfor
    assign featured_article = latest_article
  endif

  if featured_article != blank
    assign data_blog_handle = featured_article.blog.handle | default: data_blog_handle

    if banner_image == blank
      assign banner_image = featured_article.image
    endif

    if banner_alt == blank
      assign banner_alt = featured_article.title
    endif

    if subheading_text == blank
      if section.settings.subheading != blank
        assign subheading_text = section.settings.subheading
      else
        assign subheading_text = section.settings.subheading_prefix | append: featured_article.blog.title
      endif
    endif

    assign description_text = featured_article.excerpt_or_content | strip_html | strip | truncate: section.settings.description_length
  endif
-%}

{%- style -%}
  #NewMainBlogBanner--{{ section.id }} {
    --PT-BASE: {{ section.settings.padding_top }}px;
    --PT: var(--PT-BASE);
    --PB: {{ section.settings.padding_bottom }}px;
  }

  @media (min-width: 750px) and (max-width: 1024px) {
    #NewMainBlogBanner--{{ section.id }} {
      --PT: calc(var(--PT-BASE) + 100px);
    }
  }

  #NewMainBlogBanner--{{ section.id }}.new-main-blog-banner {
    --section-heading-font: var(--FONT-STACK-HEADING, 'Portrait LS', serif);
    --section-heading-style: var(--FONT-STYLE-HEADING, normal);
    --section-heading-weight: var(--FONT-WEIGHT-HEADING, 500);
    --section-heading-line-height: var(--LINE-HEIGHT-DISPLAY-L, 1.2);
  }
{%- endstyle -%}

<section
  id="NewMainBlogBanner--{{ section.id }}"
  class="new-main-blog-banner section-padding {{ color_scheme }}"
  data-section-id="{{ section.id }}"
  data-section-type="new-main-blog-banner"
  data-blog-handle="{{ data_blog_handle | escape }}"
>
  <div class="new-main-blog-banner__wrapper {{ section.settings.width }}">
    {%- if featured_article != blank -%}
      <div class="new-main-blog-banner__media">
        {%- if banner_image != blank -%}
          <a href="{{ featured_article.url }}" class="new-main-blog-banner__media-link">
            {%- if banner_image.width != blank -%}
              {{
                banner_image
                | image_url: width: 2000
                | image_tag: alt: banner_alt, width: 1000, height: 1000, loading: 'lazy'
              }}
            {%- else -%}
              <img
                src="{{ banner_image | escape }}"
                alt="{{ banner_alt | escape }}"
                width="1000"
                height="1000"
                loading="lazy"
              >
            {%- endif -%}
          </a>
        {%- endif -%}
      </div>

      <div class="new-main-blog-banner__content">
        <div class="new-main-blog-banner__text">
          {%- if section.settings.show_subheading and subheading_text != blank -%}
            <p class="new-main-blog-banner__subheading">{{ subheading_text | upcase }}</p>
          {%- endif -%}

          <h2 class="new-main-blog-banner__heading {{ section.settings.heading_font_size }}">
            <a class="h2" href="{{ featured_article.url }}">{{ featured_article.title | escape }}</a>
          </h2>

          {%- if section.settings.show_description and description_text != blank -%}
            <div class="new-main-blog-banner__description rte">
              <p>{{ description_text }}</p>
            </div>
          {%- endif -%}
        </div>

        <div class="new-main-blog-banner__button-wrap">
          <a
            href="{{ featured_article.url }}"
            class="btn {{ section.settings.button_style }} {{ section.settings.button_type }} {{ section.settings.button_size }} new-main-blog-banner__button"
          >
            {{ section.settings.button_text | default: 'Read story' | escape }}
          </a>
        </div>
      </div>
    {%- else -%}
      <p class="new-main-blog-banner__empty">{{ section.settings.empty_message | default: 'No posts yet.' }}</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .blog-banner-loading {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 60px;
    min-height: 300px;
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 4px solid #ddd;
    border-top-color: #333;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .new-main-blog-banner__wrapper {
    width: 100%;
    margin-left: auto;
    margin-right: auto;
  }

  .new-main-blog-banner__media {
    width: 100%;
    margin-bottom: 40px;
    overflow: hidden;
  }

  .new-main-blog-banner__media-link {
    display: block;
  }

  .new-main-blog-banner__media img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .new-main-blog-banner__content {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .new-main-blog-banner__text {
    flex: 1;
    min-width: 0;
  }

  @media (max-width: 768px) {
    .new-main-blog-banner__text,
    .new-main-blog-banner__button {
      min-width: 50% !important;
    }
    .new-main-blog-banner__button-wrap {
      display: none;
    }
  }
  @media (max-width: 425px) {
    .new-main-blog-banner__text,
    .new-main-blog-banner__button {
      min-width: 100% !important;
    }
    .new-main-blog-banner__button-wrap {
      width: 100%;
    }
    .blog-listing__card-title {
      font-size: 20px;
      line-height: 26px !important;
    }
    .blog-listing__card-excerpt {
      font-size: 12px;
    }
  }
  .new-main-blog-banner__subheading {
    margin: 0 0 10px;
    color: var(--000000, #000);

    /* RC26/Nav (ALL CAPS) */
    font-family: Inter;
    font-size: 12px;
    font-style: normal;
    font-weight: 400;
    line-height: 20px; /* 166.667% */
    letter-spacing: 1.2px;
    text-transform: uppercase;
  }

  .new-main-blog-banner__heading {
    margin: 0 0 20px;
    line-height: 1.2;
    font-family: var(--section-heading-font, var(--FONT-STACK-HEADING, 'Portrait LS', serif));
  }

  .new-main-blog-banner__heading a {
    text-decoration: none;
    color: inherit;
    font-family: var(--section-heading-font, var(--FONT-STACK-HEADING, 'Portrait LS', serif));
    font-style: var(--section-heading-style, var(--FONT-STYLE-HEADING, normal));
    font-weight: var(--section-heading-weight, var(--FONT-WEIGHT-HEADING, 500));
    line-height: var(--section-heading-line-height, var(--LINE-HEIGHT-DISPLAY-L, 1.2));
    text-transform: capitalize;
  }

  /* .new-main-blog-banner__heading a:hover {
    text-decoration: underline;
  } */

  .new-main-blog-banner__description {
    margin: 0;
    color: var(--000000, #000);

    /* RC26/Body */
    font-family: Inter;
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 22px; /* 157.143% */
  }

  .new-main-blog-banner__description p {
    margin: 0 0 0.5em;
  }

  .new-main-blog-banner__description p:last-child {
    margin-bottom: 0;
  }

  .new-main-blog-banner__button-wrap {
    flex-shrink: 0;
    align-self: center;
  }

  .new-main-blog-banner__empty {
    margin: 0;
    text-align: center;
    padding: 2rem;
  }

  .new-main-blog-banner__button {
    min-width: 396px;
    text-align: center;
    border: 1px solid var(--000000, #000);
    /* RC26/Button (ALL CAPS) */
    font-family: Inter;
    opacity: 1 !important;
    font-size: 12px;
    font-style: normal;
    font-weight: 600;
    line-height: 20px; /* 166.667% */
    letter-spacing: 1.2px;
    transition: none !important;
    text-transform: uppercase;
  }
  .new-main-blog-banner__button:hover {
    text-decoration: none;
    background-color: var(--000000, #000);
    color: var(--FFFFFF, #fff);
  }
  @media (max-width: 425px) {
    .new-main-blog-banner__button {
      min-width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Blog banner",
  "tag": "section",
  "class": "section-new-main-blog-banner",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Banner image",
      "info": "Overrides the latest article's featured image when set. Leave blank to use the article image."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "info": "Optional. Leave blank to use the article title."
    },
    {
      "type": "header",
      "content": "Subheading"
    },
    {
      "type": "checkbox",
      "id": "show_subheading",
      "label": "Show subheading",
      "default": true
    },
    {
      "type": "text",
      "id": "subheading_prefix",
      "label": "Subheading prefix",
      "default": "Latest in #",
      "info": "Shown before the blog title. Leave blank to show only blog title."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading override",
      "info": "Leave blank to use blog title (e.g. Celebrity). Set to override (e.g. FASHION)."
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "range",
      "id": "description_length",
      "min": 80,
      "max": 300,
      "step": 20,
      "unit": "chr",
      "label": "Description length",
      "default": 120
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Read story"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "default": "btn--outline",
      "options": [
        {"value": "btn--solid", "label": "Solid"},
        {"value": "btn--outline", "label": "Outline"},
        {"value": "btn--text", "label": "Text"}
      ]
    },
    {
      "type": "select",
      "id": "button_type",
      "label": "Button color",
      "default": "btn--black",
      "options": [
        {"value": "btn--black", "label": "Black"},
        {"value": "btn--white", "label": "White"},
        {"value": "btn--primary", "label": "Primary"},
        {"value": "btn--secondary", "label": "Secondary"}
      ]
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "Button size",
      "default": "",
      "options": [
        {"value": "btn--small", "label": "Small"},
        {"value": "", "label": "Medium"},
        {"value": "btn--large", "label": "Large"}
      ]
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "heading_font_size",
      "label": "Heading size",
      "default": "heading-large",
      "options": [
        {"value": "heading-mini", "label": "Mini"},
        {"value": "heading-x-small", "label": "Extra small"},
        {"value": "heading-small", "label": "Small"},
        {"value": "heading-medium", "label": "Medium"},
        {"value": "heading-large", "label": "Large"},
        {"value": "heading-x-large", "label": "Extra large"}
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Layout width",
      "default": "wrapper",
      "options": [
        {"value": "wrapper--full-padded", "label": "Full width padded"},
        {"value": "wrapper", "label": "Normal"},
        {"value": "wrapper--wide", "label": "Wide"},
        {"value": "wrapper--narrow", "label": "Narrow"},
        {"value": "wrapper--custom", "label": "Custom (max-width: 1232px)"}
      ]
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Bottom",
      "default": 40
    },
    {
      "type": "header",
      "content": "Empty state"
    },
    {
      "type": "text",
      "id": "empty_message",
      "label": "Message when no posts",
      "default": "No posts yet."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "Color scheme"
    }
  ],
  "presets": [
    {
      "name": "Blog banner",
      "category": "Blog"
    }
  ],
  "disabled_on": {
    "groups": ["header", "aside", "footer"]
  }
}
{% endschema %}
