<!-- /sections/section-blog-listing.liquid -->
{{ 'blog-listing.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign color_scheme = 'color-' | append: section.settings.color_scheme
  comment
    Blog is from the URL (e.g. /blogs/celebrity). On a blog template, Shopify exposes the global `blog` object.
  endcomment
  assign blog_links = section.blocks | where: 'type', 'blog_link'
  assign articles_per_page = section.settings.articles_per_page | default: 9
  assign excluded_handles = section.settings.tag_to_exclude | downcase | replace: ' ', '' | split: ','

  assign view_all_url = '/blogs/all'
  if blogs['all'] != blank and blogs['all'].url != blank
    assign view_all_url = blogs['all'].url
  elsif blog != blank and blog.url != blank
    assign view_all_url = blog.url
  endif
-%}

{%- style -%}
  #BlogListing--{{ section.id }} {
      --PT: {{ section.settings.padding_top }}px;
      --PB: {{ section.settings.padding_bottom }}px;
      --grid-cols: {{ section.settings.columns }};

      /* padding-inline:  var(--outer); */
    }
  #shopify-section-{{ section.id }} .blog-listing-section-wrapper__inner {
    border-bottom: 1px solid #e5e5e5;
  }
  #shopify-section-{{ section.id }} .blog-listing-section {
    background-color: #F9F9F9;
  }
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .blog-listing-section-wrapper__inner {
      border-top: 1px solid #e5e5e5;
    }
  }
{%- endstyle -%}

<section class="blog-listing-section-wrapper">
  <div class="blog-listing-section-wrapper__inner">
    <div class="blog-listing__bar {{ section.settings.width }}">
      <a
        href="{{ view_all_url }}"
        class="blog-listing__view-all main-blog__filter-tag {% if blog.handle == 'all' %}main-blog__filter-tag--active{% endif %}"
      >
        {{ section.settings.view_all_text | default: 'View all' | upcase }}
      </a>
      {%- if blog_links.size > 0 -%}
        <nav class="blog-listing__nav" aria-label="Blog categories">
          {%- for block in blog_links -%}
            {%- liquid
              assign selected_blog = block.settings.blog
              assign selected_handle = blank
              assign selected_title = blank
              assign selected_url = blank

              if selected_blog != blank and selected_blog.handle != blank
                assign selected_handle = selected_blog.handle | downcase
                assign selected_title = selected_blog.title
                assign selected_url = selected_blog.url
              elsif selected_blog != blank
                assign selected_handle = selected_blog | downcase
                assign selected_title = blogs[selected_handle].title
                assign selected_url = blogs[selected_handle].url
              endif

              if selected_handle != blank and excluded_handles contains selected_handle
                assign selected_handle = blank
              endif
            -%}

            {%- if selected_handle != blank and selected_url != blank -%}
              <a
                href="{{ selected_url }}"
                class="main-blog__filter-tag{% if selected_handle == blog.handle %} main-blog__filter-tag--active{% endif %}"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.label | default: selected_title | upcase }}
              </a>
            {%- endif -%}
          {%- endfor -%}
        </nav>
      {%- endif -%}
    </div>
  </div>
</section>
<section
  id="BlogListing--{{ section.id }}"
  class="blog-listing-section section-padding {{ color_scheme }}"
  data-section-id="{{ section.id }}"
  data-section-type="blog-listing"
>
  <div class="blog-listing__wrapper {{ section.settings.width }}">
    {%- if blog != blank -%}
      {%- paginate blog.articles by articles_per_page -%}
        {%- liquid
          assign article_offset = 0
          if paginate.current_page == 1 and blog.articles_count > 1
            assign article_offset = 1
          endif
        -%}

        <div class="blog-listing__grid">
          {%- for article in blog.articles offset: article_offset -%}
            <article class="blog-listing__card">
              <a href="{{ article.url }}" class="blog-listing__card-link">
                <div class="blog-listing__card-media">
                  {%- if article.image != blank -%}
                    {{
                      article.image
                      | image_url: width: 1200
                      | image_tag:
                        alt: article.title,
                        loading: 'lazy',
                        widths: '375, 550, 750, 900, 1100, 1200',
                        sizes: '(min-width: 990px) 33vw, 100vw'
                    }}
                  {%- else -%}
                    <div class="placeholder">No Image</div>
                  {%- endif -%}
                </div>

                <div class="blog-listing__card-body">
                  {%- if section.settings.show_tag and article.blog != blank -%}
                    <p class="blog-listing__card-tag">#{{ article.blog.handle | upcase }}</p>
                  {%- endif -%}

                  <h2 class="blog-listing__card-title {{ section.settings.title_font_size }}">{{ article.title }}</h2>

                  {%- if section.settings.show_excerpt -%}
                    <p class="blog-listing__card-excerpt">
                      {{
                        article.excerpt_or_content
                        | strip_html
                        | truncatewords: section.settings.excerpt_words
                      }}
                    </p>
                  {%- endif -%}
                </div>
              </a>
            </article>
          {%- else -%}
            <p class="blog-listing__empty">{{ section.settings.empty_message }}</p>
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <div class="custom-js-pagination" aria-label="Pagination">
            <div class="custom-js-pagination__container">
              {%- if paginate.previous -%}
                <a class="custom-js-pagination__link custom-js-pagination__prev" href="{{ paginate.previous.url }}">
                  <span>PREV</span>
                </a>
              {%- else -%}
                <button class="custom-js-pagination__link custom-js-pagination__prev" type="button" disabled>
                  <span>PREV</span>
                </button>
              {%- endif -%}

              <div class="custom-js-pagination__numbers">
                {%- for part in paginate.parts -%}
                  {%- if part.is_link -%}
                    <a class="custom-js-pagination__number" href="{{ part.url }}">{{ part.title }}</a>
                  {%- else -%}
                    {%- if part.title == paginate.current_page -%}
                      <span class="custom-js-pagination__number custom-js-pagination__number--current">
                        {{ part.title }}
                      </span>
                    {%- else -%}
                      <span class="custom-js-pagination__ellipsis">{{ part.title }}</span>
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>

              {%- if paginate.next -%}
                <a class="custom-js-pagination__link custom-js-pagination__next" href="{{ paginate.next.url }}">
                  <span>NEXT</span>
                </a>
              {%- else -%}
                <button class="custom-js-pagination__link custom-js-pagination__next" type="button" disabled>
                  <span>NEXT</span>
                </button>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    {%- else -%}
      <p class="blog-listing__empty">
        {{
          section.settings.empty_message
          | default: 'Add this section to a blog template to show articles (e.g. from /blogs/celebrity).'
        }}
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog listing",
  "tag": "section",
  "class": "section-blog-listing",
  "settings": [
    {
      "type": "header",
      "content": "Filter bar"
    },
    {
      "type": "text",
      "id": "tag_to_exclude",
      "label": "Tag to exclude",
      "default": "all, uncategorized, default-blog",
      "info": "Enter tags to exclude from the navigation, separated by commas."
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all label",
      "default": "View all"
    },
    {
      "type": "article_list",
      "id": "featured_articles",
      "label": "Featured articles",
      "limit": 12
    },

    {
      "type": "header",
      "content": "Blog grid"
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "min": 6,
      "max": 24,
      "step": 3,
      "label": "Articles per page",
      "default": 9,
      "info": "Articles are from the current blog (e.g. /blogs/celebrity). Add this section to a blog template."
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns (desktop)",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_tag",
      "label": "Show category tag",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": true
    },
    {
      "type": "range",
      "id": "excerpt_words",
      "min": 10,
      "max": 40,
      "step": 2,
      "label": "Excerpt length",
      "default": 20
    },
    {
      "type": "select",
      "id": "title_font_size",
      "label": "Title size",
      "default": "heading-small",
      "options": [
        {"value": "heading-mini", "label": "Mini"},
        {"value": "heading-x-small", "label": "Extra small"},
        {"value": "heading-small", "label": "Small"},
        {"value": "heading-medium", "label": "Medium"},
        {"value": "heading-large", "label": "Large"},
        {"value": "heading-x-large", "label": "Extra large"}
      ]
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "default": "wrapper",
      "options": [
        {"value": "wrapper--full-padded", "label": "Full width padded"},
        {"value": "wrapper", "label": "Normal"},
        {"value": "wrapper--wide", "label": "Wide"},
        {"value": "wrapper--narrow", "label": "Narrow"},
        {"value": "wrapper--custom", "label": "Custom (max-width: 1232px)"}
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    },
    {
      "type": "text",
      "id": "empty_message",
      "label": "Empty message",
      "default": "Add this section to a blog template to show articles (e.g. from /blogs/celebrity)."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "Color scheme"
    }
  ],
  "blocks": [
    {
      "type": "blog_link",
      "name": "Blog link",
      "settings": [
        {
          "type": "blog",
          "id": "blog",
          "label": "Blog"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "info": "Leave blank to use the blog title (e.g. Celebrity, Culture)."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blog listing",
      "category": "Blog",
      "blocks": [
        {"type": "blog_link", "settings": {"label": "Celebrity"}},
        {"type": "blog_link", "settings": {"label": "Culture"}},
        {"type": "blog_link", "settings": {"label": "Style"}},
        {"type": "blog_link", "settings": {"label": "Travel"}}
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "aside", "footer"]
  }
}
{% endschema %}
