<!-- /sections/section-associations.liquid -->
{%- liquid
  assign color_scheme = 'color-' | append: section.settings.color_scheme
  assign list_blocks = section.blocks | where: 'type', 'item'
-%}

  {%- style -%}

  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.section_background_color }};
  }
  #Associations--{{ section.id }} {
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
    padding-inline:  var(--outer);
  }
  #Associations--{{ section.id }} .associations__dark {
    background-image: url('{{ section.settings.image | img_url: 'master'}}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;

    width: 814px;
    height: 651px;
  }

  @media (max-width: 425px) {
    #Associations--{{ section.id }} .associations__dark {
     height: auto;
    }
  }

  @media (max-width: 749px) {
    {%- if section.settings.image_mobile != blank -%}
    #Associations--{{ section.id }} .associations__dark {
      background-image: url('{{ section.settings.image_mobile | img_url: 'master' }}');
      width: 100%;
      height: auto !important;
      aspect-ratio: 1 / 2
    }
    {%- endif -%}
  }
{%- endstyle -%}

<section
  id="Associations--{{ section.id }}"
  class="associations section-padding {{ color_scheme }}"
  data-section-id="{{ section.id }}"
  data-section-type="associations"
>
  <div class="associations__wrapper {{ section.settings.width }}">
    <div class="associations__grid">
      <div class="associations__dark associations__left">
        <div class="associations__left-inner">
          {%- if section.settings.heading != blank -%}
            <h2 class="associations__heading {{ section.settings.heading_font_size }}">
              {{ section.settings.heading }}
            </h2>
          {%- endif -%}
          {%- if section.settings.description != blank -%}
            <div class="associations__description rte">
              {{ section.settings.description }}
            </div>
          {%- endif -%}
    
        </div>
      </div>
      <div class="associations__right">
        {%- if list_blocks.size > 0 -%}
          <div class="associations__list">
            {%- for block in list_blocks -%}
              {%- if block.settings.text != blank -%}
                <div
                  class="associations__list-item rte"
                  style="--item-margin-bottom: {{ block.settings.margin_bottom }}px"
                  {{ block.shopify_attributes }}
                >
                  {{ block.settings.text }}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
#shopify-section-{{ section.id }} .associations__wrapper {
  max-width: var(--max-width, 1232px);
}
  .associations__wrapper {
    width: 100%;
    margin-left: auto;
    margin-right: auto;
  }

  .associations__grid {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 1px;
    gap: 59px;
  }

  @media (min-width: 990px) {
    .associations__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  h2.associations__heading.heading-large {
    color: var(--ffffff, #FFF);

/* RC26/Display/L */
font-family: "Portrait LC";
font-size: 40px;
font-style: normal;
font-weight: 500;
line-height: 48px; /* 120% */
}

.associations__left-inner {
    width:345px;
} 



  .associations__dark {
    padding: 70px 80px;
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 750px) {
    .associations__dark {
      padding: 70px 80px;
    }
  }
 

  .associations__left-inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    flex: 1;
  }

  .associations__heading {
    margin: 0;
    color: #fff;
    font-weight: 700;
    line-height: 1.2;
  }

  .associations__description {
    color: var(--ffffff, #FFF);
    margin:0px;
    /* RC26/Body */
    font-family: Inter;
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 22px; /* 157.143% */
  }

  .associations__description p {
    margin: 0 0 0.5em;
  }

  .associations__description p:last-child {
    margin-bottom: 0;
  }

  .associations__description a {
    color: rgba(255, 255, 255, 0.95);
    text-decoration: underline;
  }

  .associations__media {
    margin-top: auto;
    width: 100%;
    overflow: hidden;
  }

  .associations__media img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .associations__right {
    
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media (min-width: 750px) {
    .associations__right {
      /* padding: 3rem; */
    }
  }
  @media (max-width: 1024px) {
  .associations__left-inner {
    width: 100%;
  }
  }
  @media (max-width: 749px) {
    .associations__dark {
      padding: 35px !important;
    }
  }
  .associations__list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .associations__list-item {
    margin: 0 0 var(--item-margin-bottom, 1rem);
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  .associations__list-item:last-child {
    margin-bottom: 0;
  }

  .associations__list-item p {
    margin: 0 0 0.25em;
  }

  .associations__list-item p:last-child {
    margin-bottom: 0;
  }
  .associations__list-item {
    color: var(--000000, #000) !important;

/* RC26/Body */
    font-family: Inter;
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 22px; /* 157.143% */
  }
  .associations__list-item a {
    text-decoration: none !important;
    color: var(--000000, #000) !important;
    opacity: 1 !important;
  }
  .associations__list-item a:after{
    display: none !important;
  }

  @media (max-width: 1024px) {
    .associations__dark {
      width: 100% !important;
      height: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Associations",
  "tag": "section",
  "class": "section-associations",
  "settings": [
    {
      "type": "header",
      "content": "Left column"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Associations & Organizations"
    },
    {
      "type": "select",
      "id": "heading_font_size",
      "label": "Heading size",
      "default": "heading-large",
      "options": [
        { "value": "heading-mini", "label": "Mini" },
        { "value": "heading-x-small", "label": "Extra small" },
        { "value": "heading-small", "label": "Small" },
        { "value": "heading-medium", "label": "Medium" },
        { "value": "heading-large", "label": "Large" },
        { "value": "heading-x-large", "label": "Extra large" }
      ]
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Roberto Coin is a participating member of the following organizations that are active within both the jewelry industry and the greater social community at large.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Image (mobile)",
      "info": "Optional. Shown on small screens instead of the image above. If blank, the desktop image is used."
    },
    {
      "type": "color",
      "id": "image_background_color",
      "label": "Image background",
      "default": "#252525",
      "info": "Background behind the image. Use a different color so the image doesn’t blend with the left column."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Left column background",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Layout width",
      "default": "wrapper",
      "options": [
        { "value": "wrapper--full-padded", "label": "Full width padded" },
        { "value": "wrapper", "label": "Normal" },
        { "value": "wrapper--wide", "label": "Wide" },
        { "value": "wrapper--narrow", "label": "Narrow" },
        { "value": "wrapper--custom", "label": "Custom (max-width: 1232px)" }
      ]
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Bottom",
      "default": 60
    },
    {
      "type": "color",
      "id": "section_background_color",
      "default": "#F9F9F9",
      "label": "Section background color"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Organization",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Name and link",
          "default": "<p><strong>AMERICAN GEM SOCIETY</strong><br><a href=\"https://www.americangemsociety.org\">www.americangemsociety.org</a></p>",
          "info": "Add organization name and website link. Use the link button to make URLs clickable."
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "min": 0,
          "max": 48,
          "step": 2,
          "unit": "px",
          "label": "Margin bottom",
          "default": 16
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Associations",
      "category": "Text",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "text": "<p><strong>AMERICAN GEM SOCIETY</strong><br><a href=\"https://www.americangemsociety.org\">www.americangemsociety.org</a></p>",
            "margin_bottom": 16
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "<p><strong>MJSA</strong><br><a href=\"https://www.mjsa.org\">www.mjsa.org</a></p>",
            "margin_bottom": 16
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "<p><strong>JEWELERS OF AMERICA</strong><br><a href=\"https://www.jewelers.org\">www.jewelers.org</a></p>",
            "margin_bottom": 16
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "<p><strong>NY CHAMBER OF COMMERCE</strong><br><a href=\"https://www.ny-chamber.com\">www.ny-chamber.com</a></p>",
            "margin_bottom": 16
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "<p><strong>JEWELERS BOARD OF TRADE</strong><br><a href=\"https://www.jewelersboard.com\">www.jewelersboard.com</a></p>",
            "margin_bottom": 16
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "<p><strong>COUNCIL FOR RESPONSIBLE JEWELERS</strong><br><a href=\"https://www.responsiblejewellery.com\">www.responsiblejewellery.com</a></p>",
            "margin_bottom": 16
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "<p><strong>JEWELERS VIGILANCE COMMITTEE</strong><br><a href=\"https://www.jvclegal.org\">www.jvclegal.org</a></p>",
            "margin_bottom": 0
          }
