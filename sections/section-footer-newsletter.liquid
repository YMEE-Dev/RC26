<!-- /sections/section-footer-newsletter.liquid -->

{%- liquid
  assign color_scheme = 'color-' | append: section.settings.color_scheme
  assign trigger_label = section.settings.trigger_label | strip
  assign animation_anchor = '#FooterNewsletter--' | append: section.id
  assign animation_order = 1
-%}

{%- style -%}
  #FooterNewsletter--{{ section.id }} {
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.background_color }};
    padding-top: var(--PT);
    padding-bottom: var(--PB);
  }
{%- endstyle -%}

<footer-newsletter-drawer class="footer-newsletter-popup">
  <section
    id="FooterNewsletter--{{ section.id }}"
    class="footer-newsletter section-padding {{ color_scheme }}"
    data-section-id="{{ section.id }}"
    data-section-type="footer-newsletter"
  >
    <div class="footer-newsletter__inner wrapper--full-padded">
      {%- if trigger_label != blank -%}
        <button
          type="button"
          class="btn btn--secondary btn--outline footer-newsletter__trigger"
          data-newsletter-drawer-open
          data-aos="hero"
          data-aos-anchor="{{ animation_anchor }}"
          data-aos-order="{{ animation_order }}"
          aria-expanded="false"
          aria-controls="FooterNewsletterDrawer--{{ section.id }}"
        >
          <span class="footer-newsletter__trigger-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" viewBox="0 0 25 25" fill="none">
              <path d="M4 5.25C2.89062 5.25 2 6.1836 2 7.3047V17.6875C2 18.8086 2.89062 19.75 4 19.75H21C22.1094 19.75 23 18.8086 23 17.6875V7.3047C23 6.1836 22.1094 5.25 21 5.25H4ZM4 6.25H21C21.1465 6.25 21.289 6.28613 21.414 6.34375L13.1486 13.9923C12.7667 14.3458 12.2579 14.3458 11.8751 13.9923L3.59385 6.34375C3.71787 6.28809 3.85547 6.25 4 6.25ZM3.01562 7.17188L8.88288 12.5939L3.12512 18.1954C3.04895 18.045 3.00012 17.8751 3.00012 17.6876V7.30483C3.00012 7.25893 3.01074 7.21582 3.01562 7.17188ZM21.9844 7.17969C21.9893 7.22168 22 7.26172 22 7.30469V17.6874C22 17.871 21.9561 18.04 21.8828 18.1874L16.1406 12.5859L21.9844 7.17969ZM15.4141 13.2577L21.0314 18.7499H21.0001H4.00012H3.97669L9.61719 13.2654L11.1953 14.7264C11.9375 15.4119 13.0859 15.4129 13.8281 14.7264L15.4141 13.2577Z" fill="currentColor"/>
            </svg>
          </span>
          <span class="footer-newsletter__trigger-text">{{ trigger_label | escape }}</span>
        </button>
      {%- endif -%}
    </div>
  </section>

  <div
    id="FooterNewsletterDrawer--{{ section.id }}"
    class="collection__sidebar__slide-out footer-newsletter__drawer"
    data-newsletter-drawer
  >
    <div class="collection__sidebar__head">
      <button
        type="button"
        class="collection__sidebar__close footer-newsletter__drawer-close"
        data-newsletter-drawer-close
        aria-label="{{ 'general.accessibility.close' | t }}"
      >
        {%- render 'icon-close' -%}
      </button>
    </div>

    <div class="footer-newsletter__drawer-body" data-scroll-lock-scrollable>
      {%- render 'footer-newsletter-form', section: section -%}
    </div>
  </div>

  <div class="underlay" data-newsletter-drawer-close></div>

  {%- unless customer -%}
    <aside
      class="footer-newsletter-float"
      data-newsletter-float
      aria-hidden="true"
      data-newsletter-float-delay="{{ section.settings.float_delay_seconds | default: 3 }}"
      data-newsletter-float-delay-mobile="{{ section.settings.float_delay_seconds_mobile | default: 15 }}"
    >
      <button
        type="button"
        class="footer-newsletter-float__close"
        data-newsletter-float-close
        aria-label="{{ 'general.accessibility.close' | t }}"
      >
        {%- render 'icon-close' -%}
      </button>
      <p class="footer-newsletter-float__title h4">
        {{ section.settings.float_title | default: 'Get inspired by the world|of Roberto Coin' | escape | replace: '|', '<br>' }}
      </p>
      <button
        type="button"
        class="btn btn--secondary btn--outline btn--full footer-newsletter-float__cta"
        data-newsletter-drawer-open
        data-newsletter-float-signup
        aria-controls="FooterNewsletterDrawer--{{ section.id }}"
      >
        {{ section.settings.float_button_text | default: 'Sign up to our newsletter' | escape }}
      </button>
    </aside>
    <div class="underlay footer-newsletter-float__underlay" data-newsletter-float-underlay></div>
  {%- endunless -%}
</footer-newsletter-drawer>

{% stylesheet %}
  .footer-newsletter__inner {
    display: grid;
    grid-template-columns: repeat(8, minmax(0, 1fr));
    gap: var(--gutter);
  }

  .footer-newsletter__trigger {
    grid-column: 4 / 6;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  @media only screen and (min-width: 768px) and (max-width: 2200px) {
    .footer-newsletter__inner {
      grid-template-columns: repeat(6, minmax(0, 1fr));
    }

    .footer-newsletter__trigger {
      grid-column: 3 / 5;
    }
  }

  .footer-newsletter__trigger-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /*
   * --duration is only defined inside .collection__products so we set it
   * here to match the collection filter slide-out timing exactly.
   */
  .footer-newsletter__drawer {
    --duration: 0.6s;
  }

  .footer-newsletter__drawer-close {
    top: 55px;
    right: 15px;
  }

  .footer-newsletter__drawer-body {
    flex: 1;
    overflow-y: auto;
    padding: 0 30px 30px;
  }

  .footer-newsletter__drawer-body > [data-footer-newsletter-wrapper] {
    min-height: 100%;
    display: flex;
    flex-direction: column;
  }

  .footer-newsletter__drawer-body .modal__description p {
    margin: 0;
    padding-bottom: 80px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 22px;
  }

  .footer-newsletter-form__title {
    margin: 0;
    padding: 0;
    padding-bottom: 40px;
  }

  .footer-newsletter-form {
    width: 100%;
    max-width: 62rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
    min-height: 0;
  }

  .footer-newsletter__drawer .footer-newsletter-form select.field,
  .footer-newsletter__drawer .footer-newsletter-form input.field {
    margin-top: 12px;
    margin-bottom: 0;
    padding-top: 0px;
    padding-bottom: 11px;
  }

  .footer-newsletter-form__fields {
    display: flex;
    flex-direction: column;
    gap: 40px;
    flex: 1 1 auto;
    min-height: 0;
  }

  .footer-newsletter-form__group {
    display: flex;
    flex-direction: column;
  }
  .footer-newsletter-form__group--language {
    padding-top: 14px;
  }

  .footer-newsletter-form__eyebrow {
    margin: 0;
    padding: 0;
    padding-bottom: 0;
    text-align: left;
    text-transform: uppercase;
  }

  .footer-newsletter-form__field::placeholder {
    text-transform: uppercase;
  }

  .footer-newsletter-form__field--select {
    color: var(--text);
  }

  .footer-newsletter-form__dob-field {
    position: relative;
  }

  .footer-newsletter-form__dob-field .footer-newsletter-form__field {
    padding-right: 34px;
    height: 30px;
  }

  .footer-newsletter-form__dob-trigger {
    position: absolute;
    right: 4px;
    bottom: 10px;
    width: 22px;
    height: 22px;
    border: 0;
    padding: 0;
    background: transparent;
    color: currentColor;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .footer-newsletter-form__dob-field input {
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: textfield;
  }

  .footer-newsletter-form__dob-field input[type='date']::-webkit-calendar-picker-indicator {
    opacity: 0;
    pointer-events: none;
  }

  .footer-newsletter-form__dob-placeholder {
    position: absolute;
    left: 0;
    right: 34px;
    top: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    font-size: var(--FONT-SIZE-LABEL);
    line-height: var(--LINE-HEIGHT-LABEL);
    color: var(--text-a80, var(--text));
    text-transform: uppercase;
    pointer-events: none;
  }

  /* Hide the native empty-date text while the custom placeholder is shown */
  .footer-newsletter-form__dob-field:not(.has-value):not(:focus-within) input[type='date']::-webkit-datetime-edit {
    color: transparent;
  }

  /* Hide the custom placeholder once a value is set or the field is focused */
  .footer-newsletter-form__dob-field.has-value .footer-newsletter-form__dob-placeholder,
  .footer-newsletter-form__dob-field:focus-within .footer-newsletter-form__dob-placeholder {
    display: none;
  }

  .footer-newsletter-form__consent {
    max-width: 58rem;
    margin-top: 4px;
  }

  .footer-newsletter-form__consent input[type='checkbox'] + label {
    align-items: flex-start;
    gap: 20px;
  }

  .footer-newsletter-form__consent input[type='checkbox'] + label::before {
    width: 12px;
    height: 12px;
    margin-right: 0;
    border-color: currentColor;
    border-radius: 50%;
    margin-top: 4px;
  }

  .footer-newsletter-form__consent-copy,
  .footer-newsletter-form__consent-copy p {
    margin: 0;
    text-align: left;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-style: normal;
    font-weight: 400;
    line-height: 16px;
  }

  .footer-newsletter-form__consent-error {
    display: block;
    margin-top: 8px;
    color: #c0392b;
    font-size: 12px;
    line-height: 1.4;
    text-transform: none;
    padding-left: 30px;
  }

  .footer-newsletter-form__consent-error[hidden] {
    display: none !important;
  }

  .footer-newsletter-form__policy,
  .footer-newsletter-form__policy p {
    text-align: left;
    margin: 0;
    margin-top: 20px;
  }

  .footer-newsletter-form__submit {
    margin-top: 25px;
  }

  .footer-newsletter-form__group--submit {
    margin-top: auto;
  }

  .footer-newsletter-float {
    position: fixed;
    right: 40px;
    bottom: 40px;
    z-index: 102;
    display: flex;
    flex-direction: column;
    width: min(397px, calc(100vw - 80px));
    padding: 20px;
    background: rgba(255, 255, 255, 0.8);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    color: #111;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
    transform: translate3d(0, 120%, 0);
    opacity: 0;
    visibility: hidden;
    transition: transform 0.45s ease, opacity 0.3s ease, visibility 0s linear 0.45s;
  }

  .footer-newsletter-float.is-visible {
    transform: translate3d(0, 0, 0);
    opacity: 1;
    visibility: visible;
    transition: transform 0.45s ease, opacity 0.3s ease;
  }

  /* In-flow, right-aligned above the heading (matches Figma), not an
     overlapping corner icon. */
  /* Negative margins let the larger tap target sit flush in the corner
     (~20px inset, matching Figma) without pushing the heading down. */
  .footer-newsletter-float__close {
    position: static;
    align-self: flex-end;
    margin: -8px -8px 2px 0;
    border: 0;
    padding: 8px;
    background: transparent;
    color: currentColor;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .footer-newsletter-float__close svg {
    display: block;
    width: 24px;
    height: 24px;
  }

  .footer-newsletter-float__title {
    margin: 0 0 20px;
    text-align: center;
  }

  .footer-newsletter-float__cta {
    min-height: 44px;
  }

  /* Force a dark outline on the light translucent panel, independent of the
     section color scheme (whose secondary border can resolve to white).
     Selector matches the theme's `.btn--outline.btn--secondary` specificity plus one. */
  .footer-newsletter-float__cta.btn--outline.btn--secondary {
    --btn-border: #111;
    --btn-text: #111;
    --btn-bg: transparent;
    /* Hover/focus: dark fill slides up and text flips to white — mirrors the
       hero "Discover more" outline button's invert-on-hover behaviour. */
    --btn-border-hover: #111;
    --btn-bg-hover: #111;
    --btn-text-hover: #fff;
  }

  @media only screen and (max-width: 767px) {
    .footer-newsletter__drawer {
      max-width: 100%;
    }

    .footer-newsletter__inner {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .footer-newsletter__trigger {
      grid-column: 1;
    }

    .footer-newsletter-float {
      top: auto;
      left: 16px;
      right: 16px;
      bottom: 16px;
      width: auto;
      max-width: none;
      padding: 20px;
      border-top: 0;
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.14);
      transform: translate3d(0, calc(100% + 16px), 0);
    }

    .footer-newsletter-float.is-visible {
      transform: translate3d(0, 0, 0);
    }

    .footer-newsletter-float__underlay {
      position: fixed;
      inset: 0;
      z-index: 101;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: opacity 0.3s ease, visibility 0s linear 0.3s;
    }

    .footer-newsletter-float__underlay.is-visible {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transition: opacity 0.3s ease;
    }
  }
{% endstylesheet %}

{% javascript %}
  class FooterNewsletterDrawer extends HTMLElement {
    connectedCallback() {
      this.drawer = this.querySelector('[data-newsletter-drawer]');
      this.openTriggers = Array.from(this.querySelectorAll('[data-newsletter-drawer-open]'));
      this.scrollableEl = this.querySelector('[data-scroll-lock-scrollable]');
      this.floatPopup = this.querySelector('[data-newsletter-float]');
      this.floatClose = this.querySelector('[data-newsletter-float-close]');
      this.floatSignup = this.querySelector('[data-newsletter-float-signup]');
      this.floatUnderlay = this.querySelector('[data-newsletter-float-underlay]');
      this.lastFocusedElement = null;
      this.dismissCookie = 'footer_newsletter_float_dismissed';
      this.seenCookie = 'footer_newsletter_float_seen';
      this.seenCookieHours = 24;
      this.mobileQuery = window.matchMedia('(max-width: 767px)');
      this.hasShownFloat = false;
      this.floatDelayMs = Number(this.floatPopup?.dataset.newsletterFloatDelay || 3) * 1000;
      this.mobileFloatDelayMs = Number(this.floatPopup?.dataset.newsletterFloatDelayMobile || 15) * 1000;
      this.floatDismissDelayMs = 260;

      this.openTriggers.forEach((trigger) => {
        trigger.addEventListener('click', (event) => {
          const fromFloat = event.currentTarget?.hasAttribute('data-newsletter-float-signup');
          if (fromFloat) {
            this.dismissFloat(true);
          }
          this.open();
        });
      });

      this.floatClose?.addEventListener('click', () => {
        this.dismissFloat();
      });
      this.floatUnderlay?.addEventListener('click', () => {
        this.dismissFloat();
      });

      this.querySelectorAll('[data-newsletter-drawer-close]').forEach((el) => {
        el.addEventListener('click', () => this.close());
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && this.drawer.classList.contains('expanded')) {
          this.close();
        }
      });

      this.setupFloatPopup();
    }

    focusWithoutScroll(element) {
      if (!(element instanceof HTMLElement)) {
        return;
      }

      const scrollX = window.scrollX;
      const scrollY = window.scrollY;

      try {
        element.focus({preventScroll: true});
      } catch (error) {
        element.focus();
        window.scrollTo(scrollX, scrollY);
      }
    }

    open() {
      this.lastFocusedElement = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      this.openTriggers.forEach((trigger) => trigger.setAttribute('aria-expanded', 'true'));

      const removeExpanding = () => {
        this.drawer.classList.remove('expanding');
        this.drawer.removeEventListener('transitionend', removeExpanding);
      };
      const addExpanding = () => {
        this.drawer.classList.add('expanding');
        this.drawer.removeEventListener('transitionstart', addExpanding);
      };
      this.drawer.addEventListener('transitionstart', addExpanding);
      this.drawer.addEventListener('transitionend', removeExpanding);
      this.drawer.classList.add('expanded');

      window.dispatchEvent(new CustomEvent('theme:scroll:lock', {detail: this.scrollableEl}));

      if (window.theme?.a11y?.trapFocus) {
        window.theme.a11y.trapFocus(this.drawer);
      }
    }

    close() {
      this.openTriggers.forEach((trigger) => trigger.setAttribute('aria-expanded', 'false'));
      this.drawer.classList.remove('expanded');
      window.dispatchEvent(new CustomEvent('theme:scroll:unlock', {bubbles: true}));

      if (window.theme?.a11y?.removeTrapFocus) {
        window.theme.a11y.removeTrapFocus();
      }

      const focusTarget =
        this.lastFocusedElement instanceof HTMLElement && this.lastFocusedElement.isConnected
          ? this.lastFocusedElement
          : this.openTriggers[0];

      this.focusWithoutScroll(focusTarget);
    }

    // The popup is suppressed once a visitor has either seen it or dismissed it,
    // so it does not reappear on every page during the same visit.
    isFloatSuppressed() {
      return this.readCookie(this.dismissCookie) === '1' || this.readCookie(this.seenCookie) === '1';
    }

    setupFloatPopup() {
      if (!this.floatPopup || this.isFloatSuppressed()) {
        return;
      }

      // Desktop uses the configured delay; mobile uses its own (15s by default),
      // both purely time-based after the page loads.
      const delayMs = this.mobileQuery.matches ? this.mobileFloatDelayMs : this.floatDelayMs;

      window.setTimeout(() => {
        if (this.isFloatSuppressed() || this.hasShownFloat) {
          return;
        }
        this.showFloat();
      }, delayMs);
    }

    showFloat() {
      if (!this.floatPopup) {
        return;
      }
      this.floatPopup.classList.add('is-visible');
      this.floatPopup.setAttribute('aria-hidden', 'false');
      this.hasShownFloat = true;
      // Remember it was shown so it does not reappear on subsequent page views.
      this.writeCookie(this.seenCookie, '1', this.seenCookieHours);
    }

    hideFloat() {
      if (!this.floatPopup) {
        return;
      }
      this.floatPopup.classList.remove('is-visible');
      this.floatPopup.setAttribute('aria-hidden', 'true');
    }

    dismissFloat(withDelay = false) {
      this.writeCookie(this.dismissCookie, '1', 24);

      if (withDelay) {
        window.setTimeout(() => {
          this.hideFloat();
        }, this.floatDismissDelayMs);
        return;
      }

      this.hideFloat();
    }

    writeCookie(name, value, hours) {
      const maxAge = Math.max(0, Number(hours) * 60 * 60);
      document.cookie = `${name}=${encodeURIComponent(value)};path=/;max-age=${maxAge};SameSite=Lax`;
    }

    readCookie(name) {
      const key = `${name}=`;
      const parts = document.cookie ? document.cookie.split(';') : [];
      for (const part of parts) {
        const cookie = part.trim();
        if (cookie.startsWith(key)) {
          return decodeURIComponent(cookie.substring(key.length));
        }
      }
      return '';
    }
  }

  if (!customElements.get('footer-newsletter-drawer')) {
    customElements.define('footer-newsletter-drawer', FooterNewsletterDrawer);
  }
{% endjavascript %}

{% schema %}
{
  "name": "Footer newsletter custom",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Trigger"
    },
    {
      "type": "text",
      "id": "trigger_label",
      "label": "Trigger button label",
      "default": "Join newsletter"
    },
    {
      "type": "header",
      "content": "Floating popup"
    },
    {
      "type": "text",
      "id": "float_title",
      "label": "Popup title",
      "info": "Use | to force a line break, e.g. Get inspired by the world|of Roberto Coin",
      "default": "Get inspired by the world|of Roberto Coin"
    },
    {
      "type": "text",
      "id": "float_button_text",
      "label": "Popup button text",
      "default": "Sign up to our newsletter"
    },
    {
      "type": "range",
      "id": "float_delay_seconds",
      "min": 1,
      "max": 12,
      "step": 1,
      "unit": "s",
      "label": "Desktop popup delay",
      "default": 3
    },
    {
      "type": "range",
      "id": "float_delay_seconds_mobile",
      "min": 1,
      "max": 30,
      "step": 1,
      "unit": "s",
      "label": "Mobile popup delay",
      "default": 15
    },
    {
      "type": "header",
      "content": "Modal"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Form title",
      "default": "KEEP IN TOUCH"
    },
    {
      "type": "richtext",
      "id": "heading_text",
      "label": "Heading text",
      "default": "<p>Subscribe now to be the first to know about our latest collections and future releases, discover collaborations and events</p>"
    },
    {
      "type": "header",
      "content": "Form"
    },
    {
      "type": "text",
      "id": "required_fields_label",
      "label": "Required fields label",
      "default": "*REQUIRED FIELDS"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Submit button text",
      "default": "SIGN UP"
    },
    {
      "type": "richtext",
      "id": "consent_label",
      "label": "Consent label",
      "default": "<p>I Confirm that I have read, understood and accepted your privacy information, that I am over 16, and I agree to receive this newsletter.</p>"
    },
    {
      "type": "richtext",
      "id": "policy_text",
      "label": "Policy text",
      "default": "<p>Your personal data will be used by roberto coin s.p.a. to provide you with the newsletter service you have expressly requested. your data are safe with roberto coin s.p.a. please read the privacy policy, and the cookie policy for further information.</p>"
    },
    {
      "type": "header",
      "content": "Klaviyo"
    },
    {
      "type": "text",
      "id": "klaviyo_company_id",
      "label": "Company ID (public API key)",
      "info": "Optional override. Leave blank to use Theme settings > Klaviyo public API key."
    },
    {
      "type": "text",
      "id": "klaviyo_list_id",
      "label": "List ID",
      "default": "UAE2Jy",
      "info": "Klaviyo list ID to subscribe profiles to."
    },
    {
      "type": "text",
      "id": "klaviyo_source",
      "label": "Source label",
      "default": "Footer Newsletter",
      "info": "Optional source string saved in Klaviyo profile properties."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
