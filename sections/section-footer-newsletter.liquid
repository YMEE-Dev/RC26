    },
    {
      "type": "text",
      "id": "mailchimp_audience_id",
      "label": "Embed ID / Audience ID",
      "info": "The hidden 'id' value from Mailchimp."
    },
    {
      "type": "text",
      "id": "mailchimp_tags",
      "label": "Tags",
      "info": "Optional Mailchimp tags hidden input value."
    },
    {
      "type": "header",
      "content": "Mailchimp field names"
    },
    {
      "type": "text",
      "id": "mailchimp_first_name_field",
      "label": "First name field name",
      "default": "FNAME"
    },
    {
      "type": "text",
      "id": "mailchimp_last_name_field",
      "label": "Last name field name",
      "default": "LNAME"
    },
    {
      "type": "text",
      "id": "mailchimp_email_field",
      "label": "Email field name",
      "default": "EMAIL"
    },
    {
      "type": "text",
      "id": "mailchimp_language_field",
      "label": "Language field name",
      "default": "LANGUAGE"
    },
    {
      "type": "text",
      "id": "mailchimp_consent_field",
      "label": "Consent field name",
