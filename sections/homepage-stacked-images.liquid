<!-- /sections/homepage-stacked-images.liquid -->
{{ 'homepage-stacked-images.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign background_image = section.settings.background_image
  assign background_image_mobile = section.settings.background_image_mobile
  assign foreground_image = section.settings.foreground_image
  assign foreground_image_mobile = section.settings.foreground_image_mobile
  assign button_label = section.settings.button_label | strip
  assign button_link = section.settings.button_link
  assign animation_anchor = '#HomepageStackedImages--' | append: section.id
  assign animation_order = 0
-%}

{%- style -%}
  #HomepageStackedImages--{{ section.id }} {
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<section
  id="HomepageStackedImages--{{ section.id }}"
  class="homepage-stacked-images section-padding header-observer--{{ section.settings.header_observer_mode }}"
  data-section-id="{{ section.id }}"
  data-section-type="homepage-stacked-images"
  data-header-observer-mode="{{ section.settings.header_observer_mode }}"
>
  <div class="homepage-stacked-images__media">
    {%- assign animation_order = animation_order | plus: 1 -%}
    <div
      class="homepage-stacked-images__background{% if background_image_mobile != blank %} homepage-stacked-images__background--has-mobile-image{% endif %}"
      data-aos="hero"
      data-aos-anchor="{{ animation_anchor }}"
      data-aos-order="{{ animation_order }}"
    >
      {%- if background_image != blank or background_image_mobile != blank -%}
        {%- assign desktop_background = background_image | default: background_image_mobile -%}
        {{
          desktop_background
          | image_url: width: 2400
          | image_tag:
            class: 'homepage-stacked-images__image homepage-stacked-images__image--background homepage-stacked-images__image--background-desktop',
            loading: 'lazy',
            sizes: '100vw',
            widths: '375, 550, 750, 990, 1200, 1600, 2000, 2400'
        }}

        {%- if background_image_mobile != blank -%}
          {{
            background_image_mobile
            | image_url: width: 1600
            | image_tag:
              class: 'homepage-stacked-images__image homepage-stacked-images__image--background homepage-stacked-images__image--background-mobile',
              loading: 'lazy',
              sizes: '100vw',
              widths: '320, 375, 550, 750, 990, 1200, 1600'
          }}
        {%- endif -%}
      {%- else -%}
        <div class="homepage-stacked-images__placeholder homepage-stacked-images__placeholder--background">
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
    </div>

    <div class="homepage-stacked-images__foreground{% if foreground_image_mobile != blank %} homepage-stacked-images__foreground--has-mobile-image{% endif %}">
      {%- assign animation_order = animation_order | plus: 1 -%}
      <div
        class="homepage-stacked-images__foreground-inner"
        data-aos="hero"
        data-aos-anchor="{{ animation_anchor }}"
        data-aos-order="{{ animation_order }}"
      >
        {%- if foreground_image != blank or foreground_image_mobile != blank -%}
          {%- assign desktop_foreground = foreground_image | default: foreground_image_mobile -%}
          {{
            desktop_foreground
            | image_url: width: 2200
            | image_tag:
              class: 'homepage-stacked-images__image homepage-stacked-images__image--foreground homepage-stacked-images__image--foreground-desktop',
              loading: 'lazy',
              sizes: '(min-width: 960px) 50vw, 70vw',
              widths: '320, 420, 560, 720, 900, 1200, 1600, 2000, 2200'
          }}

          {%- if foreground_image_mobile != blank -%}
            {{
              foreground_image_mobile
              | image_url: width: 1600
              | image_tag:
                class: 'homepage-stacked-images__image homepage-stacked-images__image--foreground homepage-stacked-images__image--foreground-mobile',
                loading: 'lazy',
                sizes: '70vw',
                widths: '320, 420, 560, 720, 900, 1200, 1600'
            }}
          {%- endif -%}
        {%- else -%}
          <div class="homepage-stacked-images__placeholder homepage-stacked-images__placeholder--foreground">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}

        {%- if button_label != blank -%}
          <a
            href="{{ button_link | default: '#' }}"
            class="homepage-stacked-images__button btn btn--solid btn--primary"
          >
            {{ button_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Homepage stacked images",
  "settings": [
    {
      "type": "header",
      "content": "Header observer"
    },
    {
      "type": "select",
      "id": "header_observer_mode",
      "label": "Header mode",
      "default": "light",
      "options": [
        {"value": "light", "label": "Light"},
        {"value": "dark", "label": "Dark"}
      ]
    },
    {
      "type": "header",
      "content": "Background image"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Desktop background image"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Mobile background image"
    },
    {
      "type": "header",
      "content": "Foreground image"
    },
    {
      "type": "image_picker",
      "id": "foreground_image",
      "label": "Desktop foreground image"
    },
    {
      "type": "image_picker",
      "id": "foreground_image_mobile",
      "label": "Mobile foreground image"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "The explorer of beauty"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Homepage stacked images"
    }
  ],
  "enabled_on": {
    "templates": ["index"]
  }
}
{% endschema %}
