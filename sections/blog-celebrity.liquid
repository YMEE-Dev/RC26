<!-- /sections/blog-celebrity.liquid -->
{%- liquid
  assign featured_article = blank
  assign has_top_video = false

  if section.settings.featured_article != blank
    assign featured_article = articles[section.settings.featured_article]
  endif

  if featured_article == blank
    if article != blank
      assign featured_article = article
    endif
  endif

  if featured_article == blank
    assign featured_article = blog.articles.first
  endif

  if section.settings.video != blank or section.settings.video_url != blank
    assign has_top_video = true
  endif
-%}

{{ 'blog-celebrity.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #BlogCelebrity--{{ section.id }} {
    --celebrity-top-padding: {{ section.settings.padding_top }}px;
    --celebrity-bottom-padding: {{ section.settings.padding_bottom }}px;
    --celebrity-content-max-width: {{ section.settings.content_max_width }}px;
    --celebrity-content-gap: {{ section.settings.content_gap }}px;
    --celebrity-title-max-width: {{ section.settings.title_max_width }}px;
    --celebrity-media-height-desktop: {{ section.settings.image_height_desktop }}vh;
    --celebrity-media-height-mobile: {{ section.settings.image_height_mobile }}vh;
  }
{%- endstyle -%}

<section
  id="BlogCelebrity--{{ section.id }}"
  class="blog-celebrity"
  data-section-id="{{ section.id }}"
  data-section-type="blog-celebrity"
>
  {%- if featured_article != blank -%}
    <div class="blog-celebrity__top">
      <h2 class="h2 blog-celebrity__title" data-blog-fade data-blog-fade-delay="0">{{ featured_article.title }}</h2>
      <p class="body blog-celebrity__date" data-blog-fade data-blog-fade-delay="0.3">
        <time datetime="{{ featured_article.published_at | date: '%Y-%m-%d' }}">
          {{ featured_article.published_at | date: '%B %-d, %Y' }}
        </time>
      </p>
    </div>

    {%- if section.settings.video != blank or section.settings.video_url != blank or featured_article.image != blank -%}
      <div class="blog-celebrity__media" data-blog-fade data-blog-fade-delay="0.6">
        {%- if section.settings.video != blank -%}
          {{
            section.settings.video
            | video_tag:
              autoplay: true,
              loop: true,
              controls: false,
              muted: true,
              playsinline: true,
              class: 'blog-celebrity__video'
          }}
        {%- elsif section.settings.video_url != blank -%}
          <video class="blog-celebrity__video" autoplay loop muted playsinline>
            <source src="{{ section.settings.video_url }}">
          </video>
        {%- elsif featured_article.image != blank -%}
          {%- liquid
            assign featured_image_alt = featured_article.image.alt
            if featured_image_alt == blank
              assign featured_image_alt = featured_article.title
            endif
          -%}
          {{
            featured_article.image
            | image_url: width: 2800
            | image_tag:
              alt: featured_image_alt,
              widths: '750, 1100, 1500, 2000, 2400, 2800',
              sizes: '100vw',
              loading: 'eager',
              class: 'blog-celebrity__image'
          }}
        {%- endif -%}

        {%- if has_top_video -%}
          <button
            type="button"
            class="blog-celebrity__sound-trigger"
            data-celebrity-video-open
            aria-label="Play with sound"
          >
            <span class="blog-celebrity__sound-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 43.52 43.52" fill="none">
                <circle cx="21.76" cy="21.76" r="21.26" />
                <line x1="27.18" y1="17.88" x2="34.16" y2="24.87" />
                <line x1="34.16" y1="17.88" x2="27.18" y2="24.87" />
                <polygon points="11.47 17.21 11.47 26.31 18.41 26.31 23.99 31.89 23.99 11.63 18.41 17.21 11.47 17.21" />
              </svg>
            </span>
            <span>PLAY WITH SOUND</span>
          </button>
        {%- endif -%}
      </div>

      {%- if has_top_video -%}
        <div class="blog-celebrity__video-modal" data-celebrity-video-modal hidden>
          <div class="blog-celebrity__video-modal-backdrop" data-celebrity-video-close></div>
          <div class="blog-celebrity__video-modal-dialog" role="dialog" aria-modal="true" aria-label="Celebrity video">
            <button type="button" class="blog-celebrity__video-modal-close" data-celebrity-video-close aria-label="Close"></button>
            <div class="blog-celebrity__video-modal-player">
              {%- if section.settings.video != blank -%}
                {{
                  section.settings.video
                  | video_tag:
                    autoplay: false,
                    loop: true,
                    controls: false,
                    muted: false,
                    playsinline: true,
                    class: 'blog-celebrity__video blog-celebrity__video--modal'
                }}
              {%- else -%}
                <video class="blog-celebrity__video blog-celebrity__video--modal" playsinline>
                  <source src="{{ section.settings.video_url }}">
                </video>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endif -%}
    {%- endif -%}

    {%- if featured_article.content != blank -%}
      <div class="blog-celebrity__content-wrapper" data-blog-fade data-blog-fade-delay="0.9">
        <div class="blog-celebrity__content body rte">
          {{ featured_article.content }}
        </div>
      </div>
    {%- endif -%}
  {%- else -%}
    <div class="blog-celebrity__empty h4">{{ 'blogs.article.no_articles' | t }}</div>
  {%- endif -%}
</section>

{% stylesheet %}
  [data-blog-fade].blog-fade-init {
    opacity: 0;
    transition-property: opacity;
    transition-duration: 2s;
    transition-timing-function: ease;
    transition-delay: var(--blog-fade-delay, 0s);
    will-change: opacity;
  }

  [data-blog-fade].blog-fade-init.blog-fade-visible {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-blog-fade].blog-fade-init {
      opacity: 1;
      transition: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    const initBlogFade = () => {
      const roots = document.querySelectorAll('[data-section-type="blog-celebrity"]');
      roots.forEach((root) => {
        const targets = root.querySelectorAll('[data-blog-fade]');
        if (!targets.length) return;

        targets.forEach((el) => {
          if (el.dataset.blogFadeReady == 'true') return;
          el.dataset.blogFadeReady = 'true';
          const delay = el.getAttribute('data-blog-fade-delay');
          if (delay) el.style.setProperty('--blog-fade-delay', `${delay}s`);
          el.classList.add('blog-fade-init');
          requestAnimationFrame(() => el.classList.add('blog-fade-visible'));
        });
      });
    };

    const initCelebrityVideo = () => {
      const roots = document.querySelectorAll('[data-section-type="blog-celebrity"]');
      roots.forEach((root) => {
        const openBtn = root.querySelector('[data-celebrity-video-open]');
        const modal = root.querySelector('[data-celebrity-video-modal]');
        if (!openBtn || !modal || modal.dataset.ready === 'true') return;
        modal.dataset.ready = 'true';

        const inlineVideo = root.querySelector('.blog-celebrity__video:not(.blog-celebrity__video--modal)');
        const modalVideo = modal.querySelector('.blog-celebrity__video--modal');
        const closeEls = modal.querySelectorAll('[data-celebrity-video-close]');
        const modalTransitionMs = 400;

        const closeModal = () => {
          if (modal.hidden || modal.classList.contains('is-closing')) return;
          modal.classList.remove('is-open');
          modal.classList.add('is-closing');
          document.body.style.overflow = '';
          window.clearTimeout(modal._closeTimer);
          modal._closeTimer = window.setTimeout(() => {
            modal.hidden = true;
            modal.classList.remove('is-closing');
            if (modalVideo) {
              modalVideo.pause();
              modalVideo.currentTime = 0;
            }
            if (inlineVideo) inlineVideo.play().catch(() => {});
          }, modalTransitionMs);
        };

        openBtn.addEventListener('click', () => {
          window.clearTimeout(modal._closeTimer);
          modal.hidden = false;
          modal.classList.remove('is-closing');
          requestAnimationFrame(() => modal.classList.add('is-open'));
          document.body.style.overflow = 'hidden';
          if (inlineVideo) inlineVideo.pause();
          if (modalVideo) {
            modalVideo.muted = false;
            modalVideo.play().catch(() => {});
          }
        });

        closeEls.forEach((el) => el.addEventListener('click', closeModal));
        modal.addEventListener('click', (event) => {
          const clickedInsidePlayer = event.target.closest('.blog-celebrity__video-modal-player');
          const clickedCloseButton = event.target.closest('.blog-celebrity__video-modal-close');
          if (!clickedInsidePlayer && !clickedCloseButton) closeModal();
        });
        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && !modal.hidden) closeModal();
        });
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        initBlogFade();
        initCelebrityVideo();
      }, { once: true });
    } else {
      initBlogFade();
      initCelebrityVideo();
    }

    document.addEventListener('shopify:section:load', () => {
      initBlogFade();
      initCelebrityVideo();
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Blog - Header Video",
  "settings": [
    {
      "type": "article",
      "id": "featured_article",
      "label": "Featured blog post",
      "info": "Optional. If empty, the latest post from this blog is used."
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 700,
      "max": 1500,
      "step": 20,
      "unit": "px",
      "label": "Content max width",
      "default": 1100
    },
    {
      "type": "range",
      "id": "title_max_width",
      "min": 500,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "label": "Title max width",
      "default": 980
    },
    {
      "type": "range",
      "id": "content_gap",
      "min": 10,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Title and date spacing",
      "default": 28
    },
    {
      "type": "video",
      "id": "video",
      "label": "Top video"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Top video URL (fallback)"
    },
    {
      "type": "range",
      "id": "image_height_desktop",
      "min": 35,
      "max": 80,
      "step": 1,
      "unit": "%",
      "label": "Image height on desktop",
      "default": 58
    },
    {
      "type": "range",
      "id": "image_height_mobile",
      "min": 30,
      "max": 70,
      "step": 1,
      "unit": "%",
      "label": "Image height on mobile",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Blog - Header Video",
      "category": "Blog"
    }
  ]
}
{% endschema %}
