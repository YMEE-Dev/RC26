<!-- /sections/section-store-locator.liquid -->
{%- liquid
  assign color_scheme = 'color-' | append: section.settings.color_scheme
-%}

{%- style -%}
  #StoreLocator--{{ section.id }} {
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
    --bg-color: {{ section.settings.background_color }};
  }
{%- endstyle -%}

<section
  id="StoreLocator--{{ section.id }}"
  class="store-locator section-padding {{ color_scheme }}"
  data-section-id="{{ section.id }}"
  data-section-type="store-locator"
  data-enable-fetch="{{ section.settings.enable_fetch_from_app }}"
  style="background-color: var(--bg-color);"
>
  <div class="store-locator__wrapper {{ section.settings.width }}">
    <div class="store-locator__header">
      <div class="store-locator__header-content">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'subheading' -%}
              <p class="store-locator__subheading" {{ block.shopify_attributes }}>
                {{ block.settings.text | upcase }}
              </p>
            
            {%- when 'heading' -%}
              <h2 class="store-locator__heading {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </h2>
          {%- endcase -%}
        {%- endfor -%}
      </div>
      
      <div class="store-locator__header-button">
        {%- for block in section.blocks -%}
          {%- if block.type == 'button' -%}
            <a
              href="{{ block.settings.link | default: '#' }}"
              class="store-locator__button"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text | upcase }}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {%- assign location_blocks = section.blocks | where: 'type', 'location_card' -%}
    {%- if location_blocks.size > 0 -%}
      <div class="store-locator__carousel-container">
        <div class="swiper store-locator__swiper">
          <div class="swiper-wrapper">
            {%- for block in location_blocks -%}
              <div class="swiper-slide" {{ block.shopify_attributes }}>
                <div class="store-locator__card">
                  {%- if block.settings.image != blank -%}
                    <div class="store-locator__card-image">
                      {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
                    </div>
                  {%- else -%}
                    <div class="store-locator__card-placeholder">
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {%- endif -%}

                  <div class="store-locator__card-content">
                    {%- if block.settings.subheading != blank -%}
                      <p class="store-locator__card-subheading">{{ block.settings.subheading | upcase }}</p>
                    {%- endif -%}
                    {%- if block.settings.heading != blank -%}
                      <h3 class="store-locator__card-heading">{{ block.settings.heading }}</h3>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>
          
          <!-- Navigation buttons -->
          {% comment %} <div class="swiper-button-prev store-locator__nav-prev"></div>
          <div class="swiper-button-next store-locator__nav-next"></div> {% endcomment %}
        </div>
      </div>
    {%- endif -%}

    <!-- Loading state for app fetch -->
    <div class="store-locator__loading" id="storeLocatorLoading--{{ section.id }}" style="display: none;">
      <div class="spinner"></div>
      <p>Loading boutiques...</p>
    </div>
  </div>
</section>

<!-- Swiper JS CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('[data-section-id="{{ section.id }}"]');
    const enableFetch = section.dataset.enableFetch === 'true';
    const sectionId = '{{ section.id }}';

    // Initialize Swiper
    function initSwiper() {
      const swiper = new Swiper('#StoreLocator--' + sectionId + ' .store-locator__swiper', {
        slidesPerView: 1,
        spaceBetween: 20,
        loop: true,
 
        {% comment %} navigation: {
          nextEl: '#StoreLocator--' + sectionId + ' .store-locator__nav-next',
          prevEl: '#StoreLocator--' + sectionId + ' .store-locator__nav-prev',
        }, {% endcomment %}
        breakpoints: {
          640: {
            slidesPerView: 2,
            spaceBetween: 20,
          },
          990: {
            slidesPerView: 3,
            spaceBetween: 30,
          },
          1200: {
            slidesPerView: 3,
            spaceBetween: 40,
          }
        }
      });
    }

    // If fetch from app is enabled
    if (enableFetch) {
      const loading = document.getElementById('storeLocatorLoading--' + sectionId);
      const carousel = section.querySelector('.store-locator__carousel-container');
      
      loading.style.display = 'flex';
      if (carousel) carousel.style.display = 'none';

      // Fetch locations from your app/API
      // Replace this URL with your actual API endpoint
      fetch('/apps/store-locator/locations')
        .then(res => res.json())
        .then(data => {
          if (data && data.locations && data.locations.length > 0) {
            renderLocations(data.locations);
          }
          loading.style.display = 'none';
          if (carousel) carousel.style.display = 'block';
          initSwiper();
        })
        .catch(err => {
          console.error('Error fetching locations:', err);
          loading.style.display = 'none';
          if (carousel) carousel.style.display = 'block';
          initSwiper();
        });
    } else {
      // Initialize swiper with static blocks
      initSwiper();
    }

    function renderLocations(locations) {
      const swiperWrapper = section.querySelector('.swiper-wrapper');
      swiperWrapper.innerHTML = '';

      locations.forEach(location => {
        const slide = document.createElement('div');
        slide.className = 'swiper-slide';
        slide.innerHTML = `
          <div class="store-locator__card">
            ${location.image 
              ? `<div class="store-locator__card-image">
                  <img src="${location.image}" alt="${location.name}" loading="lazy">
                </div>`
              : `<div class="store-locator__card-placeholder">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 525.5 525.5">
                    <path d="M375 262.7L262.7 375 150.4 262.7l112.3-112.3z"/>
                  </svg>
                </div>`
            }
            <div class="store-locator__card-content">
              ${location.subheading ? `<p class="store-locator__card-subheading">${location.subheading.toUpperCase()}</p>` : ''}
              ${location.name ? `<h3 class="store-locator__card-heading">${location.name}</h3>` : ''}
            </div>
          </div>
        `;
        swiperWrapper.appendChild(slide);
      });
    }
  });
</script>

{% stylesheet %}
  .store-locator {
    position: relative;
    width: 100%;
  }
  .store-locator.wrapper--custom {
    max-width: var(--custom-width, 1232px);
    padding: 0 20px;
  }
  .store-locator__wrapper {
    width: 100%;
    margin: 0 auto;
  }

  .store-locator__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    margin-bottom: 60px;
  }

  .store-locator__header-content {
    flex: 1;
    text-align: left;
  }

  .store-locator__header-button {
    flex-shrink: 0;
  }

  .store-locator__subheading {
    margin: 0 0 10px;
    color: var(--000000, #000);

    /* RC26/Title (ALL CAPS) */
    font-family: Inter;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 22px; /* 137.5% */
    letter-spacing: 1.6px;
    text-transform: uppercase;
  }

  .store-locator__heading {
    margin: 0;
    color: var(--000000, #000);
    font-family: var(--FONT-STACK-HEADING);

    font-size: 40px;
    font-style: normal;
    font-weight: 500;
    line-height: 48px; /* 120% */
  }

  .store-locator__heading.heading-small {
    font-size: 24px;
    line-height: 32px;
  }

  .store-locator__heading.heading-medium {
    font-size: 32px;
    line-height: 40px;
  }

  .store-locator__heading.heading-large {
    font-size: 40px;
    line-height: 48px;
  }

  .store-locator__heading.heading-x-large {
    font-size: 48px;
    line-height: 56px;
  }

  .store-locator__button {
    display: inline-flex;
    padding: 14px 32px;
    justify-content: center;
    align-items: center;
    color: #000;
    background-color: #FFF;
    border: 1px solid #000;
    font-family: Inter;
    font-size: 12px;
    font-style: normal;
    font-weight: 600;
    line-height: 20px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .store-locator__button:hover {
    background-color: #000;
    color: #FFF;
  }

  .store-locator__carousel-container {
    position: relative;
    margin: 0 auto;
    max-width: 1400px;
  }

  .store-locator__swiper {
    padding: 0 50px;
  }

  .store-locator__card {
    position: relative;
    display: flex;
    flex-direction: column;
    /* background: #fff; */
    overflow: hidden;
  }

  .store-locator__card-image {
    width: 100%;
    aspect-ratio: 397/516;
    overflow: hidden;
  }

  .store-locator__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .store-locator__card-placeholder {
    width: 100%;
    aspect-ratio: 294/325;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #F5F5F5;
  }

  .store-locator__card-placeholder svg {
    width: 50%;
    height: auto;
    opacity: 0.3;
  }

  .store-locator__card-content {
    padding: 20px 0;
    text-align: center;
  }

  .store-locator__card-subheading {
    margin: 0 0 5px;
    color: var(--000000, #000);
    font-family: Inter;
    font-size: 12px;
    font-style: normal;
    font-weight: 400;
    line-height: 20px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
  }

  .store-locator__card-heading {
    margin: 0;
    color: var(--000000, #000);
    font-family: var(--FONT-STACK-HEADING);
    font-size: 24px;
    font-style: normal;
    font-weight: 500;
    line-height: 32px;
  }

  /* Swiper navigation buttons */
  .store-locator__nav-prev,
  .store-locator__nav-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    background: #fff;
    border: 1px solid #000;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    transition: all 0.3s ease;
  }

  .store-locator__nav-prev:hover,
  .store-locator__nav-next:hover {
    background: #000;
  }

  .store-locator__nav-prev:after,
  .store-locator__nav-next:after {
    font-size: 16px;
    font-weight: bold;
    color: #000;
  }

  .store-locator__nav-prev:hover:after,
  .store-locator__nav-next:hover:after {
    color: #fff;
  }

  .store-locator__nav-prev {
    left: 0;
  }

  .store-locator__nav-next {
    right: 0;
  }

  .store-locator__nav-prev.swiper-button-disabled,
  .store-locator__nav-next.swiper-button-disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  /* Loading state */
  .store-locator__loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 20px;
    gap: 20px;
  }

  .store-locator__loading .spinner {
    width: 40px;
    height: 40px;
    border: 4px solid #ddd;
    border-top-color: #000;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .store-locator__loading p {
    margin: 0;
    color: #000;
    font-family: Inter;
    font-size: 14px;
    font-weight: 400;
  }

  /* Mobile adjustments */
  @media (max-width: 768px) {
    .store-locator__header {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
      margin-bottom: 40px;
    }

    .store-locator__header-button {
      width: 100%;
    }

    .store-locator__button {
      width: 100%;
      justify-content: center;
    }

    .store-locator__heading {
      font-size: 28px;
      line-height: 36px;
    }

    .store-locator__swiper {
      padding: 0 40px;
    }

    .store-locator__nav-prev,
    .store-locator__nav-next {
      width: 32px;
      height: 32px;
    }

    .store-locator__nav-prev:after,
    .store-locator__nav-next:after {
      font-size: 14px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Store locator",
  "tag": "section",
  "class": "section-store-locator",
  "blocks": [
    {
      "type": "subheading",
      "name": "Subheading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Store Locator"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Find a Boutique"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "Heading size",
          "default": "heading-large",
          "options": [
            { "value": "heading-small", "label": "Small" },
            { "value": "heading-medium", "label": "Medium" },
            { "value": "heading-large", "label": "Large" },
            { "value": "heading-x-large", "label": "Extra large" }
          ]
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Button text",
          "default": "Find the nearest"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button link"
        }
      ]
    },
    {
      "type": "location_card",
      "name": "Location card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Roberto Coin"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Venice"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "default": "wrapper",
      "options": [
        { "value": "wrapper--full-padded", "label": "Full width padded" },
        { "value": "wrapper", "label": "Normal" },
        { "value": "wrapper--narrow", "label": "Narrow" },
        { "value": "wrapper--custom", "label": "Custom (max-width: 1232px)" }  
      ]
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F9F9F9"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    },
    {
      "type": "header",
      "content": "App Integration"
    },
    {
      "type": "checkbox",
      "id": "enable_fetch_from_app",
      "label": "Enable fetch from app",
      "info": "Fetch locations dynamically from an app/API instead of using static blocks",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "Color scheme"
    }
  ],
  "presets": [
    {
      "name": "Store locator",
      "category": "Store",
      "blocks": [
        {
          "type": "subheading",
          "settings": {
            "text": "Store Locator"
          }
        },
        {
          "type": "heading",
          "settings": {
            "text": "Find a Boutique"
          }
        },
        {
          "type": "button",
          "settings": {
            "text": "Find the nearest"
          }
        },
        {
          "type": "location_card",
          "settings": {
            "subheading": "Roberto Coin",
            "heading": "Venice"
          }
        },
        {
          "type": "location_card",
          "settings": {
            "subheading": "Roberto Coin",
            "heading": "Rome"
          }
        },
        {
          "type": "location_card",
          "settings": {
            "subheading": "Roberto Coin",
            "heading": "Florence"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "aside", "footer"]
  }
}
{% endschema %}
