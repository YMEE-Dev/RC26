{%- liquid
  assign text_color = section.settings.color
  assign color_scheme = 'color-' | append: section.settings.color_scheme
  assign header_observer_mode = section.settings.header_observer_mode | default: collection.metafields.custom.header_observer_mode.value | default: 'light'
  assign header_observer_mode = header_observer_mode | downcase | strip

  unless header_observer_mode == 'dark' or header_observer_mode == 'light'
    assign header_observer_mode = 'light'
  endunless

  assign sub_collections = linklists[collection.handle].links
  assign sub_collection_html = ''
  assign sub_collection_counter = 0
  assign sub_collection_limit = 6
-%}

{%- if linklists[collection.handle].links.size > 0 -%}
  {%- style -%}
    #Subcollections--{{ section.id }} {
      --PT: {{ section.settings.padding_top }}px;
      --PB: {{ section.settings.padding_bottom }}px;
      --globaltext: {% if header_observer_mode == 'light' %}#fff{% else %}#000{% endif %};
      --link: {% if header_observer_mode == 'light' %}#fff{% else %}#000{% endif %};
      --link-hover: {% if header_observer_mode == 'light' %}#f0f0f0{% else %}#222{% endif %};

      {%- unless text_color == 'rgba(0,0,0,0)' or text_color == blank -%}
        --text: {{ text_color }};
      {%- endunless -%}

      {%  if section.settings.subcollection_bg %}
        background: url({{ section.settings.subcollection_bg | image_url }});
        background-repeat: initial;
        background-position: bottom;
        background-size: cover;
        min-height: 400px;
      {% endif %}
    }

    @keyframes subcollections-swipe-hint-bounce-{{ section.id }} {
      0% { transform: translateX(0); }
      5.4% { transform: translateX(-28px); }
      10.8% { transform: translateX(-28px); }
      17.9% { transform: translateX(6px); }
      23.3% { transform: translateX(0); }
      35.9% { transform: translateX(0); }
      100% { transform: translateX(0); }
    }

    #Subcollections--{{ section.id }} .subcollections__swiper.subcollections__swiper--swipe-hint .swiper-wrapper .swiper-slide {
      animation: subcollections-swipe-hint-bounce-{{ section.id }} 6.8s ease-in-out infinite;
    }

    @media only screen and (min-width: 960px) {
      #Subcollections--{{ section.id }} .subcollections__swiper.subcollections__swiper--swipe-hint .swiper-wrapper .swiper-slide {
        animation: none;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      #Subcollections--{{ section.id }} .subcollections__swiper.subcollections__swiper--swipe-hint .swiper-wrapper .swiper-slide {
        animation: none;
      }
    }
  {%- endstyle -%}

  <section
    class="subcollections collection-{{ collection.handle }} section-padding {{ color_scheme }} header-observer--{{ header_observer_mode }}"
    data-section-id="{{ section.id }}"
    data-section-type="subcollections"
    data-header-observer-mode="{{ header_observer_mode }}"
    id="Subcollections--{{ section.id }}"
  >
    {%- if sub_collections.size > 0 -%}
      {%- for sublink in sub_collections -%}
        {%- liquid
          if sublink.type != 'collection_link' or sublink.object.handle == blank
            continue
          endif

          assign sub_collection_handle = sublink.object.handle
          assign sub_collection_title = sublink.title
          assign sub_collection_handle_separator = sub_collection_handle | append: ',' | prepend: ','
          assign sub_collection = collections[sub_collection_handle]

          if sublink.object.handle contains sub_collection_handle_separator
            continue
          endif
        -%}

        {%- capture sub_collection_html -%}
          {{ sub_collection_html }}

          <div class="swiper-slide subcollection__item">
            <div class="subcollection__inner">
              <a
                class="subcollection__link{% if sub_collection.handle == collection.handle %} is-active{% endif %}"
                href="{{ sub_collection.url }}"
              >
                <div class="subcollection__image">
                  {%- assign image = sub_collection.image -%}

                  {%- if section.settings.select_image == 'product' or image == blank -%}
                    {%- assign image = sub_collection.products.first.featured_media.preview_image -%}
                  {%- endif -%}

                  {%- capture sizes -%}
                    (min-width: 750px) (calc(100vw - 16px) / 3), calc(100vw - 32px)
                  {%- endcapture -%}

                  {%- render 'image' image: image, sizes: sizes, cover: true, show_backfill: false, loading: 'eager' -%}
                </div>
              </a>
            </div>
            <div class="subcollection__text">
              <p class="subcollection__title navlink">{{ sub_collection_title }}</p>
              {%- if sub_collection.description != '' and section.settings.subcollection_description -%}
                <div class="subcollection__description">{{ sub_collection.description }}</div>
              {%- endif -%}
            </div>
          </div>
        {%- endcapture -%}

        {%- assign sub_collection_counter = sub_collection_counter | plus: 1 -%}

        {%- if sub_collection_counter >= sub_collection_limit -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if sub_collection_html != '' and template.suffix != 'media-only' -%}
        <script src="{{ 'subcollections-slider.js' | asset_url }}" defer></script>
        <div class="subcollections__swiper swiper" data-subcollections-swiper>
          <div class="swiper-wrapper">
            {{ sub_collection_html }}
          </div>
        </div>
      {%- endif -%}
    {%- endif -%}
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Subcollections",
  "class": "section-overlay-header",
  "settings": [
    {
      "type": "header",
      "content": "Header observer"
    },
    {
      "type": "text",
      "id": "header_observer_mode",
      "label": "Header mode",
      "default": "light",
      "info": "Enter light or dark. Can be connected to a collection metafield."
    },
    {
      "type": "paragraph",
      "content": "Create a [navigation list](/admin/content/menus) with the same name as this collection and link to other collections. [Learn more](https://broadcast.presidiocreative.com/collections/collection-pages/sub-collections)"
    },
    {
      "type": "image_picker",
      "id": "subcollection_bg",
      "label": "Background image"
    },
    {
      "type": "checkbox",
      "id": "subcollection_description",
      "label": "Show description",
      "default": false
    },
    {
      "type": "select",
      "id": "select_image",
      "label": "Select a photo to display",
      "options": [
        {
          "value": "collection",
          "label": "Collection image"
        },
        {
          "value": "product",
          "label": "Product image"
        }
      ]
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "Color scheme"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Text",
      "default": "#ffffff",
      "alpha": true
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom",
      "default": 20
    }
  ]
}
{% endschema %}
