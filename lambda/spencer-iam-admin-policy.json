{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CreateUsersOnlyTaggedAndBounded",
      "Effect": "Allow",
      "Action": "iam:CreateUser",
      "Resource": "arn:aws:iam::376129434684:user/*",
      "Condition": {
        "StringEquals": {
          "aws:RequestTag/team": "rc-us",
          "iam:PermissionsBoundary": "arn:aws:iam::376129434684:policy/RC-US-Boundary"
        }
      }
    },
    {
      "Sid": "SetBoundaryOnlyToRcUsBoundary",
      "Effect": "Allow",
      "Action": "iam:PutUserPermissionsBoundary",
      "Resource": "arn:aws:iam::376129434684:user/*",
      "Condition": {
        "StringEquals": {
          "iam:PermissionsBoundary": "arn:aws:iam::376129434684:policy/RC-US-Boundary"
        }
      }
    },
    {
      "Sid": "ManageOnlyRcUsTaggedUsers",
      "Effect": "Allow",
      "Action": [
        "iam:DeleteUser",
        "iam:CreateAccessKey",
        "iam:DeleteAccessKey",
        "iam:ListAccessKeys",
        "iam:UpdateAccessKey",
        "iam:CreateLoginProfile",
        "iam:DeleteLoginProfile",
        "iam:UpdateLoginProfile",
        "iam:GetLoginProfile"
      ],
      "Resource": "arn:aws:iam::376129434684:user/*",
      "Condition": {
        "StringEquals": {
          "iam:ResourceTag/team": "rc-us"
        }
      }
    },
    {
      "Sid": "AttachPoliciesOnlyToRcUsTaggedUsers",
      "Effect": "Allow",
      "Action": [
        "iam:AttachUserPolicy",
        "iam:DetachUserPolicy",
        "iam:PutUserPolicy",
        "iam:DeleteUserPolicy"
      ],
      "Resource": "arn:aws:iam::376129434684:user/*",
      "Condition": {
        "StringEquals": {
          "iam:ResourceTag/team": "rc-us"
        }
      }
    },
    {
      "Sid": "TagOnlyWithinRcUsTeam",
      "Effect": "Allow",
      "Action": [
        "iam:TagUser",
        "iam:UntagUser"
      ],
      "Resource": "arn:aws:iam::376129434684:user/*",
      "Condition": {
        "StringEquals": {
          "iam:ResourceTag/team": "rc-us"
        },
        "StringEqualsIfExists": {
          "aws:RequestTag/team": "rc-us"
        }
      }
    },
    {
      "Sid": "DenyRemovingAnyBoundary",
      "Effect": "Deny",
      "Action": "iam:DeleteUserPermissionsBoundary",
      "Resource": "*"
    },
    {
      "Sid": "ProtectTheBoundaryPolicyItself",
      "Effect": "Deny",
      "Action": [
        "iam:CreatePolicyVersion",
        "iam:DeletePolicyVersion",
        "iam:SetDefaultPolicyVersion",
        "iam:DeletePolicy"
      ],
      "Resource": "arn:aws:iam::376129434684:policy/RC-US-Boundary"
    },
    {
      "Sid": "ReadOnlyIamVisibility",
      "Effect": "Allow",
      "Action": [
        "iam:ListUsers",
        "iam:GetUser",
        "iam:ListAttachedUserPolicies",
        "iam:ListUserPolicies",
        "iam:ListPolicies",
        "iam:GetPolicy",
        "iam:GetPolicyVersion",
        "iam:GetAccountPasswordPolicy",
        "iam:ListAccountAliases"
      ],
      "Resource": "*"
    }
  ]
}
