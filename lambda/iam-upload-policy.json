{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowUpload",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::robertocoin-3d-models",
        "arn:aws:s3:::robertocoin-3d-models/models/*"
      ]
    }
  ]
}
