{% doc %}
  Renders composite side drawer content with intro media/text, product tiles, and FAQ accordion.

  @param {object} block - Side drawer block object
  @param {string} [template] - Template mode: composite, intro, products, or faq
{% enddoc %}

{%- liquid
  assign drawer_template = template | default: 'composite'
  assign show_intro = false
  assign show_products = false
  assign show_faq = false

  if drawer_template == 'composite'
    assign show_intro = true
    assign show_products = true
    assign show_faq = true
  endif

  if drawer_template == 'intro'
    assign show_intro = true
  endif

  if drawer_template == 'products'
    assign show_products = true
  endif

  if drawer_template == 'faq'
    assign show_faq = true
  endif
-%}

<div class="drawer-content-composite">
  {%- if show_intro and (block.settings.intro_image != blank or block.settings.heading != blank or block.settings.text != blank or block.settings.page != blank) -%}
    <section class="drawer-content-composite__intro">
      {%- if block.settings.intro_image != blank -%}
        <div class="drawer-content-composite__intro-media">
          {{
            block.settings.intro_image
            | image_url: width: 1400
            | image_tag:
              loading: 'lazy',
              widths: '360, 540, 720, 960, 1200, 1400',
              sizes: '(min-width: 990px) 45vw, 100vw',
              class: 'drawer-content-composite__intro-image'
          }}
        </div>
      {%- endif -%}

      <div class="drawer-content-composite__intro-content">
        {%- if block.settings.heading != blank -%}
          <h3 class="drawer-content-composite__heading">{{ block.settings.heading }}</h3>
        {%- endif -%}
        {%- if block.settings.text != blank -%}
          <div class="drawer-content-composite__text rte">{{ block.settings.text }}</div>
        {%- endif -%}
        {%- if block.settings.page != blank -%}
          <div class="drawer-content-composite__page rte">{{ block.settings.page.content }}</div>
        {%- endif -%}
      </div>
    </section>
  {%- endif -%}

  {%- if show_products and block.settings.products != blank -%}
    <section class="drawer-content-composite__products">
      {%- if block.settings.products_heading != blank -%}
        <h4 class="drawer-content-composite__section-title">{{ block.settings.products_heading }}</h4>
      {%- endif -%}

      <div class="drawer-content-composite__product-grid">
        {%- for tile_product in block.settings.products -%}
          <a class="drawer-content-composite__product" href="{{ tile_product.url }}">
            {%- if tile_product.featured_image != blank -%}
              {{
                tile_product.featured_image
                | image_url: width: 600
                | image_tag:
                  loading: 'lazy',
                  widths: '180, 240, 320, 420, 600',
                  sizes: '(min-width: 990px) 200px, 40vw',
                  class: 'drawer-content-composite__product-image'
              }}
            {%- endif -%}
            <p class="drawer-content-composite__product-title">{{ tile_product.title }}</p>
            <p class="drawer-content-composite__product-price">{{ tile_product.price | money }}</p>
          </a>
        {%- endfor -%}
      </div>
    </section>
  {%- endif -%}

  {%- if show_faq and (block.settings.faq_title_1 != blank or block.settings.faq_title_2 != blank or block.settings.faq_title_3 != blank) -%}
    <section class="drawer-content-composite__faq">
      {%- if block.settings.faq_heading != blank -%}
        <h4 class="drawer-content-composite__section-title">{{ block.settings.faq_heading }}</h4>
      {%- endif -%}

      <div class="drawer-content-composite__accordion">
        {%- if block.settings.faq_title_1 != blank and block.settings.faq_text_1 != blank -%}
          <details class="drawer-content-composite__accordion-item">
            <summary class="drawer-content-composite__accordion-summary">{{ block.settings.faq_title_1 }}</summary>
            <div class="drawer-content-composite__accordion-content rte">{{ block.settings.faq_text_1 }}</div>
          </details>
        {%- endif -%}

        {%- if block.settings.faq_title_2 != blank and block.settings.faq_text_2 != blank -%}
          <details class="drawer-content-composite__accordion-item">
            <summary class="drawer-content-composite__accordion-summary">{{ block.settings.faq_title_2 }}</summary>
            <div class="drawer-content-composite__accordion-content rte">{{ block.settings.faq_text_2 }}</div>
          </details>
        {%- endif -%}

        {%- if block.settings.faq_title_3 != blank and block.settings.faq_text_3 != blank -%}
          <details class="drawer-content-composite__accordion-item">
            <summary class="drawer-content-composite__accordion-summary">{{ block.settings.faq_title_3 }}</summary>
            <div class="drawer-content-composite__accordion-content rte">{{ block.settings.faq_text_3 }}</div>
          </details>
        {%- endif -%}
      </div>
    </section>
  {%- endif -%}
</div>

{% stylesheet %}
  .drawer-content-composite {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .drawer-content-composite__intro {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .drawer-content-composite__intro-image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .drawer-content-composite__intro-content {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .drawer-content-composite__heading,
  .drawer-content-composite__section-title,
  .drawer-content-composite__product-title,
  .drawer-content-composite__product-price {
    margin: 0;
  }

  .drawer-content-composite__text > *:first-child,
  .drawer-content-composite__page > *:first-child {
    margin-top: 0;
  }

  .drawer-content-composite__product-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .drawer-content-composite__product {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-decoration: none;
    color: inherit;
  }

  .drawer-content-composite__product-image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .drawer-content-composite__product-title {
    font-size: 0.95rem;
  }

  .drawer-content-composite__product-price {
    opacity: 0.8;
  }

  .drawer-content-composite__accordion {
    border-top: 1px solid var(--border);
  }

  .drawer-content-composite__accordion-item {
    border-bottom: 1px solid var(--border);
  }

  .drawer-content-composite__accordion-summary {
    list-style: none;
    cursor: pointer;
    padding: 12px 0;
    font-weight: var(--FONT-WEIGHT-BODY-BOLD);
  }

  .drawer-content-composite__accordion-summary::-webkit-details-marker {
    display: none;
  }

  .drawer-content-composite__accordion-content {
    padding: 0 0 12px;
  }

  @media only screen and (min-width: 990px) {
    .drawer-content-composite__product-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
{% endstylesheet %}
