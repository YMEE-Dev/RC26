{% doc %}
  Renders a hero-style background media layer with optional text and CTA content.

  @param {object} [section] - Section or block context to read settings from
  @param {string} [desktop_height] - Optional desktop height class override
  @param {string} [mobile_height] - Optional mobile height class override
  @param {boolean} [block_element] - Whether this snippet is rendered inside a block context
{% enddoc %}

{%- liquid
  assign block_settings = block_settings | default: section.settings
  assign block_element = block_element | default: false
  assign desktop_height = desktop_height | default: block_settings.desktop_height
  if request.visual_preview_mode
    assign desktop_height = ''
  endif
  assign mobile_height = mobile_height | default: block_settings.mobile_height
  assign media = block_settings.video
  assign mobile_media = block_settings.mobile_video
  assign has_background_video_desktop = false
  if media != blank
    if media.media_type == 'video'
      assign has_background_video_desktop = true
    elsif media.sources != blank
      assign has_background_video_desktop = true
    endif
  endif
  assign has_background_video_mobile = false
  if mobile_media != blank
    if mobile_media.media_type == 'video'
      assign has_background_video_mobile = true
    elsif mobile_media.sources != blank
      assign has_background_video_mobile = true
    endif
  endif
  assign has_background_video = false
  if has_background_video_desktop or has_background_video_mobile
    assign has_background_video = true
  endif
  assign has_video_variants = false
  if has_background_video_desktop and has_background_video_mobile
    assign has_video_variants = true
  endif
  assign aspect_ratio = aspect_ratio | default: media.aspect_ratio | default: mobile_media.aspect_ratio
  assign media_aspect_ratio = video_aspect_ratio | default: media.aspect_ratio | default: mobile_media.aspect_ratio | default: 1
  assign video_popup = block_settings.video_popup | default: block_settings.video_popup_social
  assign image_desktop = block_settings.image | default: media.preview_image | default: mobile_media.preview_image | default: media
  assign image_mobile = block_settings.mobile_image | default: mobile_media.preview_image
  assign text_color = block_settings.color
  assign overlay_type = block_settings.overlay_type
  assign opacity_overlay = false
  assign text_underlay = false
  if overlay_type == 'opacity'
    assign opacity_overlay = true
  elsif overlay_type == 'text'
    assign text_underlay = true
  endif
  assign animation_anchor = '#Video--' | append: section.id

  assign title = block_settings.title
  assign text = block_settings.text
  assign link_text = block_settings.link_text
  assign heading_font_size_desktop = block_settings.heading_font_size | default: 'heading-medium' | strip
  assign heading_font_size_mobile = block_settings.heading_font_size_mobile | default: heading_font_size_desktop | strip
  assign heading_font_size_desktop_class = heading_font_size_desktop | replace: 'heading-', 'heading-desktop-'
  assign heading_font_size_mobile_class = heading_font_size_mobile | replace: 'heading-', 'heading-mobile-'
  assign flex_align_desktop = block_settings.flex_align_desktop | strip
  assign flex_align_mobile = block_settings.flex_align_mobile | strip
  assign button_align_desktop = block_settings.button_align_desktop | strip
  assign button_align_mobile = block_settings.button_align_mobile | strip
  assign button_vertical_position_mobile = block_settings.button_vertical_position_mobile | strip

  if flex_align_desktop == blank
    assign flex_align_desktop = block_settings.flex_align | default: 'align--middle-center' | append: '-desktop'
  endif

  if flex_align_mobile == blank
    assign flex_align_mobile = block_settings.flex_align | default: 'align--middle-center' | append: '-mobile'
  endif

  if button_align_desktop == blank
    assign button_align_desktop = 'button-group-align--center-desktop'
  endif

  if button_align_mobile == blank
    assign button_align_mobile = 'button-group-align--center-mobile'
  endif

  if button_vertical_position_mobile == blank
    assign button_vertical_position_mobile = 'button-position--top-mobile'
  endif

  assign button_style = block_settings.button_style
  if button_style == 'btn--text' and block_settings.show_arrow
    assign button_style = button_style | append: ' btn--text-no-underline'
  endif

  assign show_video_popup = false
  if block_settings.show_video_popup and video_popup != blank
    assign show_video_popup = true
  endif

  assign show_text_background = block_settings.show_text_background
  assign selected_color_scheme = block_settings.color_scheme | strip
  assign scheme_bg_color = settings.color_schemes[selected_color_scheme].settings.section_bg

  assign hero_transparent = true
  if show_text_background and scheme_bg_color.alpha != 0 or scheme_bg_color.alpha != 0.0
    assign hero_transparent = false
  endif

  assign show_header_backdrop = false
  if hero_transparent and text_underlay
    assign show_header_backdrop = true
  endif

  assign animation_order = 0

  comment
    The poster is the page's LCP candidate when this section is first in the
    template: fetch it at high priority.

    When a background video will replace the poster, cap the widths ladder at
    3000 so high-DPR devices don't pull an oversized poster file that only
    shows for a moment. With no video the poster IS the permanent hero, so
    leave widths unset and let image-hero use its full ladder (up to 5760) to
    stay sharp on large / high-DPR screens.
  endcomment
  assign poster_fetchpriority = nil
  if section.location == 'template' and section.index == 1
    assign poster_fetchpriority = 'high'
  endif

  assign poster_widths = nil
  if has_background_video
    assign poster_widths = '180, 360, 540, 720, 900, 1080, 1296, 1512, 1728, 1950, 2100, 2260, 2450, 2700, 3000'
  endif

  capture video_poster
    render 'image-hero', image_desktop: image_desktop, image_mobile: image_mobile, desktop_height: desktop_height, mobile_height: mobile_height, aspect_ratio: aspect_ratio, aspect_ratio_mobile: aspect_ratio, fetchpriority: poster_fetchpriority, widths: poster_widths
  endcapture
-%}

{%- capture style -%}
  {%- unless text_color.alpha == 0.0 or text_color == blank -%}
    --text: {{ text_color }};
  {%- endunless -%}

  {% if show_header_backdrop %}
    --header-overlay-color: var(--overlay-bg);
  {% endif %}
{%- endcapture -%}

{%- if block_settings.link != blank and link_text == blank -%}
  <a class="hero__video frame__item" href="{{ block_settings.link }}">
{%- else -%}
  <div class="hero__video frame__item">
{%- endif -%}

{%- if has_background_video -%}
  {%- liquid
    comment
      Shopify transcodes hosted videos into a rendition ladder (e.g. 1080p /
      720p / 480p mp4 + HLS). video_tag lists every source and browsers grab
      the heaviest mp4 — 6.5MB+ for a 1080p hero. A ~720p rendition is plenty
      for a muted background loop, so pick the best mp4 capped at 720p and
      render the <video> ourselves. Falls back to video_tag when no capped
      mp4 rendition exists.
    endcomment
    assign desktop_video_source = nil
    if has_background_video_desktop
      for source in media.sources
        if source.format == 'mp4' and source.height <= 720
          if desktop_video_source == nil or source.height > desktop_video_source.height
            assign desktop_video_source = source
          endif
        endif
      endfor
    endif
    assign mobile_video_source = nil
    if has_background_video_mobile
      for source in mobile_media.sources
        if source.format == 'mp4' and source.height <= 720
          if mobile_video_source == nil or source.height > mobile_video_source.height
            assign mobile_video_source = source
          endif
        endif
      endfor
    endif
  -%}
  <div
    class="video-background {{ desktop_height }} {{ mobile_height }}"
    style="--aspect-ratio: {{ media_aspect_ratio }};"
  >
    <div class="video__poster">
      {{ video_poster }}
    </div>
    {%- if has_background_video_desktop -%}
      <video-background
        class="video__player is-loading{% if has_video_variants %} video__player--desktop{% endif %}"
        data-video-player
        data-video-id="{{ section.id }}-video-background{% if has_video_variants %}-desktop{% endif %}"
      >
        <template data-video-template>
          {%- if desktop_video_source -%}
            <video autoplay loop muted playsinline>
              <source src="{{ desktop_video_source.url }}" type="{{ desktop_video_source.mime_type }}">
            </video>
          {%- else -%}
            {{ media | video_tag: autoplay: true, image_size: '1085x', loop: true, muted: true, controls: false }}
          {%- endif -%}
        </template>
      </video-background>
    {%- endif -%}
    {%- if has_background_video_mobile -%}
      <video-background
        class="video__player is-loading{% if has_video_variants %} video__player--mobile{% endif %}"
        data-video-player
        data-video-id="{{ section.id }}-video-background{% if has_video_variants %}-mobile{% endif %}"
      >
        <template data-video-template>
          {%- if mobile_video_source -%}
            <video autoplay loop muted playsinline>
              <source src="{{ mobile_video_source.url }}" type="{{ mobile_video_source.mime_type }}">
            </video>
          {%- else -%}
            {{ mobile_media | video_tag: autoplay: true, image_size: '1085x', loop: true, muted: true, controls: false }}
          {%- endif -%}
        </template>
      </video-background>
    {%- endif -%}
  </div>
{%- else -%}
  {{ video_poster }}
{%- endif -%}

{%- if opacity_overlay -%}
  <div class="image-overlay"></div>
{%- endif -%}

{%- if block_settings.link != blank and link_text == blank -%}
  </a>
{%- else -%}
  </div>
{%- endif -%}

{%- if title != blank or text != blank or link_text != blank or show_video_popup -%}
  <div
    class="hero__content__wrapper frame__item {{ flex_align_desktop }} {{ flex_align_mobile }}{% if show_header_backdrop %} backdrop--linear{% endif %}"
    id="Video--{{ section.id }}"
    style="{{ style }}"
  >
    <div
      class="hero__content hero__content--video {{ button_vertical_position_mobile }}{% if hero_transparent %} hero__content--transparent{% endif %}{% if text_underlay %} backdrop--radial{% endif %}"
    >
      {%- if title != blank -%}
        {%- liquid
          assign animation_order = animation_order | plus: 1
          assign heading_tag = 'h2'

          unless block_settings.heading_tag == 'automatic' or block_settings.heading_tag == blank
            assign heading_tag = block_settings.heading_tag
          endunless
        -%}
        <{{ heading_tag }}
          class="hero__title {{ heading_font_size_desktop_class }} {{ heading_font_size_mobile_class }}"
          data-aos="hero"
          data-aos-anchor="{{ animation_anchor }}"
          data-aos-order="{{ animation_order }}"
        >
          {{ title | escape }}
        </{{ heading_tag }}>
      {%- endif -%}

      {%- if text != blank -%}
        {%- assign animation_order = animation_order | plus: 1 -%}
        <div
          class="hero__description {{ block_settings.text_font_size }}"
          data-aos="hero"
          data-aos-anchor="{{ animation_anchor }}"
          data-aos-order="{{ animation_order }}"
        >
          {{ text }}
        </div>
      {%- endif -%}

      {%- if link_text != blank or show_video_popup -%}
        <div class="hero__button-group hero__button-group--video {{ button_align_desktop }} {{ button_align_mobile }}">
          {%- if link_text != blank -%}
            {%- assign animation_order = animation_order | plus: 1 -%}
            <div
              class="hero__button hero__button--video"
              data-aos="hero"
              data-aos-anchor="{{ animation_anchor }}"
              data-aos-order="{{ animation_order }}"
            >
              <a
                class="btn {{ button_style }} {{ block_settings.button_type }} {{ block_settings.button_size }}"
                href="{{ block_settings.link }}"
              >
                <span>{{ link_text | escape }}</span>

                {%- if block_settings.show_arrow -%}
                  {%- render 'icon-nav-arrow-right' -%}
                {%- endif -%}
              </a>
            </div>
          {%- endif -%}

          {%- if show_video_popup -%}
            {%- liquid
              assign video_parent_id = 'item-video-' | append: section.id
              assign animation_order = animation_order | plus: 1
            -%}

            <video-popup
              class="hero__button hero__button--video"
              data-aos="hero"
              data-aos-anchor="{{ animation_anchor }}"
              data-aos-order="{{ animation_order }}"
            >
              <a
                href="{{ video_popup }}"
                class="btn {{ block_settings.button_size }} {{ block_settings.button_style }} {{ block_settings.button_type }} image__video__play"
                data-video-play="{%- render 'photoswipe-video-html' item_link: video_popup, item_id: video_parent_id, item_enable_sound: 'false' -%}"
              >
                {% render 'icon-play' %}
              </a>
            </video-popup>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .hero__button-group--video {
    justify-content: var(--video-button-justify-content, var(--alignment-justify-content, center));
  }

  .hero__button--video {
    justify-content: var(--video-button-justify-content, var(--alignment-justify-content, flex-start));
  }

  @media only screen and (min-width: 750px) {
    .button-group-align--left-desktop {
      --video-button-justify-content: flex-start;
    }

    .button-group-align--center-desktop {
      --video-button-justify-content: center;
    }

    .button-group-align--right-desktop {
      --video-button-justify-content: flex-end;
    }
  }

  @media only screen and (max-width: 749px) {
    .button-group-align--left-mobile {
      --video-button-justify-content: flex-start;
    }

    .button-group-align--center-mobile {
      --video-button-justify-content: center;
    }

    .button-group-align--right-mobile {
      --video-button-justify-content: flex-end;
    }

    .hero__content--video.button-position--bottom-mobile {
      min-height: 100%;
      width: 78%;
    }

    .hero__content--video.button-position--bottom-mobile .hero__button-group--video {
      margin-top: auto;
      margin-bottom: 0;
      width: 100%;
      margin-bottom: 20px;
      margin-left: auto;
      margin-right: auto;
    }
    .hero__content--video.button-position--bottom-mobile .hero__button-group--video .hero__button,
    .hero__content--video.button-position--bottom-mobile .hero__button-group--video .hero__button .btn {
      width: 100%;
    }
  }

  @media only screen and (max-width: 749px) {
    .video__player--desktop {
      display: none;
    }
  }

  @media only screen and (min-width: 750px) {
    .video__player--mobile {
      display: none;
    }
  }
{% endstylesheet %}
