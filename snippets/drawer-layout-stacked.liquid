{% doc %}
  Renders a stacked side-drawer layout with heading, text, optional page, accordion rows, and image.

  @param {object} block - Side drawer block object
{% enddoc %}

<div class="drawer-layout drawer-layout--stacked">
  {%- if block.settings.heading != blank -%}
    <h3 class="drawer-layout__heading">{{ block.settings.heading }}</h3>
  {%- endif -%}

  {%- if block.settings.text != blank -%}
    <div class="drawer-layout__text rte">{{ block.settings.text }}</div>
  {%- endif -%}

  {%- if block.settings.page != blank -%}
    <div class="drawer-layout__page rte">{{ block.settings.page.content }}</div>
  {%- endif -%}

  <div class="drawer-layout__accordion">
    {%- if block.settings.accordion_title_1 != blank and block.settings.accordion_text_1 != blank -%}
      <details class="drawer-layout__accordion-item">
        <summary class="drawer-layout__accordion-summary">{{ block.settings.accordion_title_1 }}</summary>
        <div class="drawer-layout__accordion-content rte">{{ block.settings.accordion_text_1 }}</div>
      </details>
    {%- endif -%}

    {%- if block.settings.accordion_title_2 != blank and block.settings.accordion_text_2 != blank -%}
      <details class="drawer-layout__accordion-item">
        <summary class="drawer-layout__accordion-summary">{{ block.settings.accordion_title_2 }}</summary>
        <div class="drawer-layout__accordion-content rte">{{ block.settings.accordion_text_2 }}</div>
      </details>
    {%- endif -%}

    {%- if block.settings.accordion_title_3 != blank and block.settings.accordion_text_3 != blank -%}
      <details class="drawer-layout__accordion-item">
        <summary class="drawer-layout__accordion-summary">{{ block.settings.accordion_title_3 }}</summary>
        <div class="drawer-layout__accordion-content rte">{{ block.settings.accordion_text_3 }}</div>
      </details>
    {%- endif -%}
  </div>

  {%- if block.settings.stacked_image != blank -%}
    <div class="drawer-layout__media drawer-layout__media--stacked">
      {{
        block.settings.stacked_image
        | image_url: width: 1600
        | image_tag:
          loading: 'lazy',
          widths: '360, 540, 720, 960, 1200, 1600',
          sizes: '100vw',
          class: 'drawer-layout__image'
      }}
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .drawer-layout--stacked {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .drawer-layout--stacked .drawer-layout__heading {
    margin: 0;
  }

  .drawer-layout--stacked .drawer-layout__text > *:first-child,
  .drawer-layout--stacked .drawer-layout__page > *:first-child {
    margin-top: 0;
  }

  .drawer-layout--stacked .drawer-layout__accordion {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--border);
  }

  .drawer-layout--stacked .drawer-layout__accordion-item {
    border-bottom: 1px solid var(--border);
  }

  .drawer-layout--stacked .drawer-layout__accordion-summary {
    list-style: none;
    cursor: pointer;
    padding: 12px 0;
    font-weight: var(--FONT-WEIGHT-BODY-BOLD);
  }

  .drawer-layout--stacked .drawer-layout__accordion-summary::-webkit-details-marker {
    display: none;
  }

  .drawer-layout--stacked .drawer-layout__accordion-content {
    padding: 0 0 12px;
  }

  .drawer-layout--stacked .drawer-layout__media--stacked {
    margin-top: 8px;
  }

  .drawer-layout--stacked .drawer-layout__image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }
{% endstylesheet %}
