{% doc %}
  Returns the current collection result count excluding storytelling products.

  The count is based on the current collection filter state. When a product type
  filter exists, the snippet subtracts the current storytelling bucket count
  from the current filtered result set. If that bucket isn't exposed by Shopify,
  it falls back to scanning the current collection slice.

  @param {collection} collection_obj - The collection to count
  @example
  {% render 'collection-products-count', collection_obj: collection %}
{% enddoc %}

{%- liquid
  assign display_products_count = 0

  if collection_obj != blank
    assign display_products_count = collection_obj.products_count
    assign storytelling_products_count = 0
    assign storytelling_bucket_found = false

    for filter in collection_obj.filters
      if filter.param_name contains 'product_type'
        for filter_value in filter.values
          assign filter_value_label = filter_value.label | downcase | strip
          assign filter_value_value = filter_value.value | downcase | strip

          if filter_value_label == 'storytelling' or filter_value_value == 'storytelling'
            assign storytelling_products_count = filter_value.count
            assign storytelling_bucket_found = true
            break
          endif
        endfor

        break
      endif
    endfor

    if storytelling_bucket_found == false
      for product in collection_obj.products
        assign product_type = product.type | downcase | strip

        if product_type contains 'storytelling'
          assign storytelling_products_count = storytelling_products_count | plus: 1
        endif
      endfor
    endif

    assign display_products_count = collection_obj.products_count | minus: storytelling_products_count

    if display_products_count < 0
      assign display_products_count = 0
    endif
  endif

  echo display_products_count
-%}
