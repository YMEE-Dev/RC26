{% comment %}
  YMEE Variant Dropdown — SIZE only
  Renders a custom dropdown for the SIZE option on Variable PDPs.
  Metal color / other options remain rendered by the default theme picker.

  Accepts:
  - product: {Object} product object
  - current_variant: {Object} the selected or first available variant
  - section_id: {String} section ID for scoping
  - ring_sizing_link: {String} URL for ring sizing guide (optional)
  - bracelet_sizing_link: {String} URL for bracelet sizing guide (optional)

  Usage:
  {% render 'ymee-variant-dropdown', product: product, current_variant: current_variant, section_id: section.id %}
  {% render 'ymee-variant-dropdown', product: product, current_variant: current_variant, section_id: section.id, ring_sizing_link: 'https://your-custom-link.com/ring-guide.pdf' %}
{% endcomment %}

{%- liquid
  assign selected_variant = current_variant | default: product.selected_or_first_available_variant

  assign ymee_size_option_index = -1
  assign size_translation = 'general.size_chart.size' | t
  assign translation_string_size = size_translation | remove: ' ' | replace: ', ', ',' | replace: ' ,', ',' | replace: ',', '____' | handle | replace: '____', ',' | append: ',' | prepend: ','

  for option in product.options_with_values
    assign opt_handle = option.name | handle
    if translation_string_size contains opt_handle
      assign ymee_size_option_index = forloop.index0
      break
    endif
  endfor
-%}

{%- if ymee_size_option_index >= 0 -%}
  {%- liquid
    assign ymee_selected_size = selected_variant.options[ymee_size_option_index]
  -%}

  <div
    class="ymee-variant-dropdown"
    data-ymee-variant-dropdown
    data-section-id="{{ section_id }}"
    data-size-option-index="{{ ymee_size_option_index }}"
  >
    <button
      type="button"
      class="ymee-variant-dropdown__toggle"
      aria-haspopup="listbox"
      aria-expanded="false"
    >
      <span class="ymee-variant-dropdown__placeholder" data-ymee-variant-dropdown-placeholder>
        {{ 'products.product.choose_size' | t }}
      </span>
      <span class="ymee-variant-dropdown__value" data-ymee-variant-dropdown-value hidden>
        {{- ymee_selected_size | escape -}}
      </span>
    </button>

    <div class="ymee-variant-dropdown__menu" role="listbox" tabindex="-1" hidden>
      {%- for variant in product.variants -%}
        {%- liquid
          assign ymee_size_value = variant.options[ymee_size_option_index]

          assign ymee_is_limited = false
          if variant.available and variant.inventory_management == 'shopify' and variant.inventory_policy != 'continue'
            if variant.inventory_quantity > 0 and variant.inventory_quantity <= 1
              assign ymee_is_limited = true
            endif
          endif
        -%}
        <div
          class="ymee-variant-dropdown__option{% if variant == selected_variant %} is-selected{% endif %}{% unless variant.available %} is-oos{% endunless %}"
          role="option"
          aria-selected="{% if variant == selected_variant %}true{% else %}false{% endif %}"
          data-variant-id="{{ variant.id }}"
          data-option1="{{ variant.option1 | escape }}"
          {%- if variant.option2 %} data-option2="{{ variant.option2 | escape }}"{% endif %}
          {%- if variant.option3 %} data-option3="{{ variant.option3 | escape }}"{% endif %}
          data-size-value="{{ ymee_size_value | escape }}"
        >
          <span class="ymee-variant-dropdown__size">{{ ymee_size_value | escape }}</span>
          <span class="ymee-variant-dropdown__right">
            {%- if variant.available -%}
              {%- if ymee_is_limited -%}
                <span class="ymee-variant-dropdown__note">
                  {{ 'products.product.limited_availability' | t }}
                </span>
              {%- endif -%}
              <div class="ymee-variant-dropdown__submit">
                <button type="button" data-action="buy">
                  {%- render 'icon-add2cart' -%}
                  {{ 'products.product.add_to_cart' | t }}
                </button>
              </div>
              <div class="ymee-variant-dropdown__accelerated" data-ymee-accelerated-slot></div>
            {%- else -%}
              <button type="button" class="ymee-variant-dropdown__action" data-action="notify">
                {{ 'general.newsletter_form.notify' | t }}
              </button>
            {%- endif -%}
          </span>
        </div>
      {%- endfor -%}

      <div class="ymee-variant-dropdown__footer">
        {%- liquid
          assign product_type_handle = product.type | handle
          assign sizing_link = '#'
          assign sizing_link_text = 'products.product.sizing_help' | t

          # Default sizing links - users can override these by passing parameters
          assign default_ring_link = 'https://cdn.shopify.com/s/files/1/0969/2990/7075/files/Sizing-Guide-Rings_ENG_2024.pdf?v=1772819108'
          assign default_bracelet_link = 'https://cdn.shopify.com/s/files/1/0969/2990/7075/files/Size-Guide-Bracelets_ENG_2024.pdf?v=1772819107'

          # Use custom links if provided, otherwise use defaults
          assign ring_sizing_link = ring_sizing_link | default: default_ring_link
          assign bracelet_sizing_link = bracelet_sizing_link | default: default_bracelet_link

          if product_type_handle contains 'ring'
            assign sizing_link = ring_sizing_link
          elsif product_type_handle contains 'bracelet' or product_type_handle contains 'bangle'
            assign sizing_link = bracelet_sizing_link
          endif
        -%}

        {%- if sizing_link != '#' -%}
          <a href="{{ sizing_link }}" class="ymee-variant-dropdown__sizing-link" data-ymee-sizing-help target="_blank" rel="noopener">
            {%- render 'icon-tape' -%}
            {{ sizing_link_text }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>

  <script>
    window.ymeeChooseSizeText = {{ 'products.product.choose_size' | t | json }};
    window.ymeeSizePrefixText = {{ 'products.product.size_prefix' | t | json }};
  </script>
  <script type="application/json" data-product-json>
    {{ product | json }}
  </script>
{%- endif -%}
