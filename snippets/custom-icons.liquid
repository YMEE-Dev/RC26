{% doc %}
  Renders the custom value-props icon list used in text blocks.

  @param {string} [animation_anchor] - Optional anchor used by theme animations.
  @param {number} [animation_order] - Optional animation sequence order.
  @param {boolean} [enable_drawers] - When true, render each item as a drawer trigger using link-with-icon.

  @example
  {% render 'custom-icons', animation_anchor: animation_anchor, animation_order: animation_order %}
{% enddoc %}

{%- liquid
  assign animation_anchor = animation_anchor | default: ''
  assign animation_order = animation_order | default: 1
  assign enable_drawers = enable_drawers | default: false
-%}

<div class="custom-icons">
  <ul
    class="custom-icons__list"
    role="list"
    {% if animation_anchor %}
      data-aos="hero"
      data-aos-anchor="{{ animation_anchor }}"
      data-aos-order="{{ animation_order }}"
    {% endif %}
  >
    <li class="custom-icons__item{% if enable_drawers %} custom-icons__item--drawer{% endif %}">
      {%- if enable_drawers -%}
        {%- comment -%}Drawer IDs must match the product side-drawer `data-drawer` values.{%- endcomment -%}
        {%- render 'link-with-icon',
          text: 'general.free_shipping' | t,
          drawer_open: 'drawer-free-shipping',
          icon: 'icon-free-shipping',
          icon_position: 'left',
          content_alignment: 'left',
          class_name: 'custom-icons__link navlink',
          text_margin_bottom: 0
        -%}
      {%- else -%}
        <span class="custom-icons__icon custom-icons__icon--shipping" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" viewBox="0 0 25 25" fill="none">
            <path d="M19.875 8.90028L16.6505 4.80078H8.35072L5.12622 8.90028V20.2H19.8762L19.875 8.90028ZM18.5996 8.62488H12.9248V5.65038H16.2501L18.5996 8.62488ZM8.75007 5.65038H12.0753V8.62488H6.40057L8.75007 5.65038ZM5.95032 19.3496V9.44913H19.0498V19.3496H5.95032ZM12.5001 11.2754L14.6749 13.4502L14.0753 14.0498L12.9005 12.875V17.3252H12.0753V12.875L10.9005 14.0498L10.3009 13.4502L12.5001 11.2754Z" fill="black"/>
          </svg>
        </span>
        <span class=" navlink">{{ 'general.free_shipping' | t }}</span>
      {%- endif -%}
    </li>

    <li class="custom-icons__item{% if enable_drawers %} custom-icons__item--drawer{% endif %}">
      {%- if enable_drawers -%}
        {%- render 'link-with-icon',
          text: 'general.free_returns' | t,
          drawer_open: 'drawer-14-days-free-returns',
          icon: 'icon-14-days-free-returns',
          icon_position: 'left',
          content_alignment: 'left',
          class_name: 'custom-icons__link navlink',
          text_margin_bottom: 0
        -%}
      {%- else -%}
        <span class="custom-icons__icon custom-icons__icon--returns" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" viewBox="0 0 25 25" fill="none">
            <path d="M18.5 19.3748C18.5 20.2078 17.25 20.2078 17.25 19.3748C17.25 18.5417 18.5 18.5417 18.5 19.3748Z" fill="black"/>
