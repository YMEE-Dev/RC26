      {%- endif -%}
    </li>

    <li class="custom-icons__item{% if enable_drawers %} custom-icons__item--drawer{% endif %}">
      {%- if enable_drawers -%}
        {%- render 'link-with-icon',
          text: 'general.gift_packaging' | t,
          drawer_open: 'drawer-gift-packaging',
          icon: 'icon-gift-packaging',
          icon_position: 'left',
          content_alignment: 'left',
          class_name: 'custom-icons__link navlink',
          text_margin_bottom: 0
        -%}
      {%- else -%}
        <span class="custom-icons__icon custom-icons__icon--packaging" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" viewBox="0 0 25 25" fill="none">
            <path d="M19 7H16.5742C16.6885 6.7666 16.749 6.50977 16.75 6.25C16.749 5.28417 15.9658 4.50097 15 4.5C14.1269 4.5 13.0976 5.3916 12.5 6.27443C11.9023 5.39163 10.873 4.5 10 4.5C9.03417 4.50098 8.25097 5.28417 8.25 6.25C8.25097 6.50977 8.31152 6.7666 8.42578 7H6C5.17188 7.00098 4.50098 7.67188 4.5 8.5V11.5C4.50195 12.2305 5.0293 12.8535 5.75 12.9746V19.0001C5.75098 19.8282 6.42188 20.4991 7.25 20.5001H17.75C18.5781 20.4991 19.249 19.8282 19.25 19.0001V12.9746C19.9707 12.8535 20.4981 12.2305 20.5 11.5V8.5C20.499 7.67188 19.8281 7.00097 19 7ZM15 5.5C15.4131 5.5 15.749 5.83495 15.75 6.24902C15.75 6.6621 15.416 6.99805 15.0019 7H13.2041C13.5869 6.37305 14.4297 5.5 15 5.5ZM9.24999 6.25C9.24999 5.83595 9.58594 5.5 9.99999 5.5C10.5703 5.5 11.4131 6.37305 11.7959 7H9.99804C9.58497 6.99805 9.25097 6.66307 9.24999 6.25ZM5.49999 11.5V8.5C5.49999 8.22362 5.72362 8 5.99999 8H12V12H5.99999C5.72362 11.999 5.49999 11.7754 5.49999 11.5ZM6.74999 19V13H12V19.5H7.24999C6.97362 19.5 6.74999 19.2764 6.74999 19ZM17.75 19.5H13V13H18.25V19C18.25 19.2764 18.0264 19.5 17.75 19.5ZM19.5 11.5C19.5 11.7754 19.2764 11.999 19 12H13V8H19C19.2764 8 19.5 8.22363 19.5 8.5V11.5Z" fill="black"/>
