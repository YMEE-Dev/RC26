            <path d="M18.0547 14.8827C19.3272 13.6298 20.0196 11.958 20 10.1777C19.9873 8.97751 18.9776 7.99998 17.75 7.99998H12.207L14.085 6.12206C14.2627 5.94237 14.2998 5.67478 14.1728 5.48241C14.083 5.34764 13.9551 5.26952 13.8008 5.25194C13.6504 5.23729 13.5029 5.28905 13.3955 5.39647L11.498 7.29392C11.1758 7.61619 10.998 8.04684 10.998 8.50094C10.998 8.95602 11.1758 9.38572 11.498 9.70797L13.3926 11.6054C13.498 11.7109 13.6426 11.7626 13.79 11.7499C13.9424 11.7373 14.0703 11.6621 14.1601 11.5322C14.293 11.3417 14.25 11.0468 14.0605 10.8574L12.2051 8.99995H17.7481C18.4356 8.99995 18.9981 9.55758 18.9981 10.2451C18.9981 11.7578 18.3985 13.1698 17.3008 14.2196C16.2061 15.2694 14.7685 15.8124 13.2558 15.745C10.3085 15.617 7.99804 13.1472 7.99804 10.123V7.50098C7.99804 6.15138 6.90039 5.02833 5.55076 5.00098H5.541C5.25877 5.00098 5.00877 5.2207 4.99802 5.48145C4.99314 5.61622 5.04099 5.7461 5.13572 5.84375C5.22849 5.94141 5.35544 5.99902 5.49119 5.99902C6.33592 6.01367 6.99899 6.67187 6.99899 7.4961V10.0986C6.99899 13.6688 9.83099 16.6484 13.3165 16.7461C15.0987 16.791 16.7842 16.1309 18.0567 14.8809L18.0547 14.8827Z" fill="black"/>
