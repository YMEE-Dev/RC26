{% doc %}
  Renders a side-drawer form for Back in Stock / Inquire / Available Soon.
  The drawer mode is set dynamically via JS based on which trigger was clicked.

  @param {object} product - The product object
  @param {object} current_variant - The currently selected variant

  @example
  {% render 'drawer-bis-form', product: product, current_variant: current_variant %}
{% enddoc %}

{%- liquid
  assign product_image = product.featured_image
  assign variant_title = current_variant.title
  if variant_title == 'Default Title'
    assign variant_title = ''
  endif
-%}

<div class="drawer-bis drawer__content-wrapper" data-bis-drawer>
  {%- comment -%} ── FORM VIEW ── {%- endcomment -%}
  <div class="drawer-bis__form-view" data-bis-form-view>
    <div class="bis-header">
      <h3 class="drawer__title drawer-content__title" data-bis-title>
        {{ 'general.bis_form.notify_title' | t }}
      </h3>
    </div>

    <div class="drawer__content drawer-content__main">
      <div class="drawer-bis__fields" data-scroll-lock-scrollable>
        <p class="drawer-bis__subtitle" data-bis-subtitle>
          {{ 'general.bis_form.notify_subtitle' | t }}
        </p>

        {%- comment -%} ── Inquire-only name fields ── {%- endcomment -%}
        <div class="drawer-bis__inquire-fields" data-bis-inquire-fields style="display:none">
          <div class="form-section">
            <h4 class="form-section__title">*{{ 'general.bis_form.required_fields' | t }}</h4>
            <div class="form-field">
              <input
                type="text"
                name="first_name"
                form="bis-drawer-form"
                class="form-field__input"
                placeholder="{{ 'general.bis_form.first_name' | t }}"
                autocapitalize="words"
                required
              >
            </div>
            <div class="form-field">
              <input
                type="text"
                name="last_name"
                form="bis-drawer-form"
                class="form-field__input"
                placeholder="{{ 'general.bis_form.last_name' | t }}"
                autocapitalize="words"
                required
              >
            </div>
          </div>
        </div>

        {%- comment -%} ── Email section (all modes) ── {%- endcomment -%}
        <div class="form-section">
          <h4 class="form-section__title drawer-bis__required-label" data-bis-required-label>
            *{{ 'general.bis_form.required_fields' | t }}
          </h4>
          <div class="form-field">
            <input
              type="email"
              name="email"
              form="bis-drawer-form"
              class="form-field__input"
              placeholder="{{ 'general.bis_form.email_placeholder' | t }}"
              autocorrect="off"
              autocapitalize="off"
              required
              data-bis-email
            >
          </div>
        </div>

        {%- comment -%} ── Message (inquire only) ── {%- endcomment -%}
        <div class="drawer-bis__inquire-fields" data-bis-inquire-fields style="display:none">
          <div class="form-section">
            <h4 class="form-section__title">{{ 'general.bis_form.message_label' | t }}</h4>
            <div class="form-field">
              <textarea
                name="message"
                form="bis-drawer-form"
                class="form-field__input"
                placeholder="{{ 'general.bis_form.message_placeholder' | t }}"
                rows="3"
              ></textarea>
            </div>
          </div>

          <label class="drawer-bis__checkbox">
            <input type="checkbox" name="privacy" form="bis-drawer-form" required data-bis-privacy>
            <span>{{ 'general.bis_form.privacy_consent' | t }}</span>
          </label>
        </div>

        <div class="drawer-bis__error" data-bis-error style="display:none"></div>
      </div>

      {%- comment -%} ── Product card + submit (pinned bottom, like hint preview card) ── {%- endcomment -%}
      <div class="drawer-bis__preview" data-bis-product-card>
        <div class="drawer-bis__product-image" data-bis-product-image>
          {%- if product_image -%}
            {{ product_image | image_url: width: 600 | image_tag: loading: 'lazy' }}
          {%- endif -%}
        </div>

        <div class="drawer-bis__product-info">
          <p class="drawer-bis__product-title" data-bis-product-title>{{ product.title }}</p>
          <p class="drawer-bis__product-variant" data-bis-variant-title>
            {%- if variant_title != blank -%}{{ variant_title }}{%- endif -%}
          </p>
        </div>

        <form class="drawer-bis__form-el" id="bis-drawer-form" data-bis-form novalidate>
          <input type="hidden" name="product_id" value="{{ product.id }}" data-bis-product-id>
          <input type="hidden" name="variant_id" value="{{ current_variant.id }}" data-bis-variant-id>
          <input type="hidden" name="product_title" value="{{ product.title | escape }}" data-bis-product-title-input>
          <input type="hidden" name="form_type" value="notify" data-bis-form-type>
        </form>

        <button type="submit" form="bis-drawer-form" class="drawer-bis__submit" data-bis-submit>
          <span class="drawer-bis__submit-text" data-bis-submit-text>
            {{ 'general.bis_form.submit_notify' | t }}
          </span>
          <span class="drawer-bis__submit-loader" style="display:none" data-bis-loader>
            <svg height="18" width="18" class="svg-loader">
              <circle r="7" cx="9" cy="9" />
              <circle stroke-dasharray="87.96 87.96" r="7" cx="9" cy="9" />
            </svg>
          </span>
        </button>
      </div>
    </div>
  </div>

  {%- comment -%} ── SUCCESS VIEW ── {%- endcomment -%}
  <div class="drawer-bis__success-view" data-bis-success-view style="display:none">
    <button
      type="button"
      class="drawer-bis__close drawer-bis__close--success"
      data-drawer-close
      aria-label="{{ 'general.accessibility.close' | t }}"
    >
      {%- render 'icon-close' -%}
    </button>

    <div class="drawer-bis__success-content">
      <div class="drawer-bis__success-icon">
        <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="32" cy="32" r="30" stroke="#4a7c6f" stroke-width="1.5"/>
          <polyline points="20,33 28,41 44,25" fill="none" stroke="#4a7c6f" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h2 class="drawer-bis__success-title" data-bis-success-title>
        {{ 'general.bis_form.success_title' | t }}
      </h2>
      <p class="drawer-bis__success-subtitle" data-bis-success-subtitle>
        {{ 'general.bis_form.success_subtitle' | t }}
      </p>
    </div>
  </div>
</div>

{% stylesheet %}
  /* ── Drawer shell ── */
  #side-drawer-bis-form .drawer__inner {
    background-color: #fff;
  }

  #side-drawer-bis-form .drawer__body {
    background-color: #fff;
  }

  @media only screen and (max-width: 574px) {
    #side-drawer-bis-form .drawer__inner {
      width: 100vw !important;
      max-width: 100vw !important;
    }
  }

  @media only screen and (min-width: 575px) {
    #side-drawer-bis-form .drawer__inner {
      height: 100dvh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    #side-drawer-bis-form .drawer__body {
      flex: 1;
      min-height: 0;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    #side-drawer-bis-form .drawer-bis {
      overflow: hidden;
      padding: 0;
    }
  }

  /* ── Drawer wrapper ── */
  .drawer-bis {
    --drawer-padding-x: 40px;
    --drawer-padding: clamp(16px, 4vh, 40px);
    padding: 0;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  /* ── Sticky grey header – mirrors .care-header ── */
  .bis-header {
    background-color: #f9f9f9;
    padding: 40px 40px 20px;
    flex-shrink: 0;
  }

  /* ── Form view layout ── */
  .drawer-bis__form-view {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 0;
    overflow: hidden;
  }

  /* ── Title (fixed, outside scroll) ── */
  .drawer-bis .drawer-content__title {
    color: #000;
    font-family: var(--FONT-STACK-NAV);
    font-size: var(--FONT-SIZE-NAV);
    font-style: normal;
    font-weight: var(--FONT-WEIGHT-NAV);
    line-height: var(--LINE-HEIGHT-NAV);
    letter-spacing: var(--LETTER-SPACING-NAV);
    text-transform: uppercase;
    margin-bottom: 0;
  }

  /* ── Main content area ── */
  .drawer-bis .drawer-content__main {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
    overflow: hidden;
  }

  /* ── Scrollable fields ── */
  .drawer-bis__fields {
    flex: 0 1 auto;
    min-height: 0;
    overflow-y: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    margin: 0;
    padding: 30px 40px;
    background-color: #ffffff;
  }

  .drawer-bis__fields::-webkit-scrollbar {
    display: none;
  }

  .drawer-bis__subtitle {
    font-family: var(--FONT-STACK-BODY);
    font-size: 14px;
    font-weight: var(--FONT-WEIGHT-BODY);
    line-height: 1.6;
    color: var(--COLOR-TEXT);
    margin: 0 0 clamp(8px, 2vh, 20px);
  }

  /* ── Form sections ── */
  .drawer-bis .form-section {
    margin-bottom: clamp(8px, 2vh, 20px);
  }

  .drawer-bis .form-section__title {
    margin: 0 0 4px;
    color: #000;
    font-family: var(--FONT-STACK-NAV);
    font-size: var(--FONT-SIZE-NAV);
    font-style: normal;
    font-weight: var(--FONT-WEIGHT-NAV);
    line-height: var(--LINE-HEIGHT-NAV);
    letter-spacing: var(--LETTER-SPACING-NAV);
    text-transform: uppercase;
  }

  .drawer-bis .form-field {
    display: flex;
    flex-direction: column;
  }

  .drawer-bis .form-field__input {
    padding: 10px 0;
    border: none;
    border-bottom: 1px solid #e5e5e5;
    border-radius: 0;
    color: var(--000000, #000);
    font-family: var(--FONT-STACK-BODY);
    font-size: var(--FONT-SIZE-INPUT-LABEL);
    font-style: normal;
    font-weight: var(--FONT-WEIGHT-BODY);
    line-height: var(--LINE-HEIGHT-INPUT-LABEL);
    background-color: transparent;
    transition: border-color 0.2s ease;
    width: 100%;
  }

  .drawer-bis .form-field__input::placeholder {
    color: var(--COLOR-TEXT);
    opacity: 1;
  }

  .drawer-bis .form-field__input:focus {
    outline: none;
    border-bottom-color: var(--COLOR-TEXT);
  }

  .drawer-bis textarea.form-field__input {
    resize: vertical;
    min-height: 60px;
  }

  /* ── Checkbox ── */
  .drawer-bis__checkbox {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-top: clamp(8px, 2vh, 20px);
    font-family: var(--FONT-STACK-BODY);
    font-size: 13px;
    font-weight: var(--FONT-WEIGHT-BODY);
    line-height: 1.5;
    color: var(--COLOR-TEXT);
    cursor: pointer;
  }

  .drawer-bis__checkbox input[type='checkbox'] {
    width: 18px;
    height: 18px;
    border: 1px solid #ccc;
    border-radius: 50%;
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
    flex-shrink: 0;
    margin-top: 2px;
    padding: initial;
    position: relative;
  }

  .drawer-bis__checkbox input[type='checkbox']:checked {
    background-color: #1a1a1a;
    border-color: #1a1a1a;
  }

  .drawer-bis__checkbox input[type='checkbox']:checked::after {
    content: '';
    position: absolute;
    top: 3px;
    left: 5px;
    width: 5px;
    height: 9px;
    border: solid #fff;
    border-width: 0 1.5px 1.5px 0;
    transform: rotate(45deg);
  }

  .drawer-bis__error {
    color: #c00;
    font-size: 13px;
    margin-top: 8px;
  }

  /* ── Preview card (product image + info + submit, pinned bottom) ── */
  .drawer-bis__preview {
    flex: 1;
    min-height: 0;
    background-color: #f5f5f5;
    padding: 0 0 var(--drawer-padding) 0;
    display: flex;
    flex-direction: column;
    border-top: 1px solid #e5e5e5;
  }

  .drawer-bis__product-image {
    flex: 1;
    min-height: 150px;
    overflow-y: auto;
    overflow-x: hidden;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .drawer-bis__product-image img {
    width: auto;
    height: 100%;
    max-width: 100%;
    min-height: 150px;
    max-height: min(400px, 40vh);
    aspect-ratio: 1 / 1;
    display: block;
    object-fit: cover;
    mix-blend-mode: multiply;
  }

  .drawer-bis__product-info {
    padding: clamp(10px, 2vh, 25px) 0;
    margin: 0 var(--drawer-padding);
  }

  .drawer-bis__product-title {
    margin: 0;
    color: #000;
    font-family: var(--FONT-STACK-NAV);
    font-size: var(--FONT-SIZE-NAV);
    font-style: normal;
    font-weight: var(--FONT-WEIGHT-NAV);
    line-height: var(--LINE-HEIGHT-NAV);
    letter-spacing: var(--LETTER-SPACING-NAV);
    text-transform: uppercase;
  }

  .drawer-bis__product-variant {
    font-family: var(--FONT-STACK-BODY);
    font-size: 13px;
    font-weight: var(--FONT-WEIGHT-BODY);
    line-height: 1.4;
    text-transform: uppercase;
    color: var(--COLOR-TEXT);
    margin: 4px 0 0;
    min-height: 1em;
  }

  /* ── Submit button ── */
  .drawer-bis__submit {
    margin: 0 var(--drawer-padding) clamp(10px, 2vh, 30px) var(--drawer-padding);
    background: var(--btn-bg, #000);
    color: var(--btn-text, #fff);
    border: 1px solid var(--btn-border, #000);
    border-radius: 0;
    padding: 12px 20px;
    text-align: center;
    font-size: var(--BTN-FONT-SIZE);
    font-weight: var(--BTN-FONT-WEIGHT);
    line-height: var(--BTN-LINE-HEIGHT);
    letter-spacing: var(--BTN-LETTER-SPACING);
    text-transform: uppercase;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: background 180ms ease, color 180ms ease, border-color 180ms ease;
  }

  .drawer-bis__submit:hover {
    background-color: #27574d;
    border-color: #27574d;
    color: #fff;
  }

  .drawer-bis__submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* ── Loader spinner ── */
  .drawer-bis__submit .svg-loader circle {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
  }

  .drawer-bis__submit .svg-loader circle:last-child {
    animation: bis-spin 0.8s linear infinite;
    transform-origin: center;
  }

  @keyframes bis-spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* ── Hidden form element (no visual) ── */
  .drawer-bis__form-el {
    display: contents;
  }

  /* ── Success view ── */
  .drawer-bis__success-view {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: var(--drawer-padding, 40px);
    text-align: center;
    position: relative;
  }

  .drawer-bis__close--success {
    position: absolute;
    top: 36px;
    right: 36px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    color: #1a1a1a;
  }

  .drawer-bis__close--success:hover {
    opacity: 0.6;
  }

  .drawer-bis__success-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .drawer-bis__success-icon {
    margin-bottom: 8px;
  }

  .drawer-bis__success-title {
    color: #000;
    font-family: var(--FONT-STACK-NAV);
    font-size: var(--FONT-SIZE-NAV);
    font-style: normal;
    font-weight: var(--FONT-WEIGHT-NAV);
    line-height: var(--LINE-HEIGHT-NAV);
    letter-spacing: var(--LETTER-SPACING-NAV);
    text-transform: uppercase;
    margin: 0;
  }

  .drawer-bis__success-subtitle {
    font-family: var(--FONT-STACK-BODY);
    font-size: 14px;
    font-weight: var(--FONT-WEIGHT-BODY);
    line-height: 1.6;
    color: var(--COLOR-TEXT);
    margin: 0;
    opacity: 0.6;
  }

  @media (max-width: 574px) {
    .drawer-bis {
      padding: 0;
    }

    .bis-header {
      padding: 20px 20px 20px;
    }

    .drawer-bis__fields {
      padding: 30px 20px;
    }

    .drawer-bis__product-info {
      margin: 0 20px;
    }

    .drawer-bis__submit {
      margin: 0 20px clamp(10px, 2vh, 30px) 20px;
    }
  }
{% endstylesheet %}
