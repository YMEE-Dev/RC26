<style>
  zoom-images {
    display: contents;
  }

  zoom-images [data-zoom-image] {
    cursor: zoom-in;
  }

  .pswp__button,
  .pswp__button *,
  .pswp__caption-close,
  .pswp__caption-close * {
    pointer-events: none;
  }

  .pswp__button {
    pointer-events: auto;
    -webkit-tap-highlight-color: transparent;
    outline: none;
    touch-action: manipulation;
  }

  .pswp__button:active {
    background: transparent;
  }

  .pswp__caption-close {
    pointer-events: auto;
    -webkit-tap-highlight-color: transparent;
    outline: none;
  }

  body:has(.pswp--open) .js__header__stuck,
  body:has(.pswp--open) .theme__header {
    z-index: 0;
  }

  /* Immediate white background on open — prevents page content bleeding through during pswp__bg fade-in */
  .pswp[data-pswp-option-classes*="pswp-zoom-gallery"],
  .pswp-zoom-gallery {
    background: #fff;
  }

  /* iOS Safari: constrain to visual viewport height so gallery doesn't extend behind browser chrome */
  @supports (-webkit-touch-callout: none) {
    .pswp[data-pswp-option-classes*="pswp-zoom-gallery"],
    .pswp-zoom-gallery {
      height: -webkit-fill-available;
    }
  }

  /* Offset scroll-wrap top so PhotoSwipe centers the image in the visible area below the caption/title bar */
  @media only screen and (min-width: 990px) {
    .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__scroll-wrap,
    .pswp-zoom-gallery .pswp__scroll-wrap {
      top: 0;
      bottom: 0;
    }
  }

  .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__bg,
  .pswp-zoom-gallery .pswp__bg {
    background: #fff;
  }

  .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__button--arrow--right,
  .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__button--arrow--left,
  .pswp-zoom-gallery .pswp__button--arrow--right,
  .pswp-zoom-gallery .pswp__button--arrow--left {
    position: absolute;
    top: 0;
    width: 5vw;
    height: 100%;
    margin-top: 0;
    border: 0;
    display: flex;
    align-items: center;
    background: transparent;
    color: inherit;
    transition: opacity 0.2s ease;
    z-index: 3;
  }

  @media only screen and (max-width: 768px) {
    .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__button--arrow--right,
    .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__button--arrow--left,
    .pswp-zoom-gallery .pswp__button--arrow--right,
    .pswp-zoom-gallery .pswp__button--arrow--left {
      width: 12vw;
    }
  }

  .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__button--arrow--left,
  .pswp-zoom-gallery .pswp__button--arrow--left {
    left: 0;
    right: auto;
    justify-content: center;
  }

  .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__button--arrow--right,
  .pswp-zoom-gallery .pswp__button--arrow--right {
    right: 0;
    left: auto;
    justify-content: center;
  }

  .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__button--arrow--right:hover,
  .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__button--arrow--left:hover,
  .pswp-zoom-gallery .pswp__button--arrow--right:hover,
  .pswp-zoom-gallery .pswp__button--arrow--left:hover {
    transform: none;
    border-color: transparent;
    opacity: 0.6;
  }

  .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__button--arrow--right .icon,
  .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__button--arrow--left .icon,
  .pswp-zoom-gallery .pswp__button--arrow--right .icon,
  .pswp-zoom-gallery .pswp__button--arrow--left .icon {
    stroke: currentColor;
  }

  .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__caption .pswp__caption-close,
  .pswp-zoom-gallery .pswp__caption .pswp__caption-close {
    width: 35px;
    height: 35px;
    display: grid;
    place-items: center;
    margin-top: -17px;
    border: 0;
    background: transparent;
    color: inherit;
    transition: opacity 0.2s ease;
    z-index: 5;
  }

  .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__caption .pswp__caption-close:hover,
  .pswp-zoom-gallery .pswp__caption .pswp__caption-close:hover {
    color: inherit;
    opacity: 0.6;
  }

  .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__caption .pswp__caption-close .icon,
  .pswp-zoom-gallery .pswp__caption .pswp__caption-close .icon {
    --icon-size: 25px;
    position: static;
  }

  .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__top-bar,
  .pswp-zoom-gallery .pswp__top-bar {
    z-index: 4;
  }

  .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__button--close,
  .pswp-zoom-gallery .pswp__button--close {
    --icon-size: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    color: #212121;
    background: transparent;
    border-radius: 0;
    border: none;
    font-size: 0;
    top: 50px;
  }

  .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__button--close svg,
  .pswp-zoom-gallery .pswp__button--close svg {
    stroke-width: 0px;
  }

  .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__button--close .icon,
  .pswp-zoom-gallery .pswp__button--close .icon {
    display: block;
    fill: currentColor;
    pointer-events: none;
  }

  .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__loader,
  .pswp-zoom-gallery .pswp__loader {
    height: 2px;
    top: 0;
    background: #fff;
  }

  .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__caption,
  .pswp-zoom-gallery .pswp__caption {
    display: none;
  }

  @media only screen and (max-width: 768px) {
    .pswp[data-pswp-option-classes*="pswp-zoom-gallery"] .pswp__custom-close,
    .pswp-zoom-gallery .pswp__custom-close {
      top: 30px;
    }
  }

</style>

<!-- Root element of PhotoSwipe. Must have class pswp. -->
<div class="pswp pswp--custom-loader" tabindex="-1" role="dialog" aria-hidden="true">
  <!-- Background of PhotoSwipe.
  It's a separate element as animating opacity is faster than rgba(). -->
  <div class="pswp__bg"></div>

  <!-- Slides wrapper with overflow:hidden. -->
  <div class="pswp__scroll-wrap">
    <!-- Container that holds slides.
        PhotoSwipe keeps only 3 of them in the DOM to save memory.
        Don't modify these 3 pswp__item elements, data is added later on. -->
    <div class="pswp__container">
      <div class="pswp__item"></div>
      <div class="pswp__item"></div>
      <div class="pswp__item"></div>
    </div>

    <!-- Default (PhotoSwipeUI_Default) interface on top of sliding area. Can be changed. -->
    <div class="pswp__ui pswp__ui--hidden">
      <div class="pswp__top-bar">
        <!--  Controls are self-explanatory. Order can be changed. -->

        <div class="pswp__counter"></div>

        <button class="pswp__button pswp__button--close pswp__custom-close pswp__ui-over-close" title="Close (Esc)">
          {%- render 'icon-cancel' -%}
        </button>

        <!-- Preloader demo https://codepen.io/dimsemenov/pen/yyBWoR -->
        <!-- element will get class pswp__preloader--active when preloader is running -->
        <div class="pswp__preloader">
          <div class="pswp__preloader__icn">
            <div class="pswp__preloader__cut">
              <div class="pswp__preloader__donut"></div>
            </div>
          </div>
        </div>
      </div>

      <div class="pswp__share-modal pswp__share-modal--hidden pswp__single-tap">
        <div class="pswp__share-tooltip"></div>
      </div>

      <button class="pswp__button pswp__button--arrow--left" title="{{ 'products.general.previous' | t }}">
        <svg pointer-events="none" aria-hidden="true" focusable="false" role="presentation" width="25px" height="25px" stroke-width="1" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <span class="visually-hidden">{{ 'products.general.previous' | t }}</span>
      </button>

      <button class="pswp__button pswp__button--arrow--right" title="{{ 'products.general.next' | t }}">
        <svg pointer-events="none" aria-hidden="true" focusable="false" role="presentation" width="25px" height="25px" stroke-width="1" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <span class="visually-hidden">{{ 'products.general.next' | t }}</span>
      </button>

      <div class="pswp__thumbs"></div>

      <div class="pswp__caption">
        <div class="pswp__caption__center"></div>

        <button type="button" class="pswp__caption-close">
          <svg pointer-events="none" aria-hidden="true" focusable="false" role="presentation" width="25px" height="25px" stroke-width="1" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
          <span class="visually-hidden">{{ 'general.accessibility.close' | t }}</span>
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    // Caption-close: trigger gallery close on touch (PhotoSwipe touch handler requires BUTTON tagName,
    // but closeElClasses path only fires for mouse — so we proxy to the registered close button)
    var captionClose = document.querySelector('.pswp__caption-close');
    if (captionClose) {
      captionClose.addEventListener('touchend', function (e) {
        e.preventDefault();
        e.stopPropagation();
        var closeBtn = document.querySelector('.pswp__button--close');
        if (closeBtn) closeBtn.click();
      }, { passive: false });
    }

    // Sync theme scroll-lock state with gallery open/close
    var pswpEl = document.querySelector('.pswp');
    if (pswpEl) {
      var lockedByGallery = false;
      new MutationObserver(function () {
        if (pswpEl.classList.contains('pswp--open')) {
          document.documentElement.setAttribute('data-scroll-locked', '');
          lockedByGallery = true;
        } else if (lockedByGallery) {
          document.documentElement.removeAttribute('data-scroll-locked');
          lockedByGallery = false;
        }
      }).observe(pswpEl, { attributes: true, attributeFilter: ['class'] });
    }
  })();
</script>
