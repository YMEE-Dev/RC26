{% doc %}
  Renders custom pagination with underline style.

  @param {paginate} paginate - The paginate object from Shopify

  @example
  {% render 'custom-pagination', paginate: paginate %}
{% enddoc %}

<nav class="custom-pagination" role="navigation" aria-label="Pagination">
  <div class="custom-pagination__container">
    {%- if paginate.previous -%}
      <a href="{{ paginate.previous.url }}" class="custom-pagination__link custom-pagination__prev">
        <span>{{ 'general.pagination.previous' | t | default: 'PREV' }}</span>
      </a>
    {%- endif -%}

    <div class="custom-pagination__numbers">
      {%- for part in paginate.parts -%}
        {%- if part.is_link -%}
          <a href="{{ part.url }}" class="custom-pagination__number">
            {{ part.title }}
          </a>
        {%- else -%}
          {%- if part.title == paginate.current_page -%}
            <span class="custom-pagination__number custom-pagination__number--current">
              {{ part.title }}
            </span>
          {%- else -%}
            <span class="custom-pagination__ellipsis">{{ part.title }}</span>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if paginate.next -%}
      <a href="{{ paginate.next.url }}" class="custom-pagination__link custom-pagination__next">
        <span>{{ 'general.pagination.next' | t | default: 'NEXT' }}</span>
      </a>
    {%- endif -%}
  </div>
</nav>

{% stylesheet %}
  .custom-pagination {
    width: 100%;
    margin-top: 60px;
    padding: 40px 0;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  .custom-pagination__container {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 32px;
  }

  .custom-pagination__numbers {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .custom-pagination__number,
  .custom-pagination__link {
    color: var(--000000, #000);
    font-family: Inter, sans-serif;
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 20px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    text-decoration: none;
    position: relative;
    padding-bottom: 4px;
    transition: opacity 0.3s ease;
  }

  .custom-pagination__number:hover,
  .custom-pagination__link:hover {
    opacity: 0.7;
  }

  .custom-pagination__number--current {
    font-weight: 600;
  }

  .custom-pagination__number--current::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background-color: currentColor;
  }

  .custom-pagination__ellipsis {
    color: var(--000000, #000);
    font-family: Inter, sans-serif;
    font-size: 14px;
    opacity: 0.5;
  }

  .custom-pagination__link {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
  }

  @media (max-width: 767px) {
    .custom-pagination__container {
      gap: 16px;
    }

    .custom-pagination__numbers {
      gap: 16px;
    }

    .custom-pagination__number,
    .custom-pagination__link {
      font-size: 12px;
    }
  }
{% endstylesheet %}
