{% doc %}
  Renders a storytelling product tile with a full-screen "Shop the look" overlay modal.

  @param {product} product - Product object rendered in the tile
  @param {number} [index] - Position index used for unique DOM IDs
{% enddoc %}

{%- liquid
  assign first_image = product.media | where: 'media_type', 'image' | first
  assign first_media = product.media.first
  assign look_slider = ''

  assign has_video = false
  for media in product.media
    if media.media_type == 'video'
      assign has_video = true
    endif
  endfor

  assign cta_text = product.metafields.custom.ste_cta | default: 'Shop the look'
  assign storytelling_products = product.metafields.custom.ste_products.value

  assign grid_item_styles = 'grid-column: 1 / -3;'
  assign grid_item_type = 'one_column'
  if product.metafields.custom.ste_full_bleed == true
    assign grid_item_styles = 'grid-column: 1 / -1; object-fit: contain; width: 100%; height: auto;'
    assign grid_item_type = 'full_bleed'
  endif

  assign modal_id = 'StorytellingModal--' | append: product.id
  if index != blank
    assign modal_id = modal_id | append: '-' | append: index
  endif
  if product.handle != blank
    assign modal_id = modal_id | append: '-' | append: product.handle
  endif
-%}
{%- for storytelling_product in storytelling_products -%}
  {%- capture look_slider -%}
  {{ look_slider }}

  <div class="grid-item look__slide look__slide--{{ forloop.index0 }}" data-slide="{{ forloop.index0 }}" data-grid-item >
    {%- if storytelling_product != blank -%}
      {%- render 'product-grid-item', product: storytelling_product, index: forloop.index, show_product_card: true, disable_image_hover: true -%}
    {%- else -%}
      {%- assign placeholder = 'product-' | append: forloop.index -%}
      {%- render 'onboarding-product-grid-item', title: 'Product Title', show_product_card: true, placeholder: placeholder, index: forloop.index, animation_delay: forloop.index0 -%}
    {%- endif -%}
  </div>
{%- endcapture -%}
{% endfor %}

<grid-item
  class="product-storytelling grid-item product-item  product-item--left product-item--overlay-text {{ grid_item_type }}"
  data-product-available="{{ product.available }}"
  style="{{ grid_item_styles }} grid-row: span 1;"
>
  <div class="grid-media__media-wrapper">
    {%- if has_video and first_media.media_type == 'video' -%}
      <video
        class="custom-autoplay-video"
        autoplay="1"
        muted
        loop
        playsinline
        poster="{{ first_media.preview_image | image_url: width: 2048 }}"
      >
        {% for source in first_media.sources %}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {% endfor %}
        Your browser does not support the video tag.
      </video>
    {%- else -%}
      {%- if first_image -%}
        {{
          first_image
          | image_url: width: 2048
          | image_tag: alt: product.title, loading: 'eager', fetchpriority: 'high'
        }}
      {%- endif -%}
    {%- endif -%}
    {% comment %} <div class="grid-media__text-container">{{ product.title }}</div> {% endcomment %}
    <button
      type="button"
      class="btn btn--solid btn--black btn--ar product-shop-the-look"
      data-shopify-title="{{ product.title | strip_html }}"
      data-storytelling-modal-trigger
      data-storytelling-modal-target="{{ modal_id }}"
      aria-haspopup="dialog"
      aria-controls="{{ modal_id }}"
      aria-expanded="false"
    >
      <span class="product-shop-the-look-text">{{ cta_text }}</span>
    </button>
  </div>

  <dialog
    id="{{ modal_id }}"
    class="storytelling-modal"
    aria-label="{{ cta_text | escape }}"
    aria-modal="true"
    data-storytelling-modal
    data-scroll-lock-required
  >
    <div class="storytelling-modal__inner">
      <look-component class="look">
        <div class="storytelling-look__image">
          {%- if has_video and first_media.media_type == 'video' -%}
            <video
              class="storytelling custom-autoplay-video"
              autoplay="1"
              muted
              loop
              playsinline
              poster="{{ first_media.preview_image | image_url: width: 2048 }}"
            >
              {% for source in first_media.sources %}
                <source src="{{ source.url }}" type="{{ source.mime_type }}">
              {% endfor %}
              Your browser does not support the video tag.
            </video>
          {%- else -%}
            {%- if first_image -%}
              {% comment %}
                {%- render 'image',
                  image: first_image,
                  sizes: '(min-width: 750px) 50vw, 100vw',
                  aspect_ratio: 1,
                  modifier: 'storytelling-look__image-bg',
                  placeholder: 'collection-1'
                -%}
              {% endcomment %}
              <img
                class=""
                src="{{ first_image | image_url: width: 2048 }}"
                width="auto"
                height="auto"
              >
            {%- endif -%}
          {%- endif -%}
        </div>

        <div class="look__aside" data-popup-container>
          <div class="underlay mobile look__underlay" data-popup-close></div>

          <div class="look__content" data-popup-content data-scroll-lock-scrollable>
            <p class="look__title text-center subheading">Shop the look</p>

            <grid-slider data-arrow-position-middle>
              <div
                class="grid--slider look__slider look__slider--grid"
                data-grid-slider
                data-slider-mobile="{{ product.id }}"
                data-arrow-position-middle
                data-scroll-lock-scrollable
                {% if request.design_mode %}
                  data-block-scroll
                {% endif %}
              >
                {{ look_slider }}
              </div>
            </grid-slider>
          </div>
        </div>
      </look-component>

      <button
        type="button"
        class="storytelling-modal__close"
        data-storytelling-modal-close
        aria-label="{{ 'general.accessibility.close' | t }}"
      >
        {%- render 'icon-cancel' -%}
      </button>
    </div>
  </dialog>
</grid-item>

{% javascript %}
  (() => {
    if (window.__storytellingModalInitialized) return;
    window.__storytellingModalInitialized = true;

    const getModalByTrigger = (trigger) => {
      const modalId = trigger.getAttribute('data-storytelling-modal-target');
      if (!modalId) return null;
      return document.getElementById(modalId);
    };

    const onModalClosed = (modal) => {
      if (!modal) return;

      const shouldRestoreFocus = modal.__storytellingRestoreFocus !== false;
      delete modal.__storytellingRestoreFocus;

      if (window.theme && typeof window.theme.hasOpenModals === 'function') {
        if (!window.theme.hasOpenModals()) {
          document.dispatchEvent(new CustomEvent('theme:scroll:unlock', { bubbles: true }));
        }
      } else {
        document.dispatchEvent(new CustomEvent('theme:scroll:unlock', { bubbles: true }));
      }

      const trigger = document.querySelector(`[data-storytelling-modal-target="${modal.id}"]`);
      if (!trigger) return;

      trigger.setAttribute('aria-expanded', 'false');
      if (shouldRestoreFocus) {
        trigger.focus();
      }
    };

    const closeModal = (modal, options = {}) => {
      if (!modal) return;

      const restoreFocus = options.restoreFocus !== false;
      modal.__storytellingRestoreFocus = restoreFocus;

      if (typeof modal.close === 'function') {
        if (modal.open) {
          modal.close();
        } else {
          onModalClosed(modal);
        }
      } else {
        modal.removeAttribute('open');
        onModalClosed(modal);
      }
    };

    const openModal = (trigger) => {
      const modal = getModalByTrigger(trigger);
      if (!modal) return;

      const openModalElement = document.querySelector('[data-storytelling-modal][open]');
      if (openModalElement && openModalElement !== modal) {
        closeModal(openModalElement, { restoreFocus: false });
      }

      if (typeof modal.showModal === 'function') {
        if (!modal.open) {
          modal.showModal();
        }
      } else {
        modal.setAttribute('open', '');
      }

      document.dispatchEvent(new CustomEvent('theme:scroll:lock', { bubbles: true }));
      trigger.setAttribute('aria-expanded', 'true');

      const closeButton = modal.querySelector('[data-storytelling-modal-close]');
      if (closeButton) {
        closeButton.focus();
      }
    };

    document.addEventListener(
      'click',
      (event) => {
        const trigger = event.target.closest('[data-storytelling-modal-trigger]');
        if (trigger) {
          event.preventDefault();
          event.stopPropagation();
          openModal(trigger);
          return;
        }

        const closeButton = event.target.closest('[data-storytelling-modal-close]');
        if (closeButton) {
          event.preventDefault();
          event.stopPropagation();
          closeModal(closeButton.closest('[data-storytelling-modal]'));
          return;
        }

        const modal = event.target.closest('[data-storytelling-modal]');
        if (modal && event.target === modal) {
          event.preventDefault();
          event.stopPropagation();
          closeModal(modal);
        }
      },
      true
    );

    document.addEventListener(
      'cancel',
      (event) => {
        const modal = event.target;
        if (!modal.matches('[data-storytelling-modal]')) return;

        event.preventDefault();
        closeModal(modal);
      },
      true
    );

    document.addEventListener(
      'close',
      (event) => {
        const modal = event.target;
        if (!modal.matches('[data-storytelling-modal]')) return;

        onModalClosed(modal);
      },
      true
    );
  })();
{% endjavascript %}
