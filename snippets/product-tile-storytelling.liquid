{% doc %}
  Renders a storytelling product tile with a full-screen "Shop the look" overlay modal.

  @param {product} product - Product object rendered in the tile
  @param {number} [index] - Position index used for unique DOM IDs
  @param {boolean} [pdp_mode] - When true, shows the second product image in the trigger instead of the first
{% enddoc %}

{%- liquid
  assign first_image = product.media | where: 'media_type', 'image' | first
  assign first_media = product.media.first
  assign modal_media = product.media[1]
  assign modal_image = blank
  assign look_slider = ''
  assign first_media_is_video = false
  assign modal_media_is_video = false

  if modal_media == blank
    assign modal_media = first_media
  endif

  if first_media != blank
    if first_media.media_type == 'video' or first_media.media_type == 'external_video'
      assign first_media_is_video = true
    endif
  endif

  if modal_media != blank
    if modal_media.media_type == 'video' or modal_media.media_type == 'external_video'
      assign modal_media_is_video = true
    endif
  endif

  if modal_media != blank
    if modal_media.media_type == 'image'
      assign modal_image = modal_media
    elsif modal_media.preview_image != blank
      assign modal_image = modal_media.preview_image
    endif
  endif

  assign cta_text = product.metafields.custom.ste_cta | default: 'Shop the look'
  assign storytelling_products = product.metafields.custom.ste_products.value

  assign grid_item_styles = 'grid-column: 1 / -3;'
  assign grid_item_type = 'one_column'
  if product.metafields.custom.ste_full_bleed == true
    assign grid_item_styles = 'grid-column: 1 / -1; object-fit: contain; width: 100%; height: auto;'
    assign grid_item_type = 'full_bleed'
  endif

  assign modal_id = 'StorytellingModal--' | append: product.id
  if index != blank
    assign modal_id = modal_id | append: '-' | append: index
  endif
  if product.handle != blank
    assign modal_id = modal_id | append: '-' | append: product.handle
  endif
-%}

{%- for storytelling_product in storytelling_products -%}
  {%- capture look_slider -%}
  {{ look_slider }}

  <div class="look__slide look__slide--{{ forloop.index0 }}" data-slide="{{ forloop.index0 }}" data-grid-item >
    {%- if storytelling_product != blank -%}
      {%- render 'product-grid-item', product: storytelling_product, index: forloop.index, show_product_card: true, disable_image_hover: true -%}
    {%- else -%}
      {%- assign placeholder = 'product-' | append: forloop.index -%}
      {%- render 'onboarding-product-grid-item', title: 'Product Title', show_product_card: true, placeholder: placeholder, index: forloop.index, animation_delay: forloop.index0 -%}
    {%- endif -%}
  </div>
{%- endcapture -%}
{% endfor %}

<grid-item
  class="product-storytelling grid-item product-item  product-item--left product-item--overlay-text {{ grid_item_type }}"
  data-product-available="{{ product.available }}"
  style="{{ grid_item_styles }} grid-row: span 1;"
>
  <div
    class="grid-media__media-wrapper"
    data-storytelling-modal-trigger
    data-storytelling-modal-target="{{ modal_id }}"
  >
    {%- if first_media_is_video -%}
      {%- liquid
        case first_media.media_type
          when 'video'
            echo first_media | media_tag: image_size: '2048x', class: 'custom-autoplay-video', autoplay: true, loop: true, controls: false, preload: 'none', muted: true
          when 'external_video'
            if first_media.host == 'youtube'
              echo first_media | external_video_url: autoplay: true, playsinline: true, loop: true, playlist: first_media.external_id, controls: false, mute: true, showinfo: false | external_video_tag: class: 'custom-autoplay-video', loading: 'lazy', data-host: first_media.host
            else
              echo first_media | external_video_url: autoplay: true, playsinline: true, loop: true, controls: false, muted: true | external_video_tag: class: 'custom-autoplay-video', data-host: first_media.host
            endif
        endcase
      -%}
    {%- else -%}
      {%- liquid
        if pdp_mode and modal_image != blank
          assign trigger_image = modal_image
        else
          assign trigger_image = first_image
        endif
      -%}
      {%- if trigger_image -%}
        {{
          trigger_image
          | image_url: width: 2048
          | image_tag: alt: product.title, loading: 'eager', fetchpriority: 'high'
        }}
      {%- endif -%}
    {%- endif -%}
    {% comment %} <div class="grid-media__text-container">{{ product.title }}</div> {% endcomment %}
    <button
      type="button"
      class="btn btn--solid btn--primary product-shop-the-look"
      data-shopify-title="{{ product.title | strip_html }}"
      data-storytelling-modal-trigger
      data-storytelling-modal-target="{{ modal_id }}"
      aria-haspopup="dialog"
      aria-controls="{{ modal_id }}"
      aria-expanded="false"
    >
      <span class="product-shop-the-look-text">{{ cta_text }}</span>
    </button>
  </div>

  <dialog
    id="{{ modal_id }}"
    class="storytelling-modal"
    aria-label="{{ cta_text | escape }}"
    aria-modal="true"
    data-storytelling-modal
    data-scroll-lock-required
  >
    <div class="storytelling-modal__inner">
      <look-component class="look">
        <div class="storytelling-look__image">
          {%- if modal_media_is_video -%}
            {%- liquid
              case modal_media.media_type
                when 'video'
                  echo modal_media | media_tag: image_size: '2048x', class: 'storytelling custom-autoplay-video', autoplay: true, loop: true, controls: false, preload: 'none', muted: true
                when 'external_video'
                  if modal_media.host == 'youtube'
                    echo modal_media | external_video_url: autoplay: true, playsinline: true, loop: true, playlist: modal_media.external_id, controls: false, mute: true, showinfo: false | external_video_tag: class: 'storytelling custom-autoplay-video', loading: 'lazy', data-host: modal_media.host
                  else
                    echo modal_media | external_video_url: autoplay: true, playsinline: true, loop: true, controls: false, muted: true | external_video_tag: class: 'storytelling custom-autoplay-video', data-host: modal_media.host
                  endif
              endcase
            -%}
          {%- else -%}
            {%- if modal_image -%}
              {% comment %}
                {%- render 'image',
                  image: modal_image,
                  sizes: '(min-width: 750px) 50vw, 100vw',
                  aspect_ratio: 1,
                  modifier: 'storytelling-look__image-bg',
                  placeholder: 'collection-1'
                -%}
              {% endcomment %}
              <img
                class=""
                src="{{ modal_image | image_url: width: 2048 }}"
                alt="{{ product.title | strip_html | escape }}"
                width="auto"
                height="auto"
              >
            {%- endif -%}
          {%- endif -%}
        </div>

        <div class="look__aside" data-popup-container>
          <div class="underlay mobile look__underlay" data-popup-close></div>

          <div class="look__content" data-popup-content data-scroll-lock-scrollable>
            <div class="storytelling-modal__slider-shell">
              <grid-slider data-arrow-position-middle>
                <div
                  class="grid--slider look__slider look__slider--grid"
                  data-grid-slider
                  data-slider-mobile="{{ product.id }}"
                  data-arrow-position-middle
                  data-scroll-lock-scrollable
                  {% if request.design_mode %}
                    data-block-scroll
                  {% endif %}
                >
                  {{ look_slider }}
                </div>
              </grid-slider>

              <div class="storytelling-modal__slider-progress" data-storytelling-slider-progress aria-hidden="true">
                <span class="storytelling-modal__slider-progress-thumb" data-storytelling-slider-progress-thumb></span>
              </div>
            </div>
          </div>
        </div>
      </look-component>

      <button
        type="button"
        class="storytelling-modal__close"
        data-storytelling-modal-close
        aria-label="{{ 'general.accessibility.close' | t }}"
      >
        {%- render 'icon-close' -%}
      </button>
    </div>
  </dialog>
</grid-item>

{% javascript %}
  (() => {
    if (window.__storytellingModalInitialized) return;
    window.__storytellingModalInitialized = true;
    const sliderProgressBindings = new WeakMap();
    const sliderSnapBindings = new WeakMap();

    const getModalByTrigger = (trigger) => {
      const modalId = trigger.getAttribute('data-storytelling-modal-target');
      if (!modalId) return null;
      return document.getElementById(modalId);
    };

    const getTriggersByModalId = (modalId) => {
      if (!modalId) return [];
      return Array.from(document.querySelectorAll(`[data-storytelling-modal-target="${modalId}"]`));
    };

    const refreshModalSliders = (modal) => {
      if (!modal) return;

      const gridSliders = modal.querySelectorAll('grid-slider');
      if (!gridSliders.length) return;

      gridSliders.forEach((gridSlider) => {
        if (typeof gridSlider.toggleSlider === 'function') {
          gridSlider.toggleSlider();
        }

        if (typeof gridSlider.positionArrows === 'function') {
          gridSlider.positionArrows();
        }
      });
    };

    const updateSliderProgress = (slider, progressTrack, progressThumb) => {
      if (!slider || !progressTrack || !progressThumb) return;

      const maxScroll = Math.max(slider.scrollWidth - slider.clientWidth, 0);
      if (maxScroll <= 0) {
        progressTrack.classList.add('is-hidden');
        progressThumb.style.width = '100%';
        progressThumb.style.transform = 'translateX(0)';
        return;
      }

      const trackWidth = progressTrack.clientWidth;
      if (!trackWidth) return;

      progressTrack.classList.remove('is-hidden');

      const thumbWidth = Math.max((slider.clientWidth / slider.scrollWidth) * trackWidth, 18);
      const maxOffset = Math.max(trackWidth - thumbWidth, 0);
      const scrollProgress = slider.scrollLeft / maxScroll;
      const offset = maxOffset * scrollProgress;

      progressThumb.style.width = `${thumbWidth}px`;
      progressThumb.style.transform = `translateX(${offset}px)`;
    };

    const bindSliderProgress = (slider, progressTrack, progressThumb) => {
      if (!slider || !progressTrack || !progressThumb) return;

      const existingBinding = sliderProgressBindings.get(slider);
      if (existingBinding) {
        existingBinding.update();
        return;
      }

      const update = () => updateSliderProgress(slider, progressTrack, progressThumb);
      const onScroll = () => update();
      slider.addEventListener('scroll', onScroll, {passive: true});
      let resizeObserver = null;
      let onResize = null;

      if ('ResizeObserver' in window) {
        resizeObserver = new ResizeObserver(() => update());
        resizeObserver.observe(slider);
        resizeObserver.observe(progressTrack);
      } else {
        onResize = () => requestAnimationFrame(update);
        window.addEventListener('resize', onResize);
        document.addEventListener('theme:resize:width', onResize);
      }

      sliderProgressBindings.set(slider, {update, resizeObserver, onResize});
      update();
    };

    const initModalSliderProgress = (modal) => {
      if (!modal) return;

      const sliderShells = modal.querySelectorAll('.storytelling-modal__slider-shell');
      if (!sliderShells.length) return;

      sliderShells.forEach((sliderShell) => {
        const slider = sliderShell.querySelector('[data-grid-slider]');
        const progressTrack = sliderShell.querySelector('[data-storytelling-slider-progress]');
        const progressThumb = sliderShell.querySelector('[data-storytelling-slider-progress-thumb]');
        bindSliderProgress(slider, progressTrack, progressThumb);
      });
    };

    const getNearestCenteredSlide = (slider) => {
      if (!slider) return null;

      const slides = Array.from(slider.querySelectorAll('[data-grid-item]'));
      if (!slides.length) return null;

      const sliderCenter = slider.scrollLeft + slider.clientWidth / 2;
      let nearestSlide = slides[0];
      let nearestDistance = Math.abs(sliderCenter - (nearestSlide.offsetLeft + nearestSlide.clientWidth / 2));

      slides.forEach((slide) => {
        const slideCenter = slide.offsetLeft + slide.clientWidth / 2;
        const distance = Math.abs(sliderCenter - slideCenter);

        if (distance < nearestDistance) {
          nearestSlide = slide;
          nearestDistance = distance;
        }
      });

      return nearestSlide;
    };

    const getCenteredScrollLeft = (slider, slide) => {
      if (!slider || !slide) return 0;

      const maxScrollLeft = Math.max(slider.scrollWidth - slider.clientWidth, 0);
      const centeredScrollLeft = slide.offsetLeft - slider.clientWidth / 2 + slide.clientWidth / 2;

      return Math.max(0, Math.min(centeredScrollLeft, maxScrollLeft));
    };

    const bindSliderSnap = (slider) => {
      if (!slider) return;

      const existingBinding = sliderSnapBindings.get(slider);
      if (existingBinding) return;

      const gridSlider = slider.closest('grid-slider');
      let snapTimer = null;

      const snapToNearestSlide = () => {
        const nearestSlide = getNearestCenteredSlide(slider);
        if (!nearestSlide) return;

        const targetLeft = getCenteredScrollLeft(slider, nearestSlide);
        if (Math.abs(slider.scrollLeft - targetLeft) < 2) return;

        if (gridSlider && typeof gridSlider.goToSlide === 'function') {
          gridSlider.goToSlide(nearestSlide);
          return;
        }

        slider.scrollTo({
          left: targetLeft,
          top: 0,
          behavior: 'smooth',
        });
      };

      const queueSnap = () => {
        window.clearTimeout(snapTimer);
        snapTimer = window.setTimeout(snapToNearestSlide, 140);
      };

      slider.addEventListener('scroll', queueSnap, {passive: true});

      sliderSnapBindings.set(slider, {
        queueSnap,
        snapToNearestSlide,
      });
    };

    const initModalSliderSnap = (modal) => {
      if (!modal) return;

      const sliders = modal.querySelectorAll('.storytelling-modal__slider-shell [data-grid-slider]');
      if (!sliders.length) return;

      sliders.forEach((slider) => bindSliderSnap(slider));
    };

    const onModalClosed = (modal) => {
      if (!modal) return;

      const shouldRestoreFocus = modal.__storytellingRestoreFocus !== false;
      delete modal.__storytellingRestoreFocus;

      if (window.theme && typeof window.theme.hasOpenModals === 'function') {
        if (!window.theme.hasOpenModals()) {
          document.dispatchEvent(new CustomEvent('theme:scroll:unlock', {bubbles: true}));
        }
      } else {
        document.dispatchEvent(new CustomEvent('theme:scroll:unlock', {bubbles: true}));
      }

      const triggers = getTriggersByModalId(modal.id);
      if (!triggers.length) return;

      triggers.forEach((trigger) => {
        trigger.setAttribute('aria-expanded', 'false');
      });

      if (shouldRestoreFocus) {
        const focusableTrigger = triggers.find((trigger) =>
          trigger.matches('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])')
        );

        (focusableTrigger || triggers[0]).focus();
      }
    };

    const closeModal = (modal, options = {}) => {
      if (!modal) return;

      const restoreFocus = options.restoreFocus !== false;
      modal.__storytellingRestoreFocus = restoreFocus;

      if (typeof modal.close === 'function') {
        if (modal.open) {
          modal.close();
        } else {
          onModalClosed(modal);
        }
      } else {
        modal.removeAttribute('open');
        onModalClosed(modal);
      }
    };

    const openModal = (trigger) => {
      const modal = getModalByTrigger(trigger);
      if (!modal) return;

      const openModalElement = document.querySelector('[data-storytelling-modal][open]');
      if (openModalElement && openModalElement !== modal) {
        closeModal(openModalElement, {restoreFocus: false});
      }

      if (typeof modal.showModal === 'function') {
        if (!modal.open) {
          modal.showModal();
        }
      } else {
        modal.setAttribute('open', '');
      }

      document.dispatchEvent(new CustomEvent('theme:scroll:lock', {bubbles: true}));
      getTriggersByModalId(modal.id).forEach((modalTrigger) => {
        modalTrigger.setAttribute('aria-expanded', 'true');
      });

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          refreshModalSliders(modal);
          initModalSliderProgress(modal);
          initModalSliderSnap(modal);
        });
      });

      const closeButton = modal.querySelector('[data-storytelling-modal-close]');
      if (closeButton) {
        closeButton.focus();
      }
    };

    document.addEventListener(
      'click',
      (event) => {
        const trigger = event.target.closest('[data-storytelling-modal-trigger]');
        if (trigger) {
          event.preventDefault();
          event.stopPropagation();
          openModal(trigger);
          return;
        }

        const closeButton = event.target.closest('[data-storytelling-modal-close]');
        if (closeButton) {
          event.preventDefault();
          event.stopPropagation();
          closeModal(closeButton.closest('[data-storytelling-modal]'));
          return;
        }

        const modal = event.target.closest('[data-storytelling-modal]');
        if (modal && event.target === modal) {
          event.preventDefault();
          event.stopPropagation();
          closeModal(modal);
        }
      },
      true
    );

    document.addEventListener(
      'cancel',
      (event) => {
        const modal = event.target;
        if (!modal.matches('[data-storytelling-modal]')) return;

        event.preventDefault();
        closeModal(modal);
      },
      true
    );

    document.addEventListener(
      'close',
      (event) => {
        const modal = event.target;
        if (!modal.matches('[data-storytelling-modal]')) return;

        onModalClosed(modal);
      },
      true
    );
  })();
{% endjavascript %}
