{% doc %}
  Renders a storytelling product tile with a full-screen "Shop the look" overlay modal.

  @param {product} product - Product object rendered in the tile
  @param {number} [index] - Position index used for unique DOM IDs
  @param {boolean} [pdp_mode] - When true, shows the second product image in the trigger instead of the first
{% enddoc %}

{%- liquid
  assign product_images = product.media | where: 'media_type', 'image'
  assign first_image = product_images | first
  assign second_image = product_images[1]
  assign first_media = product.media.first
  assign modal_media = product.media[1]
  assign modal_image = blank
  assign desktop_trigger_image = blank
  assign mobile_trigger_image = blank
  assign look_slider = ''
  assign storytelling_slide_count = 0
  assign first_media_is_video = false
  assign modal_media_is_video = false

  if modal_media == blank
    assign modal_media = first_media
  endif

  if first_media != blank
    if first_media.media_type == 'video' or first_media.media_type == 'external_video'
      assign first_media_is_video = true
    endif
  endif

  if modal_media != blank
    if modal_media.media_type == 'video' or modal_media.media_type == 'external_video'
      assign modal_media_is_video = true
    endif
  endif

  if modal_media != blank
    if modal_media.media_type == 'image'
      assign modal_image = modal_media
    elsif modal_media.preview_image != blank
      assign modal_image = modal_media.preview_image
    endif
  endif

  if pdp_mode and modal_image != blank
    assign desktop_trigger_image = modal_image
  else
    assign desktop_trigger_image = first_image
  endif

  assign mobile_trigger_image = second_image | default: modal_image | default: desktop_trigger_image

  assign cta_text = product.metafields.custom.ste_cta | default: 'Shop the look'
  assign storytelling_products = product.metafields.custom.ste_products.value

  assign grid_item_styles = 'grid-column: 1 / -3;'
  assign grid_item_type = 'one_column'
  if product.metafields.custom.ste_full_bleed == true
    assign grid_item_styles = 'grid-column: 1 / -1; object-fit: contain; width: 100%; height: auto;'
    assign grid_item_type = 'full_bleed'
  endif

  assign modal_id = 'StorytellingModal--' | append: product.id
  if index != blank
    assign modal_id = modal_id | append: '-' | append: index
  endif
  if product.handle != blank
    assign modal_id = modal_id | append: '-' | append: product.handle
  endif
-%}

{%- for storytelling_product in storytelling_products -%}
  {%- if storytelling_product == blank -%}
    {%- continue -%}
  {%- endif -%}

  {%- liquid
    assign storytelling_product_image = storytelling_product.featured_media.preview_image

    if storytelling_product_image == blank
      assign storytelling_product_image = storytelling_product.media | where: 'media_type', 'image' | first
    endif

    assign storytelling_slide_count = storytelling_slide_count | plus: 1
  -%}

  {%- capture look_slider -%}
    {{ look_slider }}

    <div class="swiper-slide storytelling-modal__product-slide" data-storytelling-product-slide>
      <a href="{{ storytelling_product.url }}" class="storytelling-product-card">
        <div class="storytelling-product-card__image">
          {%- if storytelling_product_image != blank -%}
            {{
              storytelling_product_image
              | image_url: width: 1200
              | image_tag:
                alt: storytelling_product.title,
                loading: 'lazy',
                widths: '480, 720, 960, 1200'
            }}
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg storytelling-product-card__placeholder' }}
          {%- endif -%}
        </div>

        <div class="storytelling-product-card__content">
          <p class="storytelling-product-card__title navlink">{{ storytelling_product.title | strip_html | escape }}</p>
          <p class="storytelling-product-card__price price">{{ storytelling_product.price | money }}</p>
        </div>
      </a>
    </div>
  {%- endcapture -%}
{% endfor %}

<grid-item
  class="product-storytelling grid-item product-item  product-item--left product-item--overlay-text {{ grid_item_type }}"
  data-product-available="{{ product.available }}"
  style="{{ grid_item_styles }} grid-row: span 1;"
>
  <div
    class="grid-media__media-wrapper"
    data-storytelling-modal-trigger
    data-storytelling-modal-target="{{ modal_id }}"
  >
    {%- if first_media_is_video -%}
      {%- assign trigger_video_classes = 'custom-autoplay-video storytelling-trigger-video' -%}
      {%- liquid
        case first_media.media_type
          when 'video'
            echo first_media | media_tag: image_size: '2048x', class: trigger_video_classes, autoplay: true, loop: true, controls: false, preload: 'none', muted: true
          when 'external_video'
            if first_media.host == 'youtube'
              echo first_media | external_video_url: autoplay: true, playsinline: true, loop: true, playlist: first_media.external_id, controls: false, mute: true, showinfo: false | external_video_tag: class: trigger_video_classes, loading: 'lazy', data-host: first_media.host
            else
              echo first_media | external_video_url: autoplay: true, playsinline: true, loop: true, controls: false, muted: true | external_video_tag: class: trigger_video_classes, data-host: first_media.host
            endif
        endcase
      -%}
    {%- else -%}
      {%- if desktop_trigger_image -%}
        <picture class="storytelling-trigger-picture">
          {%- if mobile_trigger_image != blank and mobile_trigger_image != desktop_trigger_image -%}
            <source
              media="(max-width: 960px)"
              srcset="{{ mobile_trigger_image | image_url: width: 2048 }}"
            >
          {%- endif -%}
          {{
            desktop_trigger_image
            | image_url: width: 2048
            | image_tag:
              alt: product.title,
              loading: 'eager',
              fetchpriority: 'high',
              class: 'storytelling-trigger-image'
          }}
        </picture>
      {%- endif -%}
    {%- endif -%}
    <button
      type="button"
      class="btn btn--solid btn--primary product-shop-the-look"
      data-shopify-title="{{ product.title | strip_html }}"
      data-storytelling-modal-trigger
      data-storytelling-modal-target="{{ modal_id }}"
      aria-haspopup="dialog"
      aria-controls="{{ modal_id }}"
      aria-expanded="false"
    >
      <span class="product-shop-the-look-text">{{ cta_text }}</span>
    </button>
  </div>

  <dialog
    id="{{ modal_id }}"
    class="storytelling-modal"
    aria-label="{{ cta_text | escape }}"
    aria-modal="true"
    data-storytelling-modal
    data-scroll-lock-required
  >
    <div class="storytelling-modal__inner">
      <look-component class="look">
        <div class="storytelling-look__image">
          {%- if modal_media_is_video -%}
            {%- liquid
              case modal_media.media_type
                when 'video'
                  echo modal_media | media_tag: image_size: '2048x', class: 'storytelling custom-autoplay-video', autoplay: true, loop: true, controls: false, preload: 'none', muted: true
                when 'external_video'
                  if modal_media.host == 'youtube'
                    echo modal_media | external_video_url: autoplay: true, playsinline: true, loop: true, playlist: modal_media.external_id, controls: false, mute: true, showinfo: false | external_video_tag: class: 'storytelling custom-autoplay-video', loading: 'lazy', data-host: modal_media.host
                  else
                    echo modal_media | external_video_url: autoplay: true, playsinline: true, loop: true, controls: false, muted: true | external_video_tag: class: 'storytelling custom-autoplay-video', data-host: modal_media.host
                  endif
              endcase
            -%}
          {%- else -%}
            {%- if modal_image -%}
              <img
                class=""
                src="{{ modal_image | image_url: width: 2048 }}"
                alt="{{ product.title | strip_html | escape }}"
                width="auto"
                height="auto"
              >
            {%- endif -%}
          {%- endif -%}
        </div>

        <div class="look__aside" data-popup-container>
          <div class="underlay mobile look__underlay" data-popup-close></div>

          <div class="look__content" data-popup-content data-scroll-lock-scrollable>
            <div class="storytelling-modal__slider-shell">
              <div
                class="swiper storytelling-modal__swiper"
                data-storytelling-swiper
                data-storytelling-swiper-id="{{ modal_id }}"
              >
                <div class="swiper-wrapper">
                  {{ look_slider }}
                </div>
                <div
                  class="swiper-pagination storytelling-modal__slider-progress{% if storytelling_slide_count <= 1 %} is-hidden{% endif %}"
                  data-storytelling-swiper-pagination
                  aria-hidden="true"
                ></div>
              </div>
            </div>
          </div>
          <button
            type="button"
            class="storytelling-modal__close"
            data-storytelling-modal-close
            aria-label="{{ 'general.accessibility.close' | t }}"
          >
            {%- render 'icon-close' -%}
          </button>
        </div>
      </look-component>
    </div>
  </dialog>
</grid-item>

{% javascript %}
  (() => {
    if (window.__storytellingModalInitialized) return;
    window.__storytellingModalInitialized = true;
    const swiperInstances = window.__storytellingModalSwipers || new WeakMap();
    window.__storytellingModalSwipers = swiperInstances;

    const getModalByTrigger = (trigger) => {
      const modalId = trigger.getAttribute('data-storytelling-modal-target');
      if (!modalId) return null;
      return document.getElementById(modalId);
    };

    const getTriggersByModalId = (modalId) => {
      if (!modalId) return [];
      return Array.from(document.querySelectorAll(`[data-storytelling-modal-target="${modalId}"]`));
    };

    const updateStorytellingProgress = (swiper) => {
      if (!swiper || swiper.destroyed) return;

      const progressTrack = swiper.pagination && swiper.pagination.el;
      const progressFill = progressTrack && progressTrack.querySelector('.swiper-pagination-progressbar-fill');
      if (!progressTrack || !progressFill) return;

      const slidesCount = swiper.slides ? swiper.slides.length : 0;
      if (slidesCount <= 1) return;

      const trackWidth = progressTrack.clientWidth;
      if (!trackWidth) return;

      const thumbWidth = Math.max(trackWidth / slidesCount, 36);
      const maxOffset = Math.max(trackWidth - thumbWidth, 0);
      const clampedProgress = Math.max(0, Math.min(1, swiper.progress || 0));
      const offset = maxOffset * clampedProgress;

      progressFill.style.width = `${thumbWidth}px`;
      progressFill.style.transform = `translate3d(${offset}px, 0, 0)`;
    };

    const initModalSwiper = (modal) => {
      if (!modal) return;
      if (typeof Swiper === 'undefined') return;

      const swiperElement = modal.querySelector('[data-storytelling-swiper]');
      const paginationElement = modal.querySelector('[data-storytelling-swiper-pagination]');
      if (!swiperElement || !paginationElement) return;
      if (!swiperElement.querySelector('.swiper-slide')) return;

      let swiper = swiperInstances.get(modal);

      if (swiper && !swiper.destroyed) {
        swiper.update();
        if (swiper.pagination && typeof swiper.pagination.update === 'function') {
          swiper.pagination.update();
        }
        requestAnimationFrame(() => {
          updateStorytellingProgress(swiper);
        });
        return;
      }

      swiper = new Swiper(swiperElement, {
        slidesPerView: 1,
        spaceBetween: 0,
        loop: false,
        watchOverflow: true,
        observer: true,
        observeParents: true,
        a11y: true,
        keyboard: {
          enabled: true,
          onlyInViewport: false,
        },
        pagination: {
          el: paginationElement,
          type: 'progressbar',
        },
        on: {
          afterInit(instance) {
            requestAnimationFrame(() => {
              updateStorytellingProgress(instance);
            });
          },
          progress(instance) {
            requestAnimationFrame(() => {
              updateStorytellingProgress(instance);
            });
          },
          resize(instance) {
            requestAnimationFrame(() => {
              updateStorytellingProgress(instance);
            });
          },
          update(instance) {
            requestAnimationFrame(() => {
              updateStorytellingProgress(instance);
            });
          },
        },
      });

      swiperInstances.set(modal, swiper);
    };

    const onModalClosed = (modal) => {
      if (!modal) return;

      const shouldRestoreFocus = modal.__storytellingRestoreFocus !== false;
      delete modal.__storytellingRestoreFocus;

      if (window.theme && typeof window.theme.hasOpenModals === 'function') {
        if (!window.theme.hasOpenModals()) {
          document.dispatchEvent(new CustomEvent('theme:scroll:unlock', {bubbles: true}));
        }
      } else {
        document.dispatchEvent(new CustomEvent('theme:scroll:unlock', {bubbles: true}));
      }

      const triggers = getTriggersByModalId(modal.id);
      if (!triggers.length) return;

      triggers.forEach((trigger) => {
        trigger.setAttribute('aria-expanded', 'false');
      });

      if (shouldRestoreFocus) {
        const focusableTrigger = triggers.find((trigger) =>
          trigger.matches('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])')
        );

        (focusableTrigger || triggers[0]).focus();
      }
    };

    const closeModal = (modal, options = {}) => {
      if (!modal) return;

      const restoreFocus = options.restoreFocus !== false;
      modal.__storytellingRestoreFocus = restoreFocus;

      if (typeof modal.close === 'function') {
        if (modal.open) {
          modal.close();
        } else {
          onModalClosed(modal);
        }
      } else {
        modal.removeAttribute('open');
        onModalClosed(modal);
      }
    };

    const openModal = (trigger) => {
      const modal = getModalByTrigger(trigger);
      if (!modal) return;

      const openModalElement = document.querySelector('[data-storytelling-modal][open]');
      if (openModalElement && openModalElement !== modal) {
        closeModal(openModalElement, {restoreFocus: false});
      }

      if (typeof modal.showModal === 'function') {
        if (!modal.open) {
          modal.showModal();
        }
      } else {
        modal.setAttribute('open', '');
      }

      document.dispatchEvent(new CustomEvent('theme:scroll:lock', {bubbles: true}));
      getTriggersByModalId(modal.id).forEach((modalTrigger) => {
        modalTrigger.setAttribute('aria-expanded', 'true');
      });

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          initModalSwiper(modal);
        });
      });

      const closeButton = modal.querySelector('[data-storytelling-modal-close]');
      if (closeButton) {
        closeButton.focus();
      }
    };

    document.addEventListener(
      'click',
      (event) => {
        const trigger = event.target.closest('[data-storytelling-modal-trigger]');
        if (trigger) {
          event.preventDefault();
          event.stopPropagation();
          openModal(trigger);
          return;
        }

        const closeButton = event.target.closest('[data-storytelling-modal-close]');
        if (closeButton) {
          event.preventDefault();
          event.stopPropagation();
          closeModal(closeButton.closest('[data-storytelling-modal]'));
          return;
        }

        const modal = event.target.closest('[data-storytelling-modal]');
        if (modal && event.target === modal) {
          event.preventDefault();
          event.stopPropagation();
          closeModal(modal);
        }
      },
      true
    );

    document.addEventListener(
      'cancel',
      (event) => {
        const modal = event.target;
        if (!modal.matches('[data-storytelling-modal]')) return;

        event.preventDefault();
        closeModal(modal);
      },
      true
    );

    document.addEventListener(
      'close',
      (event) => {
        const modal = event.target;
        if (!modal.matches('[data-storytelling-modal]')) return;

        onModalClosed(modal);
      },
      true
    );

    document.addEventListener('shopify:section:load', (event) => {
      const target = event.target;
      if (!target || !target.querySelectorAll) return;

      target.querySelectorAll('[data-storytelling-modal][open]').forEach((modal) => {
        requestAnimationFrame(() => {
          initModalSwiper(modal);
        });
      });
    });
  })();
{% endjavascript %}
