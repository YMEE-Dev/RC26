{% doc %}
  Renders 2 years warranty information in a drawer.
  This snippet uses metaobjects for content management.
  
  @param {object} block - The block object containing drawer settings
{% enddoc %}

<div class="drawer-2-years-warranty drawer__content-wrapper">
  {%- comment -%}
    Get warranty content from dedicated metafields
  {%- endcomment -%}
  {%- assign warranty_content = nil -%}
  
  {%- if product and product.metafields.info.two_years_warranty != blank -%}
    {%- assign warranty_content = product.metafields.info.two_years_warranty.value -%}
  {%- elsif collection and collection.metafields.info.two_years_warranty != blank -%}
    {%- assign warranty_content = collection.metafields.info.two_years_warranty.value -%}
  {%- elsif shop.metafields.info.two_years_warranty != blank -%}
    {%- assign warranty_content = shop.metafields.info.two_years_warranty.value -%}
  {%- endif -%}
  
  {%- comment -%}
    Display metaobject content if available
  {%- endcomment -%}
  {%- if warranty_content != blank -%}
    <div class="warranty__content drawer-content__main">
      <div class="warranty__text-content">
        {%- if warranty_content.title != blank -%}
          <h2 class="warranty__title drawer-content__title">{{ warranty_content.title }}</h2>
        {%- endif -%}
        
        {%- if warranty_content.description != blank -%}
          <div class="warranty__description drawer-content__description">
            {{ warranty_content.description | metafield_tag }}
          </div>
        {%- endif -%}
        
        {%- if warranty_content.link_text != blank and warranty_content.link_url != blank -%}
          <div class="warranty__link drawer-content__link">
            <a href="{{ warranty_content.link_url }}" class="link">{{ warranty_content.link_text }}</a>
          </div>
        {%- endif -%}
        
        {%- if warranty_content.accordions != blank -%}
          <div class="warranty__accordions">
            {%- for accordion in warranty_content.accordions -%}
              <div class="warranty__accordion">
                <details class="accordion" data-collapsible>
                  <summary class="accordion__title" data-collapsible-trigger>
                    {{ accordion.title }}
                  </summary>
                  <div class="accordion__content" data-collapsible-content>
                    {{ accordion.content | metafield_tag }}
                  </div>
                </details>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      
      {%- if warranty_content.image != blank -%}
        <div class="warranty__image">
          {{ warranty_content.image | image_url: width: 600 | image_tag }}
        </div>
      {%- endif -%}
    </div>
  {%- else -%}
    <div class="warranty__default">
      <h2>2 Years Warranty</h2>
      <p>Warranty information will appear here once configured.</p>
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .drawer-2-years-warranty {
    padding: 20px;
  }
  
  
  .warranty__text-content {
    flex: 1;
  }
  
  .warranty__image {
    margin-top: auto;
    text-align: center;
  }
  
  .warranty__image img {
    max-width: 100%;
    height: auto;
  }
  
  
  
  .warranty__accordions {
    margin-bottom: 20px;
  }
  
  .warranty__default {
    text-align: center;
    padding: 40px 20px;
  }
{% endstylesheet %}
