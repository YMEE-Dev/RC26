{% doc %}
  Renders a split side-drawer layout with an optional image on the left and rich content on the right.

  @param {object} block - Side drawer block object
{% enddoc %}

<div class="drawer-layout drawer-layout--split">
  {%- if block.settings.split_image != blank -%}
    <div class="drawer-layout__media">
      {{
        block.settings.split_image
        | image_url: width: 1600
        | image_tag:
          loading: 'lazy',
          widths: '360, 540, 720, 960, 1200, 1600',
          sizes: '(min-width: 990px) 50vw, 100vw',
          class: 'drawer-layout__image'
      }}
    </div>
  {%- endif -%}

  <div class="drawer-layout__content">
    {%- if block.settings.heading != blank -%}
      <h3 class="drawer-layout__heading">{{ block.settings.heading }}</h3>
    {%- endif -%}

    {%- if block.settings.text != blank -%}
      <div class="drawer-layout__text rte">{{ block.settings.text }}</div>
    {%- endif -%}

    {%- if block.settings.page != blank -%}
      <div class="drawer-layout__page rte">{{ block.settings.page.content }}</div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .drawer-layout--split {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 24px;
  }

  .drawer-layout__media {
    min-height: 260px;
  }

  .drawer-layout__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .drawer-layout__content {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .drawer-layout__heading {
    margin: 0;
  }

  .drawer-layout__text > *:first-child,
  .drawer-layout__page > *:first-child {
    margin-top: 0;
  }

  @media only screen and (min-width: 990px) {
    .drawer-layout--split {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 32px;
      align-items: stretch;
    }
  }
{% endstylesheet %}
