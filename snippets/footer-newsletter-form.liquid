{% doc %}
  Renders the footer newsletter Mailchimp form.

  @param {object} section - Footer newsletter section object

  @example
  {% render 'footer-newsletter-form', section: section %}
{% enddoc %}

{%- liquid
  assign form_id = 'FooterNewsletterForm--' | append: section.id
  assign action_url = section.settings.mailchimp_action_url | strip
  assign user_id = section.settings.mailchimp_user_id | strip
  assign audience_id = section.settings.mailchimp_audience_id | strip
  assign tags = section.settings.mailchimp_tags | strip
  assign first_name_field = section.settings.mailchimp_first_name_field | default: 'FNAME' | strip
  assign last_name_field = section.settings.mailchimp_last_name_field | default: 'LNAME' | strip
  assign email_field = section.settings.mailchimp_email_field | default: 'EMAIL' | strip
  assign language_field = section.settings.mailchimp_language_field | default: 'LANGUAGE' | strip
  assign consent_field = section.settings.mailchimp_consent_field | default: 'CONSENT' | strip
  assign current_language = localization.language.iso_code | default: request.locale.iso_code | upcase
  assign consent_copy = section.settings.consent_label
  assign policy_copy = section.settings.policy_text
-%}

<form
  id="{{ form_id }}"
  class="footer-newsletter-form"
  method="post"
  action="{{ action_url }}"
  accept-charset="UTF-8"
>
  <input type="hidden" name="u" value="{{ user_id }}">
  <input type="hidden" name="id" value="{{ audience_id }}">

  {%- if tags != blank -%}
    <input type="hidden" name="tags" value="{{ tags }}">
  {%- endif -%}

  <div class="footer-newsletter-form__fields">
    <div class="footer-newsletter-form__group">
      {%- if section.settings.required_fields_label != blank -%}
        <p class="footer-newsletter-form__eyebrow navlink">{{ section.settings.required_fields_label | escape }}</p>
      {%- endif -%}

      <label class="visually-hidden" for="FooterNewsletterFirstName--{{ section.id }}"> First name </label>
      <input
        id="FooterNewsletterFirstName--{{ section.id }}"
        class="footer-newsletter-form__field field"
        type="text"
        name="{{ first_name_field }}"
        placeholder="Name"
        value="{% if customer %}{{ customer.first_name | escape }}{% endif %}"
        required
      >

      <label class="visually-hidden" for="FooterNewsletterLastName--{{ section.id }}"> Last name </label>
      <input
        id="FooterNewsletterLastName--{{ section.id }}"
        class="footer-newsletter-form__field field"
        type="text"
        name="{{ last_name_field }}"
        placeholder="Surname"
        value="{% if customer %}{{ customer.last_name | escape }}{% endif %}"
        required
      >

      <label class="visually-hidden" for="FooterNewsletterEmail--{{ section.id }}"> Email </label>
      <input
        id="FooterNewsletterEmail--{{ section.id }}"
        class="footer-newsletter-form__field field"
        type="email"
        name="{{ email_field }}"
        placeholder="E-mail"
        value="{% if customer %}{{ customer.email | escape }}{% endif %}"
        autocorrect="off"
        autocapitalize="off"
        required
      >
    </div>

    <div class="footer-newsletter-form__group footer-newsletter-form__group--language">
      <p class="footer-newsletter-form__eyebrow navlink">I WANT TO RECEIVE EMAILS IN</p>

      <label class="visually-hidden" for="FooterNewsletterLanguage--{{ section.id }}"> Language </label>
      <select
        id="FooterNewsletterLanguage--{{ section.id }}"
        class="footer-newsletter-form__field footer-newsletter-form__field--select field"
        name="{{ language_field }}"
        required
      >
        {%- if localization.available_languages.size > 0 -%}
          {%- for language in localization.available_languages -%}
            <option
              value="{{ language.iso_code | upcase }}"
              {% if language.iso_code == localization.language.iso_code %}
                selected
              {% endif %}
            >
              {{ language.endonym_name }}
            </option>
          {%- endfor -%}
        {%- else -%}
          <option value="{{ current_language }}" selected>{{ current_language }}</option>
        {%- endif -%}
      </select>
    </div>

    <div class="footer-newsletter-form__consent checkbox">
      <input
        id="FooterNewsletterConsent--{{ section.id }}"
        type="checkbox"
        name="{{ consent_field }}"
        value="true"
        required
      >
      <label for="FooterNewsletterConsent--{{ section.id }}">
        <span class="footer-newsletter-form__consent-copy rte body">
          {%- if consent_copy != blank -%}
            {{ consent_copy }}
          {%- else -%}
            <p>
              I confirm that I have read, understood and accepted your privacy information, that I am over 16, and I
              agree to receive this newsletter.
            </p>
          {%- endif -%}
        </span>
      </label>
    </div>

    <div>
      <button type="submit" class="footer-newsletter-form__submit btn btn--primary btn--solid btn--full">
        {{ section.settings.button_text | default: 'SIGN UP' | escape }}
      </button>

      <div class="footer-newsletter-form__policy rte legal">
        {%- if policy_copy != blank -%}
          {{ policy_copy }}
        {%- else -%}
          <p>
            Your personal data will be used to provide you with the newsletter service you have expressly requested.
            Please read the privacy policy and cookie policy for further information.
          </p>
        {%- endif -%}
      </div>
    </div>
  </div>
</form>
