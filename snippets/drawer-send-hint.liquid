{% doc %}
  Renders a drawer content for "Send a hint" functionality.
  Submits to Klaviyo Client API (Create Event) instead of Shopify contact form.
{% enddoc %}

<div class="drawer-hint drawer__content-wrapper">
  <h3 class="drawer__title drawer-content__title">{{ 'products.product.send_hint_title' | t }}</h3>

  <div class="drawer__content drawer-content__main">
    <form class="hint-form" id="hint-form" novalidate>
      <div class="hint-form__status hint-form__status--error" id="hint-form-error" style="display:none"></div>

      <input type="hidden" id="hint-product-title" value="{{ product.title | escape }}">
      <input type="hidden" id="hint-product-url" value="{{ shop.url }}{{ product.url }}">
      {% if product.selected_or_first_available_variant %}
        <input
          type="hidden"
          id="hint-product-variant"
          value="{{ product.selected_or_first_available_variant.title | escape }}"
        >
        <input
          type="hidden"
          id="hint-product-variant-id"
          value="{{ product.selected_or_first_available_variant.id }}"
        >
        <input
          type="hidden"
          id="hint-product-price"
          value="{{ product.selected_or_first_available_variant.price | money }}"
        >
        {%- assign _hint_image = product.selected_or_first_available_variant.featured_image | default: product.featured_image -%}
        {% if _hint_image %}
          <input
            type="hidden"
            id="hint-product-image"
            value="{{ _hint_image | image_url: width: 600 }}"
          >
        {% endif %}
      {% endif %}
      <input
        class="hint-form__honeypot"
        type="text"
        id="hint-honeypot"
        value=""
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
      >

      <div class="hint-form__fields" id="hint-form-fields">
        <div class="form-section">
          <h4 class="form-section__title">{{ 'products.product.recipient_section_title' | t }}</h4>
          <div class="form-field">
            <input
              type="text"
              id="hint-recipient-name"
              class="form-field__input"
              placeholder="{{ 'products.product.recipient_name' | t }}"
              required
            >
          </div>
          <div class="form-field">
            <input
              type="email"
              id="hint-recipient-email"
              class="form-field__input"
              placeholder="{{ 'products.product.recipient_email' | t }}"
              required
            >
          </div>
        </div>

        <div class="form-section">
          <h4 class="form-section__title">{{ 'products.product.your_name' | t | upcase }}</h4>
          <div class="form-field">
            <input
              type="text"
              id="hint-your-name"
              class="form-field__input"
              placeholder="{{ 'contact.form.name' | t }}"
              required
            >
          </div>
          <div class="form-field{% if customer %} hint-form__email-field--hidden{% endif %}">
            <input
              type="email"
              id="hint-your-email"
              class="form-field__input"
              placeholder="{{ 'contact.form.email' | t }}"
              value="{{ customer.email }}"
              {% unless customer %}
                required
              {% endunless %}
            >
          </div>
        </div>
      </div>

      {%- assign preview_image = product.selected_or_first_available_variant.featured_image
        | default: product.featured_image
      -%}
      <div class="hint-preview-card">
        {% if preview_image %}
          <div class="hint-preview-card__image">
            {{ preview_image | image_url: width: 600 | image_tag: alt: product.title }}
          </div>
        {% endif %}

        <div class="hint-preview-card__message">
          <p class="hint-preview-card__text">
            DEAR <span id="recipient-name-display">NAME</span>,<br>
            LOOKS LIKE <span id="sender-name-display">NAME</span> REALLY LOVES THIS PIECE<br>
            AND WE THOUGHT YOU'D WANT TO KNOW.
          </p>
        </div>

        <button type="submit" class="hint-form__submit" id="hint-form-submit">
          <img
            src="{{ 'icon-send-hint.svg' | asset_url }}"
            alt=""
            class="btn__icon hint-form__submit-icon"
            width="20"
            height="20"
          >
          {{ 'products.product.send_hint' | t }}
        </button>
      </div>
    </form>

    <div class="hint-form__success-view" id="hint-form-success" style="display:none">
      <div class="hint-form__success-content">
        <div class="hint-form__success-icon">
          <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="32" cy="32" r="30" stroke="#4a7c6f" stroke-width="1.5"/>
            <polyline points="20,33 28,41 44,25" fill="none" stroke="#4a7c6f" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h2 class="hint-form__success-title">
          {{ 'products.product.send_hint_success' | t }}
        </h2>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    var DRAWER_ID = 'side-drawer-send-hint';
    var IMAGE_WIDTH = 600;
    var DEBOUNCE_MS = 150;
    var KLAVIYO_API_KEY = {{ settings.klaviyo_public_api_key | json }};
    var KLAVIYO_API_URL = 'https://a.klaviyo.com/client/events/?company_id=' + encodeURIComponent(KLAVIYO_API_KEY || '');

    var messageTemplate = {{ 'products.product.hint_message_template' | t | json }};
    var productTitle = {{ product.title | json }};
    var productUrl = {{ shop.url | append: product.url | json }};
    var shopCurrency = {{ shop.currency | json }};
    var defaultVariantId = {{ product.selected_or_first_available_variant.id | json }};
    var defaultProductImage = {{ product.featured_image | image_url: width: 600 | json }};

    // All variants embedded from Liquid — used to look up title/price/image at submit time.
    var allVariants = {{ product.variants | json }};
    var variantsById = {};
    for (var _i = 0; _i < allVariants.length; _i++) {
      variantsById[String(allVariants[_i].id)] = allVariants[_i];
    }

    // Reads the current variant ID from the URL (both ymee and product-info.js always update it).
    function getCurrentVariantId() {
      try {
        var params = new URLSearchParams(window.location.search);
        var v = params.get('variant');
        if (v) return String(v);
      } catch (e) {}
      return String(defaultVariantId);
    }

    // Returns the full variant object for the currently selected variant.
    function getCurrentVariant() {
      var id = getCurrentVariantId();
      var v = variantsById[id];
      if (v) return v;
      // Fallback to default
      return variantsById[String(defaultVariantId)] || allVariants[0] || null;
    }

    function isDrawerOpen() {
      var drawer = document.getElementById(DRAWER_ID);
      return drawer && drawer.classList.contains('is-open');
    }

    function getGalleryImageSrc() {
      var selected = document.querySelector('.ymee-color-picker__item.is-selected .ymee-color-picker__thumb img');
      if (selected && selected.src) return selected.src;

      var active = document.querySelector('.pdp-embla__slide--active img');
      if (active) return active.currentSrc || active.src;

      var first = document.querySelector('.pdp-embla__slide img');
      if (first) return first.currentSrc || first.src;

      return null;
    }

    function resizeImageSrc(src) {
      if (!src) return src;
      try {
        if (src.startsWith('//')) src = 'https:' + src;
        var url = new URL(src);
        url.searchParams.delete('height');
        url.searchParams.delete('crop');
        url.searchParams.set('width', String(IMAGE_WIDTH));
        return url.toString();
      } catch(e) {
        return src;
      }
    }

    function syncHintImage() {
      var previewImg = document.querySelector('#' + DRAWER_ID + ' .hint-preview-card__image img');
      if (!previewImg) return;

      var src = getGalleryImageSrc();
      if (!src) return;

      var resized = resizeImageSrc(src);
      if (previewImg.src === resized) return;

      previewImg.src = resized;
      previewImg.srcset = '';

      var imageInput = document.getElementById('hint-product-image');
      if (imageInput) imageInput.value = resized;
    }

    function submitToKlaviyo(formData) {
      var payload = {
        data: {
          type: 'event',
          attributes: {
            profile: {
              data: {
                type: 'profile',
                attributes: {
                  email: formData.recipientEmail,
                  first_name: formData.recipientName
                }
              }
            },
            metric: {
              data: {
                type: 'metric',
                attributes: {
                  name: 'Send a Hint'
                }
              }
            },
            properties: {
              sender_name: formData.senderName,
              product_title: formData.productTitle,
              product_url: formData.productUrl,
              product_variant: formData.productVariant,
              product_price: formData.productPrice,
              product_image: formData.productImage,
              message: formData.message
            },
            time: new Date().toISOString()
          }
        }
      };

      return fetch(KLAVIYO_API_URL, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'revision': '2024-10-15'
        },
        body: JSON.stringify(payload)
      });
    }

    function initHintForm() {
      var form = document.getElementById('hint-form');
      if (!form || form.dataset.hintBound === 'true') return;

      var recipientInput = form.querySelector('#hint-recipient-name');
      var senderInput = form.querySelector('#hint-your-name');
      var recipientDisplay = form.querySelector('#recipient-name-display');
      var senderDisplay = form.querySelector('#sender-name-display');
      var variantInput = document.getElementById('hint-product-variant');

      if (!recipientInput || !senderInput || !recipientDisplay || !senderDisplay) return;

      form.dataset.hintBound = 'true';

      function buildMessage(recipientName, senderName) {
        var safeRecipient = (recipientName || 'NAME').toUpperCase();
        var safeSender = (senderName || 'NAME').toUpperCase();

        var message = messageTemplate
          .replace(/\{\{\s*recipient\s*\}\}/g, safeRecipient)
          .replace(/\{\{\s*sender\s*\}\}/g, safeSender);

        var lv = getCurrentVariant();
        message += '\n\nPRODUCT: ' + productTitle;
        message += '\nPRICE: ' + (lv ? (lv.price / 100).toLocaleString('en', { style: 'currency', currency: shopCurrency }) : '');

        if (lv && lv.title && lv.title.toLowerCase() !== 'default title') {
          message += '\nVARIANT: ' + lv.title;
        }

        message += '\nURL: ' + productUrl;
        return message;
      }

      var previewMessage = form.querySelector('.hint-preview-card__message');
      var recipientEmailInput = form.querySelector('#hint-recipient-email');
      var senderEmailInput = form.querySelector('#hint-your-email');

      function updatePreview() {
        var recipientName = recipientInput.value.trim();
        var senderName = senderInput.value.trim();

        recipientDisplay.textContent = recipientName ? recipientName.toUpperCase() : 'NAME';
        senderDisplay.textContent = senderName ? senderName.toUpperCase() : 'NAME';

        var recipientEmail = recipientEmailInput ? recipientEmailInput.value.trim() : '';
        var senderEmailFilled = senderEmailInput
          ? (senderEmailInput.value.trim() !== '' || senderEmailInput.closest('.hint-form__email-field--hidden') !== null)
          : false;
        var allFilled = recipientName !== '' && recipientEmail !== '' && senderName !== '' && senderEmailFilled;

        if (previewMessage) {
          if (allFilled) {
            previewMessage.classList.add('hint-preview-card__message--visible');
          } else {
            previewMessage.classList.remove('hint-preview-card__message--visible');
          }
        }
      }

      recipientInput.addEventListener('input', updatePreview);
      senderInput.addEventListener('input', updatePreview);
      if (recipientEmailInput) recipientEmailInput.addEventListener('input', updatePreview);
      if (senderEmailInput) senderEmailInput.addEventListener('input', updatePreview);
      updatePreview();

      // Form submission via Klaviyo
      form.addEventListener('submit', function(e) {
        e.preventDefault();

        var honeypot = document.getElementById('hint-honeypot');
        if (honeypot && honeypot.value) return; // bot detected

        var successEl = document.getElementById('hint-form-success');
        var errorEl = document.getElementById('hint-form-error');
        var submitBtn = document.getElementById('hint-form-submit');
        var formEl = document.getElementById('hint-form');

        // Basic validation
        var recipientName = recipientInput.value.trim();
        var recipientEmail = recipientEmailInput ? recipientEmailInput.value.trim() : '';
        var senderName = senderInput.value.trim();
        var senderEmail = senderEmailInput ? senderEmailInput.value.trim() : '';

        if (!recipientName || !recipientEmail || !senderName || !senderEmail) {
          if (errorEl) {
            errorEl.textContent = 'Please fill in all required fields.';
            errorEl.style.display = '';
          }
          return;
        }

        // Email format check
        var emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailRegex.test(recipientEmail) || !emailRegex.test(senderEmail)) {
          if (errorEl) {
            errorEl.textContent = 'Please enter valid email addresses.';
            errorEl.style.display = '';
          }
          return;
        }

        if (!KLAVIYO_API_KEY) {
          console.error('[Send a Hint] Klaviyo public API key is not configured.');
          if (errorEl) {
            errorEl.textContent = 'Configuration error. Please contact the store.';
            errorEl.style.display = '';
          }
          return;
        }

        // Disable button
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.classList.add('is-loading');
        }
        if (errorEl) errorEl.style.display = 'none';

        // Read current variant from URL at submit time — the most reliable source.
        var liveVariant = getCurrentVariant();
        var variantId = liveVariant ? String(liveVariant.id) : '';
        var variantTitle = liveVariant ? (liveVariant.title || '') : '';
        if (variantTitle.toLowerCase() === 'default title') variantTitle = '';
        var variantPrice = liveVariant
          ? (liveVariant.price / 100).toLocaleString('en', { style: 'currency', currency: shopCurrency })
          : '';

        var fullProductUrl = productUrl;
        if (variantId) {
          fullProductUrl += (productUrl.indexOf('?') === -1 ? '?' : '&') + 'variant=' + variantId;
        }

        // Resolve image: variant featured image > gallery visible image > product image
        var resolvedProductImage = '';
        if (liveVariant && liveVariant.featured_image && liveVariant.featured_image.src) {
          var imgSrc = liveVariant.featured_image.src;
          resolvedProductImage = resizeImageSrc(imgSrc.startsWith('//') ? 'https:' + imgSrc : imgSrc);
        }
        if (!resolvedProductImage) {
          resolvedProductImage = getGalleryImageSrc() || defaultProductImage || '';
          if (resolvedProductImage) resolvedProductImage = resizeImageSrc(resolvedProductImage);
        }

        var formData = {
          recipientName: recipientName,
          recipientEmail: recipientEmail,
          senderName: senderName,
          productTitle: productTitle,
          productUrl: fullProductUrl,
          productVariant: variantTitle,
          productPrice: variantPrice,
          productImage: resolvedProductImage,
          message: buildMessage(recipientName, senderName)
        };

        submitToKlaviyo(formData)
          .then(function(response) {
            if (response.ok || response.status === 202) {
              // Success — hide form and title, show success view
              if (formEl) formEl.style.display = 'none';
              if (successEl) successEl.style.display = '';
              var drawerEl = document.getElementById(DRAWER_ID);
              if (drawerEl) drawerEl.classList.add('hint-is-success');
            } else {
              throw new Error('Klaviyo API returned status ' + response.status);
            }
          })
          .catch(function(err) {
            console.error('[Send a Hint] Klaviyo submission error:', err);
            if (errorEl) {
              errorEl.textContent = 'Something went wrong. Please try again.';
              errorEl.style.display = '';
            }
          })
          .finally(function() {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.classList.remove('is-loading');
            }
          });
      });
    }

    document.addEventListener('DOMContentLoaded', initHintForm);

    function resetHintForm() {
      var form = document.getElementById('hint-form');
      var successEl = document.getElementById('hint-form-success');
      var errorEl = document.getElementById('hint-form-error');
      var drawerEl = document.getElementById(DRAWER_ID);

      if (form) {
        form.reset();
        form.style.display = '';
        // Do NOT clear hintBound — submit listener must only be attached once.
        // Clearing it would cause initHintForm() to re-bind on every drawer open,
        // resulting in multiple Klaviyo requests per submit.
      }
      if (successEl) successEl.style.display = 'none';
      if (errorEl) {
        errorEl.style.display = 'none';
        errorEl.textContent = '';
      }
      if (drawerEl) drawerEl.classList.remove('hint-is-success');

      // Reset live preview name displays
      var recipientDisplay = document.getElementById('recipient-name-display');
      var senderDisplay = document.getElementById('sender-name-display');
      if (recipientDisplay) recipientDisplay.textContent = 'NAME';
      if (senderDisplay) senderDisplay.textContent = 'NAME';

      var previewMessage = document.querySelector('#' + DRAWER_ID + ' .hint-preview-card__message');
      if (previewMessage) previewMessage.classList.remove('hint-preview-card__message--visible');
    }

    document.addEventListener('click', function(e) {
      if (e.target.closest('[data-drawer-open="send-hint"]')) {
        resetHintForm();
        setTimeout(function() {
          initHintForm();
          syncHintImage();
        }, DEBOUNCE_MS);
      }
    });

    document.addEventListener('theme:variant:change', function() {
      if (isDrawerOpen()) {
        setTimeout(syncHintImage, 300);
      }
    });

    (function() {
      var gallery = document.querySelector('.pdp-embla__container');
      if (!gallery) return;

      var debounceTimer = null;
      var observer = new MutationObserver(function() {
        if (!isDrawerOpen()) return;
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(syncHintImage, DEBOUNCE_MS);
      });

      observer.observe(gallery, {
        attributes: true,
        subtree: true,
        attributeFilter: ['class']
      });
    })();
  })();
</script>

{% stylesheet %}
  #side-drawer-send-hint .drawer__body {
    background-color: #fff;
  }

  @media only screen and (max-width: 574px) {
    #side-drawer-send-hint .drawer__inner {
      width: 100vw;
      max-width: 100vw;
    }
  }

  @media only screen and (min-width: 575px) {
    #side-drawer-send-hint .drawer__inner {
      height: 100dvh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    #side-drawer-send-hint .drawer__body {
      flex: 1;
      min-height: 0;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    #side-drawer-send-hint .drawer-hint {
      overflow: hidden;
      padding: var(--drawer-padding) 0 0;
    }
  }

  .drawer-hint {
    --drawer-padding-x: 40px;
    --drawer-padding: clamp(16px, 4vh, 40px);
    padding: var(--drawer-padding) var(--drawer-padding-x);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .drawer-hint .drawer-content__title {
    color: #000;
    font-family: var(--FONT-STACK-NAV);
    font-size: var(--FONT-SIZE-NAV);
    font-style: normal;
    font-weight: var(--FONT-WEIGHT-NAV);
    line-height: var(--LINE-HEIGHT-NAV);
    letter-spacing: var(--LETTER-SPACING-NAV);
    text-transform: uppercase;
    margin-bottom: 0;
    padding: 0 var(--drawer-padding);
  }

  .drawer-hint .drawer-content__main {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .hint-form {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  .hint-form__fields {
    flex: 0 1 auto;
    min-height: 0;
    overflow-y: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    margin: clamp(12px, 3vh, 40px) 0 clamp(8px, 2vh, 20px) 0;
    padding: 0 var(--drawer-padding);
  }

  .hint-form__fields::-webkit-scrollbar {
    display: none;
  }

  .hint-form .form-section {
    margin-bottom: clamp(8px, 2vh, 20px);
  }

  .hint-form .form-section__title {
    margin: 0 0 4px;
    color: #000;
    font-family: var(--FONT-STACK-NAV);
    font-size: var(--FONT-SIZE-NAV);
    font-style: normal;
    font-weight: var(--FONT-WEIGHT-NAV);
    line-height: var(--LINE-HEIGHT-NAV);
    letter-spacing: var(--LETTER-SPACING-NAV);
    text-transform: uppercase;
  }

  .hint-form .form-field {
    display: flex;
    flex-direction: column;
  }

  .hint-form .form-field__input {
    padding: 10px 0;
    border: none;
    border-bottom: 1px solid #e5e5e5;
    border-radius: 0;
    color: var(--000000, #000);
    font-family: var(--FONT-STACK-BODY);
    font-size: var(--FONT-SIZE-INPUT-LABEL);
    font-style: normal;
    font-weight: var(--FONT-WEIGHT-BODY);
    line-height: var(--LINE-HEIGHT-INPUT-LABEL);
    background-color: transparent;
    transition: border-color 0.2s ease;
    width: 100%;
  }

  .hint-form .form-field__input::placeholder {
    color: var(--COLOR-TEXT);
    opacity: 1;
  }

  .hint-form .form-field__input:focus {
    outline: none;
    border-bottom-color: var(--COLOR-TEXT);
  }

  .hint-form__email-field--hidden {
    display: none;
  }

  .hint-preview-card {
    flex: 1;
    min-height: 0;
    background-color: #f5f5f5;
    padding: 0 0 var(--drawer-padding) 0;
    display: flex;
    flex-direction: column;
    border-top: 1px solid #e5e5e5;
  }

  .hint-preview-card__image {
    flex: 1;
    min-height: 150px;
    overflow-y: auto;
    overflow-x: hidden;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hint-preview-card__image img {
    width: auto;
    height: 100%;
    max-width: 100%;
    min-height: 150px;
    max-height: min(400px, 40vh);
    aspect-ratio: 1 / 1;
    display: block;
    object-fit: cover;
    mix-blend-mode: multiply;
  }

  .hint-preview-card__message {
    padding: clamp(10px, 2vh, 25px) 0;
    margin: 0 var(--drawer-padding);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .hint-preview-card__message--visible {
    opacity: 1;
  }

  .hint-preview-card__text {
    margin: 0;
    color: #000;
    font-family: var(--FONT-STACK-NAV);
    font-size: var(--FONT-SIZE-NAV);
    font-style: normal;
    font-weight: var(--FONT-WEIGHT-NAV);
    line-height: var(--LINE-HEIGHT-NAV);
    letter-spacing: var(--LETTER-SPACING-NAV);
    text-transform: uppercase;
  }

  .hint-form__submit {
    margin: 0 var(--drawer-padding) clamp(10px, 2vh, 30px) var(--drawer-padding);
    background: var(--btn-bg, #000);
    color: var(--btn-text, #fff);
    border: 1px solid var(--btn-border, #000);
    border-radius: 0;
    padding: 12px 20px;
    text-align: center;
    font-size: var(--BTN-FONT-SIZE);
    font-weight: var(--BTN-FONT-WEIGHT);
    line-height: var(--BTN-LINE-HEIGHT);
    letter-spacing: var(--BTN-LETTER-SPACING);
    text-transform: uppercase;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: background 180ms ease, color 180ms ease;
  }

  .hint-form__submit:hover {
    border-color: var(--btn-border, #000);
    background-color: #27574d;
    color: #fff;
  }

  .hint-form__submit-icon {
    width: 25px;
    height: 25px;
    filter: invert(1);
    transition: filter 0.25s ease-out;
  }

  #side-drawer-send-hint.hint-is-success .drawer-content__title {
    display: none;
  }

  .hint-form__success-view {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    padding: var(--drawer-padding);
    text-align: center;
  }

  .hint-form__success-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 30px;
  }

  .hint-form__success-icon svg {
    width: clamp(64px, 8vw, 90px);
    height: clamp(64px, 8vw, 90px);
  }

  .hint-form__success-title {
    color: #000;
    font-family: var(--FONT-STACK-HEADING);
    font-size: var(--FONT-DISPLAY-S);
    font-style: normal;
    font-weight: var(--FONT-WEIGHT-NAV-BOLD);
    line-height: var(--LINE-HEIGHT-DISPLAY-S);
    text-transform: none;
    margin: 0;
    text-wrap: balance;
    max-width: 400px;
  }

  @media (max-width: 574px) {
    #side-drawer-send-hint .drawer__content-wrapper {
      padding: var(--drawer-padding) 0 0;
    }

    #side-drawer-send-hint .hint-form {
      flex: none;
      min-height: auto;
      overflow: visible;
    }
  }
{% endstylesheet %}
