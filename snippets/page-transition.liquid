{% comment %}
  Page transition. Self-contained: inline <style> + <script>.

  Outgoing fade: intercepts clicks on links whose pathname matches TRANSITION_TARGETS,
  fades body opacity 100→0 (600ms), then navigates.

  Incoming entrance: on /pages/product-care, plays a staggered reveal of page heading +
  first sticky-scroll block (image, title, description) on both desktop and mobile section
  variants. Existing header animation (header-init-animation.liquid) is not touched.

  Render once near the top of <body> in layout/theme.liquid.
  Idempotent: safe if rendered multiple times.

  Disables under prefers-reduced-motion (both halves).
  Dispatches `theme:page-care:entrance-ready` when entrance fires.

  Renders `header-init-animation` globally so the staggered header entrance runs on every
  page (was previously only invoked from sections/collection.liquid). The snippet itself is
  idempotent (window.__plpHeaderAnimInit guard) and self-disables on mobile (< 960px).
{% endcomment %}

{% render 'header-init-animation' %}

<style>
  /* Outgoing fade — body class swap on link click */
  body.page-transition-leaving {
    opacity: 0;
    transition: opacity 600ms cubic-bezier(0.70, 0, 0.3, 1);
    pointer-events: none;
    overflow: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    body.page-transition-leaving {
      transition: none;
      opacity: 1;
    }
  }

  /* Incoming entrance — gated behind no-preference for defense in depth */
  @media (prefers-reduced-motion: no-preference) {
    @keyframes pt-fade-in {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes pt-slide-up-card {
      from { transform: translate3d(0, 50px, 0); }
      to { transform: translate3d(0, 0, 0); }
    }
    @keyframes pt-slide-up-element {
      from { transform: translate3d(0, 30px, 0); }
      to { transform: translate3d(0, 0, 0); }
    }

    /* Loading state — hide targets pre-trigger to prevent FOUC */
    body#product-care.page-care-loading .heading-image__heading,
    body#product-care.page-care-loading .sticky-scroll__block:first-of-type .sticky-scroll__block-media,
    body#product-care.page-care-loading .sticky-scroll__block:first-of-type .sticky-scroll__title,
    body#product-care.page-care-loading .sticky-scroll__block:first-of-type .sticky-scroll__description,
    body#product-care.page-care-loading .sticky-scroll-mobile__block--image:first-of-type,
    body#product-care.page-care-loading .sticky-scroll-mobile__block--text:first-of-type .sticky-scroll-mobile__title,
    body#product-care.page-care-loading .sticky-scroll-mobile__block--text:first-of-type .sticky-scroll-mobile__description {
      opacity: 0;
    }

    /* Single knob to delay the entire entrance stagger after page-care-ready fires.
       Lets header-init-animation establish itself before content reveals.
       Header completes at ~1400ms (logo 550ms, meta 700ms, bars start at 700ms + 700ms duration). */
    body#product-care.page-care-ready {
      --pt-base-delay: 600ms;
    }

    /* Per-target stagger delays (relative to --pt-base-delay) */
    body#product-care.page-care-ready .heading-image__heading {
      --pt-delay: calc(var(--pt-base-delay) + 300ms);
    }
    body#product-care.page-care-ready .sticky-scroll__block:first-of-type .sticky-scroll__block-media,
    body#product-care.page-care-ready .sticky-scroll-mobile__block--image:first-of-type {
      --pt-delay: calc(var(--pt-base-delay) + 500ms);
    }
    body#product-care.page-care-ready .sticky-scroll__block:first-of-type .sticky-scroll__title,
    body#product-care.page-care-ready .sticky-scroll-mobile__block--text:first-of-type .sticky-scroll-mobile__title {
      --pt-delay: calc(var(--pt-base-delay) + 700ms);
    }
    body#product-care.page-care-ready .sticky-scroll__block:first-of-type .sticky-scroll__description,
    body#product-care.page-care-ready .sticky-scroll-mobile__block--text:first-of-type .sticky-scroll-mobile__description {
      --pt-delay: calc(var(--pt-base-delay) + 900ms);
    }

    /* Element pattern (30px y delta) */
    body#product-care.page-care-ready .heading-image__heading,
    body#product-care.page-care-ready .sticky-scroll__block:first-of-type .sticky-scroll__title,
    body#product-care.page-care-ready .sticky-scroll__block:first-of-type .sticky-scroll__description,
    body#product-care.page-care-ready .sticky-scroll-mobile__block--text:first-of-type .sticky-scroll-mobile__title,
    body#product-care.page-care-ready .sticky-scroll-mobile__block--text:first-of-type .sticky-scroll-mobile__description {
      animation:
        pt-fade-in 600ms var(--pt-delay) cubic-bezier(0.70, 0, 0.3, 1) backwards,
        pt-slide-up-element 600ms calc(var(--pt-delay) + 150ms) cubic-bezier(0.05, 0, 0, 1) backwards;
    }

    /* Card pattern (50px y delta) */
    body#product-care.page-care-ready .sticky-scroll__block:first-of-type .sticky-scroll__block-media,
    body#product-care.page-care-ready .sticky-scroll-mobile__block--image:first-of-type {
      animation:
        pt-fade-in 600ms var(--pt-delay) cubic-bezier(0.70, 0, 0.3, 1) backwards,
        pt-slide-up-card 600ms calc(var(--pt-delay) + 150ms) cubic-bezier(0.05, 0, 0, 1) backwards;
    }
  }
</style>

<script>
  (function () {
    if (window.__pageTransitionInit) return;
    window.__pageTransitionInit = true;

    var FADE_MS = 600;
    /* To enable site-wide later: set TRANSITION_TARGETS to '*' and populate TRANSITION_EXCLUDE.
       Example for site-wide:
         TRANSITION_TARGETS = '*';
         TRANSITION_EXCLUDE = ['/cart', '/search', /^\/account(\/|$)/, /^\/checkouts?(\/|$)/]; */
    var TRANSITION_TARGETS = ['/pages/product-care'];
    var TRANSITION_EXCLUDE = [];

    var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function matchesTarget(pathname) {
      for (var i = 0; i < TRANSITION_EXCLUDE.length; i++) {
        var rule = TRANSITION_EXCLUDE[i];
        if (typeof rule === 'string' && pathname === rule) return false;
        if (rule instanceof RegExp && rule.test(pathname)) return false;
      }
      if (TRANSITION_TARGETS === '*') return true;
      if (Array.isArray(TRANSITION_TARGETS)) return TRANSITION_TARGETS.indexOf(pathname) !== -1;
      return false;
    }

    function shouldIntercept(event, link) {
      if (event.defaultPrevented) return false;
      if (event.button !== 0) return false;
      if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return false;
      if (link.target && link.target !== '' && link.target !== '_self') return false;
      if (prefersReduced) return false;
      if (document.body.classList.contains('page-transition-leaving')) return false;

      var url;
      try { url = new URL(link.href, location.href); } catch (e) { return false; }
      if (url.origin !== location.origin) return false;
      if (url.pathname === location.pathname) return false;
      return matchesTarget(url.pathname);
    }

    document.addEventListener('click', function (event) {
      var link = event.target.closest && event.target.closest('a[href]');
      if (!link) return;
      if (!shouldIntercept(event, link)) return;

      event.preventDefault();
      document.body.classList.add('page-transition-leaving');

      var destination = link.href;
      setTimeout(function () {
        /* Re-check at fire time: user may have hit back during the fade */
        if (!document.body.classList.contains('page-transition-leaving')) return;
        window.location.href = destination;
      }, FADE_MS);
    });

    /* Always strip leaving state on any pageshow — protects against stuck opacity:0 body
       when user navigates back mid-fade. */
    window.addEventListener('pageshow', function () {
      document.body.classList.remove('page-transition-leaving');
    });

    /* ── Incoming entrance, scoped to /pages/product-care ──────────────────── */
    if (document.body.id === 'product-care' && !prefersReduced) {
      document.body.classList.add('page-care-loading');

      var triggered = false;
      function triggerEntrance() {
        if (triggered) return;
        if (document.body.classList.contains('page-care-ready')) return;
        triggered = true;
        /* Double rAF — guarantees a paint with `page-care-loading` before the swap. */
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            document.body.classList.add('page-care-ready');
            document.body.classList.remove('page-care-loading');
            document.dispatchEvent(new CustomEvent('theme:page-care:entrance-ready'));
          });
        });
      }

      var firstImg = document.querySelector(
        '.sticky-scroll__block:first-of-type .sticky-scroll__image, ' +
        '.sticky-scroll-mobile__block--image:first-of-type .sticky-scroll-mobile__image'
      );
      var imgPromise = (firstImg && firstImg.decode)
        ? firstImg.decode().catch(function () {})
        : Promise.resolve();
      var fontsReady = (document.fonts && document.fonts.ready) ? document.fonts.ready : Promise.resolve();

      Promise.all([fontsReady, imgPromise]).then(triggerEntrance);
      setTimeout(triggerEntrance, 3000); /* safety fallback */

      /* BFCache replay */
      window.addEventListener('pageshow', function (e) {
        if (!e.persisted) return;
        triggered = false;
        document.body.classList.remove('page-care-ready');
        document.body.classList.add('page-care-loading');
        triggerEntrance();
      });
    }
  })();
</script>
