{%- liquid
  assign featured_product = featured_product | default: false
  assign onboarding_product = false
  assign current_variant = product.selected_or_first_available_variant
  assign product_sticky_enable = section.settings.product_sticky_enable
  assign enable_video_looping = section.settings.enable_video_looping
  assign enable_history_state = true
  assign image_size = section.settings.image_size | default: 'normal'
  assign image_layout = section.settings.image_layout
  assign mobile_image_style = section.settings.mobile_image_style
  assign featured_media = current_variant.featured_media | default: product.featured_media
  assign featured_media_aspect_ratio = featured_media.aspect_ratio | default: 1
  assign first_3d_model = product.media | where: 'media_type', 'model' | first

  if template.name == 'product' and featured_product == false
    if first_3d_model != blank
      assign featured_media = first_3d_model
      assign featured_media_aspect_ratio = featured_media.aspect_ratio | default: 1
    endif
  endif

  assign ordered_media = product.media
  if first_3d_model != blank
    assign model_media = product.media | where: 'media_type', 'model'
    assign non_model_media = product.media | reject: 'media_type', 'model'
    assign ordered_media = model_media | concat: non_model_media
  endif

  if template.name == 'product' and featured_product == false
    if first_3d_model == blank
      assign featured_media = ordered_media | first
      assign featured_media_aspect_ratio = featured_media.aspect_ratio | default: 1
    endif
  endif
  assign is_title_linked = true
  if template.name == 'product' and featured_product == false
    assign is_title_linked = false
  endif

  if product.empty?
    assign onboarding_product = true
  endif

  if featured_product
    assign product_sticky_enable = false
    assign enable_history_state = false
  endif

  assign thumbnails_enabled = false
  if onboarding_product
    assign thumbnails_enabled = true
  endif

  if product.media.size > 1
    assign thumbnails_enabled = true
  endif

  assign modifier = image_layout | default: 'thumbnails'
  assign product_wrapper_modifier = 'product__wrapper--' | append: modifier

  assign wrapper_tag = 'div'
  if product_sticky_enable
    assign wrapper_tag = 'product-sticky'
  endif

  assign show_buy_buttons = false
  assign buy_buttons = section.blocks | where: 'type', 'buttons'

  if buy_buttons.size > 0
    assign show_buy_buttons = true
  endif

  assign image_width = 770

  if image_size == 'small'
    assign product_wrapper_modifier = product_wrapper_modifier | append: ' product__wrapper--small'
    assign image_width = 525
  endif

  if image_size == 'stretch'
    assign product_wrapper_modifier = product_wrapper_modifier | append: ' product__wrapper--stretch'
    assign image_width = 970
  endif

  assign product_form_id = 'product-form-' | append: section.id
  assign show_cart_bar = false

  assign sibling_color = product.metafields.theme.sibling_color.value | default: product.metafields.theme.sibling_colour.value | default: product.metafields.theme.siblings_color.value | default: product.metafields.theme.siblings_colour.value | default: product.metafields.theme.siblings_colors.value | default: product.metafields.theme.siblings_colours.value

  if section.settings.show_cart_bar and featured_product == false
    assign show_cart_bar = false
  endif

  capture product_images_classlist
    echo 'product__images'

    if template.name == 'product' and featured_product == false
      if thumbnails_enabled
        echo ' product__images--thumbs'
      else
        echo ' product__images--no-thumbs'
      endif
    else
      if thumbnails_enabled
        echo ' product__images--thumbs'
      else
        echo ' product__images--no-thumbs'
      endif
    endif

    if mobile_image_style == 'thumbs'
      echo ' product__images--mobile-thumbs'
    else
      echo ' product__images--mobile-slider'
    endif
  endcapture

  assign preorder = false
  if product.metafields.theme.preorder.type == 'boolean' and product.metafields.theme.preorder.value == true
    assign preorder = true
  endif

  if current_variant.metafields.theme.preorder.type == 'boolean' and current_variant.metafields.theme.preorder.value == true
    assign preorder = true
  endif

  assign product_tags = product.tags | join: ','
  if product_tags contains '_preorder'
    assign preorder = true
  endif

  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
  endif

  assign should_redirect_storytelling_product = false
  if template.name == 'product'
    if featured_product == false
      if product.type == 'storytelling'
        assign should_redirect_storytelling_product = true
      endif
    endif
  endif

  assign badge = ''
  if badge == '' and product_tags contains '_badge_'
    assign badge = product_tags | split: '_badge_'
    assign badge = badge[1] | split: ',' | first | replace: '_', ' '
  endif

  assign color_scheme = 'color-' | append: section.settings.color_scheme
  assign header_observer_mode = blank

  if template.name == 'product' and featured_product == false
    assign header_observer_mode = 'dark'
  endif
-%}

{%- if should_redirect_storytelling_product -%}
  <script>
    window.location.replace('/');
  </script>
{%- endif -%}
<product-info
  id="MainProduct--{{ section.id }}"
  class="index-product section-padding {{ color_scheme }} pdp-dropdown-inline{% if header_observer_mode != blank %} header-observer--{{ header_observer_mode }}{% endif %}"
  data-section="{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-product-handle="{{ product.handle }}"
  data-product-id="{{ product.id }}"
  data-enable-history-state="{{ enable_history_state }}"
  data-url="{{ product.url }}"
  {% if header_observer_mode != blank %}
    data-header-observer-mode="{{ header_observer_mode }}"
  {% endif %}
  data-overlay-header
  data-sticky-enabled="{{ product_sticky_enable }}"
  data-variant-image-scroll="{{ section.settings.variant_image_scroll }}"
>
  {%- style -%}
    {%- if show_cart_bar -%}
      :root { --cart-bar-height: 80px; }
    {%- endif -%}

    #MainProduct--{{ section.id }} {
      --PT: {{ section.settings.padding_top }}px;
      --PB: {{ section.settings.padding_bottom }}px;

      --swatch-size: var(--swatch-size-product);
      --pdp-sticky-bar-height: 100px; /* fallback, will be overridden on mobile */
      --bg-color: #f9f9f9;
    }

    {%- if template.name == 'product' and featured_product == false -%}

      body.template-product header-component.js__header__stuck .theme__header::after {
        content: "";
        background: transparent;
      }

      body.template-product .header-sections {
        background: transparent;
      }

      body.template-product .header__wrapper,
      body.template-product .header__mobile__bottom {
        --bg: transparent;
      }

      /* ── PDP mobile/tablet: gallery fills behind transparent header ── */

      @media only screen and (max-width: 989px) {
        /* Pull gallery up under header, pad to keep slides in place */
        #MainProduct--{{ section.id }} .product__images {
          background-color: var(--bg-color);
          margin-top: calc(-1 * var(--header-height, 80px));
          padding-top: var(--header-height, 80px);
        }

        /* Sections below ATF stay white */
        #MainProduct--{{ section.id }} .product__content,
        #MainProduct--{{ section.id }} .product__sticky-bar {
          background-color: var(--COLOR-BG);
        }
      }

      body.template-product .main-content {
        margin-top: 0;
        padding-top: 0;
      }

      body.template-product .main-content > *:first-child {
        margin-top: 0;
      }

      #MainProduct--{{ section.id }} {
        padding-top: 0;
        padding-bottom: 0;
      }

      #MainProduct--{{ section.id }} .product__wrapper {
        max-width: none;
        margin: 0;
      }

      #MainProduct--{{ section.id }} .product__wrapper__inner {
        max-width: none;
        margin: 0;
      }

      #MainProduct--{{ section.id }} .product__title-price {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: var(--inner);
      }

      #MainProduct--{{ section.id }} .product__title-price .product__title {
        font-family: var(--FONT-STACK-BODY);
        font-style: var(--FONT-STYLE-BODY);
        font-weight: var(--FONT-WEIGHT-BODY);
        font-size: var(--FONT-TITLE);
        line-height: var(--LINE-HEIGHT-TITLE);
        letter-spacing: var(--LETTER-SPACING-NAV);
        text-transform: uppercase;
        color: var(--COLOR-TEXT-DARK);
      }

      #MainProduct--{{ section.id }} .product__title-price .price-item,
      #MainProduct--{{ section.id }} .product__description {
        font-family: var(--FONT-STACK-BODY);
        font-style: var(--FONT-STYLE-BODY);
        font-weight: var(--FONT-WEIGHT-BODY);
        font-size: var(--FONT-SIZE-BASE);
        line-height: var(--LINE-HEIGHT-BODY);
        color: var(--COLOR-TEXT-DARK);
      }

      @media (min-width: 990px) {
        html.ja {
          --content-max: 1320px;
        }

        #MainProduct--{{ section.id }} .product__images {
          display: flex;
          flex-direction: column;
          gap: 0;
          align-items: start;
          margin: 0;
        }

        #MainProduct--{{ section.id }} .product__content {
          margin: 0 auto;
          padding: 0;
          width: 100%;
          max-width: max(var(--content-max), 1200px);
        }

        #MainProduct--{{ section.id }} .product__sticky-bar {
          position: relative;
          top: auto;
          z-index: 6;
          border-top: 1px solid #E5E5E5;
          margin: 0;
          width: 100%;
        }

        #MainProduct--{{ section.id }} .product__sticky-bar__inner {
          display: grid;
          grid-template-columns: 7fr 3fr;
          gap: 50px;
          align-items: center;
          min-height: var(--pdp-sticky-bar-height);
          padding: 0;
          max-width: max(var(--content-max), 1200px);
          margin: 0 auto;
        }

        #MainProduct--{{ section.id }} .product__sticky-bar__swatches {
          display: none;
        }

        #MainProduct--{{ section.id }} .form__width {
          max-width: max(var(--content-max), 1200px);
        }

        #MainProduct--{{ section.id }} .product__content-columns {
          display: grid;
          grid-template-columns: 7fr 3fr;
          gap: 50px;
          align-items: start;
        }

        #MainProduct--{{ section.id }} .product__title-price {
          flex-direction: row;
        }

        #MainProduct--{{ section.id }} .product__title-price .block-padding {
          margin: 0;
        }

        #MainProduct--{{ section.id }} .product__title-price .product__price__wrap {
          text-align: right;
          flex-direction: row;
        }

        #MainProduct--{{ section.id }} .product__title-price .product__price__wrap .product__price {
          padding: 0;
        }

        #MainProduct--{{ section.id }} .product__title-price .product__title {
          margin: 0;
          max-width: 40ch;
        }

        #MainProduct--{{ section.id }} .product__description {
          max-width: 80%;
          margin-bottom: 65px;
        }

        #MainProduct--{{ section.id }} .product__content-columns__aside {
          position: -webkit-sticky;
          position: sticky;
          top: var(--sticky-top, calc(var(--header-height, 0px) + var(--announcement-height, 0px)));
          align-self: start;
          height: max-content;
          overflow: visible;
          z-index: 9;
          transition: top 0.3s ease;
        }

        body.template-product:not(.header-scroll-hide) #MainProduct--{{ section.id }} {
          --sticky-top: calc(var(--header-height, 0px)*2 + var(--announcement-height, 0px));
        }

        #MainProduct--{{ section.id }} .product__content-columns__aside .product__block--buttons {
          margin-top: calc(var(--pdp-sticky-bar-height, 100px) * -1 / 1.4);
          margin-bottom: 10px;
        }

        #MainProduct--{{ section.id }} .product__content-columns__aside .product__block--buttons.has-ymee-color-picker {
          margin-top: calc(var(--pdp-sticky-bar-height, 100px) * -1 - 26px);
          background: transparent;
        }

        /* ── Desktop dropdown-slide animation (scrollTop === 0) ── */
        /* Inline: color picker shifts LEFT, dropdown moves UP to sit right of it.
           Title-price shrinks to give room. On scroll: all animate back to default. */

        body.template-product {
          overflow-x: hidden;
        }

        #MainProduct--{{ section.id }} .product__title-price {
          overflow: hidden;
        }

        /* Before JS measures: hide dropdown to avoid flash at wrong position */
        #MainProduct--{{ section.id }}.pdp-dropdown-inline:not(.pdp-dropdown-measured) .product__content-columns__aside .ymee-variant-dropdown,
        #MainProduct--{{ section.id }}.pdp-dropdown-inline:not(.pdp-dropdown-measured) .product__content-columns__aside .ymee-variant-dropdown--form-only {
          opacity: 0;
        }

        /* After JS measures: picker and dropdown animate; title-price snaps (no reflow lag) */
        #MainProduct--{{ section.id }}.pdp-dropdown-measured .product__title-price {
          max-width: var(--pdp-title-default-width, 100%);
        }

        #MainProduct--{{ section.id }}.pdp-dropdown-measured .product__content-columns__aside [data-ymee-color-picker] {
          transition: transform 0.5s cubic-bezier(.4,0,.2,1);
        }

        #MainProduct--{{ section.id }}.pdp-dropdown-measured .product__content-columns__aside .ymee-variant-dropdown,
        #MainProduct--{{ section.id }}.pdp-dropdown-measured .product__content-columns__aside .ymee-variant-dropdown--form-only {
          transition: transform 0.5s cubic-bezier(.4,0,.2,1),
                      opacity 0.3s ease;
        }

        /* Inline state (scrollTop === 0) */
        #MainProduct--{{ section.id }}.pdp-dropdown-measured.pdp-dropdown-inline .product__title-price {
          max-width: var(--pdp-title-inline-width, 100%);
        }

        #MainProduct--{{ section.id }}.pdp-dropdown-measured.pdp-dropdown-inline .product__content-columns__aside [data-ymee-color-picker] {
          transform: var(--pdp-cp-transform, none);
        }

        #MainProduct--{{ section.id }}.pdp-dropdown-measured.pdp-dropdown-inline .product__content-columns__aside .ymee-variant-dropdown,
        #MainProduct--{{ section.id }}.pdp-dropdown-measured.pdp-dropdown-inline .product__content-columns__aside .ymee-variant-dropdown--form-only {
          transform: var(--pdp-dd-transform, none);
          z-index: 10;
        }
      }

      #MainProduct--{{ section.id }} .product__content-columns__aside .product__text .product__heading {
        font-size: 12px;
        line-height: 20px;
        font-family: var(--FONT-STACK-BODY);
        font-style: var(--FONT-STYLE-BODY);
        font-weight: 400;
        letter-spacing: var(--LETTER-SPACING-NAV);
        text-transform: uppercase;
      }

      #MainProduct--{{ section.id }} .product__content-columns__aside .divider {
        border-color: #E5E5E5;
      }

      #MainProduct--{{ section.id }} .product__content-columns__aside .link-with-icon__text,
      #MainProduct--{{ section.id }} .product__content-columns__aside .block__icon__text,
      #MainProduct--{{ section.id }} .product__content-columns__aside .block__icon__text p {
        font-size: 12px;
        line-height: 20px;
        font-weight: 400;
        letter-spacing: var(--LETTER-SPACING-NAV);
        text-align: left;
      }

      #MainProduct--{{ section.id }} .product__content-columns__aside .product__submit__buttons button[type="submit"] {
        margin-top: 0px;
        min-height: 50px;
      }

      #MainProduct--{{ section.id }} .product__page {
        display: flex;
        flex-direction: column;
        width: 100%;
        align-items: stretch;
      }

      #MainProduct--{{ section.id }} .product__images {
        position: relative;
      }

      #MainProduct--{{ section.id }} .product__images .pdp-embla .image-wrapper--cover {
        background-color: var(--bg-color);
      }

      #MainProduct--{{ section.id }} .product__images .pdp-embla .image-wrapper--cover img {
        object-fit: contain;
      }

      #MainProduct--{{ section.id }} .product__images .pdp-embla.pdp-embla--mobile .image-wrapper--cover img {
        object-fit: contain;
      }

      #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__pair__item:not([data-pair-role='secondary']) .image-wrapper--cover {
        display: flex;
        align-items: center;
        justify-content: center;
      }

      #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__pair__item:not([data-pair-role='secondary']) .image-wrapper--cover img {
        width: 100%;
        height: 100%;
        max-width: 100%;
        max-height: calc(100% - var(--header-height));
        object-fit: contain;
        object-position: center;
        margin: var(--header-height) 0 0;
        mix-blend-mode: multiply;
        user-select: none;
        -webkit-user-select: none;
        -moz-user-select: none;
        -ms-user-select: none;
      }

      #MainProduct--{{ section.id }} .pdp-embla img {
        border: 0;
        outline: 0;
        box-shadow: none;
      }

      #MainProduct--{{ section.id }} .pdp-embla {
        position: relative;
        width: 100%;
      }

      #MainProduct--{{ section.id }} .pdp-embla--desktop {
        display: none;
      }

      #MainProduct--{{ section.id }} .pdp-embla--mobile {
        display: block;
        padding-top: var(--header-height);
      }

      #MainProduct--{{ section.id }} .pdp-thumbs--desktop {
        display: none;
      }

      #MainProduct--{{ section.id }} .pdp-thumbs--mobile {
        display: block;
      }

      @media (min-width: 990px) {
        #MainProduct--{{ section.id }} .pdp-embla--desktop {
          display: block;
        }

        #MainProduct--{{ section.id }} .pdp-embla--mobile {
          display: none;
        }

        #MainProduct--{{ section.id }} .pdp-thumbs--desktop {
          display: block;
        }

        #MainProduct--{{ section.id }} .pdp-thumbs--mobile {
          display: none;
        }
      }

      #MainProduct--{{ section.id }} .pdp-embla__viewport {
        overflow: hidden;
        width: 100%;
        height: var(--full-screen, var(--full-height, 100vh));
        touch-action: pan-y;
      }

      @media (min-width: 990px) {
        #MainProduct--{{ section.id }} .pdp-embla__viewport {
          margin-top: 0;
          height: calc(100vh - var(--pdp-sticky-bar-height, 100px));
          min-height: 0;
        }
      }

      @media only screen and (min-width: 750px) and (max-width: 989px) {

        #MainProduct--{{ section.id }} .pdp-embla__viewport {
          height: calc(var(--full-height, 100svh) - var(--header-height, 0px) - var(--pdp-sticky-bar-height, 60px) - var(--pdp-dropdown-height, 70px));
        }
      }

      @media only screen and (max-width: 749px) {

        #MainProduct--{{ section.id }} .pdp-embla__viewport {
          height: calc(var(--full-height, 100svh) - var(--header-height, 0px) - var(--pdp-sticky-bar-height, 60px) - var(--pdp-dropdown-height, 70px));
        }
      }

      #MainProduct--{{ section.id }} .pdp-embla__progress {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        height: 1px;
        background: #f9f9f9;
        z-index: 6;
        overflow: hidden;
        display: none;
      }

      #MainProduct--{{ section.id }} .pdp-embla__progress__bar {
        width: 0;
        height: 100%;
        background: #000;
        transform: translateX(0);
        transition: transform 200ms ease, width 200ms ease;
        will-change: transform, width;
      }

      @media (prefers-reduced-motion: reduce) {
        #MainProduct--{{ section.id }} .pdp-embla__progress__bar {
          transition: none;
        }
      }

      /* Swipe hint: nudges the active slide image left and bounces it back (mobile + tablet) */
      @keyframes pdp-swipe-hint-bounce-{{ section.id }} {
        0%   { transform: translateX(0); }
        15%  { transform: translateX(-28px); }
        30%  { transform: translateX(-28px); }
        50%  { transform: translateX(6px); }
        65%  { transform: translateX(0); }
        100% { transform: translateX(0); }
      }

      #MainProduct--{{ section.id }} .pdp-embla--mobile.pdp-embla--swipe-hint .pdp-embla__slide--active img,
      #MainProduct--{{ section.id }} .pdp-embla--mobile.pdp-embla--swipe-hint .pdp-embla__slide:first-child img {
        animation: pdp-swipe-hint-bounce-{{ section.id }} 2.8s ease-in-out 1s infinite;
      }

      @media (min-width: 990px) {
        #MainProduct--{{ section.id }} .pdp-embla--mobile.pdp-embla--swipe-hint .pdp-embla__slide--active img,
        #MainProduct--{{ section.id }} .pdp-embla--mobile.pdp-embla--swipe-hint .pdp-embla__slide:first-child img {
          animation: none;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        #MainProduct--{{ section.id }} .pdp-embla--mobile.pdp-embla--swipe-hint .pdp-embla__slide img {
          animation: none;
        }
      }

      #MainProduct--{{ section.id }} .pdp-embla__container {
        display: flex;
        height: 100%;
        margin: 0;
        padding: 0;
        align-items: stretch;
      }

      #MainProduct--{{ section.id }} .pdp-embla__slide {
        flex: 0 0 100%;
        min-width: 0;
        height: 100%;
        margin: 0;
        padding: 0;
      }

      #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__slide {
        flex: 0 0 50%;
        box-sizing: border-box;
      }

      #MainProduct--{{ section.id }} .pdp-embla--desktop.pdp-embla--transitioning .pdp-embla__slide:first-child {
        transition: flex-basis 300ms cubic-bezier(.4,0,.2,1);
      }

      #MainProduct--{{ section.id }} .pdp-embla--desktop:not(.pdp-embla--started) .pdp-embla__slide:first-child {
        flex: 0 0 100%;
      }

      #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__slide[data-media-type="model"] {
        flex: 0 0 100% !important;
      }

      /* 3D products: keep desktop gallery one slide at a time. */
      #MainProduct--{{ section.id }} .pdp-embla--desktop.pdp-embla--single-slide .pdp-embla__slide {
        flex: 0 0 100% !important;
      }

      /* Desktop only: hide non-active 3D viewer content to prevent split view. */
      #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__slide[data-media-type="model"]:not(.pdp-embla__slide--active) .product__media,
      #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__slide[data-media-type="model"]:not(.pdp-embla__slide--active) .webgi-container {
        opacity: 0 !important;
        visibility: hidden !important;
        pointer-events: none !important;
      }

      #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__slide[data-media-type="model"].pdp-embla__slide--active .product__media,
      #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__slide[data-media-type="model"].pdp-embla__slide--active .webgi-container {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
      }

      /* Animate the 3D model content in and out so switching 3D → gallery fades
         smoothly instead of snapping to invisible mid-scroll. */
      #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__slide[data-media-type="model"] .product__media,
      #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__slide[data-media-type="model"] .webgi-container {
        transition: opacity 0.35s ease, visibility 0.35s ease;
      }

      #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__viewport {
        overflow: hidden;
      }

      #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__pair {
        display: flex;
        height: 100%;
        width: 100%;
        overflow: hidden;
        gap: 0;
      }

      #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__pair__item {
        flex: 1 1 0;
        min-width: 0;
        height: 100%;
        backface-visibility: hidden;
        transform: translateZ(0);
      }

