  {%- if thumbnails_enabled -%}
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const desktopThumbs = document.querySelector(
          '#MainProduct--{{ section.id }} .product__thumbs.pdp-thumbs--desktop'
        );

        if (desktopThumbs) {
          let lastScrollY = window.scrollY;
          let ticking = false;

          function updateThumbsVisibility() {
            const scrollY = window.scrollY;
            const windowHeight = window.innerHeight;
            const documentHeight = document.documentElement.scrollHeight;
            const scrollThreshold = documentHeight - windowHeight - 200; // 200px from bottom
            const isScrollingDown = scrollY > lastScrollY;
            const isScrollingUp = scrollY < lastScrollY;

            // Hide when scrolling down near bottom, show when scrolling up or not near bottom
            if (isScrollingDown && scrollY > scrollThreshold) {
              desktopThumbs.style.opacity = '0';
              desktopThumbs.style.pointerEvents = 'none';
              desktopThumbs.style.transition = 'opacity 0.3s ease-in-out';
            } else {
              desktopThumbs.style.opacity = '1';
              desktopThumbs.style.pointerEvents = 'auto';
              desktopThumbs.style.transition = 'opacity 0.3s ease-in-out';
            }

            lastScrollY = scrollY;
            ticking = false;
          }

          function requestTick() {
            if (!ticking) {
              window.requestAnimationFrame(updateThumbsVisibility);
              ticking = true;
            }
          }

          window.addEventListener('scroll', requestTick, {passive: true});
        }
      });
    </script>
  {%- endif -%}

