            </script>

            <script>
              document.addEventListener('click', function (e) {
                var thumb = e.target.closest('.pdp-thumbs--desktop [data-thumb-link]');
                if (thumb) {
                  window.scrollTo({top: 0, behavior: 'smooth'});
                }
