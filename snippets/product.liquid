<script>
  (function () {
    var sectionId = '{{ section.id }}';
    var sectionEl = document.getElementById('MainProduct--' + sectionId);
    if (!sectionEl) return;

    var isMobile = window.matchMedia && window.matchMedia('(max-width: 989px)').matches;

    function updateStickyBarHeight() {
      if (!isMobile) return;
      var stickyBar = sectionEl.querySelector('.product__sticky-bar');
      var dropdown =
        sectionEl.querySelector('[data-ymee-variant-dropdown]') ||
        sectionEl.querySelector('[data-ymee-variant-dropdown-form-only]');
      if (!stickyBar) return;

      var stickyBarHeight = stickyBar.getBoundingClientRect().height;
      sectionEl.style.setProperty('--pdp-sticky-bar-height', stickyBarHeight + 'px');

      // Dropdown is always fixed on mobile — reserve its space via a separate variable
      if (dropdown) {
        var dropdownHeight = dropdown.getBoundingClientRect().height;
        // 20px = bottom offset of the fixed dropdown
        sectionEl.style.setProperty('--pdp-dropdown-height', dropdownHeight + 20 + 'px');
      }
    }

    // Re-check mobile on resize
    if (window.matchMedia) {
      window.matchMedia('(max-width: 989px)').addEventListener('change', function (e) {
        isMobile = e.matches;
        updateStickyBarHeight();
      });
    }

    // Initial measurement
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', updateStickyBarHeight);
    } else {
      updateStickyBarHeight();
    }

    // Watch for size changes
    var resizeObserver = new ResizeObserver(function () {
      updateStickyBarHeight();
    });

    var stickyBar = sectionEl.querySelector('.product__sticky-bar');
    var dropdown =
      sectionEl.querySelector('[data-ymee-variant-dropdown]') ||
      sectionEl.querySelector('[data-ymee-variant-dropdown-form-only]');
    if (stickyBar) {
      resizeObserver.observe(stickyBar);
    }

    // Also watch the inner content since buttons might change
    var stickyBarInner = sectionEl.querySelector('.product__sticky-bar__inner');
    if (stickyBarInner) {
      resizeObserver.observe(stickyBarInner);
    }

    // Watch the dropdown for height changes
    if (dropdown) {
      resizeObserver.observe(dropdown);
    }
  })();
</script>

<script>
  (function () {
    if (!window.matchMedia || !window.matchMedia('(max-width: 1024px)').matches) return;

    // Always hide the flower (hamburger button) on mobile PDP
    var hamburger = document.querySelector('.header__mobile__hamburger');
    var flowerBtn = hamburger ? hamburger.closest('.header__mobile__button') : null;
    if (flowerBtn) {
      flowerBtn.style.visibility = 'hidden';
      flowerBtn.style.opacity = '0';
    }

    // Smooth hide dropdown when footer enters viewport, show when it leaves
    function initFooterObserver() {
      var dropdown =
        document.querySelector('[data-ymee-variant-dropdown]') ||
        document.querySelector('[data-ymee-variant-dropdown-form-only]');
      var footer = document.querySelector('.site-footer-wrapper');
      if (!dropdown || !footer || !('IntersectionObserver' in window)) return;
      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              dropdown.classList.add('is-hidden');
            } else {
              dropdown.classList.remove('is-hidden');
            }
          });
        },
        {threshold: 0, rootMargin: '80px 0px 0px 0px'}
      );
      observer.observe(footer);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFooterObserver);
    } else {
      initFooterObserver();
    }
  })();
</script>

<script>
  /* ── Desktop dropdown-slide animation ──
     Class pdp-dropdown-inline is ON by default (added in Liquid).
     JS measures the layout and sets CSS vars, then removes the class on scroll.
     No grid changes. Title-price shrinks via max-width. Dropdown slides via transform.
     Dropdown & color picker keep their original size. */
  (function () {
    if (document.documentElement.hasAttribute('data-geo-hidden')) return;

    var desktopMQ = window.matchMedia ? window.matchMedia('(min-width: 990px)') : null;
    if (!desktopMQ) return;

    var sectionEl = document.getElementById('MainProduct--{{ section.id }}');
    if (!sectionEl) return;

    var CLS = 'pdp-dropdown-inline';
    var CLS_M = 'pdp-dropdown-measured';
    var THRESHOLD = 5;
    var GAP = 12;
    var GRID_GAP = 50;
    var isDesktop = desktopMQ.matches;
    var ticking = false;
    var measured = false;
    var resizeTimer;

    /* Cached DOM refs (set once in measure) */
    var titlePrice = null;
    var stickyInner = null;

    function stripClasses() {
      sectionEl.classList.remove(CLS);
      sectionEl.classList.remove(CLS_M);
    }

    if (!isDesktop) stripClasses();

    function measure() {
      var buttonsBlock = sectionEl.querySelector('.product__content-columns__aside .product__block--buttons');
      if (!buttonsBlock) return false;

      var colorPicker = buttonsBlock.querySelector('[data-ymee-color-picker]');
      var dropdown =
        buttonsBlock.querySelector('[data-ymee-variant-dropdown]') ||
        buttonsBlock.querySelector('[data-ymee-variant-dropdown-form-only]');
      if (!dropdown || dropdown.offsetHeight === 0) return false;

      if (!titlePrice) titlePrice = sectionEl.querySelector('.product__title-price');
      if (!stickyInner) stickyInner = sectionEl.querySelector('.product__sticky-bar__inner');

      /* Disable transitions, measure in default (stacked) state */
      var els = [titlePrice, colorPicker, dropdown].filter(Boolean);
      els.forEach(function (el) {
        el.style.transition = 'none';
      });
      sectionEl.classList.remove(CLS);
      sectionEl.classList.remove(CLS_M);
      void sectionEl.offsetHeight;

      if (titlePrice) {
        sectionEl.style.setProperty(
          '--pdp-title-default-width',
          Math.round(titlePrice.getBoundingClientRect().width) + 'px'
        );
      }

      var ddRect = dropdown.getBoundingClientRect();

      if (colorPicker) {
        var pickerOpts = colorPicker.querySelector('.ymee-color-picker__options') || colorPicker;
        var optsRect = pickerOpts.getBoundingClientRect();

        /* Color picker shifts LEFT so its right edge + GAP = dropdown's left edge.
           Dropdown moves UP only to align vertically with the picker. */
        var pickerTx = ddRect.left - GAP - optsRect.width - optsRect.left;
        sectionEl.style.setProperty('--pdp-cp-transform', 'translateX(' + Math.round(pickerTx) + 'px)');

        /* Find the visible button element for precise vertical alignment */
        var ddAlignRect = (function () {
          var sels = ['[data-add-to-cart]', '[data-bis-drawer-open]', '.ymee-variant-dropdown__toggle-bg'];
          for (var i = 0; i < sels.length; i++) {
            var el = dropdown.querySelector(sels[i]);
            if (el && el.offsetHeight > 0) return el.getBoundingClientRect();
          }
          return ddRect;
        })();
        var ddTy = optsRect.top + optsRect.height / 2 - (ddAlignRect.top + ddAlignRect.height / 2);
        sectionEl.style.setProperty('--pdp-dd-transform', 'translateY(' + Math.round(ddTy) + 'px)');

        /* Shrink title-price to not overlap the inline row */
        if (stickyInner && titlePrice) {
          var inlineRowLeft = optsRect.left + pickerTx;
          var availableForTitle = Math.max(inlineRowLeft - stickyInner.getBoundingClientRect().left - GRID_GAP, 100);
          sectionEl.style.setProperty('--pdp-title-inline-width', Math.round(availableForTitle) + 'px');
        }
      } else {
        /* No color picker — slide dropdown up to sticky bar area */
        sectionEl.style.removeProperty('--pdp-cp-transform');
        var isNotifyOnly = !!dropdown.querySelector('[data-bis-drawer-open="notify"]');
        var stickyBar = sectionEl.querySelector('.product__sticky-bar');
        if (stickyBar && !isNotifyOnly) {
          var barRect = stickyBar.getBoundingClientRect();
          sectionEl.style.setProperty(
            '--pdp-dd-transform',
            'translateY(' + Math.round(barRect.top + barRect.height / 2 - (ddRect.top + ddRect.height / 2)) + 'px)'
          );
        }
        sectionEl.style.setProperty('--pdp-title-inline-width', '100%');
      }

      sectionEl.classList.add(CLS_M);
      if (window.scrollY <= THRESHOLD) sectionEl.classList.add(CLS);
      void sectionEl.offsetHeight;
      els.forEach(function (el) {
        el.style.transition = '';
      });

      measured = true;
      return true;
    }

    function update() {
      ticking = false;
      if (!isDesktop) {
        stripClasses();
        return;
      }
      if (!measured) measure();
      if (window.scrollY <= THRESHOLD) {
        sectionEl.classList.add(CLS);
      } else {
        sectionEl.classList.remove(CLS);
      }
    }

    function onScroll() {
      if (!ticking) {
        window.requestAnimationFrame(update);
        ticking = true;
      }
    }

    function recalc() {
      if (!isDesktop) return;
      measured = false;
      measure();
    }

    function init() {
      if (!isDesktop) {
        stripClasses();
        return;
      }
      if (!measure()) {
        var attempts = 0;
        var interval = setInterval(function () {
          if (measure() || ++attempts > 30) {
            clearInterval(interval);
            update();
          }
        }, 150);
      }
      window.addEventListener('scroll', onScroll, {passive: true});
      window.addEventListener(
        'resize',
        function () {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(recalc, 150);
        },
        {passive: true}
      );
    }

    desktopMQ.addEventListener('change', function (e) {
      isDesktop = e.matches;
      if (!isDesktop) stripClasses();
      else recalc();
    });

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }

    /* Strip animation if geo-hide resolves async (first visit) */
    if (window.MutationObserver) {
      var geoObserver = new MutationObserver(function (mutations) {
        for (var i = 0; i < mutations.length; i++) {
          if (document.documentElement.hasAttribute('data-geo-hidden')) {
            stripClasses();
            geoObserver.disconnect();
            return;
          }
        }
      });
      geoObserver.observe(document.documentElement, {attributes: true, attributeFilter: ['data-geo-hidden']});
    }
  })();
</script>
