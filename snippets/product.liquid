                    var carouselHasIntroStage =
                      activeCarousel.el.classList.contains('pdp-embla--desktop') &&
                      getContainerSlides(activeCarousel.el).length > 1 &&
                      getContainerSlides(activeCarousel.el)[0] &&
                      getContainerSlides(activeCarousel.el)[0].getAttribute('data-media-type') !== 'model';

                    if (carouselHasIntroStage && isDesktop && !isStarted && targetIndex >= 1) {
