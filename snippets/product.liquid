{%- liquid
  assign featured_product = featured_product | default: false
  assign onboarding_product = false
  assign current_variant = product.selected_or_first_available_variant
  assign product_sticky_enable = section.settings.product_sticky_enable
  assign enable_video_looping = section.settings.enable_video_looping
  assign enable_history_state = true
  assign image_size = section.settings.image_size | default: 'normal'
  assign image_layout = section.settings.image_layout
  assign mobile_image_style = section.settings.mobile_image_style
  assign featured_media = current_variant.featured_media | default: product.featured_media
  assign featured_media_aspect_ratio = featured_media.aspect_ratio | default: 1
  assign first_3d_model = product.media | where: 'media_type', 'model' | first

  if template.name == 'product' and featured_product == false
    if first_3d_model != blank
      assign featured_media = first_3d_model
      assign featured_media_aspect_ratio = featured_media.aspect_ratio | default: 1
    endif
  endif

  assign ordered_media = product.media
  if first_3d_model != blank
    assign model_media = product.media | where: 'media_type', 'model'
    assign non_model_media = product.media | reject: 'media_type', 'model'
    assign ordered_media = model_media | concat: non_model_media
  endif

  if template.name == 'product' and featured_product == false
    if first_3d_model == blank
      assign featured_media = ordered_media | first
      assign featured_media_aspect_ratio = featured_media.aspect_ratio | default: 1
    endif
  endif
  assign is_title_linked = true
  if template.name == 'product' and featured_product == false
    assign is_title_linked = false
  endif

  if product.empty?
    assign onboarding_product = true
  endif

  if featured_product
    assign product_sticky_enable = false
    assign variant_image_scroll = false
    assign enable_history_state = false
  endif

  assign thumbnails_enabled = false
  if onboarding_product
    assign thumbnails_enabled = true
  endif

  if product.media.size > 1
    assign thumbnails_enabled = true
  endif

  assign modifier = image_layout | default: 'thumbnails'
  assign product_wrapper_modifier = 'product__wrapper--' | append: modifier

  assign wrapper_tag = 'div'
  if product_sticky_enable
    assign wrapper_tag = 'product-sticky'
  endif

  assign show_buy_buttons = false
  assign buy_buttons = section.blocks | where: 'type', 'buttons'

  if buy_buttons.size > 0
    assign show_buy_buttons = true
  endif

  assign image_width = 770

  if image_size == 'small'
    assign product_wrapper_modifier = product_wrapper_modifier | append: ' product__wrapper--small'
    assign image_width = 525
  endif

  if image_size == 'stretch'
    assign product_wrapper_modifier = product_wrapper_modifier | append: ' product__wrapper--stretch'
    assign image_width = 970
  endif

  assign product_form_id = 'product-form-' | append: section.id
  assign show_cart_bar = false

  assign sibling_color = product.metafields.theme.sibling_color.value | default: product.metafields.theme.sibling_colour.value | default: product.metafields.theme.siblings_color.value | default: product.metafields.theme.siblings_colour.value | default: product.metafields.theme.siblings_colors.value | default: product.metafields.theme.siblings_colours.value

  if section.settings.show_cart_bar and featured_product == false
    assign show_cart_bar = false
  endif

  capture product_images_classlist
    echo 'product__images'

    if template.name == 'product' and featured_product == false
      if thumbnails_enabled
        echo ' product__images--thumbs'
      else
        echo ' product__images--no-thumbs'
      endif
    else
      if thumbnails_enabled
        echo ' product__images--thumbs'
      else
        echo ' product__images--no-thumbs'
      endif
    endif

    if mobile_image_style == 'thumbs'
      echo ' product__images--mobile-thumbs'
    else
      echo ' product__images--mobile-slider'
    endif
  endcapture

  assign preorder = false
  if product.metafields.theme.preorder.type == 'boolean' and product.metafields.theme.preorder.value == true
    assign preorder = true
  endif

  if current_variant.metafields.theme.preorder.type == 'boolean' and current_variant.metafields.theme.preorder.value == true
    assign preorder = true
  endif

  assign product_tags = product.tags | join: ','
  if product_tags contains '_preorder'
    assign preorder = true
  endif

  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
  endif

  assign badge = ''
  if badge == '' and product_tags contains '_badge_'
    assign badge = product_tags | split: '_badge_'
    assign badge = badge[1] | split: ',' | first | replace: '_', ' '
  endif

  assign color_scheme = 'color-' | append: section.settings.color_scheme
-%}

<product-info
  id="MainProduct--{{ section.id }}"
  class="index-product section-padding {{ color_scheme }}"
  data-section="{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-product-handle="{{ product.handle }}"
  data-product-id="{{ product.id }}"
  data-enable-history-state="{{ enable_history_state }}"
  data-url="{{ product.url }}"
  data-overlay-header
  data-sticky-enabled="{{ product_sticky_enable }}"
  data-variant-image-scroll="{{ section.settings.variant_image_scroll }}"
>
  {%- style -%}
    {%- if show_cart_bar -%}
      :root { --cart-bar-height: 80px; }
    {%- endif -%}

    #MainProduct--{{ section.id }} {
      --PT: {{ section.settings.padding_top }}px;
      --PB: {{ section.settings.padding_bottom }}px;

      --swatch-size: var(--swatch-size-product);
      --pdp-sticky-bar-height: 100px;
      --bg-color: #f9f9f9;
    }

    {%- if template.name == 'product' and featured_product == false -%}

      body.template-product .header__desktop__upper {
        overflow-x: hidden;
      }

      body.template-product header-component.js__header__stuck .theme__header::after {
        content: "";
        background: transparent;
      }

      body.template-product .header-sections {
        background: transparent;
      }

      body.template-product .header__wrapper,
      body.template-product .header__mobile__bottom {
        --bg: transparent;
      }

      body.template-product .main-content {
        margin-top: 0;
        padding-top: 0;
      }

      body.template-product .main-content > *:first-child {
        margin-top: 0;
      }

      #MainProduct--{{ section.id }} {
        padding-top: 0;
        padding-bottom: 0;
      }

      #MainProduct--{{ section.id }} .product__wrapper {
        max-width: none;
        margin: 0;
      }

      #MainProduct--{{ section.id }} .product__wrapper__inner {
        max-width: none;
        margin: 0;
      }

      @media (max-width: 767px) {
        #MainProduct--{{ section.id }} .product__content {
          margin: 20px 0 0;
        }

        product-info.index-product .product__content {
          margin-top: 16px;
          padding-left: var(--inner);
          padding-right: var(--inner);
        }
      }

      @media (min-width: 990px) {

        #MainProduct--{{ section.id }} .product__images {
          display: flex;
          flex-direction: column;
          gap: 0;
          align-items: start;
          margin: 0;
        }

        #MainProduct--{{ section.id }} .product__content {
          margin: 0 auto;
          padding: 0;
          width: 100%;
        }

        #MainProduct--{{ section.id }} .product__sticky-bar {
          /* position: sticky;
          top: calc(var(--header-height, 0px) + var(--announcement-height, 0px)); */
          position: relative;
          top: auto;
          z-index: 6;
          border-top: 1px solid var(--border);
          margin: 0;
          width: 100%;
        }

        #MainProduct--{{ section.id }} .product__sticky-bar__inner {
          display: grid;
          grid-template-columns: 7fr 3fr;
          gap: 50px;
          align-items: center;
          min-height: var(--pdp-sticky-bar-height);
          padding: 0;
          max-width: min(var(--content-max), 1200px);
          margin: 0 auto;
        }

        #MainProduct--{{ section.id }} .form__width {
          max-width: min(var(--content-max), 1200px);
        }

        #MainProduct--{{ section.id }} .product__content-columns {
          display: grid;
          grid-template-columns: 7fr 3fr;
          gap: var(--inner);
          align-items: start;
        }

        #MainProduct--{{ section.id }} .product__title-price {
          display: flex;
          justify-content: space-between;
          align-items: center;
          gap: var(--inner);
        }

        #MainProduct--{{ section.id }} .product__title-price .block-padding {
          margin: 0;
        }

        #MainProduct--{{ section.id }} .product__title-price .product__price__wrap {
          text-align: right;
          flex-direction: row;
        }

        #MainProduct--{{ section.id }} .product__title-price .product__price__wrap .product__price {
          padding: 0;
        }

        #MainProduct--{{ section.id }} .product__title-price .product__title {
          margin: 0;
          font-family: var(--FONT-STACK-BODY);
          font-style: var(--FONT-STYLE-BODY);
          font-weight: var(--FONT-WEIGHT-BODY);
          font-size: var(--FONT-TITLE);
          line-height: var(--LINE-HEIGHT-TITLE);
          text-transform: uppercase;
          max-width: 40ch;
          color: var(--COLOR-TEXT-DARK);
        }

        #MainProduct--{{ section.id }} .product__title-price .price-item,
        #MainProduct--{{ section.id }} .product__description {
          font-family: var(--FONT-STACK-BODY);
          font-style: var(--FONT-STYLE-BODY);
          font-weight: var(--FONT-WEIGHT-BODY);
          font-size: var(--FONT-SIZE-BASE);
          line-height: var(--LINE-HEIGHT-BODY);
          color: var(--COLOR-TEXT-DARK);
        }

        #MainProduct--{{ section.id }} .product__description {
          max-width: 60ch;
        }

        #MainProduct--{{ section.id }} .product__content-columns__aside {
          position: sticky;
          top: calc(var(--header-height, 0px) + var(--announcement-height, 0px));
          align-self: start;
          z-index: 9;
        }

        #MainProduct--{{ section.id }} .product__content-columns__aside .product__block--buttons {
          margin-top: calc(var(--pdp-sticky-bar-height, 100px) * -1 / 1.4);
          margin-bottom: 30px;
        }
      }

      #MainProduct--{{ section.id }} .product__page {
        display: flex;
        flex-direction: column;
        width: 100%;
        align-items: stretch; 
      }

      #MainProduct--{{ section.id }} .product__images {
        position: relative;
      }

      #MainProduct--{{ section.id }} .product__images .image-wrapper--cover {
        background-color: var(--bg-color);
      }

      #MainProduct--{{ section.id }} .product__images .image-wrapper--cover img {
        object-fit: contain;
      }

      #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__pair__item:not([data-pair-role='secondary']) .image-wrapper--cover {
        display: flex;
        align-items: center;
        justify-content: center;
      }

      #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__pair__item:not([data-pair-role='secondary']) .image-wrapper--cover img {
        width: 100%;
        height: 100%;
        max-width: 100%;
        max-height: calc(100% - var(--header-height));
        object-fit: contain;
        object-position: center;
        margin: var(--header-height) 0 0;
      }

      #MainProduct--{{ section.id }} .pdp-embla img {
        border: 0;
        outline: 0;
        box-shadow: none;
      }

      #MainProduct--{{ section.id }} .pdp-embla {
        position: relative;
        width: 100%;
      }

      #MainProduct--{{ section.id }} .pdp-embla--desktop {
        display: none;
      }

      #MainProduct--{{ section.id }} .pdp-embla--mobile {
        display: block;
      }

      #MainProduct--{{ section.id }} .pdp-thumbs--desktop {
        display: none;
      }

      #MainProduct--{{ section.id }} .pdp-thumbs--mobile {
        display: block;
      }

      @media (min-width: 990px) {
        #MainProduct--{{ section.id }} .pdp-embla--desktop {
          display: block;
        }

        #MainProduct--{{ section.id }} .pdp-embla--mobile {
          display: none;
        }

        #MainProduct--{{ section.id }} .pdp-thumbs--desktop {
          display: block;
        }

        #MainProduct--{{ section.id }} .pdp-thumbs--mobile {
          display: none;
        }
      }

      #MainProduct--{{ section.id }} .pdp-embla__viewport {
        overflow: hidden;
        width: 100%;
        height: var(--full-screen, var(--full-height, 100vh));
        touch-action: pan-y;
      }

      @media (min-width: 990px) {
        #MainProduct--{{ section.id }} .pdp-embla__viewport {
          margin-top: 0;
          height: calc(100vh - var(--pdp-sticky-bar-height, 100px));
          min-height: 0;
        }
      }

      #MainProduct--{{ section.id }} .pdp-embla__progress {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        height: 1px;
        background: #f9f9f9;
        z-index: 6;
        overflow: hidden;
        display: none;
      }

      #MainProduct--{{ section.id }} .pdp-embla__progress__bar {
        width: 0;
        height: 100%;
        background: #000;
        transform: translateX(0);
        transition: transform 200ms ease, width 200ms ease;
        will-change: transform, width;
      }

      @media (prefers-reduced-motion: reduce) {
        #MainProduct--{{ section.id }} .pdp-embla__progress__bar {
          transition: none;
        }
      }

      #MainProduct--{{ section.id }} .pdp-embla__container {
        display: flex;
        height: 100%;
        margin: 0;
        padding: 0;
        align-items: stretch;
      }

      #MainProduct--{{ section.id }} .pdp-embla__slide {
        flex: 0 0 100%;
        min-width: 0;
        height: 100%;
        margin: 0;
        padding: 0;
      }

      #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__slide {
        flex: 0 0 50%;
        box-sizing: border-box;
        transition: flex-basis 500ms ease;
      }

      #MainProduct--{{ section.id }} .pdp-embla--desktop:not(.pdp-embla--started) .pdp-embla__slide:first-child {
        flex: 0 0 100%;
      }

      #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__viewport {
        overflow: hidden;
      }

      #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__pair {
        display: flex;
        height: 100%;
        width: 100%;
        overflow: hidden;
        gap: 0;
      }

      #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__pair__item {
        flex: 1 1 0;
        min-width: 0;
        height: 100%;
        backface-visibility: hidden;
        transform: translateZ(0);
      }

      #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__pair__item img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        backface-visibility: hidden;
        transform: translateZ(0);
      }

      @media (min-width: 990px) {
        #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__pair__item[data-pair-role='secondary'] {
          position: relative;
          outline: 0;
          box-shadow: inset 0 0 0 2px currentcolor;
        }

        #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__pair__item[data-pair-role='secondary'] img {
          text-indent: -100vw;
          overflow: hidden;
        }
      }

      @media (min-width: 990px) {
        #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__slide[data-pair-layout='60-40'] .pdp-embla__pair__item:first-child {
          flex: 0 0 60%;
        }

        #MainProduct--{{ section.id }} .pdp-embla--desktop .pdp-embla__slide[data-pair-layout='60-40'] .pdp-embla__pair__item:nth-child(2) {
          flex: 0 0 40%;
        }
      }

      #MainProduct--{{ section.id }} .pdp-thumbs--desktop .product__thumb__link {
        display: block;
      }

      #MainProduct--{{ section.id }} .pdp-thumbs--desktop .product__thumb__link img {
        width: 45px;
        height: 45px;
        object-fit: cover;
      }

      #MainProduct--{{ section.id }} .pdp-thumbs--desktop .product__thumb__link--pair img {
        box-sizing: border-box;
      }

      #MainProduct--{{ section.id }} .pdp-thumbs--desktop .product__thumb__link--pair {
        display: flex;
        flex-direction: column;
        width: 45px;
        height: 90px;
      }

      #MainProduct--{{ section.id }} .pdp-thumbs--desktop .product__thumb__link--pair img {
        width: 45px;
        height: 45px;
        display: block;
        object-fit: cover;
        border: 0;
      }

      #MainProduct--{{ section.id }} .pdp-thumbs--desktop .product__thumb__link--pair::after {
        content: '';
        border-color: transparent;
      }

      #MainProduct--{{ section.id }} .pdp-thumbs--desktop .product__thumb.is-active .product__thumb__link--pair::after {
        border-color: #000;
      }

      #MainProduct--{{ section.id }} .pdp-embla__slide .product__slide,
      #MainProduct--{{ section.id }} .pdp-embla__slide .product__photo,
      #MainProduct--{{ section.id }} .pdp-embla__slide .product__media {
        height: 100%;
      }

      @media only screen and (max-width: 749px) {
        #MainProduct--{{ section.id }} .pdp-embla__slide .product__slide {
          width: 100%;
        }
      }

      #MainProduct--{{ section.id }} .pdp-embla__slide .product__media.deferred-media {
        padding-top: 0 !important;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        position: relative;
      }

      #MainProduct--{{ section.id }} .pdp-embla__slide .shopify-model-viewer-ui__controls-overlay,
      #MainProduct--{{ section.id }} .pdp-embla__slide .shopify-model-viewer-ui__controls-area,
      #MainProduct--{{ section.id }} .pdp-embla__slide .shopify-model-viewer-ui__button {
        display: none !important;
      }

      #MainProduct--{{ section.id }} .pdp-embla__slide .product__media.deferred-media > model-viewer,
      #MainProduct--{{ section.id }} .pdp-embla__slide .product__media.deferred-media > video,
      #MainProduct--{{ section.id }} .pdp-embla__slide .product__media.deferred-media > iframe {
        width: 100%;
        height: 100%;
      }

      #MainProduct--{{ section.id }} .pdp-embla__slide .product__media.deferred-media > model-viewer {
        display: block;
        margin: auto;
        pointer-events: auto;
        opacity: 0;
        transition: opacity 200ms ease;
      }

      #MainProduct--{{ section.id }} .pdp-embla__slide model-viewer::part(default-progress-bar) {
        background: rgba(0, 0, 0, 0.12);
        height: 1px;
      }

      #MainProduct--{{ section.id }} .pdp-embla__slide model-viewer::part(default-progress-mask) {
        background: #000;
      }

      #MainProduct--{{ section.id }} .pdp-embla__slide .product__media.deferred-media .deferred-media__poster {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 1;
        transition: opacity 200ms ease;
      }

      #MainProduct--{{ section.id }} .pdp-embla__slide product-model .deferred-media__poster {
        display: none !important;
      }

      #MainProduct--{{ section.id }} .pdp-embla__slide .product__media.deferred-media[loaded] .deferred-media__poster {
        opacity: 0;
        pointer-events: none;
      }

      #MainProduct--{{ section.id }} .pdp-embla__slide .product__media.deferred-media[loaded] > model-viewer {
        opacity: 1;
      }

      #MainProduct--{{ section.id }} .pdp-embla__slide .product__photo {
        height: 100%;
        padding-top: 0;
      }

      #MainProduct--{{ section.id }} .pdp-embla .media--hidden,
      #MainProduct--{{ section.id }} .pdp-embla .media--hiding {
        position: unset;
        left: unset;
        opacity: unset;
        visibility: unset;
      }

      #MainProduct--{{ section.id }} .pdp-embla__arrows {
        position: absolute;
        left: 50%;
        bottom: var(--inner);
        transform: translateX(-50%);
        display: flex;
        gap: 0px;
        z-index: 6;
      }

      #MainProduct--{{ section.id }} .pdp-embla__arrow {
        width: 35px;
        height: 35px;
        display: grid;
        place-items: center;
        border: 0;
        background: transparent;
        color: inherit;
      }

      #MainProduct--{{ section.id }} .pdp-embla__arrow:disabled {
        opacity: 0.3;
        cursor: default;
      }

      #MainProduct--{{ section.id }} .product__thumbs {
        position: absolute;
        left: var(--outer);
        top: 50%;
        transform: translateY(-100%);
        z-index: 6;
        display: block;
        margin: 0;
      }

      #MainProduct--{{ section.id }} .product__thumbs.pdp-thumbs--desktop {
        display: none !important;
      }

      #MainProduct--{{ section.id }} .product__thumbs.pdp-thumbs--mobile {
        display: none !important;
      }

      @media (min-width: 990px) {
        #MainProduct--{{ section.id }} .product__thumbs.pdp-thumbs--desktop {
          display: block !important;
        }

        #MainProduct--{{ section.id }} .product__thumbs.pdp-thumbs--mobile {
          display: none !important;
        }
      }

      #MainProduct--{{ section.id }} .product__thumbs__holder {
        display: flex;
        flex-direction: column;
        gap: 0;
        max-height: calc(100vh - (var(--inner) * 2));
        overflow: auto;
      }

      @media (min-width: 990px) {
        #MainProduct--{{ section.id }} .product__thumbs__holder {
          gap: 0;
          align-items: flex-start;
        }
      }

      #MainProduct--{{ section.id }} .product__thumb {
        width: 45px;
        margin: 0;
        padding: 0;
      }

      #MainProduct--{{ section.id }} .product__thumb::after {
        content: none;
      }

      #MainProduct--{{ section.id }} .product__thumb__link {
        display: block;
        width: 45px;
        height: 45px;
        position: relative;
        text-decoration: none;
        border: 0;
      }

      #MainProduct--{{ section.id }} .product__thumb__link::after {
        content: '';
        position: absolute;
        inset: 0;
        border: 1px solid transparent;
        pointer-events: none;
        z-index: 2;
      }

      #MainProduct--{{ section.id }} .product__thumb__link img {
        display: block;
        width: 45px;
        height: 45px;
        object-fit: cover;
      }

      #MainProduct--{{ section.id }} .product__thumb.is-active {
        position: relative;
        z-index: 2;
      }

      #MainProduct--{{ section.id }} .product__thumb.is-active .product__thumb__link {
        z-index: 1;
      }

      #MainProduct--{{ section.id }} .product__thumb.is-active .product__thumb__link::after {
        border-color: #000;
      }

      @media only screen and (max-width: 749px) {
        #MainProduct--{{ section.id }} .pdp-embla__arrows {
          display: none;
        }

        #MainProduct--{{ section.id }} .pdp-embla__viewport {
          height: 80vh;
        }

        #MainProduct--{{ section.id }} .pdp-embla__progress {
          display: block;
        }
      }
    {%- endif -%}
  {%- endstyle -%}

  <{{ wrapper_tag }} class="product__wrapper {{ product_wrapper_modifier }}" data-product>
    <div class="{% if featured_product %}{{ section.settings.width }}{% else %}product__wrapper__inner{% endif %}">
      <div class="product__page">
        <product-images
          class="{{ product_images_classlist }}"
          data-active-media="{{ section.id }}-{{ featured_media.id }}"
        >
          {%- if template.name == 'product' and featured_product == false -%}
            <script src="https://unpkg.com/embla-carousel@8.5.1/embla-carousel.umd.js" defer="defer"></script>

            <script>
              (function () {
                function ensurePageScrollUnlocked() {
                  try {
                    if (window.theme && typeof window.theme.hasOpenModals === 'function' && window.theme.hasOpenModals()) return;

                    if (window.scrollLock) {
                      if (typeof window.scrollLock.clearQueueScrollLocks === 'function') window.scrollLock.clearQueueScrollLocks();
                      if (typeof window.scrollLock.enablePageScroll === 'function') window.scrollLock.enablePageScroll();
                    }

                    window.dispatchEvent(new CustomEvent('theme:scroll:unlock', { bubbles: true }));
                    document.documentElement.removeAttribute('data-scroll-locked');

                    if (document.body) {
                      document.body.style.position = '';
                      document.body.style.top = '';
                      document.body.style.left = '';
                      document.body.style.right = '';
                      document.body.style.width = '';
                    }
                  } catch (e) {}
                }

                function initEmbla(productImagesEl) {
                  if (productImagesEl && productImagesEl.dataset && productImagesEl.dataset.emblaInitialized === 'true') return;
                  if (!window.EmblaCarousel) return;

                  var isDesktop = false;
                  try {
                    isDesktop = window.matchMedia && window.matchMedia('(min-width: 990px)').matches;
                  } catch (e) {}

                  var carouselEl = isDesktop
                    ? productImagesEl.querySelector('.pdp-embla--desktop[data-embla-carousel]')
                    : productImagesEl.querySelector('.pdp-embla--mobile[data-embla-carousel]');

                  if (!carouselEl) return;

                  if (productImagesEl && productImagesEl.dataset) productImagesEl.dataset.emblaInitialized = 'true';

                  ensurePageScrollUnlocked();

                  productImagesEl.querySelectorAll('[data-media-id]').forEach(function (el) {
                    el.classList.remove('media--hidden');
                    el.classList.remove('media--hiding');
                  });

                  var carousels = [];

                  function getActiveCarousel() {
                    for (var i = 0; i < carousels.length; i++) {
                      if (carousels[i].el && carousels[i].el.offsetParent !== null) return carousels[i];
                    }
                    return carousels[0];
                  }

                  function escapeAttrValue(value) {
                    if (typeof CSS !== 'undefined' && CSS.escape) return CSS.escape(String(value));
                    return String(value).replace(/"/g, '\\"');
                  }

                  function updateProgressByIndex(carousel, index) {
                    if (!carousel || !carousel.progressBar) return;
                    var slideCount = carousel.embla.scrollSnapList().length;
                    if (slideCount <= 1) {
                      carousel.progressBar.style.width = '100%';
                      carousel.progressBar.style.transform = 'translateX(0)';
                      return;
                    }
                    var segmentWidth = 100 / slideCount;
                    carousel.progressBar.style.width = segmentWidth + '%';
                    carousel.progressBar.style.transform = 'translateX(' + (segmentWidth * index) + '%)';
                  }

                  function loadDeferredMediaByIndex(carousel, index) {
                    if (!carousel) return;
                    var slideEls = carousel.el.querySelectorAll('[data-embla-slide]');
                    var slide = slideEls[index];
                    if (!slide) return;

                    var primaryMediaId = slide.getAttribute('data-primary-media-id');
                    var primaryMediaEl = null;
                    if (primaryMediaId) {
                      primaryMediaEl = slide.querySelector('[data-media-id="' + escapeAttrValue(primaryMediaId) + '"]');
                    }

                    var deferredMedia = primaryMediaEl
                      ? primaryMediaEl.querySelector('deferred-media, product-model')
                      : slide.querySelector('deferred-media, product-model');
                    if (!deferredMedia) return;

                    if (deferredMedia.hasAttribute('loaded')) return;

                    if (typeof deferredMedia.loadContent === 'function') {
                      deferredMedia.loadContent(false);
                      return;
                    }

                    var button = deferredMedia.querySelector('[data-deferred-media-button]');
                    if (!button) return;

                    button.click();
                  }

                  function setActiveMediaByIndex(carousel, index) {
                    if (!carousel) return;
                    var slideEls = carousel.el.querySelectorAll('[data-embla-slide]');
                    var slide = slideEls[index];
                    if (!slide) return;

                    var primaryMediaId = slide.getAttribute('data-primary-media-id');
                    if (primaryMediaId) {
                      productImagesEl.setAttribute('data-active-media', primaryMediaId);
                      return;
                    }

                    var mediaEl = slide.querySelector('[data-media-id]');
                    if (!mediaEl) return;
                    productImagesEl.setAttribute('data-active-media', mediaEl.getAttribute('data-media-id'));
                  }

                  function findIndexByMediaId(carousel, mediaId) {
                    if (!carousel) return -1;
                    var targetMediaId = String(mediaId);
                    var slideEls = carousel.el.querySelectorAll('[data-embla-slide]');

                    for (var i = 0; i < slideEls.length; i++) {
                      if (slideEls[i].getAttribute('data-primary-media-id') === targetMediaId) return i;
                    }

                    var mediaEl = carousel.el.querySelector('[data-media-id="' + escapeAttrValue(targetMediaId) + '"]');
                    if (!mediaEl) return -1;
                    var slide = mediaEl.closest('[data-embla-slide]');
                    if (!slide) return -1;
                    return Array.prototype.indexOf.call(slideEls, slide);
                  }

                  function makeCarousel(carouselEl) {
                    if (carouselEl && carouselEl.dataset && carouselEl.dataset.emblaInitialized === 'true') return null;
                    var viewport = carouselEl.querySelector('[data-embla-viewport]');
                    if (!viewport) return null;

                    var isDesktopCarousel = carouselEl.classList.contains('pdp-embla--desktop');

                    var emblaOptions = {
                      loop: false,
                      containScroll: 'trimSnaps',
                      slidesToScroll: 1,
                      watchDrag: function (emblaApi, event) {
                        var target = event && event.target;
                        if (!target || !target.closest) return true;
                        var isTouch = false;
                        try {
                          isTouch = window.matchMedia && window.matchMedia('(hover: none)').matches;
                        } catch (e) {}

                        if (!isTouch) {
                          if (target.closest('model-viewer')) return false;
                          if (target.closest('product-model')) return false;
                        }
                        return true;
                      }
                    };

                    if (isDesktopCarousel) {
                      emblaOptions.align = 'start';
                      emblaOptions.containScroll = 'trimSnaps';
                      emblaOptions.slidesToScroll = 1;
                      emblaOptions.dragFree = false;
                      emblaOptions.loop = false;
                    }

                    var embla = window.EmblaCarousel(viewport, emblaOptions);

                    var prevBtn = carouselEl.querySelector('[data-embla-prev]');
                    var nextBtn = carouselEl.querySelector('[data-embla-next]');
                    var progressBar = carouselEl.querySelector('[data-embla-progress-bar]');
                    var hasIntroStage = isDesktopCarousel && carouselEl.querySelectorAll('[data-embla-slide]').length > 0;
                    var carouselStarted = false;

                    function setCarouselStarted(started) {
                      if (!hasIntroStage) return;
                      carouselStarted = !!started;
                      if (carouselStarted) {
                        carouselEl.classList.add('pdp-embla--started');
                      } else {
                        carouselEl.classList.remove('pdp-embla--started');
                      }
                    }

                    setCarouselStarted(carouselStarted);

                    function updateArrows() {
                      var selectedIndex = embla.selectedScrollSnap();
                      var canPrev = embla.canScrollPrev();
                      var canNext = embla.canScrollNext();

                      if (prevBtn) prevBtn.disabled = !canPrev;
                      if (nextBtn) nextBtn.disabled = !canNext;
                    }

                    prevBtn && prevBtn.addEventListener('click', function (e) {
                      e.preventDefault();
                      if (hasIntroStage && carouselStarted && embla.selectedScrollSnap() === 1) {
                        setCarouselStarted(false);
                        updateArrows();
                        embla.scrollPrev();
                        return;
                      }
                      embla.scrollPrev();
                    });

                    nextBtn && nextBtn.addEventListener('click', function (e) {
                      e.preventDefault();
                      if (hasIntroStage && !carouselStarted && embla.selectedScrollSnap() === 0) {
                        setCarouselStarted(true);
                        updateArrows();
                        return;
                      }
                      embla.scrollNext();
                    });

                    var carousel = { el: carouselEl, embla: embla, prevBtn: prevBtn, nextBtn: nextBtn, progressBar: progressBar, updateArrows: updateArrows };

                    embla.on('select', function () {
                      var activeCarousel = getActiveCarousel();
                      var index = embla.selectedScrollSnap();

                      var slides = carouselEl.querySelectorAll('[data-embla-slide]');
                      slides.forEach(function(slide) {
                        slide.classList.remove('pdp-embla__slide--active');
                      });

                      if (slides[index]) {
                        slides[index].classList.add('pdp-embla__slide--active');
                      }

                      if (isDesktopCarousel) {
                        if (index > 0 && !carouselStarted) {
                          setCarouselStarted(true);
                        } else if (index === 0 && carouselStarted) {
                          setCarouselStarted(false);
                        }
                      }

                      if (!activeCarousel || activeCarousel.el !== carouselEl) return;

                      setActiveMediaByIndex(activeCarousel, index);
                      loadDeferredMediaByIndex(activeCarousel, index);
                      updateArrows();
                      updateProgressByIndex(activeCarousel, index);
                      
                      if (isDesktopCarousel && carouselStarted) {
                        var thumbs = productImagesEl.querySelectorAll('.product__thumb');
                        thumbs.forEach(function(thumb) {
                          thumb.classList.remove('is-active');
                        });
                        
                        if (thumbs[index]) {
                          thumbs[index].classList.add('is-active');
                        }
                        if (thumbs[index + 1]) {
                          thumbs[index + 1].classList.add('is-active');
                        }
                      } else {
                        var thumbs = productImagesEl.querySelectorAll('.product__thumb');
                        thumbs.forEach(function(thumb) {
                          thumb.classList.remove('is-active');
                        });
                        if (thumbs[index]) {
                          thumbs[index].classList.add('is-active');
                        }
                      }
                    });

                    embla.on('reInit', function () {
                      var activeCarousel = getActiveCarousel();
                      if (!activeCarousel || activeCarousel.el !== carouselEl) return;
                      updateArrows();
                      updateProgressByIndex(activeCarousel, embla.selectedScrollSnap());
                    });

                    updateArrows();

                    if (carouselEl && carouselEl.dataset) carouselEl.dataset.emblaInitialized = 'true';
                    return carousel;
                  }

                  var c = makeCarousel(carouselEl);
                  if (c) carousels.push(c);

                  if (!carousels.length) return;

                  productImagesEl.addEventListener('theme:media:select', function (e) {
                    if (!e || !e.detail || !e.detail.id) return;
                    var activeCarousel = getActiveCarousel();
                    if (!activeCarousel) return;
                    
                    var isDesktop = activeCarousel.el.classList.contains('pdp-embla--desktop');
                    var isStarted = activeCarousel.el.classList.contains('pdp-embla--started');
                    var currentIndex = activeCarousel.embla.selectedScrollSnap();
                    var targetIndex = findIndexByMediaId(activeCarousel, e.detail.id);
                    
                    if (isDesktop && !isStarted && currentIndex === 0) {
                      if (targetIndex === 1) {
                        activeCarousel.el.classList.add('pdp-embla--started');
                        activeCarousel.updateArrows && activeCarousel.updateArrows();
                        setActiveMediaByIndex(activeCarousel, 1);
                        loadDeferredMediaByIndex(activeCarousel, 1);
                        updateProgressByIndex(activeCarousel, 1);
                        return;
                      }
                    }
                    
                    if (isDesktop && isStarted && targetIndex === 0) {
                      activeCarousel.el.classList.remove('pdp-embla--started');
                      activeCarousel.embla.scrollTo(0, true);
                      activeCarousel.updateArrows && activeCarousel.updateArrows();
                      setActiveMediaByIndex(activeCarousel, 0);
                      loadDeferredMediaByIndex(activeCarousel, 0);
                      updateProgressByIndex(activeCarousel, 0);
                      return;
                    }
                    
                    if (targetIndex < 0) return;
                    activeCarousel.embla.scrollTo(targetIndex);
                    setActiveMediaByIndex(activeCarousel, targetIndex);
                    loadDeferredMediaByIndex(activeCarousel, targetIndex);
                    activeCarousel.updateArrows && activeCarousel.updateArrows();
                    updateProgressByIndex(activeCarousel, targetIndex);
                  });

                  var active = productImagesEl.getAttribute('data-active-media');

                  function desiredIndexForCarousel(carousel) {
                    if (!carousel) return 0;
                    if (!active) return 0;
                    var idx = findIndexByMediaId(carousel, active);
                    return idx >= 0 ? idx : 0;
                  }

                  requestAnimationFrame(function () {
                    carousels.forEach(function (carousel) {
                      var startIndex = desiredIndexForCarousel(carousel);
                      carousel.embla.scrollTo(startIndex, true);

                      if (carousel.el && carousel.el.offsetParent !== null) {
                        setActiveMediaByIndex(carousel, startIndex);
                        loadDeferredMediaByIndex(carousel, startIndex);
                        carousel.updateArrows && carousel.updateArrows();
                        updateProgressByIndex(carousel, startIndex);
                      }
                    });
                  });
                }

                function tryInit() {
                  document.querySelectorAll('product-images').forEach(initEmbla);
                }

                document.addEventListener('DOMContentLoaded', function () {
                  var attempts = 0;
                  function poll() {
                    attempts += 1;
                    if (window.EmblaCarousel) {
                      tryInit();
                      return;
                    }
                    if (attempts < 50) requestAnimationFrame(poll);
                  }
                  poll();
                });
              })();
            </script>

            {%- if product.media.size > 0 -%}
              <div class="pdp-embla pdp-embla--mobile" data-embla-carousel>
                <div class="pdp-embla__viewport" data-embla-viewport>
                  <div class="pdp-embla__container">
                    {%- for media in ordered_media -%}
                      <div class="pdp-embla__slide" data-embla-slide>
                        {%- render 'media',
                          media: media,
                          featured_media: featured_media,
                          enable_video_looping: enable_video_looping,
                          sectionkey: section.id,
                          image_width: image_width,
                          cover: true
                        -%}
                      </div>
                    {%- endfor -%}
                  </div>
                </div>

                <div class="pdp-embla__arrows" aria-label="{{ 'general.accessibility.controls' | t | escape }}">
                  <button type="button" class="pdp-embla__arrow" data-embla-prev aria-label="{{ 'general.accessibility.previous' | t | escape }}">
                    {%- render 'icon-nav-arrow-left' -%}
                  </button>
                  <button type="button" class="pdp-embla__arrow" data-embla-next aria-label="{{ 'general.accessibility.next' | t | escape }}">
                    {%- render 'icon-nav-arrow-right' -%}
                  </button>
                </div>

                <div class="pdp-embla__progress" aria-hidden="true">
                  <div class="pdp-embla__progress__bar" data-embla-progress-bar></div>
                </div>
              </div>

              <div class="pdp-embla pdp-embla--desktop" data-embla-carousel>
                <div class="pdp-embla__viewport" data-embla-viewport>
                  <div class="pdp-embla__container">
                    {%- assign media_count = ordered_media.size -%}
                    {%- if media_count > 0 -%}
                      {%- assign intro_media = ordered_media[0] -%}
                      {%- assign intro_next_media = ordered_media[1] -%}
                      <div class="pdp-embla__slide" data-embla-slide data-gallery-layout="single" data-primary-media-id="{{ section.id }}-{{ intro_media.id }}">
                        <div class="pdp-embla__pair">
                          <div class="pdp-embla__pair__item">
                            {%- render 'media',
                              media: intro_media,
                              featured_media: featured_media,
                              enable_video_looping: enable_video_looping,
                              sectionkey: section.id,
                              image_width: image_width,
                              cover: true
                            -%}
                          </div>
                        </div>
                      </div>

                      {%- if intro_next_media != blank -%}
                        <div class="pdp-embla__slide" data-embla-slide data-gallery-layout="single" data-primary-media-id="{{ section.id }}-{{ intro_next_media.id }}">
                          <div class="pdp-embla__pair">
                            <div class="pdp-embla__pair__item">
                              {%- render 'media',
                                media: intro_next_media,
                                featured_media: featured_media,
                                enable_video_looping: enable_video_looping,
                                sectionkey: section.id,
                                image_width: image_width,
                                cover: true
                              -%}
                            </div>
                          </div>
                        </div>
                      {%- endif -%}

                      {%- if media_count > 2 -%}
                        {%- for media in ordered_media offset: 2 -%}
                          <div class="pdp-embla__slide" data-embla-slide data-gallery-layout="single" data-primary-media-id="{{ section.id }}-{{ media.id }}">
                            <div class="pdp-embla__pair">
                              <div class="pdp-embla__pair__item">
                                {%- render 'media',
                                  media: media,
                                  featured_media: featured_media,
                                  enable_video_looping: enable_video_looping,
                                  sectionkey: section.id,
                                  image_width: image_width,
                                  cover: true
                                -%}
                              </div>
                            </div>
                          </div>
                        {%- endfor -%}
                      {%- endif -%}
                    {%- endif -%}
                  </div>
                </div>

                <div class="pdp-embla__arrows" aria-label="{{ 'general.accessibility.controls' | t | escape }}">
                  <button type="button" class="pdp-embla__arrow" data-embla-prev aria-label="{{ 'general.accessibility.previous' | t | escape }}">
                    {%- render 'icon-nav-arrow-left' -%}
                  </button>
                  <button type="button" class="pdp-embla__arrow" data-embla-next aria-label="{{ 'general.accessibility.next' | t | escape }}">
                    {%- render 'icon-nav-arrow-right' -%}
                  </button>
                </div>

                <div class="pdp-embla__progress" aria-hidden="true">
                  <div class="pdp-embla__progress__bar" data-embla-progress-bar></div>
                </div>
              </div>

              {%- if thumbnails_enabled -%}
                <product-thumbs class="product__thumbs pdp-thumbs--mobile">
                  <div class="product__thumbs__holder" data-thumbs-slider>
                    {%- for media in ordered_media -%}
                      <div class="product__thumb{% if media == featured_media %} is-active{% endif %}" data-thumb-item>
                        <a
                          class="product__thumb__link"
                          href="{{ media.preview_image.src | image_url }}"
                          aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
                          data-media-id="{{ section.id }}-{{ media.id }}"
                          data-thumb-link
                        >
                          {%- liquid
                            render 'image', image: media.preview_image, width: 90, height: 90, sizes: '45px', widths: '45, 60, 90, 120, 180', aspect_ratio: 1

                            if media.media_type == 'video' or media.media_type == 'external_video'
                              render 'icon-media-video'
                            else
                              if media.media_type == 'model'
                                render 'icon-media-model'
                              endif
                            endif
                          -%}
                        </a>
                      </div>
                    {%- endfor -%}
                  </div>
                </product-thumbs>

                <product-thumbs class="product__thumbs pdp-thumbs--desktop">
                  <div class="product__thumbs__holder" data-thumbs-slider>
                    {%- for media in ordered_media -%}
                      <div class="product__thumb{% if media == featured_media %} is-active{% endif %}" data-thumb-item>
                        <a
                          class="product__thumb__link"
                          href="{{ media.preview_image.src | image_url }}"
                          data-media-id="{{ section.id }}-{{ media.id }}"
                          data-thumb-link
                        >
                          {%- liquid
                            render 'image', image: media.preview_image, width: 90, height: 90, sizes: '45px', widths: '45, 60, 90, 120, 180', aspect_ratio: 1

                            if media.media_type == 'video' or media.media_type == 'external_video'
                              render 'icon-media-video'
                            else
                              if media.media_type == 'model'
                                render 'icon-media-model'
                              endif
                            endif
                          -%}
                        </a>
                      </div>
                    {%- endfor -%}
                  </div>
                </product-thumbs>
              {%- endif -%}
            {%- endif -%}
          {%- else -%}
            {%- if product.media.size > 0 -%}
              {%- capture product_slides_attributes -%}
                class="product__slides product-single__photos"
                style="--featured-media-aspect-ratio: {{ featured_media_aspect_ratio | round: 2 }};"
                data-product-media-list
              {%- endcapture -%}

              <div {{ product_slides_attributes }}>

              {%- for media in ordered_media -%}
                {%- render 'media',
                  media: media,
                  featured_media: featured_media,
                  enable_video_looping: enable_video_looping,
                  sectionkey: section.id,
                  image_width: image_width,
                  cover: true
                -%}
              {%- endfor -%}

              </div>

              {%- if thumbnails_enabled -%}
                <product-thumbs class="product__thumbs">
                  <div class="product__thumbs__holder" data-thumbs-slider>
                    {%- for media in ordered_media -%}
                      <div class="product__thumb{% if media == featured_media %} is-active{% endif %}" data-thumb-item>
                        <a
                          class="product__thumb__link"
                          href="{{ media.preview_image.src | image_url }}"
                          aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
                          data-media-id="{{ section.id }}-{{ media.id }}"
                          data-thumb-link
                        >
                          {%- liquid
                            render 'image', image: media.preview_image, width: 90, height: 90, sizes: '45px', widths: '45, 60, 90, 120, 180', aspect_ratio: 1

                            if media.media_type == 'video' or media.media_type == 'external_video'
                              render 'icon-media-video'
                            else
                              if media.media_type == 'model'
                                render 'icon-media-model'
                              endif
                            endif
                          -%}
                        </a>
                      </div>
                    {%- endfor -%}
                  </div>
                </product-thumbs>
              {%- endif -%}

            {%- endif -%}

          {%- if product.media.size == 0 and onboarding_product == false -%}
            <div class="product__slides product__slides--{{ image_size }} product-single__photos">
              <div class="product__photo product__slide product__photo--blank"></div>
            </div>
          {%- endif -%}

          {%- if onboarding_product -%}
            <div
              class="product__slides product__slides--{{ image_size }} product-single__photos"
              data-product-media-list
            >
              {%- for i in (1..5) -%}
                <div
                  class="product__photo product__slide svg-placeholder {% if forloop.first %}media--active{% else %}media--hidden{% endif %}"
                  data-slide
                  data-type="image"
                  data-image-id="{{ section.id }}-{{ i }}"
                  data-media-id="{{ section.id }}-media-{{ i }}"
                >
                  {% capture product_name %}product-{{ i }}{% endcapture %}
                  {{ product_name | placeholder_svg_tag: 'svg-placeholder' }}
                </div>
              {%- endfor -%}
            </div>

            {%- if thumbnails_enabled -%}
              <product-thumbs class="product__thumbs">
                <div class="product__thumbs__holder" data-thumbs-slider>
                  {%- for i in (1..5) -%}
                    <div class="product__thumb{% if forloop.first %} is-active{% endif %}" data-thumb-item>
                      <a
                        class="product__thumb__link"
                        href="#!"
                        data-media-id="{{ section.id }}-media-{{ i }}"
                        data-thumb-link
                      >
                        {% capture product_name %}product-{{ i }}{% endcapture %}
                        {{ product_name | placeholder_svg_tag: 'svg-placeholder' }}
                      </a>
                    </div>
                  {%- endfor -%}
                </div>
              </product-thumbs>

              <script src="{{ 'product-thumbs.js' | asset_url }}" defer="defer"></script>
            {%- endif -%}
          {%- endif -%}

          {%- endif -%}
        {%- liquid
          assign title_block = section.blocks | where: 'type', 'title' | first
          assign price_block = section.blocks | where: 'type', 'price' | first
          assign buttons_block = section.blocks | where: 'type', 'buttons' | first

          assign title_block_style = ''
          if title_block != blank and title_block.settings.padding_bottom
            assign title_block_style = '--block-padding-bottom: ' | append: title_block.settings.padding_bottom | append: 'px;'
            assign title_block_style = 'style="' | append: title_block_style | append: '"'
          endif

          assign price_block_style = ''
          if price_block != blank and price_block.settings.padding_bottom
            assign price_block_style = '--block-padding-bottom: ' | append: price_block.settings.padding_bottom | append: 'px;'
            assign price_block_style = 'style="' | append: price_block_style | append: '"'
          endif

          assign buttons_block_style = ''
          if buttons_block != blank
            assign bg_accent = buttons_block.settings.bg_color
            assign icon_size = buttons_block.settings.icon_size

            capture buttons_block_style
              echo '--block-padding-bottom: 0px;'

              if buttons_block.type == 'upsell' or buttons_block.type == 'bundle-save' or buttons_block.type == 'complementary-products'
                unless bg_accent == 'rgba(0,0,0,0)' or bg_accent == blank
                  echo '--bg-accent: ' | append: bg_accent | append: ';'
                endunless
              endif

              if icon_size
                echo '--icon-size:' | append: icon_size | append: 'px;'
              endif
            endcapture

            if buttons_block_style != blank
              assign buttons_block_style = 'style="' | append: buttons_block_style | append: '"'
            endif
          endif
        -%}

        {%- if title_block != blank or price_block != blank -%}
          <div class="product__sticky-bar">
            <div class="product__sticky-bar__inner">
              <div class="product__title-price">
                {%- if title_block != blank -%}
                  {%- render 'product-title',
                    product: product,
                    block: title_block,
                    block_style: title_block_style,
                    is_title_linked: is_title_linked,
                    onboarding_product: onboarding_product
                  -%}
                {%- endif -%}

                {%- if price_block != blank -%}
                  {%- render 'product-price',
                    product: product,
                    block: price_block,
                    block_style: price_block_style,
                    onboarding_product: onboarding_product
                  -%}
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endif -%}

        <div class="product__content">
          <div
            class="form__wrapper{% unless show_buy_buttons %} form__wrapper--no-buttons{% endunless %}{% unless current_variant.available or onboarding_product %} variant--soldout{% endunless %}{% if settings.form_style == 'classic' %} form__wrapper--classic{% else %} form__wrapper--modern{% endif %}{% if settings.show_newsletter %} show-product-notification{% endif %}"
            data-form-wrapper
          >
            <div class="form__width">
              {% comment %} The input with name="id" submits to cart {% endcomment %}
              <input type="hidden" name="id" value="{{ current_variant.id }}" form="{{ product_form_id }}">

              {% comment %} Depending whether the product variant is a preorder or not, we will submit a line item property: "preorder" in the cart {% endcomment %}
              <input
                type="hidden"
                name="properties[{{ 'products.product.sale_type' | t }}]"
                value="{{ 'products.product.pre_order' | t }}"
                form="{{ product_form_id }}"
                data-product-preorder
              >

              {%- if sibling_color != blank -%}
                <input
                  type="hidden"
                  form="{{ product_form_id }}"
                  name="properties[{{ 'general.siblings.label' | t }}]"
                  value="{{ sibling_color }}"
                >
              {%- endif -%}

              {%- liquid
                assign title_block = section.blocks | where: 'type', 'title' | first
                assign price_block = section.blocks | where: 'type', 'price' | first
                assign description_block = section.blocks | where: 'type', 'description' | first
                assign icon_blocks = section.blocks | where: 'type', 'icon'
                assign side_drawer_blocks = section.blocks | where: 'type', 'side_drawer'
                assign aside_has_content = false

                if buttons_block != blank or icon_blocks.size > 0 or side_drawer_blocks.size > 0
                  assign aside_has_content = true
                endif

                assign title_block_style = ''
                if title_block != blank and title_block.settings.padding_bottom
                  assign title_block_style = '--block-padding-bottom: ' | append: title_block.settings.padding_bottom | append: 'px;'
                  assign title_block_style = 'style="' | append: title_block_style | append: '"'
                endif

                assign price_block_style = ''
                if price_block != blank and price_block.settings.padding_bottom
                  assign price_block_style = '--block-padding-bottom: ' | append: price_block.settings.padding_bottom | append: 'px;'
                  assign price_block_style = 'style="' | append: price_block_style | append: '"'
                endif

                assign description_block_style = ''
                if description_block != blank and description_block.settings.padding_bottom
                  assign description_block_style = '--block-padding-bottom: ' | append: description_block.settings.padding_bottom | append: 'px;'
                  assign description_block_style = 'style="' | append: description_block_style | append: '"'
                endif
              -%}

              <div class="product__content-columns">
                <div class="product__content-columns__main">
                  {%- if description_block != blank -%}
                    {%- render 'product-description',
                      product: product,
                      block: description_block,
                      block_style: description_block_style
                    -%}
                  {%- endif -%}

              {%- for block in section.blocks -%}
                {%- if title_block != blank and block.id == title_block.id -%}
                  {%- continue -%}
                {%- endif -%}
                {%- if price_block != blank and block.id == price_block.id -%}
                  {%- continue -%}
                {%- endif -%}
                {%- if description_block != blank and block.id == description_block.id -%}
                  {%- continue -%}
                {%- endif -%}
                {%- if block.type == 'buttons' or block.type == 'icon' -%}
                  {%- continue -%}
                {%- endif -%}
                {%- liquid
                  assign padding_bottom = block.settings.padding_bottom
                  assign bg_accent = block.settings.bg_color
                  assign icon_size = block.settings.icon_size

                  capture block_style
                    if padding_bottom
                      echo '--block-padding-bottom: ' | append: block.settings.padding_bottom | append: 'px;'
                    endif

                    if block.type == 'upsell' or block.type == 'bundle-save' or block.type == 'complementary-products'
                      unless bg_accent == 'rgba(0,0,0,0)' or bg_accent == blank
                        echo '--bg-accent: ' | append: bg_accent | append: ';'
                      endunless
                    endif

                    if icon_size
                      echo '--icon-size:' | append: icon_size | append: 'px;'
                    endif

                    if block.type == 'countdown'
                      assign bg_color = block.settings.bg_color
                      assign text_color = block.settings.color

                      unless bg_color == 'rgba(0,0,0,0)' or bg_color == blank
                        echo '--bg: ' | append: bg_color | append: ';'
                        echo '--countdown-padding: ' | append: 'var(--inner);'
                      endunless

                      unless text_color == 'rgba(0,0,0,0)' or text_color == blank
                        echo '--text: ' | append: text_color | append: ';'
                      endunless
                    endif
                  endcapture

                  if block_style != blank
                    assign block_style = 'style="' | append: block_style | append: '"'
                  endif
                -%}

                {%- case block.type -%}
                  {%- when '@app' -%}
                    {%- render block -%}

                  {%- when 'title' -%}
                    {%- render 'product-title',
                      product: product,
                      block: block,
                      block_style: block_style,
                      is_title_linked: is_title_linked,
                      onboarding_product: onboarding_product
                    -%}

                  {%- when 'price' -%}
                    {%- render 'product-price',
                      product: product,
                      block: block,
                      block_style: block_style,
                      onboarding_product: onboarding_product
                    -%}

                  {%- when 'variants' -%}
                    {%- render 'product-variant-picker',
                      product: product,
                      current_variant: current_variant,
                      block: block,
                      block_style: block_style,
                      product_form_id: product_form_id,
                      enable_size_chart: true
                    -%}

                  {%- when 'buttons' -%}
                    {%- render 'product-buttons',
                      block: block,
                      block_style: block_style,
                      product: product,
                      product_form_id: product_form_id,
                      preorder: preorder,
                      onboarding_product: onboarding_product
                    -%}

                  {%- when 'description' -%}
                    {%- render 'product-description', product: product, block: block, block_style: block_style -%}

                  {%- when 'tab_richtext' -%}
                    {%- render 'product-description', product: product, block: block, block_style: block_style -%}

                  {%- when 'accordion' -%}
                    {%- render 'product-description', product: product, block: block, block_style: block_style -%}

                  {%- when 'inventory_countdown' -%}
                    {%- render 'product-inventory', product: product, block: block, block_style: block_style -%}

                  {%- when 'upsell', 'bundle-save' -%}
                    {%- liquid
                      if block.type == 'upsell'
                        assign product_metafield = product.metafields.theme.upsell.value
                        assign product_list_metafield = product.metafields.theme.upsell_list.value
                        assign fallback_product = block.settings.upsell_product
                        assign fallback_product_list = block.settings.upsell_product_list
                        assign show_available_only = block.settings.show_available_upsell_only
                        assign block_title = 'products.general.upsell_title' | t
                        assign block_class = 'upsell-products'
                        assign wrapper_class = 'product__upsell'
                        assign title_class = 'product-upsell__holder__title'
                      else
                        assign product_metafield = product.metafields.theme.bundle.value
                        assign product_list_metafield = product.metafields.theme.bundle_list.value
                        assign fallback_product = block.settings.bundle_product
                        assign fallback_product_list = block.settings.bundle_product_list
                        assign show_available_only = block.settings.show_available_bundle_only
                        assign block_title = block.settings.bundle_title
                        assign block_class = 'bundle-products'
                        assign wrapper_class = 'product__bundle'
                        assign title_class = 'product-bundle__holder__title'
                      endif

                      assign target_product = product_metafield | default: fallback_product
                      assign target_product_list = product_list_metafield | default: fallback_product_list
                      assign slider_enabled = false
                      assign block_tag = 'div'

                      if block.settings.layout == 'slider'
                        assign slider_enabled = true
                        assign block_tag = 'slider-component'
                        assign dots_style = settings.dots_style
                        assign autoplay_speed = false
                        assign autoplay = block.settings.autoplay

                        if autoplay
                          assign autoplay_speed = block.settings.autoplay_speed | times: 1000
                        endif
                      endif
                    -%}

                    {%- if target_product != blank or target_product_list != blank or request.design_mode -%}
                      {%- capture block_products -%}
                        {%- if target_product == blank and target_product_list == blank -%}
                          {%- render 'upsell-product' -%}
                        {%- else -%}
                          {%- if target_product != blank -%}
                            {%- render 'upsell-product', upsell_product: target_product, show_available_upsell_only: show_available_only, slider_enabled: slider_enabled, is_product_block: true -%}
                          {%- endif -%}

                          {%- if target_product_list != blank -%}
                            {%- for list_product in target_product_list -%}
                              {%- render 'upsell-product', upsell_product: list_product, show_available_upsell_only: show_available_only, slider_enabled: slider_enabled, is_product_block: true -%}
                            {%- endfor -%}
                          {%- endif -%}
                        {%- endif -%}
                      {%- endcapture -%}

                      {%- if block_products != blank -%}
                        <div
                          class="product__block {{ block_class }} block-padding"
                          {{ block.shopify_attributes }}
                          {{ block_style }}
                        >
                          <p class="{{ title_class }}">{{ block_title }}</p>
                          <{{ block_tag }}
                            class="{{ wrapper_class }} {{ wrapper_class }}--{{ block.settings.layout }}"
                            {% if slider_enabled %}
                              data-slider
                              data-dots="{{ dots_style }}"
                              data-options='{"autoPlay": {{ autoplay_speed }}, "prevNextButtons": false }'
                            {% endif %}
                            {{ block.shopify_attributes }}
                            {{ block_style }}
                          >
                            {{ block_products }}
                          </{{ block_tag }}>
                        </div>
                      {%- endif -%}
                    {%- endif -%}

                  {%- when 'complementary-products' -%}
                    {%- liquid
                      assign slider_enabled = false

                      if block.settings.layout == 'slider'
                        assign slider_enabled = true
                        assign dots_style = settings.dots_style
                        assign autoplay_speed = false
                        assign autoplay = block.settings.autoplay

                        if autoplay
                          assign autoplay_speed = block.settings.autoplay_speed | times: 1000
                        endif
                      endif
                    -%}
                    <div
                      class="product__block product__complementary block-padding"
                      {{ block.shopify_attributes }}
                      {{ block_style }}
                    >
                      <complementary-products
                        class="complementary-products"
                        data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit=10&intent=complementary"
                      >
                        {%- if slider_enabled -%}
                          <slider-component
                            data-dots="{{ dots_style }}"
                            data-options='{"autoPlay": {{ autoplay_speed }}, "prevNextButtons": false }'
                          >
                        {%- endif -%}

                        {%- if recommendations.performed and recommendations.products_count > 0 -%}
                          {%- assign complementary_products_title = 'products.general.complementary_products_title'
                            | t
                          -%}
                          {%- if complementary_products_title != blank -%}
                            <p class="complementary-products__title">{{ complementary_products_title }}</p>
                          {%- endif -%}

                          {%- for product in recommendations.products limit: block.settings.complementary_limit -%}
                            {%- render 'upsell-product', upsell_product: product, slider_enabled: slider_enabled -%}
                          {%- endfor -%}
                        {%- endif -%}

                        {%- if slider_enabled -%}
                          </slider-component>
                        {%- endif -%}
                      </complementary-products>
                    </div>

                    <script src="{{ 'complementary-products.js' | asset_url }}" defer="defer"></script>

                  {%- when 'pickup' -%}
                    {%- assign pick_up_availabilities = current_variant.store_availabilities
                      | where: 'pick_up_enabled', true
                    -%}

                    <pickup-availability
                      class="product__block product__pickup block-padding"
                      {% if current_variant.available and pick_up_availabilities.size > 0 %}
                        available
                      {% endif %}
                      data-root-url="{{ routes.root_url }}"
                      data-variant-id="{{ current_variant.id }}"
                      data-has-only-default-variant="{{ product.has_only_default_variant }}"
                      data-product-page-color-scheme="{{ color_scheme }}"
                      {{ block.shopify_attributes }}
                      {{ block_style }}
                    >
                      <template>
                        <pickup-availability-preview class="pickup__preview">
                          {%- render 'icon-cancel' -%}
                          <div class="pickup__info">
                            <p class="pickup__info__text">
                              {{ 'products.product.pickup_availability.unavailable' | t }}
                            </p>
                            <button class="pickup__button text-link small">
                              {{ 'products.product.pickup_availability.refresh' | t }}
                            </button>
                          </div>
                        </pickup-availability-preview>
                      </template>
                    </pickup-availability>

                    <script src="{{ 'pickup-availability.js' | asset_url }}" defer="defer"></script>

                  {%- when 'code' -%}
                    <div
                      class="product__block product__custom-code block-padding"
                      {{ block_style }}
                      {{ block.shopify_attributes }}
                    >
                      {{ block.settings.code }}
                    </div>

                  {%- when 'siblings' -%}
                    {%- render 'product-siblings',
                      product: product,
                      product_form_id: product_form_id,
                      current_variant: current_variant,
                      block: block,
                      block_style: block_style,
                      quick_add_product: false
                    -%}

                  {%- when 'text' -%}
                    {%- render 'product-block-text', block: block, block_style: block_style -%}

                  {%- when 'icon' -%}
                    {%- render 'icon', block: block, index: forloop.index0, is_product: true -%}

                  {%- when 'sharing' -%}
                    <div class="product__block block-padding" {{ block.shopify_attributes }} {{ block_style }}>
                      {%- assign share_url = current_variant.url | prepend: request.origin -%}
                      {%- render 'share-button', share_url: share_url -%}
                    </div>

                  {%- when 'divider' -%}
                    {%- render 'divider', block: block, modifier: 'product__block product__block--divider' -%}

                  {%- when 'line-item' -%}
                    {%- render 'product-properties',
                      product: product,
                      block: block,
                      block_style: block_style,
                      product_form_id: product_form_id
                    -%}

                  {%- when 'features' -%}
                    {%- liquid
                      assign block_id = block.id
                      assign text = block.settings.text
                      assign title = block.settings.title
                      assign prev_index = forloop.index0 | minus: 1
                      assign next_index = forloop.index0 | plus: 1
                      assign prev_block = section.blocks[prev_index]
                      assign next_block = section.blocks[next_index]
                      assign image = block.settings.icon_alt
                      assign bg_color = block.settings.bg_color
                      assign text_color = block.settings.color

                      comment
                        Always force dots style to be "line" except if "Circle" is chosen from the global settings
                      endcomment
                      assign dots_style = 'line'
                      if settings.dots_style == 'circle'
                        assign dots_style = 'circle'
                      endif

                      capture style
                        if bg_color != 'rgba(0,0,0,0)' and bg_color != blank
                          echo '--bg-accent: ' | append: bg_color | append: ';'
                        endif

                        if text_color != 'rgba(0,0,0,0)' and text_color != blank
                          echo '--text: ' | append: text_color | append: ';'
                        endif
                      endcapture
                    -%}

                    {%- if forloop.index0 == 0 or prev_block.type != 'features' -%}
                      <slider-component
                        class="product__block product__features block-padding"
                        {{ block_style }}
                        data-slider
                        data-slider-fullwidth
                        data-dots="{{ dots_style }}"
                        data-options='{"pageDots": true, "adaptiveHeight": true, "autoPlay": false, "prevNextButtons": false, "fade": false, "draggable": ">1"}'
                      >
                    {%- endif -%}

                    <div
                      class="product__feature"
                      data-slide="{{ block_id }}"
                      {% if style != blank %}
                        style="{{ style }}"
                      {% endif %}
                      {{ block.shopify_attributes }}
                    >
                      <div class="product__feature__content">
                        <div class="block__icon__container product__feature__heading">
                          {%- assign icon_size = block.settings.icon_size -%}
                          <div class="block__icon" style="--icon-size: {{ icon_size }}px;">
                            {%- liquid
                              if image
                                assign icon_width = icon_size
                                assign icon_width_retina = icon_width | times: 2
                                assign icon_sizes = icon_width | append: 'px'
                                assign icon_widths = icon_width | append: ', ' | append: icon_width_retina
                                render 'image', image: image, width: icon_width_retina, sizes: icon_sizes, widths: icon_widths, show_backfill: false
                              else
                                render 'animated-icon', filename: block.settings.icon_name
                              endif
                            -%}
                          </div>

                          {%- if title != blank -%}
                            <div class="block__icon__text {{ block.settings.text_font_size }}">
                              <p>{{ title }}</p>
                            </div>
                          {%- endif -%}
                        </div>

                        {%- if text != blank -%}
                          <div class="rte">
                            {{ text }}
                          </div>
                        {%- endif -%}
                      </div>
                    </div>

                    {%- if forloop.index == section.blocks.size or next_block.type != 'features' -%}
                      </slider-component>
                    {%- endif -%}

                  {%- when 'popup' -%}
                    {%- render 'product-popup', block: block -%}

                  {%- when 'badges' -%}
                    <div
                      id="Badges-{{ section.id }}"
                      class="product__block product__badges block-padding {{ settings.badge_font_size }}"
                      {{ block.shopify_attributes }}
                      {{ block_style }}
                    >
                      {%- if badge != '' and block.settings.product_badges -%}
                        <span class="badge-box">{{ badge }}</span>
                      {%- endif -%}

                      {%- if preorder and product.available and block.settings.product_badges -%}
                        <span class="badge-box preorder-box" data-preorder-badge>
                          {{- 'products.product.pre_order' | t -}}
                        </span>
                      {%- endif -%}

                      {%- if on_sale and product.available and block.settings.sale_badge -%}
                        <span class="badge-box sale-box">{{ 'products.product.on_sale' | t }}</span>
                      {%- endif -%}
                    </div>

                  {%- when 'countdown' -%}
                    {%- assign layout = block.settings.text_align -%}

                    <div
                      class="product__block countdown-block block-padding flex-column {{ layout }}"
                      {{ block_style }}
                      data-countdown-block
                      {{ block.shopify_attributes }}
                    >
                      <div class="countdown-block__text {{ block.settings.heading_font_size }}">
                        {%- if block.settings.text != blank -%}
                          {{ block.settings.text }}
                        {%- endif -%}
                      </div>

                      <div class="countdown-block__timer">
                        {%- render 'countdown-timer',
                          digits_font_size: block.settings.digits_font_size,
                          text_font_size: block.settings.text_font_size,
                          end_date: block.settings.end_date,
                          end_time: block.settings.end_time,
                          period: block.settings.period,
                          end_message: block.settings.end_message,
                          hide_on_complete: block.settings.hide_on_complete
                        -%}
                      </div>
                    </div>

                  {%- when 'sku' -%}
                    <div
                      class="product__block product__sku block-padding"
                      id="Sku-{{ section.id }}"
                      role="status"
                      {{ block_style }}
                      {{ block.shopify_attributes }}
                    >
                      {{ 'products.product.sku' | t }}: {{ current_variant.sku }}
                    </div>

                  {%- when 'fit-guide' -%}
                    {%- liquid
                      assign fit_color = block.settings.fit_color
                      unless fit_color.alpha == 0.0 or fit_color == blank
                        capture style
                          echo '--text:' | append: fit_color
                        endcapture
                      endunless
                    -%}

                    <div
                      class="product__block product__guide guide block-padding"
                      {{ block.shopify_attributes }}
                      {{ block_style }}
                    >
                      {%- if block.settings.heading != blank -%}
                        <p class="guide__heading strong">{{ block.settings.heading }}</p>
                      {%- endif -%}

                      <div class="guide__line" style="{{ style }}">
                        {%- assign segment_selected = block.settings.segment_selected | plus: 0 -%}
                        {%- for idx in (1..5) -%}
                          <span
                            {% if forloop.index == segment_selected %}
                              class="is-active"
                            {% endif %}
                          >
                            {{- forloop.index -}}
                          </span>
                        {%- endfor -%}
                      </div>

                      {%- if block.settings.left_label != blank
                        or block.settings.middle_label != blank
                        or block.settings.right_label != blank
                      -%}
                        <div class="guide__content{% unless block.settings.left_label != blank %} guide__content--skip-left{% endunless %}{% unless block.settings.right_label != blank %} guide__content--skip-right{% endunless %}">
                          {%- if block.settings.left_label != blank -%}
                            <small class="guide__left">{{ block.settings.left_label }}</small>
                          {%- endif -%}

                          {%- if block.settings.middle_label != blank -%}
                            <small class="guide__middle">{{ block.settings.middle_label }}</small>
                          {%- endif -%}

                          {%- if block.settings.right_label != blank -%}
                            <small class="guide__right">{{ block.settings.right_label }}</small>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    </div>

                  {%- when 'estimate_delivery' -%}
                    {%- liquid
                      assign days = block.settings.days_from_today
                      assign now_timestamp = 'now' | date: '%s'
                      assign delivery_days = days | times: 86400
                      assign delivery_date = now_timestamp | plus: delivery_days | date: '%A, %B %e'
                    -%}

                    <div
                      class="product__block estimate-delivery block-padding {{ block.settings.text_font_size }}"
                      {{ block.shopify_attributes }}
                      {{ block_style }}
                    >
                      {{ block.settings.label }}
                      {{ delivery_date }}
                    </div>
                {%- endcase -%}
              {%- endfor -%}

                </div>

                {%- if aside_has_content -%}
                  <div class="product__content-columns__aside">
                    {%- if buttons_block != blank -%}
                      {%- render 'product-buttons',
                        block: buttons_block,
                        block_style: buttons_block_style,
                        product: product,
                        product_form_id: product_form_id,
                        preorder: preorder,
                        onboarding_product: onboarding_product
                      -%}
                    {%- endif -%}

                    {%- for block in section.blocks -%}
                      {%- if block.type == 'icon' -%}
                        {%- render 'icon', block: block, index: forloop.index0, is_product: true -%}
                      {%- endif -%}
                    {%- endfor -%}

                    {%- for block in side_drawer_blocks -%}
                      {%- liquid
                        assign drawer_id = block.settings.drawer_id | strip | handleize
                        if drawer_id == blank
                          assign drawer_id = block.id
                        endif
                      -%}

                      <div class="product__block" {{ block.shopify_attributes }}>
                        {% render 'link-with-icon',
                          text: block.settings.trigger_text,
                          drawer_open: drawer_id,
                          icon: block.settings.trigger_icon,
                          icon_position: block.settings.trigger_icon_position,
                          content_alignment: block.settings.trigger_alignment
                        %}
                      </div>
                    {%- endfor -%}
                  </div>

                {%- endif -%}
              </div>
            </div>
          </div>
        </div>
        </product-images>
      </div>
    </div>
  </{{ wrapper_tag }}>

  {%- if show_cart_bar -%}
    {%- render 'cart-bar', product: product -%}
  {%- endif -%}

  <script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
  {%- if product_sticky_enable -%}
    <script src="{{ 'product-sticky.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- if product.quantity_price_breaks_configured? -%}
    <script src="{{ 'show-more.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- if thumbnails_enabled -%}
    <script src="{{ 'product-thumbs.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- if first_3d_model -%}
    <script type="application/json" id="ProductJSON-{{ product.id }}">
      {{ product.media | where: 'media_type', 'model' | json }}
    </script>
    <script src="{{ 'product-model.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  <script type="application/ld+json">
    {{ product | structured_data }}
  </script>
</product-info>

{%- assign side_drawer_blocks = section.blocks | where: 'type', 'side_drawer' -%}

{%- for block in side_drawer_blocks -%}
  {%- liquid
    assign drawer_id = block.settings.drawer_id | strip | handleize
    if drawer_id == blank
      assign drawer_id = block.id
    endif
  -%}

  <side-drawer
    class="drawer"
    data-drawer="{{ drawer_id }}"
    id="side-drawer-{{ block.id }}"
    data-drawer-size="{{ block.settings.drawer_size }}"
    data-drawer-direction="{{ block.settings.drawer_direction }}"
    {{ block.shopify_attributes }}
  >
    <div class="drawer__inner" data-drawer-inner>
      <button class="drawer__close" data-drawer-close aria-label="{{ 'general.accessibility.close' | t }}">
        {% render 'icon-close' %}
      </button>

      <div class="drawer__body">
        {%- case block.settings.drawer_snippet -%}
          {%- when 'drawer-free-shipping' -%}
            {%- render 'drawer-free-shipping', block: block -%}
          {%- when 'drawer-gift-packaging' -%}
            {%- render 'drawer-gift-packaging', block: block -%}
        {%- endcase -%}
      </div>
    </div>
    <span class="underlay drawer__underlay" data-drawer-underlay></span>
  </side-drawer>
{%- endfor -%}