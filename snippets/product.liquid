                      var vp = hintEl.querySelector('[data-embla-viewport]');
                      if (vp) vp.addEventListener('pointerdown', removeHint, {once: true});

                      // Also stop when the user actually scrolls the carousel
                      function onScroll() {
                        removeHint();
                        carousel.embla.off('scroll', onScroll);
                      }
                      carousel.embla.on('scroll', onScroll);
                    });
                  });
                }

                function tryInit() {
                  document.querySelectorAll('product-images').forEach(initEmbla);
                }

                document.addEventListener('DOMContentLoaded', function () {
