{%- comment -%}
  nav-mega-desktop — Roberto Coin desktop header + hover mega-menu.
  Primary bar links come from the `rc_menu` link list (top level).
  Each mega panel is driven by an `rc_panel` section block: a link list whose
  level-1 items are the column headings and level-2 items are the links.
  Panel imagery/layout stays hardcoded and is chosen per block via `panel_style`.
  Utility stack (right side) is intentionally hardcoded — some items trigger JS.
  Interaction + styles live in the javascript / stylesheet tags of snippets/nav-header.liquid.

  @param {string} [rc_menu] - Handle of the main (left) link list
  @param {block[]} [blocks] - The section blocks (defaults to section.blocks)
{%- endcomment -%}

{%- liquid
  assign logo = 'nav-rc-logo-light.svg' | asset_url
  assign jewelry_spotlight = 'https://cdn.shopify.com/s/files/1/1007/1697/0327/files/roberto-coin-homepage-july.jpg?v=1784714833'

  assign rc_menu = rc_menu | default: section.settings.rc_menu_linklist | default: 'main-menu'
  assign nav_blocks = blocks | default: section.blocks
-%}

<div class="rc-desktop">
  {%- comment -%} ---------- transparent header ---------- {%- endcomment -%}
  <div class="rc-d-bar">
    <div class="rc-d-bar__grid">
      {%- comment -%} left: search + primary stack (menu-driven) {%- endcomment -%}
      <div class="rc-d-left rc-slide rc-slide--l">
        <button
          type="button"
          class="rc-d-icon"
          data-rc-search
          aria-label="{{ 'general.search.title' | t | default: 'Search' }}"
        >
          {%- render 'icon-search' -%}
        </button>
        <nav class="rc-d-stack rc-d-stack--primary" aria-label="Primary">
          {%- for link in linklists[rc_menu].links -%}
            {%- liquid
              assign pos = forloop.index | append: ''
              assign panel_key = ''
              for block in nav_blocks
                if block.type == 'rc_panel' and block.settings.position == pos
                  assign panel_key = 'rcp-' | append: pos
                  break
                endif
              endfor
            -%}
            {%- if panel_key != '' -%}
              <a class="rc-d-link" href="{{ link.url }}" data-rc-trigger="{{ panel_key }}" aria-haspopup="true">
                {{- link.title | strip_html | escape -}}
              </a>
            {%- else -%}
              <a class="rc-d-link" href="{{ link.url }}">{{ link.title | strip_html | escape }}</a>
            {%- endif -%}
          {%- endfor -%}
        </nav>
      </div>

      {%- comment -%} center: wordmark {%- endcomment -%}
      <a class="rc-d-logo rc-slide rc-slide--t" href="{{ routes.root_url }}" data-rc-close aria-label="{{ shop.name }} — home">
        <img src="{{ logo }}" alt="{{ shop.name }}" width="180" height="50">
      </a>

      {%- comment -%} right: utility stack + bag (hardcoded — some items trigger JS) {%- endcomment -%}
      <div class="rc-d-right rc-slide rc-slide--r">
        <nav class="rc-d-stack rc-d-stack--utility" aria-label="Utility">
          <a class="rc-d-link" href="{% render 'nav-url', key: 'find-a-boutique' %}" data-rc-close>Find a Boutique</a>
          <a class="rc-d-link" href="{% render 'nav-url', key: 'concierge' %}" data-rc-close>Concierge</a>
          <a class="rc-d-link" href="{% render 'nav-url', key: 'login' %}" data-rc-close>Log In</a>
          {% comment %}
            <a class="rc-d-link" href="{% render 'nav-url', key: 'keep-in-touch' %}" data-rc-newsletter data-rc-close
              >Keep in Touch
            </a>
          {% endcomment %}
        </nav>
        <a
          class="rc-d-bag"
          href="{{ routes.cart_url }}"
          data-cart-toggle
          data-rc-close
          aria-label="{{ 'cart.general.title' | t | default: 'Cart' }}"
        >
          {%- render 'icon-cart' -%}
          <cart-count
            class="rc-d-bag__count"
            data-cart-count="{{ cart.item_count }}"
          >
            {{- cart.item_count -}}
          </cart-count>
        </a>
      </div>
    </div>
  </div>

  {%- comment -%} ---------- mega-menu panels (green veil) ---------- {%- endcomment -%}
  <div class="rc-d-panels" data-rc-panels>
    {%- for block in nav_blocks -%}
      {%- if block.type != 'rc_panel' -%}{%- continue -%}{%- endif -%}
      {%- assign panel_key = 'rcp-' | append: block.settings.position -%}
      {%- assign panel_menu = block.settings.panel_menu -%}

      <div class="rc-d-panel" data-panel="{{ panel_key }}" {{ block.shopify_attributes }}>
        <div class="rc-d-panel__inner">
          {%- comment -%} ---------- hardcoded imagery (kept as-is), chosen per panel_style ---------- {%- endcomment -%}
          {%- case block.settings.panel_style -%}
            {%- when 'occasions' -%}
              <div class="rc-d-imgzone rc-d-imgzone--wide">
                <div class="rc-d-dual">
                  <a class="rc-d-tile" href="{% render 'nav-url', key: 'gift-ideas' %}">
                    <div
                      class="rc-d-tile__bg"
                      data-rc-parallax
                      style="background-image:url('{{ 'nav-occasions-1.png' | asset_url }}');"
                    ></div>
                    <div class="rc-d-tile__scrim"></div>
                    <div class="rc-d-tile__caption">
                      <span class="rc-eyebrow" style="display:block;color:rgba(255,255,255,0.85);margin-bottom:6px;"
                        >Discover</span
                      >
                      <div class="rc-display">Gift Ideas</div>
                    </div>
                  </a>
                  <a class="rc-d-tile" href="{% render 'nav-url', key: 'beyond-jewels' %}">
                    <div
                      class="rc-d-tile__bg"
                      data-rc-parallax
                      style="background-image:url('{{ 'nav-occasions-2.png' | asset_url }}');"
                    ></div>
                    <div class="rc-d-tile__scrim"></div>
                    <div class="rc-d-tile__caption">
                      <span class="rc-eyebrow" style="display:block;color:rgba(255,255,255,0.85);margin-bottom:6px;"
                        >Discover</span
                      >
                      <div class="rc-display">Beyond Jewels</div>
                    </div>
                  </a>
                </div>
              </div>

            {%- when 'maison' -%}
              {%- comment -%} static cover image (always renders); the brand blog only overrides it when present {%- endcomment -%}
              {%- liquid
                assign maison_img = 'nav-maison-cover.jpg' | asset_url
                assign maison_article = blogs.brand.articles.first
                if maison_article.image
                  assign maison_img = maison_article.image | image_url: width: 1200
                endif
                assign maison_href = maison_article.url | default: blogs.brand.url | default: routes.root_url
                assign maison_title = maison_article.title | default: 'A Dream Campaign'
              -%}
              <div class="rc-d-imgzone rc-d-imgzone--wide">
                <a class="rc-d-tile" href="{{ maison_href }}">
                  <div class="rc-d-tile__bg" data-rc-parallax style="background-image:url('{{ maison_img }}');"></div>
                  <div class="rc-d-tile__scrim"></div>
                  <div class="rc-d-tile__caption">
                    <span class="rc-eyebrow" style="display:block;color:rgba(255,255,255,0.85);margin-bottom:6px;"
                      >Latest in #Brand</span
                    >
                    <div class="rc-display">{{ maison_title | escape }}</div>
                  </div>
                </a>
              </div>

            {%- else -%}
              {%- comment -%} jewelry (default): anchored 1:1 image with parallax {%- endcomment -%}
              <div class="rc-d-imgzone">
                <div class="rc-d-imgzone__inner" data-rc-parallax>
                  <div class="rc-d-imgzone__layer" data-rc-img-back></div>
                  <div
                    class="rc-d-imgzone__layer"
                    data-rc-img-front
                    data-default="{{ jewelry_spotlight }}"
                    style="background-image:url('{{ jewelry_spotlight }}'); background-position:center;"
                  ></div>
                </div>
                <div class="rc-d-imgzone__scrim"></div>
                <div class="rc-d-imgzone__caption">
                  <span class="rc-eyebrow" style="display:block;color:rgba(255,255,255,0.85);margin-bottom:6px;"
                    >Discover the Collection</span
                  >
                  <div class="rc-display">{{ block.settings.panel_heading | default: 'Love in Verona' | escape }}</div>
                </div>
              </div>
          {%- endcase -%}

          {%- comment -%} ---------- menu-driven link columns ---------- {%- endcomment -%}
          {%- if block.settings.panel_style == 'jewelry' -%}
            {%- comment -%}
              Structured jewelry layout (3 columns split by vertical dividers):
                col 1 — OUR SELECTION stacked over SHOP BY CATEGORY (body voices)
                col 2 — FEATURED (serif voices)
                col 3 — ALL COLLECTIONS (two-up grid, body voices)
              Columns are matched by heading keyword so menu order doesn't matter.
            {%- endcomment -%}
            <div class="rc-d-left-area rc-d-left-area--jewelry">
              <div class="rc-d-cells">
                <div class="rc-d-cell rc-d-cell--fixed">
                  {%- for group in linklists[panel_menu].links -%}
                    {%- assign gh = group.title | downcase -%}
                    {%- if gh contains 'selection' or gh contains 'category' -%}
                      <div class="rc-d-sec">
                        {%- if group.title != blank -%}
                          <span class="rc-label rc-d-sec__head">{{ group.title | strip_html | escape }}</span>
                        {%- endif -%}
                        <div class="rc-d-links">
                          {%- for l in group.links -%}
                            <a class="rc-d-voice rc-d-voice--body" href="{{ l.url }}"
                              ><span>{{ l.title | strip_html | downcase | escape }}</span>
                              {%- render 'icon-nav-arrow', size: 'sm' -%}
                            </a>
                          {%- else -%}
                            <a class="rc-d-voice rc-d-voice--body" href="{{ group.url }}"
                              ><span>{{ group.title | strip_html | downcase | escape }}</span>
                              {%- render 'icon-nav-arrow', size: 'sm' -%}
                            </a>
                          {%- endfor -%}
                        </div>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>

                <div class="rc-d-vdiv" aria-hidden="true"></div>

                <div class="rc-d-cell rc-d-cell--feat">
                  {%- for group in linklists[panel_menu].links -%}
                    {%- assign gh = group.title | downcase -%}
                    {%- if gh contains 'featured' -%}
                      <div class="rc-d-sec">
                        {%- if group.title != blank -%}
                          <span class="rc-label rc-d-sec__head">{{ group.title | strip_html | escape }}</span>
                        {%- endif -%}
                        <div class="rc-d-links">
                          {%- for l in group.links -%}
                            <a class="rc-d-voice rc-d-voice--body" href="{{ l.url }}"
                              ><span>{{ l.title | strip_html | downcase | escape }}</span>
                              {%- render 'icon-nav-arrow', size: 'sm' -%}
                            </a>
                          {%- else -%}
                            <a class="rc-d-voice rc-d-voice--body" href="{{ group.url }}"
                              ><span>{{ group.title | strip_html | downcase | escape }}</span>
                              {%- render 'icon-nav-arrow', size: 'sm' -%}
                            </a>
                          {%- endfor -%}
                        </div>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>

                <div class="rc-d-vdiv" aria-hidden="true"></div>

                <div class="rc-d-cell rc-d-cell--grow">
                  {%- for group in linklists[panel_menu].links -%}
                    {%- assign gh = group.title | downcase -%}
                    {%- if gh contains 'collection' -%}
                      <div class="rc-d-sec">
                        {%- if group.title != blank -%}
                          <span class="rc-label rc-d-sec__head">{{ group.title | strip_html | escape }}</span>
                        {%- endif -%}
                        <div class="rc-d-links rc-d-links--two">
                          {%- for l in group.links -%}
                            <a class="rc-d-voice rc-d-voice--body" href="{{ l.url }}"
                              ><span>{{ l.title | strip_html | downcase | escape }}</span>
                              {%- render 'icon-nav-arrow', size: 'sm' -%}
                            </a>
                          {%- else -%}
                            <a class="rc-d-voice rc-d-voice--body" href="{{ group.url }}"
                              ><span>{{ group.title | strip_html | downcase | escape }}</span>
                              {%- render 'icon-nav-arrow', size: 'sm' -%}
                            </a>
                          {%- endfor -%}
                        </div>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
            </div>
          {%- elsif block.settings.panel_style == 'occasions' or block.settings.panel_style == 'maison' -%}
            {%- comment -%} occasions / maison: headings stacked in one column, divider between (e.g. GIFT IDEAS over BY OCCASION; THE MAISON over STORIES) {%- endcomment -%}
            <div class="rc-d-left-area rc-d-left-area--stack">
              <div class="rc-d-cells">
                <div class="rc-d-cell rc-d-cell--stack">
                  {%- for group in linklists[panel_menu].links -%}
                    <div class="rc-d-sec">
                      {%- if group.title != blank -%}
                        <span class="rc-label rc-d-sec__head">{{ group.title | strip_html | escape }}</span>
                      {%- endif -%}
                      <div class="rc-d-links">
                        {%- for l in group.links -%}
                          <a class="rc-d-voice rc-d-voice--body" href="{{ l.url }}"
                            ><span>{{ l.title | strip_html | downcase | escape }}</span>
                            {%- render 'icon-nav-arrow', size: 'sm' -%}
                          </a>
                        {%- else -%}
                          <a class="rc-d-voice rc-d-voice--body" href="{{ group.url }}"
                            ><span>{{ group.title | strip_html | downcase | escape }}</span>
                            {%- render 'icon-nav-arrow', size: 'sm' -%}
                          </a>
                        {%- endfor -%}
                      </div>
                    </div>
                  {%- endfor -%}
                </div>
              </div>
            </div>
          {%- else -%}
            {%- comment -%} maison: one column per heading {%- endcomment -%}
            <div class="rc-d-left-area">
              <div class="rc-d-cells">
                {%- for group in linklists[panel_menu].links -%}
                  <div class="rc-d-cell">
                    <div class="rc-d-sec">
                      {%- if group.title != blank -%}
                        <span class="rc-label rc-d-sec__head">{{ group.title | strip_html | escape }}</span>
                      {%- endif -%}
                      <div class="rc-d-links">
                        {%- for l in group.links -%}
                          <a class="rc-d-voice rc-d-voice--body" href="{{ l.url }}"
                            ><span>{{ l.title | strip_html | downcase | escape }}</span>
                            {%- render 'icon-nav-arrow', size: 'sm' -%}
                          </a>
                        {%- else -%}
                          {%- comment -%} heading has no children — render it as a direct link {%- endcomment -%}
                          <a class="rc-d-voice rc-d-voice--body" href="{{ group.url }}"
                            ><span>{{ group.title | strip_html | downcase | escape }}</span>
                            {%- render 'icon-nav-arrow', size: 'sm' -%}
                          </a>
                        {%- endfor -%}
                      </div>
                    </div>
                  </div>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>
