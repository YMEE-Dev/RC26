{% doc %}
  Renders a drawer content for "Ask our concierge" functionality.
{% enddoc %}

<div class="drawer-concierge drawer__content-wrapper">
  <h2 class="drawer-concierge__title drawer-content__title">{{ 'products.product.ask_concierge_title' | t }}</h2>

  <div class="drawer-concierge__video-panel" id="drawer-video-panel" aria-hidden="true">
    <div class="drawer-concierge__video-header">
      <button class="drawer-concierge__back-btn" id="drawer-video-back" aria-label="Back">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>
      <span class="drawer-concierge__video-title">BOOK A VIDEO APPOINTMENT</span>
      <button class="drawer-concierge__close-btn" id="drawer-video-close" aria-label="Close">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="drawer-concierge__calendly">
      <!-- Calendly inline widget begin -->
      <div
        class="calendly-inline-widget"
        data-url="https://calendly.com/annalisa-ymee?hide_event_type_details=1&hide_landing_page_details=1&hide_gdpr_banner=1&primary_color=000000&text_color=000000&background_color=ffffff&branding=false"
        style="min-width:320px;height:700px;"
      ></div>
      <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
      <!-- Calendly inline widget end -->
    </div>
  </div>

  <div class="drawer__content drawer-content__main">
    <div class="drawer__image">
      <img
        src="https://cdn.shopify.com/s/files/1/0969/2990/7075/files/roberto-concierge_header_V2.jpg?v=1771364672"
        alt="Roberto Coin Concierge"
        loading="lazy"
        width="600"
        height="400"
      >
    </div>

    <div class="drawer__section">
      <div class="drawer__opening-hours">
        <p class="drawer-content__title--nav">OPENING HOURS</p>
        <p>We are available Mon-Fri from 10am to 5pm CET (Central European Time)</p>
      </div>

      <a href="tel:+39044202216" class="drawer__link">
        <span class="drawer__link-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
          </svg>
        </span>
        <div class="drawer__link-content">
          <span class="drawer__link-text">CALL NOW</span>
          <span class="drawer__link-value">+39 044 202 216</span>
        </div>
      </a>

      {% comment %}
        <a href="#" class="drawer__link" data-drawer-open="video-appointment">
          <span class="drawer__link-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M23 7l-7 5 7 5V7z"/>
              <rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
            </svg>
          </span>
          <div class="drawer__link-content">
            <span class="drawer__link-text">BOOK A VIDEO APPOINTMENT</span>
          </div>
        </a>
      {% endcomment %}

      <a href="mailto:customercare@robertocoin.com" class="drawer__link">
        <span class="drawer__link-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </span>
        <div class="drawer__link-content">
          <span class="drawer__link-text">SEND AN EMAIL</span>
          <span class="drawer__link-value">customercare@robertocoin.com</span>
        </div>
      </a>
    </div>
  </div>
</div>

{% stylesheet %}
  .drawer-concierge .drawer__image {
    margin-top: 50px;
  }

  .drawer-concierge .drawer__section {
    margin-bottom: 0;
  }

  .drawer-concierge .drawer__opening-hours {
    margin-bottom: 30px;
  }

  .drawer-concierge {
    position: relative;
    overflow: hidden;
  }

  .drawer-concierge__video-panel {
    padding: 0 40px;
    position: absolute;
    inset: 0;
    background: #fff;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 10;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .drawer-concierge__video-panel.is-open {
    transform: translateX(0);
  }

  .drawer-concierge__video-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 0px;
    border-bottom: 1px solid #e5e5e5;
    flex-shrink: 0;
    margin-bottom: 50px;
  }

  .drawer-concierge__back-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    color: #1a1a1a;
    flex-shrink: 0;
  }

  .drawer-concierge__back-btn:hover,
  .drawer-concierge__close-btn:hover {
    opacity: 0.6;
  }

  .drawer-concierge__close-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    color: #1a1a1a;
    flex-shrink: 0;
  }

  .drawer-concierge__video-title {
    font-size: 12px;
    letter-spacing: 0.1em;
    font-weight: 500;
    text-align: center;
    flex: 1;
  }

  .drawer-concierge__calendly {
    flex: 1;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .drawer-concierge__calendly .calendly-inline-widget {
    width: 100% !important;
    height: 100% !important;
    min-height: 600px;
    border-radius: 0;
    overflow: hidden;
  }

  .drawer-concierge__calendly iframe {
    border: none !important;
    border-radius: 0 !important;
    width: 100% !important;
    height: 100% !important;
  }
{% endstylesheet %}

<script>
  (function () {
    var videoTrigger = document.querySelector('[data-drawer-open="video-appointment"]');
    var videoPanel = document.getElementById('drawer-video-panel');
    var backBtn = document.getElementById('drawer-video-back');
    var closeBtn = document.getElementById('drawer-video-close');

    if (!videoTrigger || !videoPanel || !backBtn || !closeBtn) return;

    // Ensure video panel is hidden when drawer opens
    var sideDrawer = videoPanel.closest('side-drawer');
    if (sideDrawer) {
      sideDrawer.addEventListener('theme:drawer:open', function () {
        videoPanel.classList.remove('is-open');
        videoPanel.setAttribute('aria-hidden', 'true');
      });
    }

    videoTrigger.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopPropagation();
      videoPanel.classList.add('is-open');
      videoPanel.setAttribute('aria-hidden', 'false');
    });

    backBtn.addEventListener('click', function () {
      videoPanel.classList.remove('is-open');
      videoPanel.setAttribute('aria-hidden', 'true');
    });

    closeBtn.addEventListener('click', function () {
      // Find and close the side-drawer
      var sideDrawer = videoPanel.closest('side-drawer');
      if (sideDrawer) {
        sideDrawer.dispatchEvent(new CustomEvent('theme:drawer:close', {bubbles: true}));
      }
    });
  })();
</script>
