{% doc %}
  Renders 14 days free returns information in a drawer.
  This snippet uses metaobjects for content management.
  
  @param {object} block - The block object containing drawer settings
{% enddoc %}

<div class="drawer-14-days-free-returns drawer__content-wrapper">
  {%- comment -%}
    Get returns content from dedicated metafields
  {%- endcomment -%}
  {%- assign returns_content = nil -%}
  
  {%- if product and product.metafields.info.fourteen_days_free_returns != blank -%}
    {%- assign returns_content = product.metafields.info.fourteen_days_free_returns.value -%}
  {%- elsif collection and collection.metafields.info.fourteen_days_free_returns != blank -%}
    {%- assign returns_content = collection.metafields.info.fourteen_days_free_returns.value -%}
  {%- elsif shop.metafields.info.fourteen_days_free_returns != blank -%}
    {%- assign returns_content = shop.metafields.info.fourteen_days_free_returns.value -%}
  {%- endif -%}
  
  {%- comment -%}
    Display metaobject content if available
  {%- endcomment -%}
  {%- if returns_content != blank -%}
    <div class="returns__content drawer-content__main">
      <div class="returns__text-content">
        {%- if returns_content.title != blank -%}
          <h2 class="returns__title drawer-content__title">{{ returns_content.title }}</h2>
        {%- endif -%}
        
        {%- if returns_content.description != blank -%}
          <div class="returns__description drawer-content__description">
            {{ returns_content.description | metafield_tag }}
          </div>
        {%- endif -%}
        
        {%- if returns_content.link_text != blank and returns_content.link_url != blank -%}
          <div class="returns__link">
            <a href="{{ returns_content.link_url }}" class="link">{{ returns_content.link_text }}</a>
          </div>
        {%- endif -%}
        
        {%- if returns_content.accordions != blank -%}
          <div class="returns__accordions">
            {%- for accordion in returns_content.accordions -%}
              <div class="returns__accordion">
                <details class="accordion" data-collapsible>
                  <summary class="accordion__title" data-collapsible-trigger>
                    {{ accordion.title }}
                  </summary>
                  <div class="accordion__content" data-collapsible-content>
                    {{ accordion.content | metafield_tag }}
                  </div>
                </details>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      
      {%- if returns_content.image != blank -%}
        <div class="returns__image">
          {{ returns_content.image | image_url: width: 600 | image_tag }}
        </div>
      {%- endif -%}
    </div>
  {%- else -%}
    <div class="returns__default">
      <h2>14-Days Free Returns</h2>
      <p>Returns information will appear here once configured.</p>
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .drawer-14-days-free-returns {
    padding: 20px;
  }
  
  
  .returns__text-content {
    flex: 1;
  }
  
  .returns__image {
    margin-top: auto;
    text-align: center;
  }
  
  .returns__image img {
    max-width: 100%;
    height: auto;
  }
  
  
  
  .returns__link {
    margin-bottom: 20px;
  }
  
  .returns__link a {
    color: #000;
    text-decoration: underline;
    font-family: Inter;
    font-size: 14px;
    font-weight: 400;
  }
  
  .returns__link a:hover {
    text-decoration: none;
  }
  
  .returns__accordions {
    margin-bottom: 20px;
  }
  
  .returns__default {
    text-align: center;
    padding: 40px 20px;
  }
{% endstylesheet %}
