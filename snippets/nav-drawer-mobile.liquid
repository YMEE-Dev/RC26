{%- comment -%}
  nav-drawer-mobile — hardcoded Roberto Coin mobile + tablet drill-down drawer.
  All nodes are rendered; assets/nav-menu.js handles the push/back slide stack, scroll-tint and open/close.
  Reuses theme hooks: data-cart-toggle (cart), data-rc-search (search).
{%- endcomment -%}

{%- liquid
  assign logo = 'nav-RC_LOGO_light.svg' | asset_url
  assign img_root = 'nav-maison-cover.jpg' | asset_url
  assign img_jewelry = 'nav-jewelry-hero.png' | asset_url
  assign img_occasions = 'nav-occasions-1.png' | asset_url
  assign img_maison = 'nav-concierge.jpg' | asset_url
-%}

<div class="rc-drawer" data-rc-drawer aria-hidden="true">
  <div class="rc-drawer__scrim"></div>

  {%- comment -%} shared header {%- endcomment -%}
  <div class="rc-drawer__header" data-rc-drawer-header>
    <div class="rc-drawer__hslot">
      <button type="button" data-rc-drawer-close aria-label="Close menu">
        <svg width="23" height="23" viewBox="0 0 24 24" fill="none"><path d="M6 6l12 12M18 6L6 18" stroke="#fff" stroke-width="1.2"></path></svg>
      </button>
    </div>
    <img class="rc-drawer__logo" src="{{ logo }}" alt="{{ shop.name }}" width="120" height="27">
    <div class="rc-drawer__hslot rc-drawer__hslot--end">
      <a href="{{ routes.cart_url }}" data-cart-toggle aria-label="{{ 'cart.general.title' | t | default: 'Cart' }}">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M6 8h12l-1 12H7L6 8z" stroke="#fff" stroke-width="1.2"></path><path d="M9 8V6.5a3 3 0 0 1 6 0V8" stroke="#fff" stroke-width="1.2"></path></svg>
      </a>
    </div>
  </div>

  <div class="rc-drawer__scroll" data-rc-scroll>

    {%- comment -%} ===== ROOT ===== {%- endcomment -%}
    <div class="rc-panel" data-node="root" data-active="1">
      <div class="rc-m-spot">
        <div class="rc-m-cover rc-m-cover--zoom" style="background-image:url('{{ img_root }}');background-position:74% center;"></div>
        <div class="rc-m-spot__scrim"></div>
        <div class="rc-m-cap">
          <div class="rc-eyebrow rc-m-cap__eyebrow">Collection Spotlight</div>
          <div class="rc-m-cap__title">Princess Flower</div>
        </div>
      </div>
      <div class="rc-m-body">
        <button type="button" class="rc-m-search" data-rc-search>
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="rgba(255,255,255,0.85)" stroke-width="1.2"></circle><path d="M20 20l-4-4" stroke="rgba(255,255,255,0.85)" stroke-width="1.2"></path></svg>
          <span>Search</span>
        </button>
        <nav class="rc-m-nav" aria-label="Primary">
          <a class="rc-m-row" href="{% render 'nav-url', key: 'bestsellers' %}"><span class="rc-m-row__label">Best Sellers</span></a>
          <button type="button" class="rc-m-row" data-rc-drill="jewelry"><span class="rc-m-row__label">Jewelry</span>{% render 'nav-chevron' %}</button>
          <button type="button" class="rc-m-row" data-rc-drill="occasions"><span class="rc-m-row__label">Occasions</span>{% render 'nav-chevron' %}</button>
          <button type="button" class="rc-m-row" data-rc-drill="maison"><span class="rc-m-row__label">Maison</span>{% render 'nav-chevron' %}</button>
        </nav>
        <nav class="rc-m-util" aria-label="Utility">
          <a class="rc-m-util__item" href="{% render 'nav-url', key: 'find-a-boutique' %}"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 21s7-6.2 7-11a7 7 0 1 0-14 0c0 4.8 7 11 7 11z M12 12.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z" stroke="rgba(255,255,255,0.88)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Find a Boutique</span></a>
          <a class="rc-m-util__item" href="{% render 'nav-url', key: 'concierge' %}"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M4 5.5h16v10H8.5L4.5 19.5V5.5z M8 9.5h8 M8 12.5h5" stroke="rgba(255,255,255,0.88)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Concierge</span></a>
          <a class="rc-m-util__item" href="{% render 'nav-url', key: 'login' %}"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 11.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7z M5 20c0-3.3 3.1-5.5 7-5.5s7 2.2 7 5.5" stroke="rgba(255,255,255,0.88)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Log In</span></a>
          <a class="rc-m-util__item" href="{% render 'nav-url', key: 'keep-in-touch' %}" data-rc-newsletter><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M3 6h18v12H3z M3.5 7l8.5 6 8.5-6" stroke="rgba(255,255,255,0.88)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Keep in Touch</span></a>
        </nav>
      </div>
    </div>

    {%- comment -%} ===== JEWELRY ===== {%- endcomment -%}
    <div class="rc-panel" data-node="jewelry" hidden>
      <div class="rc-m-spot">
        <div class="rc-m-cover rc-m-cover--zoom" style="background-image:url('{{ img_jewelry }}');background-position:center 12%;"></div>
        <div class="rc-m-spot__scrim"></div>
        <div class="rc-m-cap"><div class="rc-eyebrow rc-m-cap__eyebrow">Discover Our</div><div class="rc-m-cap__title">Jewelry</div></div>
      </div>
      <button type="button" class="rc-m-back rc-m-back--sticky" data-rc-back><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M15 5l-7 7 7 7" stroke="rgba(255,255,255,0.9)" stroke-width="1.2"></path></svg><span>Back</span></button>
      <div class="rc-m-cat-body">
        <div class="rc-m-groups">
          <div class="rc-m-group">
            <div class="rc-label rc-m-group__head">Our Selection</div>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'jewelry-bestsellers' %}"><span class="rc-m-grow__label">Best Sellers</span></a>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'timeless-pieces' %}"><span class="rc-m-grow__label">Timeless Pieces</span></a>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'newly-coined' %}"><span class="rc-m-grow__label">Newly Coined</span></a>
          </div>
          <div class="rc-m-group">
            <div class="rc-label rc-m-group__head">Shop by Category</div>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'rings' %}"><span class="rc-m-grow__label">Rings</span></a>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'earrings' %}"><span class="rc-m-grow__label">Earrings</span></a>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'necklaces' %}"><span class="rc-m-grow__label">Necklaces</span></a>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'pendants' %}"><span class="rc-m-grow__label">Pendants</span></a>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'bracelets' %}"><span class="rc-m-grow__label">Bracelets</span></a>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'bangles' %}"><span class="rc-m-grow__label">Bangles</span></a>
          </div>
        </div>
        <div class="rc-m-featcols">
          <div class="rc-m-cards">
            <div class="rc-label rc-m-cards__head">Featured Collections</div>
            <a class="rc-m-card" href="{% render 'nav-url', key: 'venetian-princess' %}"><span class="rc-m-card__label">Venetian Princess</span>{% render 'nav-arrow', size: 'sm' %}</a>
            <a class="rc-m-card" href="{% render 'nav-url', key: 'princess-flower' %}"><span class="rc-m-card__label">Princess Flower</span>{% render 'nav-arrow', size: 'sm' %}</a>
            <a class="rc-m-card" href="{% render 'nav-url', key: 'love-in-verona' %}"><span class="rc-m-card__label">Love in Verona</span>{% render 'nav-arrow', size: 'sm' %}</a>
            <a class="rc-m-card" href="{% render 'nav-url', key: 'tiare' %}"><span class="rc-m-card__label">Tiaré</span>{% render 'nav-arrow', size: 'sm' %}</a>
            <a class="rc-m-card" href="{% render 'nav-url', key: 'cento' %}"><span class="rc-m-card__label">Cento</span>{% render 'nav-arrow', size: 'sm' %}</a>
            <a class="rc-m-card" href="{% render 'nav-url', key: 'sauvage-prive' %}"><span class="rc-m-card__label">Sauvage Privé</span>{% render 'nav-arrow', size: 'sm' %}</a>
          </div>
          <div class="rc-m-cols">
            <div class="rc-label rc-m-cols__head">All Collections</div>
            <a class="rc-m-col" href="{% render 'nav-url', key: 'animalier' %}"><span class="rc-m-col__label">Animalier</span></a>
            <a class="rc-m-col" href="{% render 'nav-url', key: 'art-deco' %}"><span class="rc-m-col__label">Art Deco</span></a>
            <a class="rc-m-col" href="{% render 'nav-url', key: 'carousel' %}"><span class="rc-m-col__label">Carousel</span></a>
            <a class="rc-m-col" href="{% render 'nav-url', key: 'desert-flower' %}"><span class="rc-m-col__label">Desert Flower</span></a>
            <a class="rc-m-col" href="{% render 'nav-url', key: 'diamond-princess' %}"><span class="rc-m-col__label">Diamond Princess</span></a>
            <a class="rc-m-col" href="{% render 'nav-url', key: 'domino' %}"><span class="rc-m-col__label">Domino</span></a>
            <a class="rc-m-col" href="{% render 'nav-url', key: 'jasmine' %}"><span class="rc-m-col__label">Jasmine</span></a>
            <a class="rc-m-col" href="{% render 'nav-url', key: 'navarra' %}"><span class="rc-m-col__label">Navarra</span></a>
            <a class="rc-m-col" href="{% render 'nav-url', key: 'princess' %}"><span class="rc-m-col__label">Princess</span></a>
            <a class="rc-m-col" href="{% render 'nav-url', key: 'princess-star' %}"><span class="rc-m-col__label">Princess Star</span></a>
            <a class="rc-m-col" href="{% render 'nav-url', key: 'tiny-treasure' %}"><span class="rc-m-col__label">Tiny Treasure</span></a>
            <a class="rc-m-col" href="{% render 'nav-url', key: 'venetian-medallions' %}"><span class="rc-m-col__label">Venetian Medallions</span></a>
          </div>
        </div>
      </div>
    </div>

    {%- comment -%} ===== OCCASIONS ===== {%- endcomment -%}
    <div class="rc-panel" data-node="occasions" hidden>
      <div class="rc-m-spot">
        <div class="rc-m-cover rc-m-cover--zoom" style="background-image:url('{{ img_occasions }}');"></div>
        <div class="rc-m-spot__scrim"></div>
        <div class="rc-m-cap"><div class="rc-eyebrow rc-m-cap__eyebrow">Discover Our</div><div class="rc-m-cap__title">Occasions</div></div>
      </div>
      <button type="button" class="rc-m-back rc-m-back--sticky" data-rc-back><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M15 5l-7 7 7 7" stroke="rgba(255,255,255,0.9)" stroke-width="1.2"></path></svg><span>Back</span></button>
      <div class="rc-m-cat-body">
        <div class="rc-m-groups">
          <div class="rc-m-group">
            <div class="rc-label rc-m-group__head">Gift Ideas</div>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'beyond-jewels' %}"><span class="rc-m-grow__label">Beyond Jewels</span></a>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'everyday-treasures' %}"><span class="rc-m-grow__label">Everyday Treasures</span></a>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'gift-ideas-under-1500' %}"><span class="rc-m-grow__label">€1,500 &amp; Under</span></a>
          </div>
          <div class="rc-m-group">
            <div class="rc-label rc-m-group__head">By Occasion</div>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'anniversary' %}"><span class="rc-m-grow__label">Anniversary</span></a>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'birthday' %}"><span class="rc-m-grow__label">Birthday</span></a>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'promises' %}"><span class="rc-m-grow__label">Promises</span></a>
          </div>
        </div>
        <div class="rc-m-cards">
          <div class="rc-label rc-m-cards__head">Featured</div>
          <a class="rc-m-card" href="{% render 'nav-url', key: 'gift-ideas' %}"><span class="rc-m-card__label">Gift Ideas</span>{% render 'nav-arrow', size: 'sm' %}</a>
          <a class="rc-m-card" href="{% render 'nav-url', key: 'beyond-jewels' %}"><span class="rc-m-card__label">Beyond Jewels</span>{% render 'nav-arrow', size: 'sm' %}</a>
        </div>
      </div>
    </div>

    {%- comment -%} ===== MAISON ===== {%- endcomment -%}
    <div class="rc-panel" data-node="maison" hidden>
      <div class="rc-m-spot">
        <div class="rc-m-cover rc-m-cover--zoom" style="background-image:url('{{ img_maison }}');"></div>
        <div class="rc-m-spot__scrim"></div>
        <div class="rc-m-cap"><div class="rc-eyebrow rc-m-cap__eyebrow">Discover The</div><div class="rc-m-cap__title">Maison</div></div>
      </div>
      <button type="button" class="rc-m-back rc-m-back--sticky" data-rc-back><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M15 5l-7 7 7 7" stroke="rgba(255,255,255,0.9)" stroke-width="1.2"></path></svg><span>Back</span></button>
      <div class="rc-m-cat-body">
        <div class="rc-m-groups">
          <div class="rc-m-group">
            <div class="rc-label rc-m-group__head">The Maison</div>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'the-brand' %}"><span class="rc-m-grow__label">The Brand</span></a>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'our-commitment' %}"><span class="rc-m-grow__label">Our Commitment</span></a>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'prestige-service' %}"><span class="rc-m-grow__label">Prestige Service</span></a>
          </div>
          <div class="rc-m-group">
            <div class="rc-label rc-m-group__head">Stories</div>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'stories-brand' %}"><span class="rc-m-grow__label">#Brand</span></a>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'stories-celebrity' %}"><span class="rc-m-grow__label">#Celebrity</span></a>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'stories-occasion' %}"><span class="rc-m-grow__label">#Occasion</span></a>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'stories-style' %}"><span class="rc-m-grow__label">#Style</span></a>
            <a class="rc-m-grow" href="{% render 'nav-url', key: 'stories-all' %}"><span class="rc-m-grow__label">View All</span></a>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>
