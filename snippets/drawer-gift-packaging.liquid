{% doc %}
  Renders gift packaging information in a drawer.
  This snippet uses metaobjects for content management.
  
  @param {object} block - The block object containing drawer settings
{% enddoc %}

<div class="drawer-gift-packaging">
  {%- comment -%}
    Debug: Check all metafields to find the correct structure
  {%- endcomment -%}
  <!-- DEBUG: ALL shop metafields = {{ shop.metafields | json }} -->
  
  {%- comment -%}
    Try different possible structures
  {%- endcomment -%}
  <!-- DEBUG: Try 1 - shop.metafields.info.gift_packaging = {{ shop.metafields.info.gift_packaging | json }} -->
  <!-- DEBUG: Try 2 - shop.metafields.gift_packaging.info = {{ shop.metafields.gift_packaging.info | json }} -->
  <!-- DEBUG: Try 3 - shop.metafields.info_gift_packaging = {{ shop.metafields.info_gift_packaging | json }} -->
  <!-- DEBUG: Try 4 - shop.metafields.gift_packaging_info = {{ shop.metafields.gift_packaging_info | json }} -->
  
  {%- comment -%}
    Get gift packaging content from dedicated metafields
  {%- endcomment -%}
  {%- assign gift_content = nil -%}
  
  {%- if product and product.metafields.info_gift_packaging != blank -%}
    {%- assign gift_content = product.metafields.info_gift_packaging.value -%}
  {%- elsif collection and collection.metafields.info_gift_packaging != blank -%}
    {%- assign gift_content = collection.metafields.info_gift_packaging.value -%}
  {%- elsif shop.metafields.info_gift_packaging != blank -%}
    {%- assign gift_content = shop.metafields.info_gift_packaging.value -%}
  {%- endif -%}
  
  {%- comment -%}
    Display metaobject content if available
  {%- endcomment -%}
  {%- if gift_content != blank -%}
    <div class="gift-packaging__content">
      {%- if gift_content.image != blank -%}
        <div class="gift-packaging__image">
          {{ gift_content.image | image_url: width: 600 | image_tag }}
        </div>
      {%- endif -%}
      
      {%- if gift_content.title != blank -%}
        <h2 class="gift-packaging__title">{{ gift_content.title }}</h2>
      {%- endif -%}
      
      {%- if gift_content.description != blank -%}
        <div class="gift-packaging__description">
          {{ gift_content.description }}
        </div>
      {%- endif -%}
    </div>
  {%- else -%}
    <div class="gift-packaging__default">
      <h2>Gift Packaging</h2>
      <p>Gift packaging information will appear here once configured.</p>
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .drawer-gift-packaging {
    padding: 20px;
  }
  
  .gift-packaging__image {
    margin-bottom: 20px;
    text-align: center;
  }
  
  .gift-packaging__image img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }
  
  .gift-packaging__title {
    margin-bottom: 15px;
    font-size: 24px;
    font-weight: 600;
    text-align: center;
  }
  
  .gift-packaging__description {
    line-height: 1.6;
    color: #333;
  }
  
  .gift-packaging__default {
    text-align: center;
    padding: 40px 20px;
    color: #999;
  }
{% endstylesheet %}
