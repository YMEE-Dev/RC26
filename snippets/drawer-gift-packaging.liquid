{% doc %}
  Renders gift packaging information in a drawer.
  This snippet uses metaobjects for content management.
  
  @param {object} block - The block object containing drawer settings
{% enddoc %}

<div class="drawer-gift-packaging drawer__content-wrapper">
  {%- comment -%}
    Get gift packaging content from dedicated metafields
  {%- endcomment -%}
  {%- assign gift_content = nil -%}
  
  {%- if shop.metafields.info.gift_packaging != blank -%}
    {%- assign gift_content = shop.metafields.info.gift_packaging.value -%}
  {%- elsif product and product.metafields.info.gift_packaging != blank -%}
    {%- assign gift_content = product.metafields.info.gift_packaging.value -%}
  {%- elsif collection and collection.metafields.info.gift_packaging != blank -%}
    {%- assign gift_content = collection.metafields.info.gift_packaging.value -%}
  {%- endif -%}
  
  {%- comment -%}
    Display metaobject content if available
  {%- endcomment -%}
  {%- if gift_content != blank -%}
    <div class="gift-packaging__content drawer-content__main">
      <div class="gift-packaging__text-content">
        {%- if gift_content.title != blank -%}
          <h2 class="gift-packaging__title drawer-content__title">{{ gift_content.title }}</h2>
        {%- endif -%}
        
        {%- if gift_content.description != blank -%}
          <div class="gift-packaging__description drawer-content__description">
            {{ gift_content.description | metafield_tag }}
          </div>
        {%- endif -%}
      </div>
      
      {%- if gift_content.image != blank -%}
        <div class="gift-packaging__image drawer-content__image">
          {{ gift_content.image | image_url: width: 600 | image_tag }}
        </div>
      {%- endif -%}
    </div>
  {%- else -%}
    <div class="gift-packaging__default">
      <h2>Gift Packaging</h2>
      <p>Gift packaging information will appear here once configured.</p>
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .drawer-gift-packaging .gift-packaging__text-content {
    flex: 1;
  }
  .drawer-gift-packaging .gift-packaging__image {
    margin-bottom: 0px;
    margin-top: auto;
  }
{% endstylesheet %}
