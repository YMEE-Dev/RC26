{
  "printWidth": 120,
  "tabWidth": 1,
  "useTabs": false,
  "singleQuote": false,
  "trailingComma": "es5",
  "semi": true,
  "endOfLine": "lf",
  "overrides": [
    {
      "files": ["*.liquid"],
      "options": {
        "bracketSpacing": false
      }
    },
    {
      "files": ["*.css"],
      "options": {
        "printWidth": 160
      }
    }
  ]
}
