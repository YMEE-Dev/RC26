{% doc %}
  @prompt
    create 2x2 grid
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-grid-container-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.spacing }}px;
  }

  .ai-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(2, 1fr);
    gap: {{ block.settings.gap }}px;
    width: 100%;
  }

  .ai-grid-item-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ block.settings.item_bg_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.item_padding }}px;
  }

  .ai-grid-item-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
  }

  .ai-grid-item-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    text-align: center;
    color: {{ block.settings.text_color }};
  }

  .ai-grid-item-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    margin: 0 0 8px;
    font-weight: 600;
  }

  .ai-grid-item-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    margin: 0;
  }

  .ai-grid-item-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: 0;
    left: 0;
  }

  .ai-grid-item-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .ai-grid-{{ ai_gen_id }} {
      gap: {{ block.settings.gap | times: 0.7 }}px;
    }

    .ai-grid-item-{{ ai_gen_id }} {
      padding: {{ block.settings.item_padding | times: 0.7 }}px;
    }

    .ai-grid-item-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.85 }}px;
    }

    .ai-grid-item-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-grid-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-grid-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign image_key = 'item_' | append: i | append: '_image'
        assign title_key = 'item_' | append: i | append: '_title'
        assign text_key = 'item_' | append: i | append: '_text'
        
        assign item_image = block.settings[image_key]
        assign item_title = block.settings[title_key]
        assign item_text = block.settings[text_key]
      %}
      
      <div class="ai-grid-item-{{ ai_gen_id }}">
        {% if item_image %}
          <img
            src="{{ item_image | image_url: width: 800 }}"
            alt="{{ item_image.alt | escape }}"
            loading="lazy"
            width="{{ item_image.width }}"
            height="{{ item_image.height }}"
          >
        {% else %}
          <div class="ai-grid-item-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
        
        <div class="ai-grid-item-content-{{ ai_gen_id }}">
          {% if item_title != blank %}
            <h3 class="ai-grid-item-title-{{ ai_gen_id }}">{{ item_title }}</h3>
          {% endif %}
          {% if item_text != blank %}
            <p class="ai-grid-item-text-{{ ai_gen_id }}">{{ item_text }}</p>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "2x2 grid",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between items",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Container padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "item_padding",
      "label": "Item padding",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "item_bg_color",
      "label": "Item background",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#212121"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 10,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Item 1"
    },
    {
      "type": "image_picker",
      "id": "item_1_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "item_1_title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "item_1_text",
      "label": "Text"
    },
    {
      "type": "header",
      "content": "Item 2"
    },
    {
      "type": "image_picker",
      "id": "item_2_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "item_2_title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "item_2_text",
      "label": "Text"
    },
    {
      "type": "header",
      "content": "Item 3"
    },
    {
      "type": "image_picker",
      "id": "item_3_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "item_3_title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "item_3_text",
      "label": "Text"
    },
    {
      "type": "header",
      "content": "Item 4"
    },
    {
      "type": "image_picker",
      "id": "item_4_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "item_4_title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "item_4_text",
      "label": "Text"
    }
  ],
  "presets": [
    {
      "name": "2x2 grid"
    }
  ]
}
{% endschema %}
