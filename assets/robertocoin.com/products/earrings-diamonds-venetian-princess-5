<script>
  (function () {
    if (!window.matchMedia || !window.matchMedia('(max-width: 1024px)').matches) return;

    // Smooth hide dropdown when footer enters viewport, show when it leaves
    function initFooterObserver() {
      var dropdown =
        document.querySelector('[data-ymee-variant-dropdown]') ||
        document.querySelector('[data-ymee-variant-dropdown-form-only]');
      var footer = document.querySelector('.site-footer-wrapper');
      if (!dropdown || !footer || !('IntersectionObserver' in window)) return;
      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              dropdown.classList.add('is-hidden');
            } else {
              dropdown.classList.remove('is-hidden');
            }
          });
        },
        {threshold: 0, rootMargin: '80px 0px 0px 0px'}
      );
      observer.observe(footer);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFooterObserver);
    } else {
      initFooterObserver();
    }
  })();
