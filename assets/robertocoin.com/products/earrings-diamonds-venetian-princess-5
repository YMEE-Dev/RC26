    function updateStickyBarHeight() {
      if (!isMobile) return;
      var stickyBar = sectionEl.querySelector('.product__sticky-bar');
      var dropdown =
        sectionEl.querySelector('[data-ymee-variant-dropdown]') ||
        sectionEl.querySelector('[data-ymee-variant-dropdown-form-only]');
